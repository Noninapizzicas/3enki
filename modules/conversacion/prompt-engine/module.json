{
  "name": "prompt-engine",
  "version": "1.1.0",
  "description": "Motor de prompts JSON: lee prompt.json de cada módulo, concatena con base prompt, publica chat.prompt.ready. Reemplaza prompt-composer + prompt-manager en el pipeline.",
  "author": "Event Core Team",
  "main": "index.js",

  "subscribes": [
    { "event": "chat.message.routed",  "handler": "onChatMessageRouted" },
    { "event": "prompt.list.response", "handler": "onPromptListResponse" },
    { "event": "prompt.created",       "handler": "onPromptCreated" },
    { "event": "prompt.updated",       "handler": "onPromptUpdated" },
    { "event": "prompt.deleted",       "handler": "onPromptDeleted" }
  ],

  "publishes": [
    "chat.prompt.ready",
    "prompt.list.request"
  ],

  "apis": [
    {
      "method": "GET",
      "path": "/prompts",
      "handler": "handleListPrompts",
      "description": "Lista módulos con prompt.json cargado"
    },
    {
      "method": "GET",
      "path": "/prompts/:moduleName",
      "handler": "handleGetPrompt",
      "description": "Obtiene el prompt.json de un módulo"
    },
    {
      "method": "POST",
      "path": "/prompts/:moduleName/reload",
      "handler": "handleReloadPrompt",
      "description": "Recarga el prompt.json de un módulo desde disco"
    },
    {
      "method": "POST",
      "path": "/reload",
      "handler": "handleReloadAll",
      "description": "Recarga todos los prompt.json"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check"
    }
  ],

  "config": {
    "maxHistory": 40,
    "modulesDir": null
  }
}
