      "visibility": "private",
      "nullable": false,
      "default": "esperando_testigo"
    }
  ],

  "constructor": {
    "type": "constructor",
    "params": [],
    "pseudo_code": [
      { "type": "pseudo_step", "action": "fetch", "target": "this.fielDefinitionPath", "condition": null, "value": "Read tool" },
      { "type": "pseudo_step", "action": "branch", "target": "if_fiel_no_existe", "condition": "fiel_file_not_found", "value": null },
      { "type": "pseudo_step", "action": "return", "target": "requires_clarification", "condition": null, "value": "[fiel definition file missing at path]" },
      { "type": "pseudo_step", "action": "assign", "target": "this.fielLoaded", "condition": null, "value": "JSON.parse(fiel_file_content)" },
      { "type": "pseudo_step", "action": "validate", "target": "this.fielLoaded._meta.lenguaje", "condition": "matches 'Fiel'", "value": null },
      { "type": "pseudo_step", "action": "assign", "target": "this.estadoConversacional", "condition": null, "value": "esperando_testigo" }
    ],
    "invariants_after": [
      { "type": "invariant", "expression": "this.fielLoaded !== null", "applies_to": "Notario" },
      { "type": "invariant", "expression": "this.estadoConversacional === 'esperando_testigo'", "applies_to": "Notario" }
    ]
  },

  "methods": [
