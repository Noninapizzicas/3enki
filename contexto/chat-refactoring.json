  "message_flow": {
    "description": "Flujo completo de un mensaje del usuario",
    "steps": [
      {
        "step": 1,
        "actor": "Frontend",
        "action": "mqttRequest('conversation', 'send', { conversationId, content })",
        "target": "conversation-manager"
      },
      {
        "step": 2,
        "actor": "conversation-manager",
        "action": "handleUISend() → emite chat.send.request",
        "target": "chat-ai-bridge"
      },
      {
        "step": 3,
        "actor": "chat-ai-bridge",
        "action": "emite session.save.request (mensaje user)",
        "target": "chat-session"
      },
      {
        "step": 4,
        "actor": "chat-session",
        "action": "saveMessage() → aplica FIFO → guarda en SQLite",
        "response": "session.save.response"
      },
      {
        "step": 5,
        "actor": "chat-ai-bridge",
        "action": "emite prompt.compose.request",
        "target": "prompt-composer"
      },
      {
        "step": 6,
        "actor": "prompt-composer",
        "action": "loadProjectContext() → composeSystemPrompt()",
        "response": "prompt.compose.response con system prompt"
      },
      {
        "step": 7,
        "actor": "chat-ai-bridge",
        "action": "emite ai.chat.request con messages + tools",
        "target": "ai-gateway"
      },
      {
        "step": 8,
        "actor": "ai-gateway",
        "action": "Llama a LLM (DeepSeek/Anthropic/OpenAI)",
        "response": "ai.chat.response"
      },
      {
        "step": 9,
        "actor": "chat-ai-bridge",
        "condition": "Si hay tool_calls",
        "action": "executeToolCalls() via moduleLoader",
        "loop": "Vuelve al paso 7 con resultados de tools"
      },
      {
        "step": 10,
        "actor": "chat-ai-bridge",
        "action": "emite session.save.request (mensaje assistant)",
        "target": "chat-session"
      },
      {
        "step": 11,
        "actor": "chat-ai-bridge",
        "action": "emite chat.send.response",
        "target": "conversation-manager"
      },
      {
        "step": 12,
        "actor": "conversation-manager",
        "action": "Responde a Frontend via MQTT",
        "target": "Frontend"
      }
    ]
  },
