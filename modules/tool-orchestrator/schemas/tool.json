{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/tool-orchestrator.json",

  "definitions": {
    "tool_definition": {
      "type": "object",
      "required": ["full_name", "module_name", "tool_name", "description"],
      "properties": {
        "full_name": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+$" },
        "module_name": { "type": "string" },
        "tool_name": { "type": "string" },
        "description": { "type": "string" },
        "schema": {
          "type": "object",
          "description": "JSON Schema for tool arguments"
        }
      },
      "additionalProperties": false
    },

    "register_request": {
      "type": "object",
      "required": ["module_name", "tool_name", "description"],
      "properties": {
        "module_name": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "schema": {
          "type": "object",
          "description": "JSON Schema for arguments validation"
        }
      },
      "additionalProperties": false
    },

    "register_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "full_name": { "type": "string" },
        "message": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "unregister_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "full_name": { "type": "string" },
        "message": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "call_request": {
      "type": "object",
      "properties": {
        "args": {
          "type": "object",
          "description": "Tool arguments"
        }
      },
      "additionalProperties": false
    },

    "call_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "result": { "description": "Tool execution result" },
        "duration": { "type": "integer", "minimum": 0 },
        "error": { "type": "string" },
        "details": { "type": "array" },
        "request_id": { "type": "string" }
      },
      "additionalProperties": false
    },

    "list_response": {
      "type": "object",
      "required": ["success", "tools", "count"],
      "properties": {
        "success": { "type": "boolean" },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/definitions/tool_definition" }
        },
        "count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },

    "get_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "tool": { "$ref": "#/definitions/tool_definition" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
