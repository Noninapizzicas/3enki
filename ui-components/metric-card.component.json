{
  "component": "metric-card",
  "version": "1.0.0",
  "description": "Card individual para mostrar una métrica",

  "dimensions": {
    "width": "100%",
    "min_width": "200px",
    "height": "auto",
    "min_height": "100px"
  },

  "layout": {
    "type": "flex",
    "direction": "column",
    "align": "flex-start",
    "justify": "space-between",
    "padding": "16px"
  },

  "content": {
    "icon": {
      "position": "top-left",
      "size": "24px",
      "field": "icon",
      "default": "📊"
    },
    "title": {
      "field": "name",
      "font_size": "12px",
      "font_weight": "400",
      "color": "#9CA3AF",
      "text_transform": "uppercase",
      "letter_spacing": "0.5px"
    },
    "value": {
      "field": "value",
      "font_size": "32px",
      "font_weight": "700",
      "color": "#FFFFFF",
      "margin_top": "8px"
    },
    "subtitle": {
      "field": "timestamp",
      "font_size": "10px",
      "color": "#6B7280",
      "margin_top": "4px"
    }
  },

  "states": {
    "default": {
      "background": "linear-gradient(135deg, #1F2937 0%, #111827 100%)",
      "border": "1px solid #374151",
      "border_radius": "8px",
      "box_shadow": "0 1px 3px rgba(0,0,0,0.3)"
    },
    "hover": {
      "border_color": "#4B5563",
      "box_shadow": "0 4px 6px rgba(0,0,0,0.4)"
    }
  },

  "variants": {
    "counter": {
      "icon": "🔢",
      "accent_color": "#3B82F6"
    },
    "gauge": {
      "icon": "📏",
      "accent_color": "#10B981"
    },
    "timing": {
      "icon": "⏱️",
      "accent_color": "#F59E0B"
    },
    "error": {
      "icon": "⚠️",
      "accent_color": "#EF4444"
    }
  }
}
