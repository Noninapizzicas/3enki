{
  "_meta": {
    "documento_id": "naming",
    "version": "2.0.0",
    "creado": "2026-06-04",
    "language": "es-ES",
    "lenguaje": "Fiel",
    "base_ref": "lenguaje/_fiel-base.json",
    "fuente": "contratos-referenciados/naming.json v1.1.0",
    "intencion": "La forma de los nombres del sistema. Dice como se llama un evento, que verbos existen por idioma, y como entra uno nuevo. Segundo contrato sobre la base; segundo testigo de closed_enum; primer testigo de forma."
  },

  "type": "concrete_class",
  "name": "ContratoNaming",
  "extends": "ContratoArquitectonico",

  "identidad": "cada modulo es monolingue; su idioma se declara en module.json.language. Los nombres de eventos tienen una forma, y los verbos vienen de un whitelist por idioma",

  "forma_del_nombre": {
    "type": "forma",
    "plantilla": "<module-prefix>.<entity>.<verb>  |  <module-prefix>.<verb> cuando entity coincide con el modulo",
    "patron": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*){1,2}$",
    "alfabeto": "a-z, digitos y guion",
    "compuestos": "kebab-case",
    "razon": "una forma unica deja que cualquier modulo y el LLM lean prefijo, entidad y verbo sin ambiguedad"
  },

  "idiomas": {
    "type": "closed_enum",
    "value_type": "string",
    "entries": ["es", "en"],
    "razon": "el nombre del directorio del modulo casa con su idioma"
  },

  "por_idioma": {
