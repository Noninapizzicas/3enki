    "feature_prioritization_matrix": {
      "path": "strategy/v1/prioritization_matrix.json",
      "schema": {
        "type": "object",
        "required": ["methodology", "features", "quadrants"],
        "properties": {
          "methodology": {
            "type": "string",
            "enum": ["Value vs Effort", "RICE", "ICE", "Kano"],
            "default": "Value vs Effort"
          },
          "generated_at": {"type": "string", "format": "date-time"},
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["feature_id", "title", "impact", "effort", "quadrant", "recommendation"],
              "properties": {
                "feature_id": {"type": "string"},
                "title": {"type": "string"},
                "description": {"type": "string"},
                "impact": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5,
                  "description": "1=minimal, 5=massive"
                },
                "effort": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5,
                  "description": "1=trivial, 5=epic"
                },
                "quadrant": {
                  "type": "string",
                  "enum": ["quick_wins", "major_projects", "fill_ins", "time_sinks"]
                },
                "recommendation": {
                  "type": "string",
                  "enum": ["do_now", "do_next_quarter", "do_later", "dont_do"]
                },
                "justification": {"type": "string"},
                "aligned_okr": {"type": "string"}
              },
              "additionalProperties": false
            }
          },
          "quadrants": {
            "type": "object",
            "required": ["quick_wins", "major_projects", "fill_ins", "time_sinks"],
            "properties": {
              "quick_wins": {
                "type": "object",
                "properties": {
                  "description": {"type": "string", "const": "High impact, low effort → Do now"},
                  "count": {"type": "integer"}
                }
              },
              "major_projects": {
                "type": "object",
                "properties": {
                  "description": {"type": "string", "const": "High impact, high effort → Plan carefully"},
                  "count": {"type": "integer"}
                }
              },
              "fill_ins": {
                "type": "object",
                "properties": {
                  "description": {"type": "string", "const": "Low impact, low effort → Nice to have"},
                  "count": {"type": "integer"}
                }
              },
              "time_sinks": {
                "type": "object",
                "properties": {
                  "description": {"type": "string", "const": "Low impact, high effort → Avoid"},
                  "count": {"type": "integer"}
                }
              }
            }
          }
        },
        "additionalProperties": false
      },
      "example": {
        "methodology": "Value vs Effort",
        "generated_at": "2025-01-20T12:00:00Z",
        "features": [
          {
            "feature_id": "FEAT-001",
            "title": "Optimizar cache /help/search para latencia <100ms",
            "description": "Implementar cache LRU 5000 entries + índice invertido",
            "impact": 5,
            "effort": 2,
            "quadrant": "quick_wins",
            "recommendation": "do_now",
            "justification": "Alto impacto en UX (5000 users/día), effort moderado, ROI 2.5x",
            "aligned_okr": "2025-Q2:O2:KR1"
          },
