{
  "name": "admin-panel",
  "version": "1.0.0",
  "description": "Web-based admin panel for managing Event Core system",
  "dependencies": [
    "ui-renderer"
  ],
  "apis": [
    {
      "method": "GET",
      "path": "/",
      "handler": "handleUi"
    },
    {
      "method": "GET",
      "path": "/api/dashboard",
      "handler": "handleDashboardData"
    },
    {
      "method": "GET",
      "path": "/api/modules",
      "handler": "handleListModules"
    },
    {
      "method": "GET",
      "path": "/api/plugins",
      "handler": "handleListPlugins"
    },
    {
      "method": "POST",
      "path": "/api/plugins/:name/toggle",
      "handler": "handleTogglePlugin"
    },
    {
      "method": "GET",
      "path": "/api/agents",
      "handler": "handleListAgents"
    },
    {
      "method": "POST",
      "path": "/api/agents",
      "handler": "handleCreateAgent"
    },
    {
      "method": "DELETE",
      "path": "/api/agents/:id",
      "handler": "handleDeleteAgent"
    },
    {
      "method": "GET",
      "path": "/api/prompts",
      "handler": "handleListPrompts"
    },
    {
      "method": "GET",
      "path": "/api/prompts/:name",
      "handler": "handleGetPrompt"
    },
    {
      "method": "POST",
      "path": "/api/prompts",
      "handler": "handleCreatePrompt"
    },
    {
      "method": "PUT",
      "path": "/api/prompts/:name",
      "handler": "handleUpdatePrompt"
    }
  ],
  "events": {
    "publishes": [
      "admin.action"
    ],
    "subscribes": [
      "plugin.loaded",
      "ui.component.loaded"
    ]
  }
}