    "Changelog machine-readable generado por cada release ✅",
    "RFCs creados para cambios mayores con workflow states ✅",
    "Adoption metrics con trends temporales (no solo snapshot) ✅",
    "Deprecation data-driven: usage < 5% + 12 meses + replacement ✅",
    "Migration tooling: scripts + rollback + test coverage >= 80% ✅",
    "Sunset policy implementada (tombstone 410 Gone) ✅",
    "Client SDK versioning tracked ✅",
    "Compatibility testing en CI/CD obligatorio ✅"
  ],

  "response_policy": {
    "format": "JSON only",
    "blocks_order": [
      "inventory",
      "versioning_policy",
      "changelog",
      "rfc_registry",
      "adoption_report",
      "sunset_policy",
      "migration_tooling",
      "compatibility_testing"
    ],
    "on_missing_input": "Emitir standard_error GOVERNANCE_INPUTS_MISSING y detener"
  }
}
