{
  "name": "corner-info-button",
  "category": "navigation",
  "description": "Botón cuadrado informativo con emojis en las 4 esquinas, marco de 4mm y colores variables",
  "version": "2.0.0",
  "author": "Event Core Team",

  "variants": {
    "primary": {
      "description": "Estilo principal - azul",
      "className": "corner-info-button--primary",
      "borderColor": "#3b82f6",
      "bgColor": "#dbeafe"
    },
    "secondary": {
      "description": "Estilo secundario - gris",
      "className": "corner-info-button--secondary",
      "borderColor": "#6b7280",
      "bgColor": "#f3f4f6"
    },
    "success": {
      "description": "Éxito - verde",
      "className": "corner-info-button--success",
      "borderColor": "#10b981",
      "bgColor": "#d1fae5"
    },
    "warning": {
      "description": "Advertencia - amarillo",
      "className": "corner-info-button--warning",
      "borderColor": "#f59e0b",
      "bgColor": "#fef3c7"
    },
    "danger": {
      "description": "Peligro - rojo",
      "className": "corner-info-button--danger",
      "borderColor": "#ef4444",
      "bgColor": "#fee2e2"
    },
    "info": {
      "description": "Informativo - cyan",
      "className": "corner-info-button--info",
      "borderColor": "#06b6d4",
      "bgColor": "#cffafe"
    },
    "custom": {
      "description": "Colores personalizados",
      "className": "corner-info-button--custom",
      "borderColor": "var(--custom-border)",
      "bgColor": "var(--custom-bg)"
    }
  },

  "sizes": {
    "sm": {
      "description": "Pequeño - 120x120px",
      "width": "120px",
      "height": "120px",
      "fontSize": "0.875rem",
      "emojiSize": "1.25rem",
      "className": "corner-info-button--sm"
    },
    "md": {
      "description": "Mediano - 160x160px (por defecto)",
      "width": "160px",
      "height": "160px",
      "fontSize": "1rem",
      "emojiSize": "1.5rem",
      "className": "corner-info-button--md"
    },
    "lg": {
      "description": "Grande - 200x200px",
      "width": "200px",
      "height": "200px",
      "fontSize": "1.125rem",
      "emojiSize": "1.75rem",
      "className": "corner-info-button--lg"
    },
    "xl": {
      "description": "Extra grande - 240x240px",
      "width": "240px",
      "height": "240px",
      "fontSize": "1.25rem",
      "emojiSize": "2rem",
      "className": "corner-info-button--xl"
    }
  },

  "props": {
    "variant": {
      "type": "enum",
      "values": ["primary", "secondary", "success", "warning", "danger", "info", "custom"],
      "default": "primary",
      "required": false,
      "description": "Variante de color del botón"
    },
    "size": {
      "type": "enum",
      "values": ["sm", "md", "lg", "xl"],
      "default": "md",
      "required": false,
      "description": "Tamaño del botón cuadrado"
    },
    "text": {
      "type": "string",
      "required": true,
      "description": "Texto central descriptivo del botón",
      "default": "Acceder"
    },
    "cornerTopLeft": {
      "type": "string",
      "required": false,
      "description": "Emoji para la esquina superior izquierda",
      "default": "📊"
    },
    "cornerTopRight": {
      "type": "string",
      "required": false,
      "description": "Emoji para la esquina superior derecha",
      "default": "📈"
    },
    "cornerBottomLeft": {
      "type": "string",
      "required": false,
      "description": "Emoji para la esquina inferior izquierda",
      "default": "📉"
    },
    "cornerBottomRight": {
      "type": "string",
      "required": false,
      "description": "Emoji para la esquina inferior derecha",
      "default": "📋"
    },
    "borderWidth": {
      "type": "string",
      "default": "4px",
      "description": "Grosor del borde (por defecto 4mm ≈ 4px)"
    },
    "borderColor": {
      "type": "string",
      "required": false,
      "description": "Color personalizado del borde (solo para variant='custom')"
    },
    "bgColor": {
      "type": "string",
      "required": false,
      "description": "Color personalizado del fondo (solo para variant='custom')"
    },
    "href": {
      "type": "string",
      "required": false,
      "description": "URL de destino (si el botón es un enlace)"
    },
    "action": {
      "type": "string",
      "required": false,
      "description": "Acción personalizada al hacer click"
    },
    "target": {
      "type": "enum",
      "values": ["_self", "_blank", "_parent", "_top"],
      "default": "_self",
      "required": false,
      "description": "Target del enlace (si href está definido)"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Deshabilitar el botón"
    },
    "hoverEffect": {
      "type": "boolean",
      "default": true,
      "description": "Activar efecto hover (escala y sombra)"
    },
    "rippleEffect": {
      "type": "boolean",
      "default": true,
      "description": "Activar efecto ripple al hacer click"
    },
    "hapticFeedback": {
      "type": "boolean",
      "default": true,
      "description": "Vibración háptica al hacer click (móvil)"
    },
    "ariaLabel": {
      "type": "string",
      "required": false,
      "description": "Label para accesibilidad"
    }
  },

  "features": [
    "Botón cuadrado con texto central grande y legible",
    "4 emojis personalizables en las esquinas (información visual)",
    "Marco de 4mm de grosor configurable",
    "Colores de borde y fondo personalizables",
    "7 variantes predefinidas (primary, secondary, success, warning, danger, info, custom)",
    "4 tamaños (sm: 120px, md: 160px, lg: 200px, xl: 240px)",
    "Efecto hover con escala y sombra",
    "Efecto ripple al hacer click",
    "Vibración háptica en dispositivos móviles",
    "Puede funcionar como botón o enlace",
    "Responsive y optimizado para touch",
    "ARIA compliant",
    "Ideal para dashboards, paneles de navegación, menús visuales"
  ],

  "accessibility": {
    "role": "button",
    "ariaLabel": true,
    "keyboard": true,
    "focusable": true,
    "screenReader": true,
    "minTouchTarget": "120px"
  },

  "example": {
    "component": "corner-info-button",
    "variant": "primary",
    "size": "md",
    "props": {
      "text": "Panel de Ventas",
      "cornerTopLeft": "📊",
      "cornerTopRight": "📈",
      "cornerBottomLeft": "💰",
      "cornerBottomRight": "🎯",
      "href": "/dashboard/sales",
      "hoverEffect": true,
      "rippleEffect": true,
      "hapticFeedback": true,
      "ariaLabel": "Acceder al panel de ventas"
    }
  },

  "useCases": [
    "Botones de navegación en dashboards",
    "Acceso rápido a secciones con información visual",
    "Menús principales con categorías",
    "Paneles informativos clickeables",
    "Cards de navegación en apps móviles"
  ]
}
