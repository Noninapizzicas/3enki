  "tools": [
    {
      "name": "recetas.crear",
      "description_para_llm": "Guarda una receta nueva en el proyecto. Llámala en cuanto tengas nombre + ingredientes — aunque sean texto libre del usuario y falten otros campos, GUÁRDALA igualmente. Los campos que falten se marcarán como pendientes y se completarán después. NO PIDAS al usuario datos que no haya dado.",
      "parameters_required": ["project_id", "nombre"],
      "parameters_property_names": ["project_id", "nombre", "descripcion", "ingredientes", "instrucciones", "porciones", "tiempo_min", "dificultad", "categorias", "etiquetas", "fuente", "notas"],
      "parameters_size_chars": 866,
      "handler_metodo": "crear",
      "handler_ubicacion": "modules/recetas/index.js:312",
      "retorno": {
        "tipo": "object",
        "shape_inferido": { "id": "string", "nombre": "string", "status": "string", "incompleta": "boolean", "campos_pendientes": "array", "ingredientes_formateados": "string (markdown formateado)", "version": "number" },
        "es_markdown_formateado": true,
        "ejemplos_observados": ["return { id, nombre: receta.nombre, status: 'creada', incompleta: receta.incompleta, campos_pendientes: receta.campos_pendientes, ingredientes_formateados: this._formatIngredientesText(ingredientes), version: 1 };"],
        "publica_eventos_de_dominio": ["receta.creada"]
      },
      "errores_conocidos": []
    },
    {
      "name": "recetas.listar",
