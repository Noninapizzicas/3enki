{
  "core": {
    "id": "core-a",
    "version": "0.1.0",
    "environment": "development"
  },
  "http": {
    "port": 3000,
    "host": "0.0.0.0",
    "cors": {
      "enabled": true,
      "origins": ["*"]
    },
    "compression": {
      "enabled": true,
      "min_size": 1024,
      "level": 6
    },
    "cache": {
      "enabled": false,
      "max_size": 100,
      "default_ttl": 60000
    }
  },
  "mqtt": {
    "broker": {
      "port": 1883,
      "wsPort": 9001,
      "host": "0.0.0.0"
    },
    "client": {
      "reconnect_period": 5000,
      "keep_alive": 60,
      "clean_session": false
    },
    "pool": {
      "enabled": false,
      "min": 2,
      "max": 10,
      "idle_timeout": 30000,
      "acquire_timeout": 5000,
      "health_check_interval": 10000
    }
  },
  "modules": {
    "path": "./modules",
    "auto_load": true,
    "hot_reload": true,
    "enabled": [
      "credential-manager",
      "database-manager",
      "filesystem",
      "plugin-manager",
      "prompt-manager",
      "prompt-engine",
      "prompt-composer",
      "scheduler",
      "project-manager",
      "system-inspector",
      "ai-gateway",
      "ai-agent-framework",
      "agent-manager",
      "calling-generator",
      "bot-manager",
      "chat-ai-bridge",
      "chat-session",
      "code-executor",
      "cuentas",
