{
  "name": "staff-manager",
  "version": "2.1.0",
  "description": "Control de personal con tarjetas NFC NTAG215 — jornadas (tap_in/tap_out con auto_timeout y manager_close) y onboarding de tablets via core-tag.",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",
  "provides": {
    "events": [
      "staff.session.tap_in",
      "staff.session.tap_out",
      "staff.session.auto_timeout",
      "staff.session.manager_close"
    ]
  },
  "events": {
    "publishes": [
      { "event": "staff.session.tap_in",         "description": "Empleado inicia jornada (tap NFC entrada). Lleva project_id top-level + correlation_id + timestamp." },
      { "event": "staff.session.tap_out",        "description": "Empleado finaliza jornada (tap NFC salida)." },
      { "event": "staff.session.auto_timeout",   "description": "Jornada cerrada automaticamente por superar maxShiftHours sin tap_out." },
      { "event": "staff.session.manager_close",  "description": "Jornada cerrada manualmente por el manager via API." },
      { "event": "security.public-key.request",  "description": "Pide a security-p2p la clave publica del core via bus (reemplaza el acceso directo a moduleLoader.loadedModules)." }
    ],
    "subscribes": [
      { "event": "security.public-key.response", "handler": "onPublicKeyResponse", "description": "Recibe la public key del core en respuesta al request publicado durante handleNfcCoreTag." }
    ]
  },
  "ui_handlers": [
    { "domain": "staff-manager", "action": "status",                "handler": "handleStatus",            "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "employee.create",       "handler": "handleEmployeeCreate",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "employee.list",         "handler": "handleEmployeeList",      "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "employee.get",          "handler": "handleEmployeeGet",       "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "employee.update",       "handler": "handleEmployeeUpdate",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "employee.delete",       "handler": "handleEmployeeDelete",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "session.tap_in",        "handler": "handleTapIn",             "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "session.tap_out",       "handler": "handleTapOut",            "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "session.active",        "handler": "handleActiveSessions",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "session.history",       "handler": "handleSessionHistory",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "session.stale",         "handler": "handleStaleSessions",     "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "session.manager_close", "handler": "handleManagerClose",      "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "nfc.employee_card",     "handler": "handleNfcEmployeeCard",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "nfc.core_tag",          "handler": "handleNfcCoreTag",        "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "staff-manager", "action": "nfc.parse",             "handler": "handleNfcParse",          "type": "system_panel", "zone": "lateral_derecha" }
  ],
  "tools": [],
  "dependencies": [],
  "config": {
    "dataPath":      "./data/staff",
    "maxShiftHours": 16,
    "persistence": {
      "type":        "sqlite-via-sql.js",
      "paths": [
        "data/staff/staff.db",
        "data/staff/staff_sessions.db"
      ],
      "concurrency": "single-instance-per-process",
      "owner":       "modules/staff-manager/lib/{employee-registry,session-manager}"
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "staff.tap_in.count",
        "staff.tap_out.count",
        "staff.auto_close.count",
        "staff.manager_close.count",
        "staff-manager.errors"
      ]
    }
  }
}
