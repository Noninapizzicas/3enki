{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/storage-manager.json",

  "definitions": {
    "file_metadata": {
      "type": "object",
      "required": ["id", "project_id", "filename", "path", "size", "created_at"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "project_id": { "type": "string" },
        "filename": { "type": "string" },
        "original_filename": { "type": "string" },
        "path": { "type": "string" },
        "relative_path": { "type": "string" },
        "size": { "type": "integer" },
        "mime_type": { "type": "string" },
        "category": { "type": "string", "enum": ["uploads", "exports", "temp", "files"] },
        "created_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },

    "storage_info": {
      "type": "object",
      "required": ["project_id", "total_size", "file_count"],
      "properties": {
        "project_id": { "type": "string" },
        "total_size": { "type": "integer" },
        "file_count": { "type": "integer" },
        "by_category": {
          "type": "object",
          "properties": {
            "uploads": { "type": "object", "properties": { "size": { "type": "integer" }, "count": { "type": "integer" } } },
            "exports": { "type": "object", "properties": { "size": { "type": "integer" }, "count": { "type": "integer" } } },
            "temp": { "type": "object", "properties": { "size": { "type": "integer" }, "count": { "type": "integer" } } },
            "files": { "type": "object", "properties": { "size": { "type": "integer" }, "count": { "type": "integer" } } }
          }
        }
      },
      "additionalProperties": false
    },

    "upload_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "file": { "$ref": "#/definitions/file_metadata" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "list_response": {
      "type": "object",
      "required": ["success", "files", "count"],
      "properties": {
        "success": { "type": "boolean" },
        "files": {
          "type": "array",
          "items": { "$ref": "#/definitions/file_metadata" }
        },
        "count": { "type": "integer" },
        "total_size": { "type": "integer" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "file_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "file": { "$ref": "#/definitions/file_metadata" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "delete_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "file_id": { "type": "string" },
        "message": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "cleanup_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "files_deleted": { "type": "integer" },
        "bytes_freed": { "type": "integer" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "info_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "storage": { "$ref": "#/definitions/storage_info" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
