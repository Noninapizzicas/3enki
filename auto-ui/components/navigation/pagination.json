{
  "name": "pagination",
  "category": "navigation",
  "description": "Paginación para navegar entre páginas de datos",
  "version": "2.0.0",

  "variants": {
    "default": {
      "description": "Paginación estándar",
      "className": "pagination"
    },
    "simple": {
      "description": "Paginación simple (prev/next)",
      "className": "pagination pagination-simple"
    },
    "compact": {
      "description": "Paginación compacta",
      "className": "pagination pagination-compact"
    },
    "rounded": {
      "description": "Botones redondeados",
      "className": "pagination pagination-rounded"
    }
  },

  "sizes": {
    "sm": {
      "description": "Paginación pequeña",
      "className": "pagination-sm"
    },
    "md": {
      "description": "Paginación mediana (default)",
      "className": ""
    },
    "lg": {
      "description": "Paginación grande",
      "className": "pagination-lg"
    }
  },

  "props": {
    "currentPage": {
      "type": "number",
      "required": true,
      "description": "Página actual (1-indexed)"
    },
    "totalPages": {
      "type": "number",
      "required": true,
      "description": "Total de páginas"
    },
    "totalItems": {
      "type": "number",
      "description": "Total de items"
    },
    "pageSize": {
      "type": "number",
      "default": 10,
      "description": "Items por página"
    },
    "showFirstLast": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar botones primera/última"
    },
    "showPrevNext": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar botones prev/next"
    },
    "showPageNumbers": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar números de página"
    },
    "maxPages": {
      "type": "number",
      "default": 7,
      "description": "Máximo de números de página a mostrar"
    },
    "showInfo": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar información de items"
    },
    "showPageSize": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar selector de items por página"
    },
    "pageSizeOptions": {
      "type": "array",
      "default": [10, 20, 50, 100],
      "description": "Opciones de items por página"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Paginación deshabilitada"
    }
  },

  "labels": {
    "first": {
      "type": "string",
      "default": "Primera",
      "icon": "⏮"
    },
    "previous": {
      "type": "string",
      "default": "Anterior",
      "icon": "◀"
    },
    "next": {
      "type": "string",
      "default": "Siguiente",
      "icon": "▶"
    },
    "last": {
      "type": "string",
      "default": "Última",
      "icon": "⏭"
    },
    "info": {
      "template": "Mostrando {start} a {end} de {total} items"
    },
    "pageSize": {
      "template": "Items por página:"
    }
  },

  "features": {
    "ellipsis": {
      "enabled": true,
      "symbol": "...",
      "description": "Mostrar ellipsis cuando hay muchas páginas"
    },
    "responsive": {
      "enabled": true,
      "hideLabelsOnMobile": true,
      "simplifyOnMobile": true
    },
    "urlSync": {
      "enabled": false,
      "pageParam": "page",
      "pageSizeParam": "pageSize"
    },
    "keyboard": {
      "enabled": true,
      "leftRight": true,
      "homeEnd": true
    }
  },

  "interactions": {
    "pageClick": {
      "action": "navigate",
      "preventDefault": false
    },
    "pageSizeChange": {
      "action": "reload",
      "resetToFirstPage": true
    }
  },

  "accessibility": {
    "role": "navigation",
    "ariaLabel": "Pagination navigation",
    "ariaCurrent": true,
    "keyboardNavigation": true
  },

  "example": {
    "component": "pagination",
    "variant": "default",
    "size": "md",
    "props": {
      "currentPage": 5,
      "totalPages": 20,
      "totalItems": 200,
      "pageSize": 10,
      "showFirstLast": true,
      "showPrevNext": true,
      "showPageNumbers": true,
      "maxPages": 7,
      "showInfo": true,
      "showPageSize": true,
      "pageSizeOptions": [10, 20, 50, 100]
    }
  },

  "simpleExample": {
    "component": "pagination",
    "variant": "simple",
    "props": {
      "currentPage": 3,
      "totalPages": 10,
      "showFirstLast": false,
      "showPageNumbers": false
    },
    "note": "Solo muestra botones Previous y Next"
  }
}
