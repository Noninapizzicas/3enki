{
  "component": "overlay-panel",
  "name": "Overlay Panel",
  "description": "Panel superpuesto semi-transparente con scroll, mantiene la pantalla anterior visible como referencia",
  "sizes": {
    "small": {
      "width": "320px",
      "max_width": "90vw",
      "max_height": "50vh",
      "description": "Panel pequeño para detalles rápidos"
    },
    "medium": {
      "width": "480px",
      "max_width": "90vw",
      "max_height": "70vh",
      "description": "Panel mediano para contenido estándar"
    },
    "large": {
      "width": "640px",
      "max_width": "90vw",
      "max_height": "85vh",
      "description": "Panel grande para contenido extenso"
    },
    "custom": {
      "width": "var(--overlay-width)",
      "max_width": "95vw",
      "max_height": "90vh",
      "description": "Tamaño personalizado vía CSS variables"
    }
  },
  "styling": {
    "backdrop": {
      "background": "rgba(0, 0, 0, 0.6)",
      "blur": "4px",
      "description": "Fondo semi-transparente con blur para ver debajo"
    },
    "panel": {
      "background": "#1a1d24",
      "border_radius": "16px",
      "box_shadow": "0 20px 60px rgba(0, 0, 0, 0.5)",
      "border": "2px solid #374151"
    },
    "header": {
      "background": "#1f2937",
      "height": "56px",
      "padding": "16px",
      "border_bottom": "1px solid #374151"
    },
    "content": {
      "padding": "16px",
      "overflow": "auto",
      "max_height": "calc(100% - 56px)"
    }
  },
  "animations": {
    "open": {
      "name": "overlay-slide-in",
      "duration": "300ms",
      "timing": "ease-out",
      "from": "transform: translateY(100px); opacity: 0;",
      "to": "transform: translateY(0); opacity: 1;"
    },
    "close": {
      "name": "overlay-slide-out",
      "duration": "200ms",
      "timing": "ease-in",
      "from": "transform: translateY(0); opacity: 1;",
      "to": "transform: translateY(100px); opacity: 0;"
    },
    "backdrop_fade_in": {
      "duration": "300ms",
      "from": "opacity: 0;",
      "to": "opacity: 1;"
    }
  },
  "interactions": {
    "close_on_backdrop_click": true,
    "close_on_escape_key": true,
    "prevent_body_scroll": true,
    "focus_trap": true
  },
  "features": {
    "resizable": true,
    "draggable": false,
    "stackable": true,
    "description": "Permite múltiples overlays apilados"
  },
  "examples": [
    {
      "title": "Ver Detalles de Agente",
      "size": "medium",
      "content": "Información detallada del agente AI",
      "trigger": "Click en botón emoji 🤖"
    },
    {
      "title": "Editar Prompt",
      "size": "large",
      "content": "Editor de texto con preview",
      "trigger": "Double-click en tarjeta de prompt"
    },
    {
      "title": "Confirmación Rápida",
      "size": "small",
      "content": "¿Estás seguro de eliminar?",
      "trigger": "Long-press en botón eliminar"
    }
  ]
}
