{
  "module": "scheduler",
  "version": "2.0.0",
  "description": "Gestor central de alarmas - cada proyecto crea sus propias alarmas",

  "_AI_INSTRUCTIONS": {
    "concepto_clave": "Cada proyecto crea SUS alarmas cuando las necesita. NO hay alarmas predefinidas del sistema.",
    "NO_hacer": [
      "NO crear jobs predefinidos del sistema (schedule.hour cada hora, etc.)",
      "NO hardcodear datos de proyectos específicos",
      "NO saturar con eventos innecesarios 'por si acaso'"
    ],
    "SI_hacer": [
      "El proyecto crea su alarma: 'lunes 8am' → emite schedule.time",
      "Scheduler añade _time automáticamente con datos de tiempo",
      "Handler del proyecto escucha y actúa con SU config"
    ],
    "filosofia": "Solo se emiten eventos cuando alguien los programa. Sin ruido innecesario.",
    "ampliable": "Misma filosofía para clima, sistema, externos en el futuro"
  },

  "arquitectura": {
    "diagrama": [
      "┌─────────────────────────────────────────────────────┐",
      "│ PROYECTO crea su alarma:                            │",
      "│ 'Lunes 8am' → cron '0 8 * * 1' → topic schedule.time│",
      "└─────────────────────────────────────────────────────┘",
      "                         │",
      "                         ▼ Lunes 8:00",
      "┌─────────────────────────────────────────────────────┐",
      "│ SCHEDULER emite:                                    │",
      "│ schedule.time { _time: { hour:8, dayOfWeek:1 } }    │",
      "└─────────────────────────────────────────────────────┘",
      "                         │",
      "                         ▼",
      "┌─────────────────────────────────────────────────────┐",
      "│ HANDLER del proyecto:                               │",
      "│ - Lee SU config (gmail.account, telegram.bot)       │",
      "│ - Emite gmail.check con SUS datos                   │",
      "└─────────────────────────────────────────────────────┘"
    ],
    "flujo": [
      "1. Proyecto necesita revisar Gmail los lunes a las 8",
      "2. Proyecto crea alarma via UI o evento",
      "3. Scheduler guarda y programa la alarma",
      "4. Lunes 8:00 → Scheduler emite evento con _time",
      "5. Handler del proyecto escucha y ejecuta"
    ]
  },

  "payload_automatico": {
    "descripcion": "Scheduler añade _time y _job a TODOS los eventos MQTT automáticamente",
    "_time": {
      "timestamp": "number - Unix timestamp ms",
      "iso": "string - ISO 8601",
      "hour": "number - 0-23",
      "minute": "number - 0-59",
      "second": "number - 0-59",
      "dayOfWeek": "number - 0=Domingo, 6=Sábado",
      "dayOfMonth": "number - 1-31",
      "month": "number - 1-12",
      "year": "number",
      "timezone": "string - Europe/Madrid"
    },
    "_job": {
      "id": "string - ID del job",
      "name": "string - Nombre del job"
    }
  },

  "crear_alarma": {
    "descripcion": "Cómo un proyecto crea su alarma",
    "metodos": {
      "via_ui": "Interfaz de usuario del scheduler",
      "via_evento": "emit('ui.request.scheduler.create', { ... })",
      "via_api": "POST /modules/scheduler/jobs"
    },
    "estructura_job": {
      "id": "string - Único, descriptivo (ej: mi-proyecto-gmail-lunes)",
      "name": "string - Nombre legible",
      "description": "string - Descripción",
      "enabled": "boolean",
      "trigger": "object - Cuándo disparar",
      "action": {
        "type": "mqtt",
        "topic": "string - Evento a emitir"
      },
      "metadata": {
        "projectId": "string - Proyecto dueño",
        "category": "string - time|weather|system|custom"
      }
    },
    "ejemplos": {
      "lunes_8am": {
        "id": "facturas-gmail-lunes",
        "name": "Gmail lunes 8am",
        "trigger": { "type": "cron", "expression": "0 8 * * 1" },
        "action": { "type": "mqtt", "topic": "schedule.time" },
        "metadata": { "projectId": "facturas", "category": "time" }
      },
      "cada_30_min_laborables": {
        "id": "soporte-check-30min",
        "name": "Check cada 30 min L-V",
        "trigger": { "type": "cron", "expression": "*/30 9-18 * * 1-5" },
        "action": { "type": "mqtt", "topic": "schedule.time" },
        "metadata": { "projectId": "soporte", "category": "time" }
      },
      "domingo_3am_backup": {
        "id": "sistema-backup-domingo",
        "name": "Backup domingo 3am",
        "trigger": { "type": "cron", "expression": "0 3 * * 0" },
        "action": { "type": "mqtt", "topic": "schedule.time" },
        "metadata": { "projectId": "sistema", "category": "time" }
      }
    }
  },

  "handler_proyecto": {
    "descripcion": "El handler escucha el evento y actúa con SU configuración",
    "ejemplo": {
      "archivo": "data/projects/mi-proyecto/handlers/gmail-programado.js",
      "codigo": [
        "module.exports = {",
        "  name: 'gmail-programado',",
        "  trigger: 'schedule.time',",
        "  ",
        "  // Filtrar por MI job específico",
        "  filter: (event) => {",
        "    const job = event.data?._job || event._job;",
        "    return job?.id === 'mi-proyecto-gmail-lunes';",
        "  },",
        "  ",
        "  async handle(event, { emit, config, logger }) {",
        "    const { gmail, telegram } = config.project || {};",
        "    if (!gmail?.account) return;",
        "    ",
        "    // Emitir acción con MI configuración",
        "    emit('gmail.check', {",
        "      account: gmail.account,",
        "      query: gmail.query,",
        "      notifyTelegram: !!telegram,",
        "      botName: telegram?.botName,",
        "      chatId: telegram?.chatId",
        "    });",
        "  }",
        "};"
      ]
    }
  },

  "tipos_de_triggers": {
    "cron": {
      "descripcion": "Expresiones cron estándar",
      "propiedades": {
        "type": "cron",
        "expression": "minuto hora día-mes mes día-semana",
        "timezone": "string - default: Europe/Madrid"
      },
      "ejemplos": {
        "lunes_8am": "0 8 * * 1",
        "laborables_9am": "0 9 * * 1-5",
        "cada_30min_horario": "*/30 9-18 * * 1-5",
        "domingos_3am": "0 3 * * 0",
        "dia_1_medianoche": "0 0 1 * *"
      }
    },
    "interval": {
      "descripcion": "Intervalos fijos",
      "propiedades": {
        "type": "interval",
        "value": "number",
        "unit": "ms|s|m|h|d"
      }
    },
    "datetime": {
      "descripcion": "Fecha/hora específica",
      "propiedades": {
        "type": "datetime",
        "date": "YYYY-MM-DD",
        "time": "HH:mm:ss",
        "repeat": "once|daily|weekly|monthly|yearly"
      }
    },
    "event": {
      "descripcion": "Cuando ocurre otro evento",
      "propiedades": {
        "type": "event",
        "topic": "string - evento a escuchar",
        "condition": "string - condición JS",
        "debounce": "number - ms"
      }
    },
    "composite": {
      "descripcion": "Combinación AND/OR de triggers",
      "propiedades": {
        "type": "composite",
        "logic": "AND|OR",
        "triggers": "array de triggers"
      }
    }
  },

  "categorias_futuras": {
    "descripcion": "Misma filosofía para otros tipos de alarmas",
    "time": "Alarmas de tiempo - IMPLEMENTADO",
    "weather": "Alarmas climáticas - FUTURO (via API externa)",
    "system": "Alarmas del sistema - FUTURO (errores, health)",
    "external": "Alarmas de APIs externas - FUTURO"
  },

  "ubicacion_archivos": {
    "modulo": "modules/scheduler/",
    "jobs": "data/scheduler/jobs.json",
    "documentacion": "contexto/scheduler.json",
    "nota": "jobs.json está VACÍO por defecto. Cada proyecto crea sus alarmas."
  }
}
