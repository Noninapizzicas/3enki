  "identidad": {
    "name": "telegram-service",
    "version": "3.0.0",
    "description_oficial": "Multi-bot Telegram service - centralized management, credential-manager integration",
    "author": "Event Core Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_6_ui",
    "tier_declarado": null,
    "dev_only_declarado": false,
