<script lang="ts">
  import { onMount } from 'svelte';
  import { MobileWorkspaceLayout } from '$components/layout';
  import { ChatAIWorkspace, type AIModel, type AICredential, type AITool, type AIPlugin, type ContextItem, type QuickPrompt, type ChatMessage, DEFAULT_MODELS } from '$components/ai';
  import { Card, Button, Badge } from '$components/ui';
  import { Spinner } from '$components/feedback';
  import { subscribe, events } from '$stores/mqtt';
  import { toast } from '$stores/toast';
  import config from '$lib/config';

  // API Base
  const apiBase = `${config.apiUrl}/modules/{{name}}`;
  const credentialsApi = `${config.apiUrl}/modules/credential-manager`;
  const aiGatewayApi = `${config.apiUrl}/modules/ai-gateway`;

  // State
  let loading = true;
  let chatLoading = false;
  let currentPanel = '';

  // AI State
  let availableModels: AIModel[] = DEFAULT_MODELS;
  let selectedModelId = 'deepseek-chat';
  let credentials: AICredential[] = [];
  let currentModel = 'DeepSeek Chat';
  let currentCredentialPreview = 'sk-...';

  // Tools
  let tools: AITool[] = [
    {{#each tools}}
    { id: '{{id}}', name: '{{name}}', description: '{{description}}', enabled: {{enabled}}, category: '{{category}}' },
    {{/each}}
  ];

  // Plugins
  let plugins: AIPlugin[] = [];

  // Context
  let contextItems: ContextItem[] = [
    { type: 'style', label: 'Estilo', value: 'Default', active: true },
    { type: 'language', label: 'Idioma', value: 'Español', active: true }
  ];

  // Prompts
  let quickPrompts: QuickPrompt[] = [
    {{#each prompts}}
    { id: '{{id}}', name: '{{name}}', content: '{{content}}', category: '{{category}}', favorite: {{favorite}} },
    {{/each}}
  ];

  // Chat
  let chatMessages: ChatMessage[] = [];

  // Stats
  let stats = {
    total: 0,
    validated: 0,
    processing: 0,
    errors: 0
  };

  // Toolbar buttons
  const topButtons = [
    {
      id: 'main',
      emoji: '{{icon}}',
      label: '{{titleCase name}}',
      primaryAction: { type: 'panel' as const, panelId: 'main-list', label: 'Ver lista' }
    },
    {
      id: 'stats',
      emoji: '📊',
      label: 'Stats',
      primaryAction: { type: 'panel' as const, panelId: 'stats', label: 'Estadísticas' }
    }
  ];

  const bottomButtons = [
    {
      id: 'historial',
      emoji: '🕐',
      label: 'Historial',
      primaryAction: { type: 'panel' as const, panelId: 'history', label: 'Ver historial' }
    }
  ];

  const sideButtons = [
    {
      id: 'home',
      emoji: '🏠',
      primaryAction: { type: 'navigate' as const, target: '/', label: 'Inicio' }
    },
    {
      id: 'modulos',
      emoji: '🧩',
      primaryAction: { type: 'panel' as const, panelId: 'modulos', label: 'Módulos' }
    },
    {
      id: 'credentials',
      emoji: '🔐',
      badge: 0,
      primaryAction: { type: 'panel' as const, panelId: 'credentials', label: 'Ver credenciales' },
      secondaryAction: { type: 'panel' as const, panelId: 'credential-add', label: 'Añadir credencial' }
    },
    {
      id: 'settings',
      emoji: '⚙️',
      primaryAction: { type: 'panel' as const, panelId: 'settings', label: 'Configuración' }
    },
    {
      id: 'help',
      emoji: '❓',
      primaryAction: { type: 'panel' as const, panelId: 'help', label: 'Ayuda' }
    }
  ];

  const chatTopButtons = [
    {
      id: 'modelo',
      emoji: '🤖',
      label: 'Modelo',
      displayValue: currentModel,
      primaryAction: { type: 'panel' as const, panelId: 'modelo-selector', label: 'Seleccionar modelo' }
    },
    {
      id: 'credencial',
      emoji: '🔑',
      label: 'API Key',
      displayValue: currentCredentialPreview,
      primaryAction: { type: 'panel' as const, panelId: 'credencial-selector', label: 'Seleccionar API Key' }
    },
    {
      id: 'prompt',
      emoji: '📝',
      label: 'Prompt',
      primaryAction: { type: 'panel' as const, panelId: 'prompts', label: 'Prompts rápidos' }
    }
  ];

  const chatBottomButtons = [
    {
      id: 'tools',
      emoji: '🔧',
      label: 'Tools',
      primaryAction: { type: 'panel' as const, panelId: 'tools', label: 'Herramientas' }
    },
    {
      id: 'contexto',
      emoji: '📋',
      label: 'Contexto',
      primaryAction: { type: 'panel' as const, panelId: 'contexto', label: 'Ver contexto' }
    },
    {
      id: 'plugins',
      emoji: '🔌',
      label: 'Plugins',
      primaryAction: { type: 'panel' as const, panelId: 'plugins', label: 'Plugins activos' }
    }
  ];

  const panels = {
    'main-list': { title: 'Lista', size: 'lg' as const },
    'stats': { title: 'Estadísticas', size: 'md' as const },
    'history': { title: 'Historial', size: 'lg' as const },
    'modulos': { title: 'Módulos', size: 'md' as const },
    'credentials': { title: 'Credenciales', size: 'lg' as const },
    'credential-add': { title: 'Nueva Credencial', size: 'md' as const },
    'settings': { title: 'Configuración', size: 'md' as const },
    'help': { title: 'Ayuda', size: 'md' as const },
    'modelo-selector': { title: 'Seleccionar Modelo', size: 'sm' as const },
    'credencial-selector': { title: 'Seleccionar API Key', size: 'sm' as const },
    'prompts': { title: 'Prompts Rápidos', size: 'md' as const },
    'tools': { title: 'Herramientas', size: 'md' as const },
    'contexto': { title: 'Contexto Actual', size: 'md' as const },
    'plugins': { title: 'Plugins Activos', size: 'md' as const }
  };

  // API Functions
  async function fetchCredentials() {
    try {
      const res = await fetch(`${credentialsApi}/credentials`);
      if (!res.ok) return;
      const data = await res.json();
      credentials = data.credentials || [];
    } catch (err) {
      console.error('Error fetching credentials:', err);
    }
  }

  async function loadAll() {
    loading = true;
    await Promise.all([fetchCredentials()]);
    loading = false;
  }

  // Handlers
  function handleButtonAction(e: CustomEvent) {
    const { buttonId, actionType, action } = e.detail;
    console.log('Button action:', buttonId, actionType, action);
  }

  async function handleChatSubmit(e: CustomEvent) {
    const { message } = e.detail;
    if (!message.trim()) return;

    const userMessage: ChatMessage = {
      id: `msg-${Date.now()}`,
      role: 'user',
      content: message,
      timestamp: new Date()
    };
    chatMessages = [...chatMessages, userMessage];

    const assistantId = `msg-${Date.now() + 1}`;
    const loadingMessage: ChatMessage = {
      id: assistantId,
      role: 'assistant',
      content: '',
      timestamp: new Date(),
      loading: true
    };
    chatMessages = [...chatMessages, loadingMessage];
    chatLoading = true;

    try {
      const aiMessages = [
        { role: 'system', content: 'Eres un asistente útil.' },
        ...chatMessages.filter(m => !m.loading).slice(-10).map(m => ({ role: m.role, content: m.content }))
      ];

      const res = await fetch(`${aiGatewayApi}/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          messages: aiMessages,
          provider: 'auto',
          max_tokens: 1000,
          temperature: 0.7
        })
      });

      if (!res.ok) {
        const errorData = await res.json().catch(() => ({}));
        throw new Error(errorData.message || `Error ${res.status}`);
      }

      const data = await res.json();
      chatMessages = chatMessages.map(m =>
        m.id === assistantId
          ? { ...m, content: data.content || 'Sin respuesta', loading: false, provider: data.provider, model: data.model }
          : m
      );
    } catch (err) {
      chatMessages = chatMessages.map(m =>
        m.id === assistantId
          ? { ...m, content: `Error: ${err instanceof Error ? err.message : 'Error desconocido'}`, loading: false, error: true }
          : m
      );
      toast.error('Error al enviar mensaje');
    } finally {
      chatLoading = false;
    }
  }

  function handlePanelOpen(e: CustomEvent) {
    currentPanel = e.detail.panelId;
  }

  function handlePanelClose() {
    currentPanel = '';
  }

  // ChatAIWorkspace handlers
  function handleModelSelect(e: CustomEvent) {
    const { model } = e.detail;
    currentModel = model.name;
    toast.success(`Modelo: ${model.name}`);
  }

  function handleCredentialSelect(e: CustomEvent) {
    const { credential } = e.detail;
    currentCredentialPreview = credential.api_key_preview;
    toast.success(`API Key: ${credential.provider}`);
  }

  function handlePromptApply(e: CustomEvent) {
    const { prompt } = e.detail;
    toast.info(`Prompt aplicado: ${prompt.name}`);
  }

  function handleAddCredential() {
    currentPanel = 'credential-add';
  }

  // Lifecycle
  onMount(() => {
    loadAll();
    subscribe(['core/+/events/{{name}}/#', 'core/+/events/credential/#']);
  });
</script>

<svelte:head>
  <title>{{titleCase name}} - Event-Core</title>
</svelte:head>

<MobileWorkspaceLayout
  title="{{titleCase name}}"
  {topButtons}
  {bottomButtons}
  {sideButtons}
  {chatTopButtons}
  {chatBottomButtons}
  {panels}
  showChat={true}
  showChatBars={true}
  chatPlaceholder="{{chatPlaceholder}}"
  chatLoading={chatLoading}
  on:buttonAction={handleButtonAction}
  on:chatSubmit={handleChatSubmit}
  on:panelOpen={handlePanelOpen}
  on:panelClose={handlePanelClose}
>
  <!-- Main Content -->
  {#if loading}
    <div class="flex items-center justify-center h-full">
      <Spinner size="lg" />
    </div>
  {:else}
    <div class="space-y-4">
      <Card padding="sm">
        <div class="text-center text-sm text-text-muted">
          <p class="mb-2">👆 <strong>Tap</strong> = Ver | 👆👆 <strong>Doble</strong> = Añadir | 👇 <strong>Hold</strong> = Editar</p>
          <p>Usa el chat para interactuar con la IA</p>
        </div>
      </Card>
    </div>
  {/if}

  <!-- Panel Content -->
  <svelte:fragment slot="panel" let:panelId>
    <!-- ChatAIWorkspace panels -->
    <ChatAIWorkspace
      {currentPanel}
      {availableModels}
      bind:selectedModelId
      {credentials}
      bind:tools
      bind:plugins
      bind:contextItems
      bind:quickPrompts
      {stats}
      on:modelSelect={handleModelSelect}
      on:credentialSelect={handleCredentialSelect}
      on:promptApply={handlePromptApply}
      on:addCredential={handleAddCredential}
    >
      <!-- Custom panels -->
      <svelte:fragment slot="panel" let:panelId={customPanelId}>
        {#if customPanelId === 'help'}
          <div class="space-y-4 text-sm">
            <h4 class="font-medium">Sistema de gestos</h4>
            <div class="space-y-2">
              <p><strong>👆 1 Tap:</strong> Ver/Consultar información</p>
              <p><strong>👆👆 2 Taps:</strong> Añadir/Crear nuevo</p>
              <p><strong>👇 Hold 3s:</strong> Editar/Configurar</p>
            </div>
          </div>
        {:else}
          <p class="text-center text-text-muted py-4">Panel: {customPanelId}</p>
        {/if}
      </svelte:fragment>
    </ChatAIWorkspace>
  </svelte:fragment>
</MobileWorkspaceLayout>
