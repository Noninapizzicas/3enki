{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enki.local/arquitectura/decisiones/subsistema-recetario/produccion.compra.calculada.schema.json",
  "title": "produccion.compra.calculada — payload schema",
  "description": "Evento emitido por mise-en-place tras consolidar la lista de compra de un conjunto de recetas para un horizonte temporal (servicio del dia, semana, evento). Agrega cantidades por ingrediente y aplica redondeos a unidades de compra.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "project_id",
    "user_id",
    "horizonte",
    "items",
    "timestamp"
  ],
  "properties": {
    "correlation_id": { "$ref": "_common.schema.json#/$defs/correlation_id" },
    "project_id":     { "$ref": "_common.schema.json#/$defs/project_id" },
    "user_id":        { "$ref": "_common.schema.json#/$defs/user_id" },
    "horizonte": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tipo"],
      "properties": {
        "tipo":    { "enum": ["servicio", "dia", "semana", "evento", "personalizado"] },
        "desde":   { "type": "string", "format": "date-time" },
        "hasta":   { "type": "string", "format": "date-time" },
        "etiqueta":{ "type": "string", "minLength": 1 }
      }
    },
    "recetas_consideradas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["receta_id", "porciones"],
        "properties": {
          "receta_id": { "$ref": "_common.schema.json#/$defs/receta_id" },
          "porciones": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ingrediente", "cantidad_neta", "unidad"],
        "properties": {
          "ingrediente":     { "$ref": "_common.schema.json#/$defs/ingrediente_nombre" },
          "cantidad_neta":   { "type": "number", "minimum": 0, "description": "Cantidad calculada antes de redondeo a unidad de compra." },
          "cantidad_compra": { "type": "number", "minimum": 0, "description": "Cantidad redondeada a unidad de compra." },
          "unidad":          { "$ref": "_common.schema.json#/$defs/unidad" },
          "merma_pct":       { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "timestamp":      { "$ref": "_common.schema.json#/$defs/timestamp" }
  }
}
