# config.api-server.yaml.example — bloque a AÑADIR al config.yaml de Hermes
# (/home/hermes/.hermes/config.yaml, lo crea `hermes setup`).
#
# Enciende el api_server: la puerta LOCAL OpenAI-compatible por la que Enki
# le delega objetivos a Hermes (provider 'hermes' del ai-gateway).
#
#   POST /v1/chat/completions   — delegación con memoria (X-Hermes-Session-Key)
#   POST /v1/runs               — encargos async con run_id (capa futura de Enki)
#   GET  /v1/models             — sonda de vida
#
# La key es OBLIGATORIA: el api_server se niega a arrancar sin ella.
# La MISMA key va al lado Enki (credential-manager provider 'hermes',
# o env HERMES_API_KEY del proceso de Enki).
#
# host queda en 127.0.0.1 (default): solo procesos del propio VPS llegan.
# NO abrir este puerto en Caddy ni en el firewall.

platforms:
  api_server:
    enabled: true
    extra:
      # host: "127.0.0.1"      # default — dejarlo así (solo local)
      # port: 8642             # default — casa con providers.hermes.api_base de Enki
      key: "CAMBIA-ESTA-KEY"   # p.ej.: openssl rand -hex 32
