{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enki.local/arquitectura/decisiones/persistence.schema.json",
  "title": "Persistence Convention — Output Schema",
  "description": "Schema strict de la instancia persistence.json. Valida arquitectura/decisiones/_outputs/persistence.json. additionalProperties=false en todos los niveles. A diferencia de los schemas previos (events/lifecycle/observability/errors), persistence describe un CATÁLOGO de patrones aceptados, no UN patrón único.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_meta",
    "regla",
    "patrones",
    "reglas_universales",
    "module_declaration_shape",
    "detection_patterns"
  ],

  "properties": {
    "_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["convencion", "version", "creado_en", "contrato_referencia"],
      "properties": {
        "convencion":          { "const": "persistence" },
        "version":             { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "creado_en":           { "type": "string", "format": "date" },
        "contrato_referencia": { "type": "string", "pattern": "^arquitectura/decisiones/_contratos/" },
        "supersedes_nota":     { "type": ["string", "null"] }
      }
    },

    "regla": {
      "type": "string",
      "minLength": 80
    },

    "patrones": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/patron" }
    },

    "reglas_universales": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/regla_universal" }
    },

    "module_declaration_shape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["descripcion", "campos", "ejemplos_por_patron"],
      "properties": {
        "descripcion": { "type": "string", "minLength": 30 },
        "campos": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/manifest_field" }
        },
        "ejemplos_por_patron": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/manifest_example" }
        }
      }
    },

    "detection_patterns": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "non_atomic_write_regex",
        "secret_in_persistence_field_names",
        "silent_io_catch_regex",
        "cross_module_path_indicators",
        "schema_drift_keywords"
      ],
      "properties": {
        "non_atomic_write_regex": {
          "type": "string",
          "minLength": 10
        },
        "secret_in_persistence_field_names": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$" }
        },
        "silent_io_catch_regex": {
          "type": "string",
          "minLength": 10
        },
        "cross_module_path_indicators": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 3 }
        },
        "schema_drift_keywords": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 5 }
        }
      }
    }
  },

  "$defs": {
    "patron": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "nombre",
        "descripcion",
        "when_to_use",
        "reglas_minimas",
        "ejemplo_uso",
        "ejemplo_modulos_audit",
        "riesgos",
        "restart_resilient",
        "supports_concurrency"
      ],
      "properties": {
        "id": {
          "enum": [
            "in-memory",
            "json-file",
            "json-file-per-project",
            "sqlite",
            "append-only-log",
            "external-delegation"
          ]
        },
        "nombre":      { "type": "string", "minLength": 5 },
        "descripcion": { "type": "string", "minLength": 30 },
        "when_to_use": { "type": "string", "minLength": 30 },
        "reglas_minimas": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 15 }
        },
        "ejemplo_uso": { "type": "string", "minLength": 15 },
        "ejemplo_modulos_audit": {
          "type": "array",
          "minItems": 0,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 3 }
        },
        "riesgos": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 15 }
        },
        "restart_resilient": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 3 }
          ]
        },
        "supports_concurrency": { "type": "string", "minLength": 5 }
      }
    },

    "regla_universal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "descripcion", "viola_si_no_se_cumple"],
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "descripcion": { "type": "string", "minLength": 20 },
        "viola_si_no_se_cumple": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        },
        "aplica_a_patrones": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "in-memory",
              "json-file",
              "json-file-per-project",
              "sqlite",
              "append-only-log",
              "external-delegation",
              "*"
            ]
          }
        }
      }
    },

    "manifest_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "obligatorio_si", "descripcion"],
      "properties": {
        "name":          { "type": "string", "pattern": "^[a-z][a-z_]*$" },
        "type":          { "type": "string", "minLength": 3 },
        "obligatorio_si": { "type": "string", "minLength": 5 },
        "descripcion":   { "type": "string", "minLength": 10 },
        "valores_permitidos": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        }
      }
    },

    "manifest_example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patron", "ejemplo_json"],
      "properties": {
        "patron": {
          "enum": [
            "in-memory",
            "json-file",
            "json-file-per-project",
            "sqlite",
            "append-only-log",
            "external-delegation"
          ]
        },
        "ejemplo_json": { "type": "string", "minLength": 30 }
      }
    }
  }
}
