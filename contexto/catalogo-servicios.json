  "service_providers": {
    "cloud": {
      "anthropic": {
        "version": "1.0.0",
        "auth": "Header x-api-key",
        "base_url": "https://api.anthropic.com/v1",
        "funciones": {
          "vision.extract": {
            "descripcion": "OCR con análisis usando Claude Vision",
            "input": ["image (base64)", "media_type", "prompt", "model"],
