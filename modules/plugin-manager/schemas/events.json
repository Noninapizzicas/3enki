{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/plugin-manager/events.json",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": { "type": "string", "format": "uuid" },
        "event_type": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "producer": { "type": "string", "const": "plugin-manager" },
        "schema_version": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "plugin_loaded": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "plugin.loaded" },
            "payload": {
              "type": "object",
              "required": ["name", "functions", "loaded_at"],
              "properties": {
                "name": { "type": "string" },
                "version": { "type": "string" },
                "description": { "type": "string" },
                "functions": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "function_count": { "type": "integer" },
                "loaded_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "plugin_unloaded": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "plugin.unloaded" },
            "payload": {
              "type": "object",
              "required": ["name", "unloaded_at"],
              "properties": {
                "name": { "type": "string" },
                "unloaded_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "plugin_error": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "plugin.error" },
            "payload": {
              "type": "object",
              "required": ["error", "context"],
              "properties": {
                "name": { "type": "string" },
                "file": { "type": "string" },
                "error": { "type": "string" },
                "context": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "plugin_reloaded": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "plugin.reloaded" },
            "payload": {
              "type": "object",
              "required": ["count", "loaded", "errors", "reloaded_at"],
              "properties": {
                "count": { "type": "integer" },
                "loaded": { "type": "integer" },
                "errors": { "type": "integer" },
                "reloaded_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "plugin_get_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "plugin.get.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "plugin": { "type": "object" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "plugin_list_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "plugin.list.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success", "plugins", "count"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "plugins": { "type": "array" },
                "count": { "type": "integer" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
