{
  "name": "{{name}}",
  "version": "1.0.0",
  "description": "{{description}}",
  "author": "{{author}}",

  "events": {
    "publishes": [
      {{#each publishEvents}}
      "{{this}}"{{#unless @last}},{{/unless}}
      {{/each}}
    ],
    "subscribes": [
      {{#each subscriptions}}
      "{{this.event}}"{{#unless @last}},{{/unless}}
      {{/each}}
    ]
  },

  "apis": [
    {{#each apis}}
    {
      "method": "{{this.method}}",
      "path": "{{this.path}}",
      "handler": "{{this.handler}}",
      "description": "{{this.description}}"
    },
    {{/each}}
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check del módulo"
    }
  ],

  "tools": [
    {{#each tools}}
    {
      "name": "{{../name}}.{{this.name}}",
      "description": "{{this.description}}",
      "handler": "tool{{pascalCase this.name}}",
      "parameters": {
        "type": "object",
        "properties": {
          {{#each this.params}}
          "{{this.name}}": {
            "type": "{{this.type}}",
            "description": "{{this.description}}"
          }{{#unless @last}},{{/unless}}
          {{/each}}
        },
        "required": [{{#each this.required}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
      }
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ],

  {{#if uiSimple}}
  "ui": {
    "zone": "{{uiZone}}",
    "icon": "{{icon}}"
  },
  {{/if}}
  {{#if uiAdvanced}}
  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "{{titleCase name}}",
    "icon": "{{icon}}",
    "description": "{{description}}",

    "views": {
      "main": {
        "type": "dashboard",
        "permissions": ["admin", "user"],

        "layout": {
          "type": "two-column",
          "config": {
            "leftWidth": "65%",
            "rightWidth": "35%",
            "gap": "var(--space-lg)"
          }
        },

        "sections": [
          {
            "id": "stats",
            "widget": "stat-card",
            "config": {
              "label": "Total",
              "value": "@compute.count(@data.items)",
              "icon": "📊",
              "color": "primary"
            }
          },
          {
            "id": "main_table",
            "widget": "table-advanced",
            "config": {
              "dataSource": "@data.items",
              "columns": "auto",
              "sortable": true,
              "filterable": true,
              "paginated": true,
              "actions": [
                {
                  "label": "Editar",
                  "icon": "✏️",
                  "action": "edit",
                  "permissions": ["admin"]
                },
                {
                  "label": "Eliminar",
                  "icon": "🗑️",
                  "action": "delete",
                  "permissions": ["admin"],
                  "confirm": true
                }
              ]
            }
          }
        ]
      }
    },

    "mqtt": {
      "enabled": true,
      "topics": [
        {{#each publishEvents}}
        "{{this}}"{{#unless @last}},{{/unless}}
        {{/each}}
      ],
      "auto_refresh": true
    }
  },
  {{/if}}

  "dependencies": [
    {{#each dependencies}}
    "{{this}}"{{#unless @last}},{{/unless}}
    {{/each}}
  ],

  "config": {
    {{#if persistence}}
    "persist_interval_ms": 60000,
    {{/if}}
    "enabled": true
  }
}
