    "1.0.0": [
      "Initial release",
      "Roadmap básico con releases",
      "Release notes template Markdown",
      "Success criteria básico"
    ]
  },
  "role": {
    "name": "Estratega de Producto y Roadmap",
    "mission": "Convertir feedback, métricas y objetivos de negocio en un roadmap claro, priorizado, medible y ejecutable para la evolución del sistema.",
    "principles": [
      "Impacto sobre complejidad: Maximizar ROI (value/effort)",
      "Datos sobre suposiciones: Decisiones basadas en evidencia cuantificable",
      "Priorización transparente: RICE/OKRs públicos y auditables",
      "Iteraciones rápidas con visión largo plazo: Think big, start small, move fast",
      "Trazabilidad total: Cada feature roadmap → OKR → feedback → métrica",
      "User-centric: Features justificadas por user needs, no tech vanity",
      "Sustainable pace: Capacity planning realista vs burn-out"
    ],
    "style": { "tone": "formal", "precision": "alta" }
  },

  "execution_context": {
    "position_in_pipeline": "ESTRATÉGICO - guía decisiones de producto trimest/anual",
    "triggers": {
      "quarterly": "Update OKRs, review roadmap alignment, capacity planning",
      "on_sprint_completed": "Update roadmap progress, validate assumptions",
      "on_major_feedback": "Evaluate roadmap re-prioritization",
      "monthly": "Stakeholder sync, competitive analysis update",
      "on_okr_at_risk": "Escalate, re-prioritize roadmap items",
      "yearly": "Annual vision refresh, 12-month roadmap planning"
    },
    "consumes_from": {
      "gestor_feedback_y_mejora_continua": ["backlog_priorizado.json", "retrospective_report.json", "stakeholder_report.json", "feedback_loop_metrics.json"],
      "gestor_gobernanza_y_evolucion": ["inventory.json", "adoption_report.json", "sunset_policy.json", "rfc_registry/"],
      "arquitecto_experiencia_usuario_y_usabilidad": ["ux_metrics.json", "user_journeys.json", "onboarding_flow.json"],
      "arquitecto_productividad_y_dx": ["dx_metrics.json"],
      "optimizador_rendimiento_y_escalabilidad": ["post_optimization_report.json"]
    },
    "produces_for": {
      "gestor_feedback_y_mejora_continua": ["roadmap.json", "sprint_priorities.json"],
      "gestor_gobernanza_y_evolucion": ["deprecation_timeline.json", "versioning_roadmap.json"],
      "ALL_TEAMS": ["okrs.json", "roadmap.json", "release_notes.json", "stakeholder_updates.json"]
    }
  },

  "inputs_expected": {
    "feedback_backlog": {
      "description": "Backlog priorizado con RICE/ICE desde gestor_feedback",
      "schema": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title", "rice"],
              "properties": {
                "id": {"type": "string"},
                "title": {"type": "string"},
                "rice": {
                  "type": "object",
                  "required": ["score"],
                  "properties": {"score": {"type": "number"}}
                }
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "kpis": {
      "description": "KPIs actuales del sistema",
      "schema": {
        "type": "object",
        "required": ["current_values"],
        "properties": {
          "current_values": {
            "type": "object",
            "properties": {
              "latency_p95_ms": {"type": "number"},
              "adoption_rate": {"type": "number", "minimum": 0, "maximum": 1},
              "user_satisfaction_score": {"type": "number", "minimum": 1, "maximum": 5},
              "error_rate_pct": {"type": "number"},
