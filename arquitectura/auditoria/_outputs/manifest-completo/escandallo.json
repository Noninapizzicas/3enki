{
  "_meta": {
    "modulo": "escandallo",
    "ubicacion": "modules/escandallo",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "escandallo",
    "version": "1.0.0",
    "description_oficial": "Análisis de costes y escandallo de recetas. Calcula costes, márgenes, food cost, comparativas de precios y alertas.",
    "author": "Event Core Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_5_domain_negocio_alimentario",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "escandallo.calculado",  "description": "Escandallo calculado para una receta" },
      { "event": "escandallo.alerta",     "description": "Alerta: coste supera umbral o margen bajo" },
      { "event": "escandallo.comparativa","description": "Comparativa de precios generada" }
    ],
    "subscribes": [
      { "event": "project.activated",              "handler": "onProjectActivated",           "extras": {} },
      { "event": "project.deactivated",            "handler": "onProjectDeactivated",         "extras": {} },
      { "event": "receta.creada",                  "handler": "onRecetaCreada",               "extras": {} },
      { "event": "receta.actualizada",             "handler": "onRecetaActualizada",          "extras": {} },
      { "event": "ingrediente.precio.actualizado", "handler": "onIngredientePrecioActualizado","extras": {} }
    ],
    "provides_eventos": ["escandallo.calculado", "escandallo.alerta", "escandallo.comparativa"]
  },

  "tools": [
    {
      "name": "escandallo.receta",
      "description": "Calcula el escandallo completo de una receta: desglose de costes por ingrediente, coste total, coste por porción, porcentaje de cada ingrediente, food cost si se indica precio de venta. Puede usar precios de mercado o de compra.",
      "parameters_required": ["receta_id"],
      "parameters_property_names": ["receta_id", "precio_venta", "usar_precio_compra"],
      "parameters_size_chars": 378,
      "parameters_full_path_hint": "modules/escandallo/module.json → tools[0].parameters"
    },
    {
      "name": "escandallo.global",
      "description": "Escandallo global de todas las recetas del proyecto: coste medio, ranking por coste, ingredientes más caros, resumen por categoría. Visión completa de costes.",
      "parameters_required": [],
      "parameters_property_names": ["precios_venta"],
      "parameters_size_chars": 160,
      "parameters_full_path_hint": "modules/escandallo/module.json → tools[1].parameters"
    },
    {
      "name": "escandallo.comparar_precios",
      "description": "Compara precios de mercado vs precios de compra reales para todos los ingredientes. Muestra diferencias, ahorro potencial, y ingredientes sin precio de compra.",
      "parameters_required": [],
      "parameters_property_names": [],
      "parameters_size_chars": 33,
      "parameters_full_path_hint": "modules/escandallo/module.json → tools[2].parameters"
    },
    {
      "name": "escandallo.simular_precio",
      "description": "Simula diferentes precios de venta para una receta y muestra el impacto en margen, food cost y beneficio por porción. Útil para decidir precio de carta.",
      "parameters_required": ["receta_id"],
      "parameters_property_names": ["receta_id", "precios", "food_cost_objetivo"],
      "parameters_size_chars": 384,
      "parameters_full_path_hint": "modules/escandallo/module.json → tools[3].parameters"
    },
    {
      "name": "escandallo.ingrediente_impacto",
      "description": "Analiza el impacto de un ingrediente: en cuántas recetas aparece, coste total que representa, qué pasaría si sube de precio X%.",
      "parameters_required": ["ingrediente_nombre"],
      "parameters_property_names": ["ingrediente_nombre", "subida_porcentaje"],
      "parameters_size_chars": 255,
      "parameters_full_path_hint": "modules/escandallo/module.json → tools[4].parameters"
    },
    {
      "name": "escandallo.optimizar",
      "description": "Sugiere optimizaciones de coste: ingredientes más caros que podrían sustituirse, recetas con food cost alto, ingredientes con poco uso que encarecen stock.",
      "parameters_required": [],
      "parameters_property_names": ["food_cost_maximo"],
      "parameters_size_chars": 130,
      "parameters_full_path_hint": "modules/escandallo/module.json → tools[5].parameters"
    },
    {
      "name": "escandallo.ficha_tecnica",
      "description": "Genera la ficha técnica completa de una receta: escandallo detallado, elaboración, alérgenos, food cost, formato profesional listo para imprimir o archivar.",
      "parameters_required": ["receta_id"],
      "parameters_property_names": ["receta_id", "precio_venta"],
      "parameters_size_chars": 200,
      "parameters_full_path_hint": "modules/escandallo/module.json → tools[6].parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "escandallo", "action": "receta",     "handler": "handleEscandalloReceta" },
      { "domain": "escandallo", "action": "global",     "handler": "handleEscandalloGlobal" },
      { "domain": "escandallo", "action": "comparativa","handler": "handleComparativa" },
      { "domain": "escandallo", "action": "stats",      "handler": "handleStats" }
    ]
  },

