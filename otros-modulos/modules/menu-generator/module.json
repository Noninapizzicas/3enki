{
  "name": "menu-generator",
  "version": "1.0.0",
  "description": "Generador de menú desde carta física usando IA - Enfoque generativo",
  "author": "Pizzepos Team",

  "provides": {
    "events": ["menu.generado", "menu.validado", "ai.request"],
    "queries": ["menu.obtener_ultimo"]
  },

  "events": {
    "publishes": [
      {
        "event": "ai.request",
        "description": "Solicitud de procesamiento IA para parsear carta de menú",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/ai_request"
        }
      },
      {
        "event": "menu.generado",
        "description": "Menú generado por IA con productos enriquecidos",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/menu_generado"
        }
      },
      {
        "event": "menu.validado",
        "description": "Menú validado por operador antes de aplicar",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/menu_validado"
        }
      },
      {
        "event": "menu.error",
        "description": "Error en generación o validación de menú",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/menu_error"
        }
      }
    ],
    "subscribes": [
      {
        "event": "ai.response",
        "description": "Respuesta del ai-gateway con menú parseado",
        "handler": "onAIResponse"
      }
    ]
  },

  "apis": [
    {
      "method": "POST",
      "path": "/upload",
      "handler": "handleUploadMenu",
      "description": "Subir carta física (imagen/PDF) para generar menú",
      "request_schema": {
        "$ref": "./schemas/menu.json#/definitions/upload_request"
      },
      "response_schema": {
        "$ref": "./schemas/menu.json#/definitions/upload_response"
      }
    },
    {
      "method": "GET",
      "path": "/menus",
      "handler": "handleListMenus",
      "description": "Listar menús generados (histórico)"
    },
    {
      "method": "GET",
      "path": "/menus/:id",
      "handler": "handleGetMenu",
      "description": "Obtener menú específico"
    },
    {
      "method": "POST",
      "path": "/menus/:id/validate",
      "handler": "handleValidateMenu",
      "description": "Validar menú generado (publica menu.validado)",
      "request_schema": {
        "$ref": "./schemas/menu.json#/definitions/validate_request"
      }
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Métricas del módulo"
    }
  ],

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "menu.upload.total",
        "menu.generado.total",
        "menu.validado.total",
        "menu.errors.total"
      ],
      "gauges": [
        "menu.pendientes_validacion.count"
      ],
      "timings": [
        "menu.upload.duration",
        "menu.generation.duration"
      ]
    }
  },

  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "Menu Generator",
    "icon": "📄",
    "description": "Genera menús desde cartas físicas usando IA",

    "views": {
      "main": {
        "type": "dashboard",
        "permissions": ["gerente", "admin", "user"],

        "layout": {
          "type": "two-column",
          "config": {
            "leftWidth": "65%",
            "rightWidth": "35%",
            "gap": "var(--space-lg)"
          }
        },

        "sections": [
          {
            "id": "stats_total",
            "widget": "stat-card",
            "config": {
              "label": "Total Menús",
              "value": "@compute.count(@data.menus)",
              "icon": "📄",
              "color": "primary"
            }
          },
          {
            "id": "stats_generando",
            "widget": "stat-card",
            "config": {
              "label": "Generando",
              "value": "@compute.count(@compute.filter(@data.menus, 'estado', 'generando'))",
              "icon": "⏳",
              "color": "warning"
            }
          },
          {
            "id": "stats_pendientes",
            "widget": "stat-card",
            "config": {
              "label": "Pendientes Validación",
              "value": "@compute.count(@compute.filter(@data.menus, 'estado', 'generado'))",
              "icon": "⚠️",
              "color": "info"
            }
          },
          {
            "id": "stats_validados",
            "widget": "stat-card",
            "config": {
              "label": "Validados",
              "value": "@compute.count(@compute.filter(@data.menus, 'estado', 'validado'))",
              "icon": "✅",
              "color": "success"
            }
          },
          {
            "id": "menus_table",
            "widget": "table-advanced",
            "config": {
              "title": "📋 Menús Generados",
              "dataSource": "@data.menus",
              "columns": [
                {
                  "key": "id",
                  "label": "ID",
                  "type": "text",
                  "width": "20%"
                },
                {
                  "key": "estado",
                  "label": "Estado",
                  "type": "badge",
                  "width": "15%",
                  "badgeColors": {
                    "generando": "warning",
                    "generado": "info",
                    "validado": "success",
                    "error": "danger"
                  }
                },
                {
                  "key": "productos_count",
                  "label": "Productos",
                  "type": "number",
                  "width": "12%"
                },
                {
                  "key": "categorias_count",
                  "label": "Categorías",
                  "type": "number",
                  "width": "12%"
                },
                {
                  "key": "created_at",
                  "label": "Creado",
                  "type": "datetime",
                  "width": "20%"
                },
                {
                  "key": "validated_at",
                  "label": "Validado",
                  "type": "datetime",
                  "width": "20%"
                }
              ],
              "sortable": true,
              "filterable": true,
              "paginated": true,
              "pageSize": 10,
              "actions": [
                {
                  "label": "Ver Detalles",
                  "icon": "👁️",
                  "action": "view",
                  "permissions": ["gerente", "admin"],
                  "endpoint": "/modules/menu-generator/menus/{{id}}"
                },
                {
                  "label": "Validar",
                  "icon": "✅",
                  "action": "validate",
                  "permissions": ["gerente", "admin"],
                  "endpoint": "/modules/menu-generator/menus/{{id}}/validate",
                  "showWhen": "estado === 'generado'",
                  "confirm": true,
                  "confirmMessage": "¿Confirmar validación del menú?"
                }
              ]
            }
          },
          {
            "id": "info_panel",
            "widget": "card",
            "config": {
              "title": "ℹ️ Información",
              "content": {
                "type": "info",
                "items": [
                  {
                    "label": "Versión",
                    "value": "1.0.0",
                    "icon": "🏷️"
                  },
                  {
                    "label": "Estado",
                    "value": "Activo",
                    "color": "#22c55e"
                  },
                  {
                    "label": "Procesador",
                    "value": "IA Generativa",
                    "icon": "🤖"
                  }
                ]
              }
            }
          },
          {
            "id": "instructions_panel",
            "widget": "card",
            "config": {
              "title": "📖 Instrucciones",
              "content": {
                "type": "markdown",
                "text": "### Cómo usar Menu Generator\n\n1. **Subir carta**: Usa el endpoint `/upload` para subir imagen o PDF de tu carta\n2. **IA procesa**: El sistema extrae productos, categorías e ingredientes automáticamente\n3. **Validar**: Revisa y valida el menú generado\n4. **Aplicar**: Una vez validado, el menú se integra al sistema\n\n**Formatos soportados**: PDF, JPG, PNG, WEBP"
              }
            }
          },
          {
            "id": "credentials_panel",
            "widget": "card",
            "config": {
              "title": "🔐 Credenciales de IA",
              "content": {
                "type": "markdown",
                "text": "### Requisitos\n\nPara usar Menu Generator necesitas configurar credenciales de proveedores de IA.\n\n**Proveedores soportados:**\n- 🤖 OpenAI (GPT-4, GPT-3.5)\n- 🔮 DeepSeek\n- 🧠 Anthropic (Claude)\n\n---\n\n**[🔐 Ir a Credential Manager →](/ui/modules/credential-manager)**\n\nConfigura tus API keys antes de generar menús."
              }
            }
          }
        ]
      },

      "upload": {
        "type": "form",
        "permissions": ["gerente", "admin"],
        "config": {
          "title": "Subir Carta de Menú",
          "endpoint": "/modules/menu-generator/upload",
          "method": "POST",
          "validation": true,
          "fields": [
            {
              "name": "file_base64",
              "label": "Archivo (Base64)",
              "type": "textarea",
              "required": true,
              "placeholder": "Pega aquí el contenido en base64..."
            },
            {
              "name": "file_name",
              "label": "Nombre del archivo",
              "type": "text",
              "required": true,
              "placeholder": "menu.pdf"
            },
            {
              "name": "file_type",
              "label": "Tipo de archivo",
              "type": "select",
              "required": false,
              "options": [
                { "value": "application/pdf", "label": "PDF" },
                { "value": "image/jpeg", "label": "JPEG" },
                { "value": "image/png", "label": "PNG" },
                { "value": "image/webp", "label": "WEBP" }
              ]
            }
          ],
          "onSuccess": {
            "message": "Menú en proceso de generación",
            "redirect": "/ui/modules/menu-generator"
          }
        }
      }
    },

    "mqtt": {
      "enabled": true,
      "topics": [
        "menu.generado",
        "menu.validado",
        "menu.error",
        "ai.response"
      ],
      "auto_refresh": true
    }
  }
}
