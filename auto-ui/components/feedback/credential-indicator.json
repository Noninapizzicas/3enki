{
  "name": "credential-indicator",
  "category": "feedback",
  "description": "Indicador visual de estado de credenciales con niveles (GLOBAL/PROJECT/CLIENT/CUSTOM) y quick actions",
  "version": "1.0.0",
  "author": "Event Core Team",

  "variants": {
    "badge": {
      "description": "Badge compacto con icono y estado",
      "className": "credential-indicator--badge"
    },
    "detailed": {
      "description": "Vista detallada con nivel y botones",
      "className": "credential-indicator--detailed"
    },
    "inline": {
      "description": "Inline para formularios",
      "className": "credential-indicator--inline"
    }
  },

  "states": {
    "ok": {
      "description": "Credencial configurada correctamente",
      "icon": "🔑",
      "color": "#10b981",
      "className": "credential-indicator--ok"
    },
    "warning": {
      "description": "Credencial en nivel bajo (GLOBAL como fallback)",
      "icon": "⚠️",
      "color": "#f59e0b",
      "className": "credential-indicator--warning"
    },
    "error": {
      "description": "Sin credencial configurada",
      "icon": "❌",
      "color": "#ef4444",
      "className": "credential-indicator--error"
    },
    "loading": {
      "description": "Verificando credenciales",
      "icon": "⏳",
      "color": "#3b82f6",
      "className": "credential-indicator--loading"
    }
  },

  "levels": {
    "CUSTOM": {
      "priority": 1,
      "label": "Custom",
      "description": "Credencial específica para esta sesión",
      "color": "#7c3aed"
    },
    "CLIENT": {
      "priority": 2,
      "label": "Cliente",
      "description": "Credencial del cliente actual",
      "color": "#3b82f6"
    },
    "PROJECT": {
      "priority": 3,
      "label": "Proyecto",
      "description": "Credencial del proyecto",
      "color": "#10b981"
    },
    "GLOBAL": {
      "priority": 4,
      "label": "Global",
      "description": "Credencial global del sistema",
      "color": "#6b7280"
    }
  },

  "props": {
    "variant": {
      "type": "enum",
      "values": ["badge", "detailed", "inline"],
      "default": "badge"
    },
    "provider": {
      "type": "enum",
      "values": ["deepseek", "openai", "claude", "ollama"],
      "required": true,
      "description": "Provider de IA a verificar"
    },
    "level": {
      "type": "enum",
      "values": ["CUSTOM", "CLIENT", "PROJECT", "GLOBAL"],
      "description": "Nivel de credencial detectado"
    },
    "showLevel": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar nivel de credencial"
    },
    "showStatus": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar icono de estado"
    },
    "enableQuickAdd": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar botón 'Añadir' si falta credencial"
    },
    "endpoint": {
      "type": "string",
      "default": "/modules/credential-manager/credentials",
      "description": "Endpoint para verificar credenciales"
    },
    "checkOnInit": {
      "type": "boolean",
      "default": true,
      "description": "Verificar credenciales al inicializar"
    }
  },

  "features": [
    "Indicador visual de estado (verde/amarillo/rojo)",
    "Muestra nivel de credencial (CUSTOM/CLIENT/PROJECT/GLOBAL)",
    "Tooltip con información detallada",
    "Click para gestionar credenciales",
    "Quick add si falta credencial",
    "Auto-verificación periódica",
    "Valores enmascarados (***)",
    "Integración con credential-manager"
  ],

  "example": {
    "component": "credential-indicator",
    "variant": "detailed",
    "props": {
      "provider": "deepseek",
      "showLevel": true,
      "showStatus": true,
      "enableQuickAdd": true,
      "checkOnInit": true
    }
  },

  "useCases": [
    "AI-control-bar: Verificar credenciales antes de usar provider",
    "Menu-generator: Verificar API keys antes de generar",
    "Admin-panel: Gestión de credenciales"
  ]
}
