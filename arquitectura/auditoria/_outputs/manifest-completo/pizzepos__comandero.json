  "identidad": {
    "name": "comandero",
    "version": "2.0.0",
    "description_oficial": "Gestión de pedidos - Añadir productos a cuentas",
    "author": "Pizzepos Team",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
