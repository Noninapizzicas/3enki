{
  "_VERSION": "1.0.0",
  "_CREATED": "2026-01-13",
  "_DESCRIPTION": "Sistema de Credenciales Multi-Nivel Event-Core",

  "_AI_INSTRUCTIONS": {
    "IMPORTANT": "Este archivo define el sistema de gestión de credenciales",
    "rule_1": "Las credenciales se almacenan en .env con formato específico",
    "rule_2": "La resolución sigue una cascada de prioridad: CUSTOM > CLIENT > PROJECT > GLOBAL",
    "rule_3": "NUNCA expongas valores de API keys - solo metadata",
    "rule_4": "Google tiene DOS tipos de credenciales: API Key (Vision/TTS) y OAuth2 (Gmail)",
    "rule_5": "Cada cuenta de Google puede tener su propia API Key + OAuth2 independientes",
    "how_to_resolve": "eventBus.publish('credential.resolve.request', { provider, project_id?, client_id?, custom_id? })",
    "how_to_receive": "eventBus.subscribe('credential.resolve.response', handler)"
  },

  "overview": {
    "module": "modules/credential-manager/",
    "storage": ".env (archivo en raíz del proyecto)",
    "architecture": "Event-driven con MQTT Request/Response",
    "purpose": "Gestión centralizada de API keys con niveles de prioridad"
  },

  "levels": {
    "description": "Sistema de 4 niveles con prioridad en cascada",
    "cascade_order": [
      {
        "level": "CUSTOM",
        "priority": 1,
        "icon": "🔴",
        "requiresIdentifier": true,
        "description": "Máxima prioridad - credencial específica personalizada",
        "use_case": "Bot específico, flujo especial, caso único",
        "example_key": "OPENAI_API_KEY_CUSTOM_bot-premium"
      },
      {
        "level": "CLIENT",
        "priority": 2,
        "icon": "🟡",
        "requiresIdentifier": true,
        "description": "Credencial por cliente",
        "use_case": "Cliente que usa su propia API key",
        "example_key": "DEEPSEEK_API_KEY_CLIENT_acme-corp"
      },
      {
        "level": "PROJECT",
        "priority": 3,
        "icon": "🔵",
        "requiresIdentifier": true,
        "description": "Credencial por proyecto",
        "use_case": "Proyecto específico con sus propias keys",
        "example_key": "ANTHROPIC_API_KEY_PROJECT_chatbot-v2"
      },
      {
        "level": "GLOBAL",
        "priority": 4,
        "icon": "🟢",
        "requiresIdentifier": false,
        "description": "Fallback global - se usa si no hay match específico",
        "use_case": "Credencial por defecto del sistema",
        "example_key": "OPENAI_API_KEY_GLOBAL"
      }
    ],
    "resolution_algorithm": [
      "1. Si custom_id: busca PROVIDER_API_KEY_CUSTOM_{custom_id}",
      "2. Si client_id: busca PROVIDER_API_KEY_CLIENT_{client_id}",
      "3. Si project_id: busca PROVIDER_API_KEY_PROJECT_{project_id}",
      "4. Fallback: busca PROVIDER_API_KEY_GLOBAL",
      "5. Si no encuentra ninguno: retorna error"
    ]
  },

  "key_format": {
    "pattern": "{PROVIDER}_API_KEY_{LEVEL}[_{IDENTIFIER}]",
    "components": {
      "PROVIDER": "Nombre del proveedor en MAYÚSCULAS (OPENAI, DEEPSEEK, ANTHROPIC, OLLAMA, GOOGLE, GMAIL)",
      "LEVEL": "Nivel de la credencial (GLOBAL, PROJECT, CLIENT, CUSTOM)",
      "IDENTIFIER": "Identificador único (requerido excepto para GLOBAL)"
    },
    "examples": {
      "global": "OPENAI_API_KEY_GLOBAL",
      "project": "DEEPSEEK_API_KEY_PROJECT_mi-proyecto",
      "client": "ANTHROPIC_API_KEY_CLIENT_cliente-123",
      "custom": "OPENAI_API_KEY_CUSTOM_bot-especial"
    },
    "regex": "^([A-Z_]+)_API_KEY_(GLOBAL|PROJECT|CLIENT|CUSTOM)(?:_(.+))?$"
  },

  "providers": {
    "standard": {
      "description": "Proveedores con API key simple",
      "list": [
        {
          "id": "OPENAI",
          "name": "OpenAI",
          "icon": "🤖",
          "credential_type": "bearer_token",
          "format": "sk-...",
          "test_endpoint": "https://api.openai.com/v1/models",
          "services": ["GPT-4", "GPT-3.5", "DALL-E", "Whisper"]
        },
        {
          "id": "DEEPSEEK",
          "name": "DeepSeek",
          "icon": "🔮",
          "credential_type": "bearer_token",
          "format": "sk-...",
          "test_endpoint": "https://api.deepseek.com/v1/models",
          "services": ["DeepSeek Chat", "DeepSeek Coder"]
        },
        {
          "id": "ANTHROPIC",
          "name": "Anthropic",
          "icon": "🧠",
          "credential_type": "x-api-key_header",
          "format": "sk-ant-...",
          "test_endpoint": "https://api.anthropic.com/v1/messages",
          "services": ["Claude 3 Opus", "Claude 3 Sonnet", "Claude 3 Haiku"]
        },
        {
          "id": "OLLAMA",
          "name": "Ollama",
          "icon": "🦙",
          "credential_type": "none",
          "format": "cualquier string (local)",
          "test_endpoint": null,
          "services": ["Modelos locales"],
          "note": "No requiere validación - es local"
        },
        {
          "id": "GOOGLE",
          "name": "Google Cloud",
          "icon": "☁️",
          "credential_type": "query_param",
          "format": "AIza...",
          "env_var": "GOOGLE_API_KEY",
          "test_endpoint": "https://vision.googleapis.com/v1/images:annotate?key={API_KEY}",
          "services": ["Vision (OCR)", "Text-to-Speech", "Translate"],
          "note": "API Key de Google Cloud Console - NO es OAuth2"
        }
      ]
    },

    "oauth2": {
      "description": "Proveedores con OAuth2 (múltiples credenciales)",
      "list": [
        {
          "id": "GMAIL",
          "name": "Gmail",
          "icon": "📧",
          "credential_type": "oauth2",
          "required_credentials": ["client_id", "client_secret", "refresh_token"],
          "services": ["Send", "List", "Read", "Search", "Attachments"],
          "multi_account": true
        }
      ]
    }
  },

  "google_accounts": {
    "description": "Cada cuenta de Google puede tener DOS tipos de credenciales independientes",
    "important": "API Key y OAuth2 son sistemas de autenticación DIFERENTES - no son intercambiables",
    "per_account": {
      "api_key": {
        "description": "Una API Key por cuenta de Google Cloud",
        "used_for": ["Vision (OCR)", "Text-to-Speech", "Translate", "Maps", "YouTube Data"],
        "env_pattern": "GOOGLE_API_KEY o GOOGLE_API_KEY_{account}",
        "examples": {
          "global": "GOOGLE_API_KEY=AIzaSyB...",
          "per_account": "GOOGLE_API_KEY_trabajo=AIzaSyC..."
        },
        "how_to_get": "Google Cloud Console → APIs & Services → Credentials → Create API Key"
      },
      "oauth2": {
        "description": "Credenciales OAuth2 por cuenta de Google",
        "used_for": ["Gmail (lectura/envío)", "Calendar", "Drive", "Sheets"],
        "requires": ["client_id", "client_secret", "refresh_token"],
        "env_patterns": {
          "json_grouped": "GMAIL_OAUTH_CUSTOM_{account}",
          "individual": "GMAIL_CLIENT_ID_{account}, GMAIL_CLIENT_SECRET_{account}, GMAIL_REFRESH_TOKEN_{account}",
          "global": "GMAIL_CLIENT_ID, GMAIL_CLIENT_SECRET, GMAIL_REFRESH_TOKEN"
        },
        "how_to_get": [
          "1. Google Cloud Console → APIs & Services → Credentials → Create OAuth Client ID",
          "2. Tipo: Web Application o Desktop App",
          "3. Obtener client_id y client_secret",
          "4. Usar OAuth Playground o tu app para obtener refresh_token"
        ]
      }
    },
    "example_scenario": {
      "description": "Usuario con 2 cuentas de Google: 'personal' y 'trabajo'",
      "env_file": [
        "# Cuenta 'personal' - API Key para Vision/TTS",
        "GOOGLE_API_KEY_personal=AIzaSyBxxxxx",
        "",
        "# Cuenta 'personal' - OAuth2 para Gmail",
        "GMAIL_OAUTH_CUSTOM_personal={\"client_id\":\"123.apps.googleusercontent.com\",\"client_secret\":\"GOC...\",\"refresh_token\":\"1//...\"}",
        "",
        "# Cuenta 'trabajo' - API Key para Vision/TTS",
        "GOOGLE_API_KEY_trabajo=AIzaSyCyyyyy",
        "",
        "# Cuenta 'trabajo' - OAuth2 para Gmail",
        "GMAIL_CLIENT_ID_trabajo=456.apps.googleusercontent.com",
        "GMAIL_CLIENT_SECRET_trabajo=GOC...",
        "GMAIL_REFRESH_TOKEN_trabajo=1//...",
        "",
        "# Fallback global (si no se especifica cuenta)",
        "GOOGLE_API_KEY=AIzaSyDzzzzz",
        "GMAIL_CLIENT_ID=789.apps.googleusercontent.com",
        "GMAIL_CLIENT_SECRET=GOC...",
        "GMAIL_REFRESH_TOKEN=1//..."
      ],
      "usage": {
        "vision_personal": "google.vision.extract({ image, account: 'personal' })",
        "vision_trabajo": "google.vision.extract({ image, account: 'trabajo' })",
        "gmail_personal": "gmail.send({ to, subject, body, account: 'personal' })",
        "gmail_trabajo": "gmail.send({ to, subject, body, account: 'trabajo' })"
      }
    }
  },

  "gmail_multi_account": {
    "description": "Gmail soporta múltiples cuentas de Google con credenciales independientes",
    "credential_resolution": {
      "order": [
        "1. JSON agrupado por cuenta",
        "2. Variables individuales por cuenta",
        "3. Variables globales (fallback)"
      ],
      "methods": {
        "json_grouped": {
          "pattern": "GMAIL_OAUTH_CUSTOM_{account}",
          "format": "{\"client_id\":\"xxx\",\"client_secret\":\"yyy\",\"refresh_token\":\"zzz\"}",
          "example": "GMAIL_OAUTH_CUSTOM_trabajo={\"client_id\":\"123.apps.googleusercontent.com\",\"client_secret\":\"GOCSPX-xxx\",\"refresh_token\":\"1//xxx\"}"
        },
        "individual_per_account": {
          "pattern": [
            "GMAIL_CLIENT_ID_{account}",
            "GMAIL_CLIENT_SECRET_{account}",
            "GMAIL_REFRESH_TOKEN_{account}"
          ],
          "example": [
            "GMAIL_CLIENT_ID_trabajo=123.apps.googleusercontent.com",
            "GMAIL_CLIENT_SECRET_trabajo=GOCSPX-xxx",
            "GMAIL_REFRESH_TOKEN_trabajo=1//xxx"
          ]
        },
        "global_fallback": {
          "pattern": [
            "GMAIL_CLIENT_ID",
            "GMAIL_CLIENT_SECRET",
            "GMAIL_REFRESH_TOKEN"
          ],
          "note": "Se usan si no se especifica cuenta o no hay credenciales específicas"
        }
      }
    },
    "usage": {
      "without_account": {
        "description": "Usa credenciales globales",
        "code": "await gmail.send({ to: 'user@example.com', subject: 'Test', body: 'Hello' })"
      },
      "with_account": {
        "description": "Usa credenciales de cuenta específica",
        "code": "await gmail.send({ to: 'user@example.com', subject: 'Test', body: 'Hello', account: 'trabajo' })"
      }
    },
    "token_caching": {
      "description": "Los access tokens se cachean por cuenta",
      "duration": "45 minutos (tokens expiran en 1 hora)",
      "implementation": "Map en memoria: accountKey -> { token, expiresAt }"
    }
  },

  "events": {
    "request_response": {
      "description": "Patrón para resolver credenciales desde otros módulos",
      "request": {
        "event": "credential.resolve.request",
        "payload": {
          "provider": "string - OPENAI, DEEPSEEK, ANTHROPIC, OLLAMA, GMAIL",
          "project_id": "string? - ID del proyecto",
          "client_id": "string? - ID del cliente",
          "custom_id": "string? - ID personalizado",
          "request_id": "string - UUID para correlacionar respuesta"
        }
      },
      "response": {
        "event": "credential.resolve.response",
        "payload": {
          "request_id": "string - Mismo que el request",
          "success": "boolean",
          "provider": "string",
          "api_key": "string? - El valor de la credencial (si success)",
          "resolved_from": "string? - GLOBAL|PROJECT|CLIENT|CUSTOM",
          "error": "string? - Mensaje de error (si !success)"
        }
      }
    },
    "notifications": {
      "credential.saved": "Credencial creada o guardada",
      "credential.updated": "Credencial actualizada",
      "credential.deleted": "Credencial eliminada",
      "credential.resolved": "Credencial resuelta exitosamente",
      "credential.resolve.failed": "No se encontró credencial"
    },
    "ui_state": {
      "event": "credential.state",
      "description": "Estado completo para frontend via MQTT",
      "payload": {
        "providers": "array - Lista de proveedores disponibles",
        "levels": "array - Niveles con metadata UI",
        "credentials": "object - Credenciales agrupadas por nivel",
        "stats": "object - Contadores"
      }
    }
  },

  "mqtt_ui_pattern": {
    "description": "Frontend usa Request/Response sobre MQTT",
    "frontend_usage": {
      "list": "await mqttRequest('credential', 'list')",
      "get": "await mqttRequest('credential', 'get', { key })",
      "create": "await mqttRequest('credential', 'create', { provider, level, identifier?, api_key })",
      "update": "await mqttRequest('credential', 'update', { key, api_key })",
      "delete": "await mqttRequest('credential', 'delete', { key })",
      "test": "await mqttRequest('credential', 'test', { provider, api_key })"
    }
  },

  "http_api": {
    "base_path": "/modules/credential-manager",
    "endpoints": [
      {
        "method": "POST",
        "path": "/credentials",
        "description": "Crear/guardar credencial",
        "body": {
          "provider": "string",
          "level": "string",
          "identifier": "string?",
          "api_key": "string"
        }
      },
      {
        "method": "GET",
        "path": "/credentials",
        "description": "Listar credenciales (masked)",
        "query": {
          "level": "string? - Filtrar por nivel",
          "provider": "string? - Filtrar por proveedor"
        }
      },
      {
        "method": "GET",
        "path": "/credentials/resolve",
        "description": "Resolver credencial por cascada",
        "query": {
          "provider": "string - Requerido",
          "projectId": "string?",
          "clientId": "string?",
          "customId": "string?"
        }
      },
      {
        "method": "PUT",
        "path": "/credentials/:key",
        "description": "Actualizar credencial",
        "body": {
          "api_key": "string"
        }
      },
      {
        "method": "DELETE",
        "path": "/credentials/:key",
        "description": "Eliminar credencial"
      },
      {
        "method": "POST",
        "path": "/ui/test",
        "description": "Testear API key antes de guardar",
        "body": {
          "provider": "string",
          "api_key": "string"
        }
      }
    ]
  },

  "ai_tool": {
    "name": "credential.list",
    "description": "Herramienta para que AI liste credenciales (solo metadata, nunca valores)",
    "parameters": {
      "level": "GLOBAL|PROJECT|CLIENT|CUSTOM - Filtrar por nivel",
      "provider": "OPENAI|DEEPSEEK|ANTHROPIC|OLLAMA|GMAIL - Filtrar por proveedor"
    },
    "returns": {
      "credentials": "array - [{key, provider, level, identifier}]",
      "total": "number",
      "note": "API key values are never exposed"
    },
    "usage_example": {
      "all": "credential.list()",
      "filtered": "credential.list({ provider: 'OPENAI', level: 'GLOBAL' })"
    }
  },

  "usage_from_module": {
    "description": "Cómo usar credenciales desde un módulo",
    "via_event": {
      "code": "// Solicitar credencial\nconst requestId = uuid();\nawait this.eventBus.publish('credential.resolve.request', {\n  request_id: requestId,\n  provider: 'OPENAI',\n  project_id: 'mi-proyecto',\n  client_id: 'cliente-123'\n});\n\n// Escuchar respuesta\nthis.eventBus.subscribe('credential.resolve.response', (event) => {\n  if (event.request_id === requestId && event.success) {\n    const apiKey = event.api_key;\n    // Usar apiKey...\n  }\n});",
      "note": "El sistema busca en cascada: CUSTOM_cliente-123 → CLIENT_cliente-123 → PROJECT_mi-proyecto → GLOBAL"
    },
    "via_sendRequest": {
      "code": "const result = await this.sendRequest(\n  'credential.resolve.request',\n  'credential.resolve.response',\n  { provider: 'DEEPSEEK', project_id: 'chatbot-v2' }\n);\nif (result.success) {\n  const apiKey = result.api_key;\n}",
      "note": "Helper que encapsula el patrón request/response"
    },
    "via_process_env": {
      "code": "// Las credenciales también están en process.env\nconst apiKey = process.env.OPENAI_API_KEY_GLOBAL;",
      "note": "Acceso directo sin cascada - debes saber la key exacta"
    }
  },

  "usage_in_flows": {
    "description": "Cómo flows acceden a credenciales",
    "automatic": {
      "description": "Los servicios resuelven credenciales automáticamente",
      "example": "gmail.send con account: 'trabajo' resuelve GMAIL_OAUTH_CUSTOM_trabajo"
    },
    "via_event": {
      "description": "Emitir evento para resolver credencial",
      "flow_step": {
        "type": "emit",
        "event": "credential.resolve.request",
        "payload": {
          "provider": "@vars.provider",
          "project_id": "@vars.project_id",
          "request_id": "@functions.uuid()"
        }
      }
    }
  },

  "security": {
    "storage": {
      "location": ".env en raíz del proyecto",
      "format": "Texto plano con comentarios por nivel",
      "backup": "Responsabilidad del administrador"
    },
    "access": {
      "http_masked": "API REST retorna api_key_preview (últimos 4 caracteres visibles)",
      "mqtt_full": "Evento credential.resolve.response incluye api_key completa",
      "ai_tool": "NUNCA expone valores de API key - solo metadata"
    },
    "process_env": {
      "description": "Las credenciales se cargan en process.env al iniciar",
      "benefit": "Disponibles inmediatamente para todos los módulos",
      "caution": "Cualquier código con acceso a process.env puede leer las keys"
    }
  },

  "env_file_example": {
    "description": "Ejemplo de archivo .env con credenciales completo",
    "content": [
      "# Credentials managed by credential-manager",
      "# Last updated: 2026-01-13T10:00:00.000Z",
      "",
      "# =============================================",
      "# GLOBAL credentials (fallback por defecto)",
      "# =============================================",
      "OPENAI_API_KEY_GLOBAL=sk-proj-xxxxxxxxxxxx",
      "DEEPSEEK_API_KEY_GLOBAL=sk-xxxxxxxxxxxx",
      "ANTHROPIC_API_KEY_GLOBAL=sk-ant-xxxxxxxxxxxx",
      "",
      "# =============================================",
      "# GOOGLE CLOUD - API Keys (Vision, TTS, Translate)",
      "# =============================================",
      "# Global (si no se especifica cuenta)",
      "GOOGLE_API_KEY=AIzaSyDzzzzzzzzzzzzzzzzz",
      "",
      "# Por cuenta de Google",
      "GOOGLE_API_KEY_personal=AIzaSyBxxxxxxxxxxx",
      "GOOGLE_API_KEY_trabajo=AIzaSyCyyyyyyyyyyyy",
      "",
      "# =============================================",
      "# GMAIL OAuth2 - Multi-cuenta",
      "# =============================================",
      "# Global (si no se especifica cuenta)",
      "GMAIL_CLIENT_ID=123456789.apps.googleusercontent.com",
      "GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxx",
      "GMAIL_REFRESH_TOKEN=1//xxxxxxxxxx",
      "",
      "# Cuenta 'personal' - formato JSON agrupado",
      "GMAIL_OAUTH_CUSTOM_personal={\"client_id\":\"111.apps.googleusercontent.com\",\"client_secret\":\"GOCSPX-aaa\",\"refresh_token\":\"1//aaa\"}",
      "",
      "# Cuenta 'trabajo' - formato variables individuales",
      "GMAIL_CLIENT_ID_trabajo=222.apps.googleusercontent.com",
      "GMAIL_CLIENT_SECRET_trabajo=GOCSPX-bbb",
      "GMAIL_REFRESH_TOKEN_trabajo=1//bbb",
      "",
      "# =============================================",
      "# PROJECT credentials",
      "# =============================================",
      "OPENAI_API_KEY_PROJECT_chatbot-v2=sk-proj-yyyyyyyy",
      "",
      "# =============================================",
      "# CLIENT credentials",
      "# =============================================",
      "DEEPSEEK_API_KEY_CLIENT_acme-corp=sk-zzzzzzzz",
      "",
      "# =============================================",
      "# CUSTOM credentials",
      "# =============================================",
      "OPENAI_API_KEY_CUSTOM_bot-premium=sk-proj-wwwwwwww"
    ]
  },

  "frontend_store": {
    "location": "frontend/src/lib/stores/credentials.ts",
    "pattern": "Svelte writable store con MQTT Request/Response",
    "actions": [
      "loadCredentials() - Carga lista inicial",
      "createCredential(provider, level, identifier, apiKey)",
      "updateCredential(key, apiKey)",
      "deleteCredential(key)",
      "testCredential(provider, apiKey)"
    ],
    "derived_stores": [
      "allCredentials - Lista plana de todas",
      "globalCredentials - Solo GLOBAL",
      "projectCredentials - Solo PROJECT",
      "clientCredentials - Solo CLIENT",
      "customCredentials - Solo CUSTOM (excluyendo Telegram)",
      "botCredentials - Solo CUSTOM con provider TELEGRAM"
    ]
  },

  "files": {
    "backend": [
      "modules/credential-manager/index.js - Módulo principal",
      "modules/credential-manager/module.json - Configuración y APIs"
    ],
    "frontend": [
      "frontend/src/lib/stores/credentials.ts - Store Svelte"
    ],
    "config": [
      ".env - Almacenamiento de credenciales"
    ]
  }
}
