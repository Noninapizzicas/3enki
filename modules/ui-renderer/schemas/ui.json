{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/ui-renderer.json",

  "definitions": {
    "component_definition": {
      "type": "object",
      "required": ["component"],
      "properties": {
        "component": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "states": { "type": "object" },
        "props": { "type": "object" },
        "variants": { "type": "object" }
      }
    },

    "design_tokens": {
      "type": "object",
      "properties": {
        "tokens": {
          "type": "object",
          "properties": {
            "color": { "type": "object" },
            "espaciado": { "type": "object" },
            "typography": { "type": "object" },
            "shadows": { "type": "object" }
          }
        }
      }
    },

    "render_request": {
      "type": "object",
      "properties": {
        "state": { "type": "string" },
        "text": { "type": "string" },
        "icon": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "footer": { "type": "string" },
        "columns": { "type": "array" },
        "rows": { "type": "array" },
        "fields": { "type": "array" }
      },
      "additionalProperties": true
    },

    "render_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "component": { "type": "string" },
        "html": { "type": "string" },
        "css": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "component_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "component": { "$ref": "#/definitions/component_definition" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "list_response": {
      "type": "object",
      "required": ["success", "components", "count"],
      "properties": {
        "success": { "type": "boolean" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/component_definition" }
        },
        "count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },

    "component_summary": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "has_states": { "type": "boolean" }
      }
    }
  }
}
