  "identidad": {
    "name": "recetas",
    "version": "2.0.0",
    "description_oficial": "Gestión de recetas con almacenamiento JSON por proyecto (data/projects/{slug}/recetas.json). Cada receta tiene history interno (versionado), incompleta flag y campos_pendientes. Cero SQL, cero schema migrations.",
    "author": "Event Core Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_5_domain_negocio_alimentario",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "receta.creada",                  "description": "Receta nueva guardada en el JSON" },
      { "event": "receta.actualizada",             "description": "Receta modificada (nueva versión en history)" },
      { "event": "receta.eliminada",               "description": "Receta archivada (estado='archivada')" },
      { "event": "ingrediente.precio.actualizado", "description": "Precio de mercado de un ingrediente del catálogo actualizado" },
      { "event": "fs.read.request",                "description": "Lee recetas.json del proyecto (vía filesystem)" },
      { "event": "fs.write.request",               "description": "Escribe recetas.json del proyecto (vía filesystem)" },
      { "event": "project.get.request",            "description": "Pide al project-manager el slug del proyecto (vía cache)" }
    ],
    "subscribes": [
      { "event": "project.activated",         "handler": "onProjectActivated",       "extras": {} },
      { "event": "project.deactivated",       "handler": "onProjectDeactivated",     "extras": {} },
      { "event": "project.get.response",      "handler": "onProjectGetResponse",     "extras": {} },
      { "event": "fs.read.response",          "handler": "onFsReadResponse",         "extras": {} },
      { "event": "fs.write.response",         "handler": "onFsWriteResponse",        "extras": {} },
      { "event": "recetas.crear",             "handler": "onToolCrear",              "extras": {} },
      { "event": "recetas.listar",            "handler": "onToolListar",             "extras": {} },
      { "event": "recetas.obtener",           "handler": "onToolObtener",            "extras": {} },
      { "event": "recetas.buscar",            "handler": "onToolBuscar",             "extras": {} },
      { "event": "recetas.actualizar",        "handler": "onToolActualizar",         "extras": {} },
      { "event": "recetas.historial",         "handler": "onToolHistorial",          "extras": {} },
      { "event": "recetas.revertir",          "handler": "onToolRevertir",           "extras": {} },
      { "event": "recetas.eliminar",          "handler": "onToolEliminar",           "extras": {} },
      { "event": "recetas.estadisticas",      "handler": "onToolEstadisticas",       "extras": {} },
      { "event": "recetas.ingredientes",      "handler": "onToolIngredientes",       "extras": {} },
      { "event": "recetas.actualizar_precio", "handler": "onToolActualizarPrecio",   "extras": {} },
      { "event": "recetas.analizar",          "handler": "onToolAnalizar",           "extras": {} },
      { "event": "recetas.investigar_receta", "handler": "onToolInvestigarReceta",   "extras": {} }
    ],
    "provides_eventos": []
  },

  "tools": [
    {
      "name": "recetas.crear",
      "description": "Guarda una receta nueva en el proyecto. Llámala en cuanto tengas nombre + ingredientes — aunque sean texto libre del usuario y falten otros campos, GUÁRDALA igualmente. Los campos que falten se marcarán como pendientes y se completarán después. NO PIDAS al usuario datos que no haya dado.",
      "parameters_required": ["project_id", "nombre"],
      "parameters_property_names": ["project_id", "nombre", "descripcion", "ingredientes", "instrucciones", "porciones", "tiempo_min", "dificultad", "categorias", "etiquetas", "fuente", "notas"],
      "parameters_size_chars": 866,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[0].parameters"
    },
    {
      "name": "recetas.listar",
      "description": "Lista las recetas del proyecto. Por defecto solo activas (no archivadas). Filtros opcionales por estado o solo_incompletas.",
      "parameters_required": ["project_id"],
      "parameters_property_names": ["project_id", "estado", "solo_incompletas", "limit"],
      "parameters_size_chars": 290,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[1].parameters"
    },
    {
      "name": "recetas.obtener",
      "description": "Devuelve una receta completa con ingredientes, instrucciones, todos los campos. Acepta receta_id (UUID) o nombre.",
      "parameters_required": ["project_id"],
      "parameters_property_names": ["project_id", "receta_id", "nombre"],
      "parameters_size_chars": 245,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[2].parameters"
    },
    {
      "name": "recetas.buscar",
      "description": "Busca recetas activas por criterios combinables: texto libre, ingrediente, categoría, etiqueta, dificultad, tiempo, porciones.",
      "parameters_required": ["project_id"],
      "parameters_property_names": ["project_id", "texto", "ingrediente", "categoria", "etiqueta", "dificultad_min", "dificultad_max", "tiempo_max", "porciones", "limit"],
      "parameters_size_chars": 595,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[3].parameters"
    },
    {
      "name": "recetas.actualizar",
      "description": "Modifica campos de una receta. Crea automáticamente snapshot de la versión anterior en history. Devuelve diff de cambios aplicados.",
      "parameters_required": ["project_id", "receta_id", "cambios"],
      "parameters_property_names": ["project_id", "receta_id", "cambios"],
      "parameters_size_chars": 287,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[4].parameters"
    },
    {
      "name": "recetas.historial",
      "description": "Devuelve las versiones anteriores de una receta (cada versión es un snapshot completo). Incluye version_actual y array historial con resúmenes.",
      "parameters_required": ["project_id", "receta_id"],
      "parameters_property_names": ["project_id", "receta_id"],
      "parameters_size_chars": 152,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[5].parameters"
    },
    {
      "name": "recetas.revertir",
      "description": "Restaura una versión anterior de la receta (desde history). El estado actual se archiva primero como nueva entrada en history (audit trail). target_version es el número de versión a restaurar.",
      "parameters_required": ["project_id", "receta_id", "target_version"],
      "parameters_property_names": ["project_id", "receta_id", "target_version"],
      "parameters_size_chars": 251,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[6].parameters"
    },
    {
      "name": "recetas.eliminar",
      "description": "Archiva una receta (estado='archivada'). NO la borra del archivo — sigue accesible vía recetas.listar con estado='archivada'. Para borrado definitivo no hay tool aún.",
      "parameters_required": ["project_id", "receta_id"],
      "parameters_property_names": ["project_id", "receta_id"],
      "parameters_size_chars": 152,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[7].parameters"
    },
    {
      "name": "recetas.estadisticas",
      "description": "Resumen del proyecto: total recetas, distribución por estado, número de incompletas, tamaño del catálogo de ingredientes y cuántos tienen precio.",
      "parameters_required": ["project_id"],
      "parameters_property_names": ["project_id"],
      "parameters_size_chars": 102,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[8].parameters"
    },
    {
      "name": "recetas.ingredientes",
      "description": "Lista el catálogo de ingredientes del proyecto (independiente de las recetas). Incluye precio_mercado, unidad, fuente.",
      "parameters_required": ["project_id"],
      "parameters_property_names": ["project_id", "categoria"],
      "parameters_size_chars": 197,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[9].parameters"
    },
    {
      "name": "recetas.actualizar_precio",
      "description": "Actualiza (o crea si no existe) el precio de mercado de un ingrediente en el catálogo. Identifica por nombre.",
      "parameters_required": ["project_id", "nombre", "precio_mercado"],
      "parameters_property_names": ["project_id", "nombre", "precio_mercado", "unidad", "categoria", "fuente"],
      "parameters_size_chars": 469,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[10].parameters"
    },
    {
      "name": "recetas.analizar",
      "description": "Análisis de coste de una receta: cruza sus ingredientes con el catálogo de precios. Devuelve coste_total, coste_por_porcion, y coste_es_real (true si todos los ingredientes están en catálogo). Si la receta está incompleta (faltan ingredientes/porciones) devuelve error.",
      "parameters_required": ["project_id", "receta_id"],
      "parameters_property_names": ["project_id", "receta_id"],
      "parameters_size_chars": 152,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[11].parameters"
    },
    {
      "name": "recetas.investigar_receta",
      "description": "Comprueba si una receta existe en el proyecto. Si existe, la devuelve. Si no, devuelve instrucción para que el LLM proponga una receta nueva (que después se guardará vía recetas.crear con confirmación del usuario).",
      "parameters_required": ["project_id", "nombre_receta"],
      "parameters_property_names": ["project_id", "nombre_receta"],
      "parameters_size_chars": 235,
      "parameters_full_path_hint": "modules/recetas/module.json → tools[12].parameters"
    }
  ],

