{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/security-p2p.json",

  "definitions": {
    "keypair_response": {
      "type": "object",
      "required": ["success", "public_key"],
      "properties": {
        "success": { "type": "boolean" },
        "public_key": { "type": "string" },
        "algorithm": { "type": "string" },
        "key_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },

    "session_create_request": {
      "type": "object",
      "required": ["peer_id", "peer_public_key"],
      "properties": {
        "peer_id": { "type": "string", "minLength": 1 },
        "peer_public_key": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },

    "session_response": {
      "type": "object",
      "required": ["success", "session_id"],
      "properties": {
        "success": { "type": "boolean" },
        "session_id": { "type": "string" },
        "peer_id": { "type": "string" },
        "established_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "sessions_list_response": {
      "type": "object",
      "required": ["success", "sessions", "count"],
      "properties": {
        "success": { "type": "boolean" },
        "sessions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "session_id": { "type": "string" },
              "peer_id": { "type": "string" },
              "established_at": { "type": "string", "format": "date-time" },
              "expires_at": { "type": "string", "format": "date-time" }
            }
          }
        },
        "count": { "type": "integer" }
      },
      "additionalProperties": false
    },

    "session_terminate_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "peer_id": { "type": "string" },
        "message": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "encrypt_request": {
      "type": "object",
      "required": ["peer_id", "data"],
      "properties": {
        "peer_id": { "type": "string", "minLength": 1 },
        "data": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },

    "encrypt_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "encrypted_data": { "type": "string" },
        "iv": { "type": "string" },
        "session_id": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "decrypt_request": {
      "type": "object",
      "required": ["peer_id", "encrypted_data", "iv"],
      "properties": {
        "peer_id": { "type": "string", "minLength": 1 },
        "encrypted_data": { "type": "string", "minLength": 1 },
        "iv": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },

    "decrypt_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "decrypted_data": { "type": "string" },
        "session_id": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "peer_verify_request": {
      "type": "object",
      "required": ["peer_id", "public_key", "signature", "challenge"],
      "properties": {
        "peer_id": { "type": "string", "minLength": 1 },
        "public_key": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 },
        "challenge": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },

    "peer_verify_response": {
      "type": "object",
      "required": ["success", "verified"],
      "properties": {
        "success": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "peer_id": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "peer_revoke_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "peer_id": { "type": "string" },
        "message": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
