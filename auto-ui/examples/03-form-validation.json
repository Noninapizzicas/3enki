{
  "name": "user-registration",
  "version": "2.0.0",
  "description": "Form with advanced validation showcasing Auto-UI v2 validator",

  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "User Registration",
    "icon": "👤",

    "views": {
      "main": {
        "type": "form",
        "mode": "create",

        "header": {
          "title": "Create New Account",
          "subtitle": "Fill in your details to register"
        },

        "schema": "@context.module.schema",

        "config": {
          "endpoint": "/modules/user-registration/register",
          "method": "POST",
          "validation": true,
          "validateOnBlur": true,
          "showErrorSummary": true
        }
      }
    }
  },

  "schema": {
    "username": {
      "type": "string",
      "label": "Username",
      "required": true,
      "minLength": 3,
      "maxLength": 20,
      "pattern": "^[a-zA-Z0-9_]+$",
      "custom": "alphanumeric",
      "async": "checkUsernameAvailable",
      "help": "Only letters, numbers and underscores",
      "requiredMessage": "Username is required",
      "placeholder": "johndoe"
    },

    "email": {
      "type": "email",
      "label": "Email Address",
      "required": true,
      "email": true,
      "async": "checkEmailUnique",
      "placeholder": "john@example.com"
    },

    "password": {
      "type": "password",
      "label": "Password",
      "required": true,
      "minLength": 8,
      "custom": "strongPassword",
      "help": "Must contain: 8+ chars, uppercase, lowercase, number, special char"
    },

    "confirmPassword": {
      "type": "password",
      "label": "Confirm Password",
      "required": true,
      "match": "password",
      "dependencies": ["password"]
    },

    "fullName": {
      "type": "string",
      "label": "Full Name",
      "required": true,
      "minLength": 2,
      "maxLength": 100,
      "custom": "alphanumericSpaces"
    },

    "phone": {
      "type": "string",
      "label": "Phone Number",
      "required": false,
      "custom": "phone",
      "placeholder": "+1 234 567 8900"
    },

    "dateOfBirth": {
      "type": "date",
      "label": "Date of Birth",
      "required": true,
      "max": "@compute:formatDate(Date.now())"
    },

    "age": {
      "type": "number",
      "label": "Age",
      "required": true,
      "min": 18,
      "max": 120
    },

    "country": {
      "type": "enum",
      "label": "Country",
      "enum": ["US", "UK", "ES", "FR", "DE", "Other"],
      "required": true
    },

    "website": {
      "type": "url",
      "label": "Website",
      "required": false,
      "url": true,
      "conditional": {
        "when": "country",
        "equals": "Other",
        "rules": {
          "required": true
        }
      }
    },

    "bio": {
      "type": "text",
      "label": "Bio",
      "multiline": true,
      "maxLength": 500,
      "help": "Tell us about yourself (max 500 characters)"
    },

    "terms": {
      "type": "boolean",
      "label": "I accept the terms and conditions",
      "required": true,
      "requiredMessage": "You must accept the terms to continue"
    },

    "newsletter": {
      "type": "boolean",
      "label": "Subscribe to newsletter",
      "default": false
    }
  },

  "apis": [
    {
      "method": "POST",
      "path": "/register",
      "handler": "handleRegister",
      "validation": {
        "enabled": true,
        "sanitize": true
      }
    }
  ]
}
