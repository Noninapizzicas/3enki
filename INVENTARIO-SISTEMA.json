      {"metodo": "DELETE", "path": "/credentials/:key", "descripcion": "Eliminar credencial"}
    ],

    "notas": [
      {"metodo": "GET", "path": "/notas", "descripcion": "Listar notas"},
      {"metodo": "POST", "path": "/notas", "descripcion": "Crear nota"},
      {"metodo": "PATCH", "path": "/notas/:id", "descripcion": "Actualizar nota"},
      {"metodo": "DELETE", "path": "/notas/:id", "descripcion": "Eliminar nota"},
      {"metodo": "POST", "path": "/notas/:id/pin", "descripcion": "Fijar/desfijar nota"}
    ],

    "productos": [
      {"metodo": "GET", "path": "/productos", "descripcion": "Listar productos"},
      {"metodo": "GET", "path": "/productos/:id", "descripcion": "Obtener producto"},
      {"metodo": "GET", "path": "/productos/search", "descripcion": "Buscar productos"},
      {"metodo": "PATCH", "path": "/productos/:id", "descripcion": "Actualizar producto"},
      {"metodo": "DELETE", "path": "/productos/:id", "descripcion": "Eliminar producto"}
    ],

    "pedidos": [
      {"metodo": "POST", "path": "/pedidos", "descripcion": "Crear pedido"},
      {"metodo": "GET", "path": "/pedidos", "descripcion": "Listar pedidos"},
      {"metodo": "GET", "path": "/pedidos/:id", "descripcion": "Obtener pedido"},
      {"metodo": "POST", "path": "/pedidos/:id/items", "descripcion": "Agregar item"},
      {"metodo": "DELETE", "path": "/pedidos/:id/items/:item_id", "descripcion": "Eliminar item"},
      {"metodo": "POST", "path": "/pedidos/:id/enviar-cocina", "descripcion": "Enviar a cocina"},
      {"metodo": "POST", "path": "/pedidos/:id/completar", "descripcion": "Completar pedido"},
      {"metodo": "POST", "path": "/pedidos/:id/cancelar", "descripcion": "Cancelar pedido"}
    ],

    "cuentas": [
      {"metodo": "POST", "path": "/cuentas", "descripcion": "Crear cuenta"},
      {"metodo": "GET", "path": "/cuentas", "descripcion": "Listar cuentas"},
