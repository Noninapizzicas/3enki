{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enki.local/arquitectura/decisiones/subsistema-recetario/escandallo.comparativa.calculada.schema.json",
  "title": "escandallo.comparativa.calculada — payload schema",
  "description": "Evento emitido por escandallo tras cruzar precio_mercado del catalogo con precio_compra real. Naming canonico <prefix>.<entity>.<verb>. Drift de naming heredado (escandallo.comparativa sin verbo) cerrado en el refactor v3.0.0 → v4.0.0; el rename va acompasado con el bump de subsistema-recetario.contract a v1.0.2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "project_id",
    "user_id",
    "lineas",
    "timestamp"
  ],
  "properties": {
    "correlation_id": { "$ref": "_common.schema.json#/$defs/correlation_id" },
    "project_id":     { "$ref": "_common.schema.json#/$defs/project_id" },
    "user_id":        { "$ref": "_common.schema.json#/$defs/user_id" },
    "lineas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ingrediente", "precio_catalogo", "precio_compra", "delta_pct"],
        "properties": {
          "ingrediente":     { "$ref": "_common.schema.json#/$defs/ingrediente_nombre" },
          "precio_catalogo": { "type": ["number", "null"], "minimum": 0 },
          "precio_compra":   { "type": ["number", "null"], "minimum": 0 },
          "delta_pct":       { "type": ["number", "null"], "description": "Variacion porcentual catalogo vs compra. null si alguno de los dos lados no esta." }
        }
      }
    },
    "ingredientes_sin_compra_real": {
      "type": "array",
      "items": { "$ref": "_common.schema.json#/$defs/ingrediente_nombre" }
    },
    "timestamp":      { "$ref": "_common.schema.json#/$defs/timestamp" }
  }
}
