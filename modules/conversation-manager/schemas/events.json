{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/conversation-manager/events.json",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": { "type": "string", "format": "uuid" },
        "event_type": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "producer": { "type": "string", "const": "conversation-manager" },
        "schema_version": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "conversation_created": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "conversation.created" },
            "payload": {
              "type": "object",
              "required": ["conversation_id", "project_id"],
              "properties": {
                "conversation_id": { "type": "string" },
                "project_id": { "type": "string" },
                "user_id": { "type": "string" },
                "title": { "type": "string" },
                "created_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "conversation_updated": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "conversation.updated" },
            "payload": {
              "type": "object",
              "required": ["conversation_id"],
              "properties": {
                "conversation_id": { "type": "string" },
                "updated_fields": { "type": "array" },
                "updated_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "conversation_deleted": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "conversation.deleted" },
            "payload": {
              "type": "object",
              "required": ["conversation_id"],
              "properties": {
                "conversation_id": { "type": "string" },
                "project_id": { "type": "string" },
                "messages_deleted": { "type": "integer" },
                "deleted_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "message_sent": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "message.sent" },
            "payload": {
              "type": "object",
              "required": ["message_id", "conversation_id", "content"],
              "properties": {
                "message_id": { "type": "string" },
                "conversation_id": { "type": "string" },
                "project_id": { "type": "string" },
                "user_id": { "type": "string" },
                "content": { "type": "string" },
                "attachments": { "type": "array" },
                "sent_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "message_received": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "message.received" },
            "payload": {
              "type": "object",
              "required": ["message_id", "conversation_id", "content"],
              "properties": {
                "message_id": { "type": "string" },
                "conversation_id": { "type": "string" },
                "project_id": { "type": "string" },
                "content": { "type": "string" },
                "tokens": { "type": "integer" },
                "cost": { "type": "number" },
                "model": { "type": "string" },
                "provider": { "type": "string" },
                "received_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "context_loaded": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "conversation.context.loaded" },
            "payload": {
              "type": "object",
              "required": ["conversation_id", "project_id"],
              "properties": {
                "conversation_id": { "type": "string" },
                "project_id": { "type": "string" },
                "message_count": { "type": "integer" },
                "context_size": { "type": "integer" },
                "loaded_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "conversation_get_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "conversation.get.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "conversation": { "type": "object" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "conversation_list_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "conversation.list.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success", "conversations", "count"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "conversations": { "type": "array" },
                "count": { "type": "integer" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "message_list_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "message.list.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success", "messages", "count"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "messages": { "type": "array" },
                "count": { "type": "integer" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "send_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "conversation.send.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "user_message": { "type": "object" },
                "assistant_message": { "type": "object" },
                "tokens_used": { "type": "integer" },
                "cost": { "type": "number" },
                "duration": { "type": "integer" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
