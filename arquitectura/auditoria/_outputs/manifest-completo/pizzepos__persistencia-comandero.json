    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": false,
    "ui_handlers_field_name": null,
    "module_json_bytes": 8204,
    "module_json_lineas": 292,
    "tiene_main_no_estandar": false,
    "warnings": [
      "sin main declarado (campo ausente en module.json)",
