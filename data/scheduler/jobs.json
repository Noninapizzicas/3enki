[
  {
    "id": "ejemplo-gmail-check",
    "name": "Revisar Gmail (ejemplo)",
    "description": "Busca correos nuevos con adjuntos - CONFIGURAR account antes de habilitar",
    "enabled": false,
    "trigger": {
      "type": "interval",
      "value": 60,
      "unit": "s"
    },
    "action": {
      "type": "mqtt",
      "topic": "gmail.check",
      "payload": {
        "account": "mi-cuenta",
        "query": "has:attachment is:unread",
        "maxResults": 10
      }
    },
    "options": {
      "maxRetries": 1,
      "timeout": 30000
    }
  },
  {
    "id": "ejemplo-convertir-pdf",
    "name": "Convertir PDFs a imágenes (ejemplo)",
    "description": "Convierte PDFs a imágenes - CONFIGURAR rutas antes de habilitar",
    "enabled": false,
    "trigger": {
      "type": "cron",
      "expression": "15 3 * * *",
      "timezone": "Europe/Madrid"
    },
    "action": {
      "type": "mqtt",
      "topic": "pdf.batch.convert",
      "payload": {
        "sourceDir": "data/gmail/mi-cuenta",
        "outputDir": "data/gmail/mi-cuenta-images",
        "dpi": 300
      }
    },
    "options": {
      "maxRetries": 2,
      "timeout": 300000
    }
  },
  {
    "id": "ejemplo-ocr-imagenes",
    "name": "Procesar OCR de imágenes (ejemplo)",
    "description": "Extrae texto con Google Vision OCR - CONFIGURAR rutas antes de habilitar",
    "enabled": false,
    "trigger": {
      "type": "cron",
      "expression": "30 3 * * *",
      "timezone": "Europe/Madrid"
    },
    "action": {
      "type": "mqtt",
      "topic": "ocr.batch.process",
      "payload": {
        "sourceDir": "data/gmail/mi-cuenta-images",
        "force": false
      }
    },
    "options": {
      "maxRetries": 2,
      "timeout": 600000
    }
  }
]
