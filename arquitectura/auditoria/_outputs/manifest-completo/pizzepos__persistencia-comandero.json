{
  "_meta": {
    "modulo": "pizzepos/persistencia-comandero",
    "ubicacion": "modules/pizzepos/persistencia-comandero",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "persistencia-comandero",
    "version": "3.0.0",
    "description_oficial": "Persistencia diaria del comandero - Eventos, cuentas y cierre de caja",
    "author": "Pizzepos Team",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_5_domain_pizzepos",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      {
        "event": "caja.cerrada",
        "description": "Cierre de caja completado - comandero debe resetear"
      },
      {
        "event": "cuenta.cerrada_forzada",
        "description": "Cuenta cerrada automáticamente durante cierre de caja"
      },
      {
        "event": "dia.iniciado",
        "description": "Nuevo día iniciado - sistema reseteado"
      }
    ],
    "subscribes": [
      { "event": "boton.pulsado",           "handler": "onEvento",              "extras": {} },
      { "event": "ui.accion",               "handler": "onEvento",              "extras": {} },
      { "event": "cuenta.creada",           "handler": "onCuentaCreada",        "extras": {} },
      { "event": "cuenta.cerrada",          "handler": "onCuentaCerrada",       "extras": {} },
      { "event": "cuenta.eliminada",        "handler": "onCuentaEliminada",     "extras": {} },
      { "event": "cuenta.estado_cambiado",  "handler": "onCuentaEstadoCambiado","extras": {} },
      { "event": "cuenta.actualizada",      "handler": "onCuentaActualizada",   "extras": {} },
      { "event": "cobro.iniciado",          "handler": "onEvento",              "extras": {} },
      { "event": "cobro.procesado",         "handler": "onEvento",              "extras": {} },
      { "event": "cobro.reembolsado",       "handler": "onEvento",              "extras": {} },
      { "event": "pedido.creado",           "handler": "onPedidoCreado",        "extras": {} },
      { "event": "pedido.enviado_cocina",   "handler": "onEvento",              "extras": {} },
      { "event": "pedido.completado",       "handler": "onEvento",              "extras": {} },
      { "event": "mesa.abierta",            "handler": "onEvento",              "extras": {} },
      { "event": "mesa.cerrada",            "handler": "onEvento",              "extras": {} },
      { "event": "mesa.renombrada",         "handler": "onMesaRenombrada",      "extras": {} },
      { "event": "telefono.pedido_creado",  "handler": "onEvento",              "extras": {} },
      { "event": "llevar.ticket_creado",    "handler": "onEvento",              "extras": {} },
      { "event": "comandero.item_agregado", "handler": "onEvento",              "extras": {} },
      { "event": "comandero.item_eliminado","handler": "onEvento",              "extras": {} },
      { "event": "comandero.enviar_cocina", "handler": "onEvento",              "extras": {} },
      { "event": "catalogo.actualizado",    "handler": "onEvento",              "extras": {} },
      { "event": "cocina.item_preparando",  "handler": "onEvento",              "extras": {} },
      { "event": "cocina.item_preparado",   "handler": "onEvento",              "extras": {} },
      { "event": "cocina.item_avanzado",    "handler": "onEvento",              "extras": {} },
      { "event": "cocina.pedido_listo",     "handler": "onEvento",              "extras": {} }
    ],
    "provides_eventos": ["caja.cerrada", "cuenta.cerrada_forzada", "dia.iniciado"]
  },

  "tools": [],

  "ui_handlers": {
    "campo_origen": null,
    "items": []
  },

  "apis_http": [
    {
      "method": "GET",
      "path": "/cuentas-activas",
      "handler": "handleGetCuentasActivas",
      "description": "Listar cuentas activas (abiertas)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/eventos",
      "handler": "handleGetEventos",
      "description": "Listar eventos del día",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/eventos/:fecha",
      "handler": "handleGetEventosFecha",
      "description": "Eventos de una fecha específica",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/ventas",
      "handler": "handleGetVentas",
      "description": "Listar ventas del día",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/ventas/:fecha",
      "handler": "handleGetVentasFecha",
      "description": "Ventas de una fecha específica",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/cuadre-caja",
      "handler": "handleCuadreCaja",
      "description": "Cuadre de caja del día actual",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/cuadre-caja/:fecha",
      "handler": "handleCuadreCajaFecha",
      "description": "Cuadre de caja de fecha específica",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/cierre-caja",
      "handler": "handleCierreCaja",
      "description": "Realizar cierre de caja con arqueo",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/iniciar-dia",
      "handler": "handleIniciarDia",
      "description": "Iniciar nuevo día - resetea sistema",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/backup",
      "handler": "handleBackup",
      "description": "Crear backup de datos",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Métricas del módulo",
      "request_schema_ref": null,
      "response_schema_ref": null
    }
  ],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "data_dir",       "tipo": "string",  "valor_default": "./data" },
      { "key": "eventos_dir",    "tipo": "string",  "valor_default": "./data/eventos" },
      { "key": "ventas_dir",     "tipo": "string",  "valor_default": "./data/ventas" },
      { "key": "current_dir",    "tipo": "string",  "valor_default": "./data/current" },
      { "key": "backup_dir",     "tipo": "string",  "valor_default": "./data/backups" },
      { "key": "rotacion_diaria","tipo": "boolean", "valor_default": true },
      { "key": "rotacion_hora",  "tipo": "string",  "valor_default": "00:00" }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "persistencia.eventos_guardados.total",
        "persistencia.ventas_guardadas.total",
        "persistencia.errores_escritura.total"
      ],
      "gauges": [
        "persistencia.eventos_dia.count",
        "persistencia.ventas_dia.count"
      ],
      "timings": [
        "persistencia.escritura.duration"
      ]
    }
  },

  "agentes": {
    "inline_en_module_json": [],
