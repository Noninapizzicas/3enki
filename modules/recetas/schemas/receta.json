{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Receta",
  "description": "Receta con ingredientes, cantidades y precios de mercado",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "ID único de la receta (rec_{slug}_{timestamp})"
    },
    "nombre": {
      "type": "string",
      "description": "Nombre de la receta"
    },
    "descripcion": {
      "type": "string",
      "description": "Descripción breve"
    },
    "categoria": {
      "type": "string",
      "description": "Categoría (Pastas, Carnes, Postres, etc.)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Etiquetas para búsqueda"
    },
    "porciones": {
      "type": "number",
      "minimum": 1,
      "description": "Número de porciones/raciones que salen"
    },
    "tiempo_preparacion": {
      "type": "number",
      "description": "Tiempo en minutos"
    },
    "dificultad": {
      "type": "string",
      "enum": ["baja", "media", "alta"]
    },
    "ingredientes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ingrediente_id": {
            "type": "string",
            "description": "ID del ingrediente en el catálogo"
          },
          "nombre": {
            "type": "string",
            "description": "Nombre del ingrediente"
          },
          "cantidad": {
            "type": "number",
            "description": "Cantidad necesaria"
          },
          "unidad": {
            "type": "string",
            "description": "Unidad de medida (g, kg, ml, l, ud, cucharada, etc.)"
          },
          "precio_mercado": {
            "type": "number",
            "description": "Precio estimado de mercado para esa cantidad (€)"
          },
          "precio_compra": {
            "type": ["number", "null"],
            "description": "Precio real de compra (null hasta que se enlace con facturas)"
          },
          "notas": {
            "type": "string",
            "description": "Notas opcionales"
          }
        },
        "required": ["nombre", "cantidad", "unidad", "precio_mercado"]
      }
    },
    "elaboracion": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pasos de elaboración"
    },
    "notas": {
      "type": "string"
    },
    "fuente": {
      "type": "string",
      "description": "Referencia de origen"
    },
    "coste_total": {
      "type": "number",
      "description": "Coste total calculado (sum precios ingredientes)"
    },
    "coste_porcion": {
      "type": "number",
      "description": "Coste por porción (coste_total / porciones)"
    },
    "proyecto_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "nombre", "porciones", "ingredientes"]
}
