{
  "name": "project-manager",
  "version": "4.0.0",
  "description": "Project lifecycle management canónico: CRUD + activate/deactivate + session + AI config + bootstrap (Sistema + Mi Proyecto) + resolución 'una vía fija' de default conversation. Consume composition-manager y database-manager via events.",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",

  "events": {
    "publishes": [
      { "event": "project.created",     "description": "Proyecto creado. Payload: { project_id, name, description, parent_project_id, created_at, correlation_id, timestamp }." },
      { "event": "project.updated",     "description": "Proyecto actualizado. Payload incluye updated_fields." },
      { "event": "project.deleted",     "description": "Proyecto eliminado." },
      { "event": "project.activated",   "description": "Proyecto activado. Re-emitido al arrancar para todos los proyectos con is_active=1." },
      { "event": "project.deactivated", "description": "Proyecto desactivado." },
      { "event": "project.state",       "description": "Snapshot del estado completo (todos los proyectos + activeProjectIds). Publicado tras CRUD." },
      "project.get.response",
      "project.list.response",
      "project.active.response",
      "db.query.request",
      "db.schema.init.request",
      "composition.request"
    ],
    "subscribes": [
      { "event": "project.create",            "handler": "onProjectCreate" },
      { "event": "project.update",            "handler": "onProjectUpdate" },
      { "event": "project.delete",            "handler": "onProjectDelete" },
      { "event": "project.activate",          "handler": "onProjectActivate" },
      { "event": "project.state.request",     "handler": "onProjectStateRequest" },
      { "event": "project.get.request",       "handler": "onGetProjectRequest" },
      { "event": "project.list.request",      "handler": "onListProjectsRequest" },
      { "event": "project.active.request",    "handler": "onGetActiveProjectRequest" },
      { "event": "db.query.response",         "handler": "onDbQueryResponse" },
      { "event": "composition.response",      "handler": "onCompositionResponse" }
    ]
  },

  "apis": [
    { "method": "POST",   "path": "/projects",                          "handler": "handleCreateProject",       "description": "Crear proyecto." },
    { "method": "GET",    "path": "/projects",                          "handler": "handleListProjects",        "description": "Listar todos los proyectos." },
    { "method": "GET",    "path": "/projects/:id",                      "handler": "handleGetProject",          "description": "Obtener proyecto por id o slug." },
    { "method": "PUT",    "path": "/projects/:id",                      "handler": "handleUpdateProject",       "description": "Actualizar proyecto." },
    { "method": "DELETE", "path": "/projects/:id",                      "handler": "handleDeleteProject",       "description": "Eliminar proyecto." },
    { "method": "POST",   "path": "/projects/:id/activate",             "handler": "handleActivateProject",     "description": "Activar proyecto." },
    { "method": "GET",    "path": "/projects/active",                   "handler": "handleGetActiveProject",    "description": "Obtener proyectos activos." },
    { "method": "POST",   "path": "/projects/:id/session",              "handler": "handleSaveSession",         "description": "Guardar session_state del proyecto." },
    { "method": "GET",    "path": "/projects/:id/session",              "handler": "handleRestoreSession",      "description": "Restaurar session_state del proyecto." },
    { "method": "POST",   "path": "/projects/:id/ai-config",            "handler": "handleSetAIConfig",         "description": "Set provider/model/prompt_id por proyecto." },
    { "method": "POST",   "path": "/projects/:id/last-conversation",    "handler": "handleSetLastConversation", "description": "Set last_conversation_id del proyecto." },
    { "method": "GET",    "path": "/health",                            "handler": "handleHealthCheck",         "description": "Health check." },
    { "method": "GET",    "path": "/metrics",                           "handler": "handleGetMetrics",          "description": "Metricas." }
  ],

  "ui_handlers": [
    { "domain": "project", "action": "list",                       "handler": "handleUIList" },
    { "domain": "project", "action": "get",                        "handler": "handleUIGet" },
    { "domain": "project", "action": "create",                     "handler": "handleUICreate" },
    { "domain": "project", "action": "update",                     "handler": "handleUIUpdate" },
    { "domain": "project", "action": "delete",                     "handler": "handleUIDelete" },
    { "domain": "project", "action": "activate",                   "handler": "handleUIActivate" },
    { "domain": "project", "action": "deactivate",                 "handler": "handleUIDeactivate" },
    { "domain": "project", "action": "save-session",               "handler": "handleUISaveSession" },
    { "domain": "project", "action": "restore-session",            "handler": "handleUIRestoreSession" },
    { "domain": "project", "action": "set-ai-config",              "handler": "handleUISetAIConfig" },
    { "domain": "project", "action": "set-last-conversation",      "handler": "handleUISetLastConversation" },
    { "domain": "project", "action": "get-default-conversation",   "handler": "handleUIGetDefaultConversation" },
    { "domain": "project", "action": "get-unassigned",             "handler": "handleUIGetUnassigned" },
    { "domain": "project", "action": "list-features",              "handler": "handleUIListFeatures" },
    { "domain": "project", "action": "add-features",               "handler": "handleUIAddFeatures" }
  ],

  "tools": [],

  "dependencies": ["database-manager", "composition-manager"],

  "config": {
    "dbTimeout": 10000,
    "compositionTimeout": 10000,
    "defaultSchema": null,
    "persistence": {
      "pattern": "delegated-via-database-manager",
      "restart_resilient": true,
      "concurrency": "single-writer",
      "lost_on_restart": ["pendingDbRequests", "pendingCompositionRequests", "pendingDefaultConversations"]
    }
  },

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "project-manager.created",
        "project-manager.updated",
        "project-manager.deleted",
        "project-manager.activated",
        "project-manager.deactivated",
        "project-manager.feature_installed",
        "project-manager.errors"
      ],
      "gauges": [
        "project-manager.projects.total",
        "project-manager.projects.active"
      ]
    }
  }
}
