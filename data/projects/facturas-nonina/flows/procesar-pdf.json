{
  "id": "procesar-pdf",
  "name": "Procesar PDF con OCR",
  "description": "Convierte PDF a imagen y extrae texto con Google Vision",
  "version": "1.0.1",
  "enabled": true,

  "trigger": {
    "event": "facturas-nonina.documento.pendiente",
    "filter": {
      "mimeType": "application/pdf"
    }
  },

  "steps": [
    {
      "id": "log-inicio",
      "type": "log",
      "level": "info",
      "message": "Procesando PDF: {{ trigger.archivo }}"
    },
    {
      "id": "convertir-pdf",
      "type": "service",
      "service": "local.pdf-to-png",
      "action": "convert",
      "pdf": "{{ trigger.archivo }}",
      "pages": [1],
      "scale": 2,
      "onError": "notificar-error"
    },
    {
      "id": "guardar-imagen",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "{{ trigger.archivo }}.png",
      "content": "{{ steps.convertir-pdf.data.images[0].content }}",
      "encoding": "base64",
      "onError": "notificar-error"
    },
    {
      "id": "extraer-texto",
      "type": "service",
      "service": "local.google-vision",
      "action": "extract",
      "image": "{{ steps.convertir-pdf.data.images[0].content }}",
      "hint": "DOCUMENT_TEXT_DETECTION",
      "languageHints": ["es", "en"],
      "onError": "notificar-error"
    },
    {
      "id": "guardar-texto",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "{{ trigger.archivo }}.ocr.txt",
      "content": "{{ steps.extraer-texto.data.text }}",
      "onError": "continue"
    },
    {
      "id": "preparar-resultado-ocr",
      "type": "transform",
      "operation": "map",
      "config": {
        "mapping": {
          "archivo": "{{ trigger.archivo }}",
          "procesado": "{{ now }}",
          "exito": true,
          "confianza": "{{ steps.extraer-texto.data.confidence }}",
          "idioma": "{{ steps.extraer-texto.data.locale }}",
          "bloques": "{{ steps.extraer-texto.data.blocks }}",
          "caracteresTexto": "{{ steps.extraer-texto.data.textLength }}",
          "paginasPDF": "{{ steps.convertir-pdf.data.totalPages }}"
        }
      }
    },
    {
      "id": "guardar-resultado-ocr",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "{{ trigger.archivo }}.ocr.json",
      "content": "{{ json(steps.preparar-resultado-ocr) }}",
      "onError": "continue"
    },
    {
      "id": "notificar-exito",
      "type": "service",
      "service": "telegram",
      "action": "send_message",
      "chatId": "{{ trigger.chatId }}",
      "text": "📄 PDF procesado ({{ steps.extraer-texto.data.confidence }}% confianza).\nTexto extraído: {{ steps.extraer-texto.data.textLength }} caracteres.",
      "onError": "continue"
    },
    {
      "id": "log-exito",
      "type": "log",
      "level": "info",
      "message": "PDF OCR completado: {{ trigger.archivo }} - {{ steps.extraer-texto.data.textLength }} chars"
    },
    {
      "id": "notificar-error",
      "type": "service",
      "service": "telegram",
      "action": "send_message",
      "chatId": "{{ trigger.chatId }}",
      "text": "❌ Error procesando PDF: {{ default(error.message, 'Error desconocido') }}",
      "onError": "continue"
    },
    {
      "id": "log-error",
      "type": "log",
      "level": "error",
      "message": "Error PDF {{ trigger.archivo }}: {{ default(error.message, 'desconocido') }}"
    }
  ]
}
