{
  "id": "recipe-structurer",
  "name": "recipe-structurer",
  "description": "Estructura datos OCR y campos candidatos en JSON schema válido de receta. Entrada: ocrText + datosNormalizados. Salida: receta JSON completa.",
  "version": "1.0.0",
  "enabled": true,

  "prompt_file": "prompts/recipe-structurer-system.md",

  "tools": [
    "recetas.obtener",
    "recetas.validar_schema"
  ],

  "provider": "auto",
  "temperature": 0.1,
  "max_tokens": 4000,

  "context_enabled": true,
  "timeout_ms": 120000,
  "max_retries": 2,

  "event_listener": {
    "event": "receta.ingestion.completed",
    "context_mapping": {
      "ingestion_id": "$.ingestion_id",
      "projectId": "$.projectId",
      "ocrText": "$.ocrText",
      "datosNormalizados": "$.datosNormalizados",
      "tipo": "$.tipo",
      "fuente_referencia": "$.fuente_referencia",
      "timestamp": "$.timestamp"
    }
  },

  "publish_on_success": {
    "event": "receta.structuring.completed",
    "payload_template": {
      "ingestion_id": "$.context.ingestion_id",
      "projectId": "$.context.projectId",
      "receta": "$.result.receta",
      "validation_errors": "$.result.validation_errors",
      "timestamp": "$.timestamp"
    }
  },

  "publish_on_failure": {
    "event": "receta.structuring.failed",
    "payload_template": {
      "ingestion_id": "$.context.ingestion_id",
      "projectId": "$.context.projectId",
      "error": "$.error.message",
      "timestamp": "$.timestamp"
    }
  },

  "metadata": {
    "type": "pipeline-agent",
    "domain": "recetas",
    "pipeline_role": "step-2-structuring",
    "author": "system",
    "created_at": "2026-04-14",
    "tags": ["recipe", "structuring", "ai", "ocr", "json", "schema-validation"]
  },

  "created_at": "2026-04-14T00:00:00.000Z",
  "updated_at": "2026-04-14T00:00:00.000Z",
  "stats": {
    "executions": 0,
    "successes": 0,
    "failures": 0,
    "total_tokens": 0,
    "total_cost": 0,
    "avg_latency_ms": 0,
    "last_execution": null
  }
}
