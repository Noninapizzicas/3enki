{
  "name": "firmware-manager",
  "version": "3.0.0",
  "description": "Registro de firmwares, versionado con checksums, y orquestación de OTA via device-shadow",
  "author": "Enki",
  "language": "en",
  "tier": "tier_3_core",
  "provides": {
    "events": [
      "firmware.ota_requested",
      "firmware.ota_completed",
      "firmware.ota_failed",
      "firmware.registered"
    ]
  },
  "events": {
    "subscribes": [
      {
        "event": "shadow.updated",
        "handler": "onShadowUpdated",
        "description": "Detecta cuando reported.firmware cambia (OTA completada o fallida)"
      },
      {
        "event": "device.registered",
        "handler": "onDeviceRegistered",
        "description": "Verifica firmware de nuevos dispositivos registrados"
      },
      {
        "event": "firmware.build_completed",
        "handler": "onBuildCompleted",
        "description": "Auto-registra firmware en catálogo tras build exitoso (firmware-builder)"
      },
      {
        "event": "esp32.build_completed",
        "handler": "onBuildCompleted",
        "description": "Compatibilidad: auto-registra firmware desde legacy esp32-dev"
      }
    ],
    "publishes": [
      {
        "event": "firmware.registered",
        "description": "Nuevo firmware registrado en catálogo",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/firmware_registered"
        }
      },
      {
        "event": "firmware.ota_requested",
        "description": "OTA solicitada para un dispositivo via shadow",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/ota_requested"
        }
      },
      {
        "event": "firmware.ota_completed",
        "description": "Dispositivo actualizó firmware exitosamente",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/ota_completed"
        }
      },
      {
        "event": "firmware.ota_failed",
        "description": "OTA falló para un dispositivo (timeout, version_mismatch, stale_cleanup)",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/ota_failed"
        }
      }
    ]
  },
  "ui_handlers": [
    {
      "domain": "firmware",
      "action": "list",
      "handler": "handleList"
    },
    {
      "domain": "firmware",
      "action": "register",
      "handler": "handleRegister",
      "schema": {
        "$ref": "./schemas/firmware.json#/definitions/register_request"
      }
    },
    {
      "domain": "firmware",
      "action": "trigger-ota",
      "handler": "handleTriggerOta",
      "schema": {
        "$ref": "./schemas/firmware.json#/definitions/trigger_ota_request"
      }
    },
    {
      "domain": "firmware",
      "action": "status",
      "handler": "handleOtaStatus"
    },
    {
      "domain": "firmware",
      "action": "rollback",
      "handler": "handleRollback",
      "schema": {
        "$ref": "./schemas/firmware.json#/definitions/rollback_request"
      }
    },
    {
      "domain": "firmware",
      "action": "device-versions",
      "handler": "handleDeviceVersions"
    },
    {
      "domain": "firmware",
      "action": "cleanup-otas",
      "handler": "handleCleanupOtas"
    },
    {
      "domain": "firmware",
      "action": "update-meta",
      "handler": "handleUpdateMeta"
    },
    {
      "domain": "firmware",
      "action": "info",
      "handler": "handleGetInfo"
    },
    {
      "domain": "firmware",
      "action": "list-by-project",
      "handler": "handleListByProject"
    }
  ],
  "apis": [
    {
      "method": "GET",
      "path": "/firmware/:type/:version/:file",
      "handler": "handleServeBinary",
      "description": "Sirve binarios de firmware para descarga por ESP32"
    }
  ],
  "tools": [
    {
      "name": "firmware.list",
      "description": "Lista todos los tipos de firmware registrados con sus metadatos (utility, board, proyectos, versión latest)",
      "handler": "handleList",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "firmware.info",
      "description": "Info detallada de un tipo de firmware: todas las versiones, changelog, metadatos, checksums",
      "handler": "handleGetInfo",
      "parameters": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Tipo de firmware (ej: print-proxy)"
          }
        },
        "required": [
          "type"
        ]
      }
    },
    {
      "name": "firmware.list_by_project",
      "description": "Lista firmwares asociados a un proyecto específico",
      "handler": "handleListByProject",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "description": "ID del proyecto"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "name": "firmware.register",
      "description": "Registra un nuevo firmware en el catálogo. El binario debe existir en data/firmware/binaries/",
      "handler": "handleRegister",
      "parameters": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Tipo de firmware (ej: print-proxy)"
          },
          "version": {
            "type": "string",
            "description": "Versión semver (ej: 3.4.0)"
          },
          "file": {
            "type": "string",
            "description": "Nombre del archivo .bin"
          },
          "changelog": {
            "type": "string",
            "description": "Descripción de cambios"
          },
          "utility": {
            "type": "string",
            "description": "Para qué sirve este firmware"
          },
          "board": {
            "type": "string",
            "description": "Board target (ej: esp32dev)"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Capacidades del firmware"
          },
          "projects": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Proyectos asociados"
          }
        },
        "required": [
          "type",
          "version",
          "file"
        ]
      }
    },
    {
      "name": "firmware.trigger_ota",
      "description": "Dispara actualización OTA para un dispositivo. Escribe desired.firmware en device-shadow.",
      "handler": "handleTriggerOta",
      "parameters": {
        "type": "object",
        "properties": {
          "device_id": {
            "type": "string",
            "description": "ID del dispositivo"
          },
          "type": {
            "type": "string",
            "description": "Tipo de firmware"
          },
          "version": {
            "type": "string",
            "description": "Versión target (opcional, usa latest si no se indica)"
          },
          "project_id": {
            "type": "string",
            "description": "ID del proyecto"
          }
        },
        "required": [
          "device_id",
          "type"
        ]
      }
    },
    {
      "name": "firmware.ota_status",
      "description": "Estado de OTAs pendientes y log reciente de actualizaciones",
      "handler": "handleOtaStatus",
      "parameters": {
        "type": "object",
        "properties": {
          "device_id": {
            "type": "string",
            "description": "Filtrar por dispositivo (opcional)"
          },
          "limit": {
            "type": "number",
            "description": "Límite de entradas en el log (default 20)"
          }
        }
      }
    },
    {
      "name": "firmware.update_meta",
      "description": "Actualiza metadatos de un tipo de firmware: utility, description, board, capabilities, projects",
      "handler": "handleUpdateMeta",
      "parameters": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Tipo de firmware"
          },
          "utility": {
            "type": "string",
            "description": "Para qué sirve"
          },
          "description": {
            "type": "string",
            "description": "Descripción detallada"
          },
          "board": {
            "type": "string",
            "description": "Board target"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "projects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "type"
        ]
      }
    }
  ],
  "config": {
    "data_path": "./data/firmware",
    "auto_check_on_register": true,
    "ota_timeout_ms": 300000,
    "ota_cleanup_interval_ms": 60000,
    "validate_binaries_on_load": true
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "firmware.ota_requested.total",
        "firmware.ota_completed.total",
        "firmware.ota_failed.total",
        "firmware.ota_timeout.total",
        "firmware.ota_stale_cleanup.total",
        "firmware.catalog_entries.total",
        "firmware.rollback.total",
        "firmware.device_outdated.total",
        "firmware.binary_served.total",
        "firmware.binary_served.bytes",
        "firmware.binary_served.errors"
      ],
      "gauges": [
        "firmware.pending_otas.count",
        "firmware.catalog_types.count",
        "firmware.catalog_entries.count",
        "firmware.catalog_valid_binaries.count",
        "firmware.catalog_missing_binaries.count"
      ],
      "timings": [
        "firmware.ota.duration",
        "firmware.register.duration"
      ]
    }
  }
}
