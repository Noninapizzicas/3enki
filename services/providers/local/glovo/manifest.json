{
  "$schema": "../../../schemas/provider-manifest.schema.json",
  "name": "local.glovo",
  "version": "1.0.0",
  "description": "Integración con Glovo Partner API — polling de pedidos, aceptar/rechazar, marcar listo",
  "type": "provider",
  "requires": {
    "credentials": [
      "GLOVO_API_KEY",
      "GLOVO_STORE_ID"
    ],
    "npm": []
  },
  "functions": {
    "poll_orders": {
      "event": "local.glovo.poll_orders.request",
      "description": "Obtener pedidos nuevos/pendientes del store en Glovo",
      "input": {
        "status": {
          "type": "string",
          "description": "Filtrar por estado: ACCEPTED, NEW, ALL",
          "enum": ["NEW", "ACCEPTED", "ALL"],
          "default": "NEW"
        }
      },
      "output": {
        "orders": {
          "type": "array",
          "description": "Lista de pedidos de Glovo"
        },
        "total": {
          "type": "number",
          "description": "Total de pedidos encontrados"
        }
      }
    },
    "get_order": {
      "event": "local.glovo.get_order.request",
      "description": "Obtener detalle de un pedido específico",
      "input": {
        "order_id": {
          "type": "string",
          "description": "ID del pedido en Glovo",
          "required": true
        }
      },
      "output": {
        "order": {
          "type": "object",
          "description": "Detalle completo del pedido"
        }
      }
    },
    "accept_order": {
      "event": "local.glovo.accept_order.request",
      "description": "Aceptar un pedido de Glovo",
      "input": {
        "order_id": {
          "type": "string",
          "description": "ID del pedido en Glovo",
          "required": true
        }
      },
      "output": {
        "accepted": {
          "type": "boolean"
        }
      }
    },
    "reject_order": {
      "event": "local.glovo.reject_order.request",
      "description": "Rechazar un pedido de Glovo",
      "input": {
        "order_id": {
          "type": "string",
          "description": "ID del pedido en Glovo",
          "required": true
        },
        "reason": {
          "type": "string",
          "description": "Motivo del rechazo",
          "default": "STORE_CLOSED"
        }
      },
      "output": {
        "rejected": {
          "type": "boolean"
        }
      }
    },
    "mark_ready": {
      "event": "local.glovo.mark_ready.request",
      "description": "Marcar pedido como listo para recogida por rider",
      "input": {
        "order_id": {
          "type": "string",
          "description": "ID del pedido en Glovo",
          "required": true
        }
      },
      "output": {
        "ready": {
          "type": "boolean"
        }
      }
    }
  }
}
