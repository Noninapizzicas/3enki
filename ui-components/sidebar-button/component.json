{
  "component": "sidebar-button",
  "version": "1.0.0",
  "description": "Botón cuadrado para barra lateral - 10mm×10mm con emoji y marco resaltante",
  "author": "Event Core Team",
  "created": "2025-01-15",
  "license": "MIT",

  "dimensions": {
    "size": "10mm",
    "size_px": 38,
    "emoji_size": "20px",
    "border_width": "2px",
    "highlight_thickness": "3px",
    "responsive": true,
    "minSize": "36px"
  },

  "structure": {
    "layers": [
      {
        "id": "background",
        "description": "Fondo con color según tipo de botón"
      },
      {
        "id": "highlight",
        "description": "Marco resaltante en gradiente (top-left a bottom-right)",
        "position": "inset",
        "thickness": "3px"
      },
      {
        "id": "emoji",
        "description": "Emoji centrado sin texto"
      }
    ]
  },

  "props": {
    "required": [
      "id",
      "emoji",
      "type"
    ],
    "optional": [
      "label",
      "action",
      "route",
      "badge",
      "tooltip",
      "disabled"
    ],
    "types": {
      "id": "string",
      "emoji": "string",
      "type": "enum['primary','success','warning','danger','info','dark','purple','pink','cyan','orange']",
      "label": "string",
      "action": "string",
      "route": "string",
      "badge": "number|string",
      "tooltip": "string",
      "disabled": "boolean"
    }
  },

  "button_types": {
    "primary": {
      "name": "Principal",
      "background": "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(102, 126, 234, 0.4)"
    },
    "success": {
      "name": "Éxito",
      "background": "linear-gradient(135deg, #22c55e 0%, #16a34a 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(34, 197, 94, 0.4)"
    },
    "warning": {
      "name": "Advertencia",
      "background": "linear-gradient(135deg, #f59e0b 0%, #d97706 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(245, 158, 11, 0.4)"
    },
    "danger": {
      "name": "Peligro",
      "background": "linear-gradient(135deg, #ef4444 0%, #dc2626 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(239, 68, 68, 0.4)"
    },
    "info": {
      "name": "Información",
      "background": "linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(59, 130, 246, 0.4)"
    },
    "dark": {
      "name": "Oscuro",
      "background": "linear-gradient(135deg, #374151 0%, #1f2937 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(0, 0, 0, 0.4)"
    },
    "purple": {
      "name": "Púrpura",
      "background": "linear-gradient(135deg, #a855f7 0%, #9333ea 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(168, 85, 247, 0.4)"
    },
    "pink": {
      "name": "Rosa",
      "background": "linear-gradient(135deg, #ec4899 0%, #db2777 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(236, 72, 153, 0.4)"
    },
    "cyan": {
      "name": "Cian",
      "background": "linear-gradient(135deg, #06b6d4 0%, #0891b2 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(6, 182, 212, 0.4)"
    },
    "orange": {
      "name": "Naranja",
      "background": "linear-gradient(135deg, #f97316 0%, #ea580c 100%)",
      "highlight": "linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 100%)",
      "shadow": "0 4px 12px rgba(249, 115, 22, 0.4)"
    }
  },

  "states": {
    "default": {
      "opacity": 1,
      "scale": 1,
      "border": "1px solid rgba(255,255,255,0.2)"
    },
    "hover": {
      "opacity": 1,
      "scale": 1.1,
      "border": "1px solid rgba(255,255,255,0.4)",
      "lift": "2px"
    },
    "active": {
      "opacity": 1,
      "scale": 0.95,
      "border": "2px solid rgba(255,255,255,0.6)"
    },
    "selected": {
      "opacity": 1,
      "scale": 1.05,
      "border": "2px solid rgba(255,255,255,0.8)",
      "glow": true
    },
    "disabled": {
      "opacity": 0.4,
      "scale": 1,
      "cursor": "not-allowed"
    }
  },

  "interactions": {
    "haptic": true,
    "ripple": true,
    "tooltip": {
      "enabled": true,
      "position": "auto",
      "delay": 200
    }
  },

  "badge": {
    "size": "14px",
    "position": {
      "top": "-4px",
      "right": "-4px"
    },
    "background": "#ef4444",
    "color": "white",
    "border": "2px solid rgba(30, 30, 30, 0.95)",
    "animation": "pulse"
  },

  "events": {
    "emits": [
      "button:ready",
      "button:click",
      "button:navigate",
      "button:badge-update"
    ],
    "listens": [
      "button:select",
      "button:deselect",
      "badge:increment",
      "badge:set"
    ]
  },

  "api": {
    "endpoints": [
      {
        "method": "GET",
        "path": "/api/sidebar/buttons",
        "description": "Obtener configuración de botones de sidebar"
      },
      {
        "method": "GET",
        "path": "/api/notifications/count",
        "description": "Obtener contador de notificaciones para badge"
      }
    ],
    "mqtt": [
      {
        "topic": "/events/notifications/:section",
        "description": "Actualización de contadores en tiempo real"
      }
    ]
  },

  "accessibility": {
    "aria": true,
    "keyboard": true,
    "screenReader": true,
    "minTouchTarget": "44px",
    "contrastRatio": "4.5:1"
  },

  "dependencies": [],
  "browser": {
    "modern": true,
    "ie11": false,
    "mobile": true
  },
  "performance": {
    "lazy": false,
    "bundle": "standalone"
  },

  "preset_buttons": [
    {
      "id": "home",
      "emoji": "🏠",
      "type": "primary",
      "label": "Inicio",
      "action": "navigate",
      "route": "/"
    },
    {
      "id": "cuentas",
      "emoji": "📋",
      "type": "warning",
      "label": "Cuentas",
      "action": "navigate",
      "route": "/cuentas",
      "badge": null
    },
    {
      "id": "comandero",
      "emoji": "📝",
      "type": "success",
      "label": "Comandero",
      "action": "navigate",
      "route": "/comandero"
    },
    {
      "id": "cocina",
      "emoji": "👨‍🍳",
      "type": "orange",
      "label": "Cocina",
      "action": "navigate",
      "route": "/cocina"
    },
    {
      "id": "cobros",
      "emoji": "💰",
      "type": "info",
      "label": "Cobros",
      "action": "navigate",
      "route": "/cobros"
    },
    {
      "id": "menu",
      "emoji": "🍕",
      "type": "pink",
      "label": "Menú",
      "action": "navigate",
      "route": "/menu"
    },
    {
      "id": "delivery",
      "emoji": "🛵",
      "type": "cyan",
      "label": "Delivery",
      "action": "navigate",
      "route": "/delivery"
    },
    {
      "id": "stats",
      "emoji": "📊",
      "type": "purple",
      "label": "Estadísticas",
      "action": "navigate",
      "route": "/stats"
    },
    {
      "id": "settings",
      "emoji": "⚙️",
      "type": "dark",
      "label": "Ajustes",
      "action": "navigate",
      "route": "/settings"
    },
    {
      "id": "alert",
      "emoji": "🚨",
      "type": "danger",
      "label": "Alertas",
      "action": "navigate",
      "route": "/alerts"
    },
    {
      "id": "users",
      "emoji": "👥",
      "type": "info",
      "label": "Usuarios",
      "action": "navigate",
      "route": "/users"
    },
    {
      "id": "calendar",
      "emoji": "📅",
      "type": "primary",
      "label": "Calendario",
      "action": "navigate",
      "route": "/calendar"
    }
  ]
}
