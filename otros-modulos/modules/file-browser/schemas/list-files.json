{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["file", "directory"]
              },
              "extension": {
                "type": ["string", "null"]
              },
              "size": {
                "type": "number"
              },
              "modified": {
                "type": "string",
                "format": "date-time"
              },
              "path": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "error": {
      "type": "string"
    }
  }
}
