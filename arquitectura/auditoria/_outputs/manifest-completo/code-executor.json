{
  "_meta": {
    "modulo": "code-executor",
    "ubicacion": "modules/code-executor",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "code-executor",
    "version": "1.0.0",
    "description_oficial": "Shell command and script execution for AI with security controls",
    "author": "Event Core Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_4_features",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "shell.executed",        "description": "Command executed successfully" },
      { "event": "shell.error",           "description": "Command execution failed" },
      { "event": "shell.process.started", "description": "Background process started" },
      { "event": "shell.process.stopped", "description": "Background process stopped" }
    ],
    "subscribes": [
      { "event": "shell.exec.request", "handler": "onExecRequest", "extras": {} }
    ],
    "provides_eventos": [
      "shell.executed",
      "shell.error",
      "shell.process.started",
      "shell.process.stopped"
    ]
  },

  "tools": [
    {
      "name": "shell.exec",
      "description": "Ejecuta un comando shell. Retorna stdout, stderr y exitCode. Timeout por defecto: 30s.",
      "parameters_required": ["command"],
      "parameters_property_names": ["command", "cwd", "timeout", "env"],
      "parameters_size_chars": 306,
      "parameters_full_path_hint": "modules/code-executor/module.json → tools[0].parameters"
    },
    {
      "name": "shell.script",
      "description": "Ejecuta un archivo de script (bash, python, node). Detecta intérprete automáticamente.",
      "parameters_required": ["projectId", "scriptPath"],
      "parameters_property_names": ["projectId", "scriptPath", "args", "timeout"],
      "parameters_size_chars": 316,
      "parameters_full_path_hint": "modules/code-executor/module.json → tools[1].parameters"
    },
    {
      "name": "shell.background",
      "description": "Inicia un proceso en segundo plano (ej: servidor dev). Retorna PID para control.",
      "parameters_required": ["command"],
      "parameters_property_names": ["command", "cwd", "name"],
      "parameters_size_chars": 222,
      "parameters_full_path_hint": "modules/code-executor/module.json → tools[2].parameters"
    },
    {
      "name": "shell.kill",
      "description": "Detiene un proceso en segundo plano por PID o nombre.",
      "parameters_required": [],
      "parameters_property_names": ["pid", "name"],
      "parameters_size_chars": 157,
      "parameters_full_path_hint": "modules/code-executor/module.json → tools[3].parameters"
    },
    {
      "name": "shell.list",
      "description": "Lista procesos en segundo plano activos.",
      "parameters_required": [],
      "parameters_property_names": [],
      "parameters_size_chars": 47,
      "parameters_full_path_hint": "modules/code-executor/module.json → tools[4].parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": null,
    "items": []
  },

  "apis_http": [],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "defaultTimeout",  "tipo": "number",  "valor_default": 30000 },
      { "key": "maxTimeout",      "tipo": "number",  "valor_default": 300000 },
      { "key": "maxProcesses",    "tipo": "number",  "valor_default": 10 },
      { "key": "allowedCommands", "tipo": "array",   "valor_default": [] },
      { "key": "blockedCommands", "tipo": "array",   "valor_default": ["rm -rf /", "rm -rf /*", "mkfs", "dd if=/dev/zero", ":(){:|:&};:", "chmod -R 777 /", "chown -R", "sudo rm", "sudo dd", "sudo mkfs", "> /dev/sda", "mv /* /dev/null"] },
      { "key": "blockedPatterns", "tipo": "array",   "valor_default": ["rm\\s+-rf\\s+/[^a-zA-Z]", ">(\\s+)?/dev/[hs]d", "\\|\\s*sh\\s*$", "\\|\\s*bash\\s*$", "curl.*\\|.*sh", "wget.*\\|.*sh"] },
      { "key": "shell",           "tipo": "string",  "valor_default": "/bin/sh" },
      { "key": "projectsPath",    "tipo": "string",  "valor_default": "./data/projects" }
    ]
  },

  "observability_declarada": {
