      "_nota_events_inline_schema": "events.publishes[].schema contiene JSON Schema inline (caja.cerrada, cuenta.cerrada_forzada, dia.iniciado) — inusual; la mayoría de módulos no inline schemas en publishes.",
      "_nota_observability_correlation_id": "observability.logging.correlation_id=true es campo extra no declarado en el schema de observability del contrato."
    }
  },

  "version_archivada": {
