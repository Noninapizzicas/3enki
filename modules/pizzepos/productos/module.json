{
  "name": "productos",
  "version": "3.0.0",
  "description": "Catalogo de productos pizzepos multi-tenant. Cada proyecto tiene su propio catalogo, sincronizado desde menus generados por IA o cartas (carta.actualizada). Persiste a disco como cartas JSON en {project.base_path}/storage/pizzepos/cartas/. Emite producto.{creado,actualizado,eliminado} y catalogo.actualizado para que comandero/pedidos refresquen su cache.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "events": {
    "publishes": [
      { "event": "producto.creado",       "description": "Nuevo producto creado desde menu generado o carta. project_id top-level + correlation_id + timestamp." },
      { "event": "producto.actualizado",  "description": "Producto actualizado (precio, ingredientes, activo). project_id top-level + correlation_id + timestamp." },
      { "event": "producto.eliminado",    "description": "Producto eliminado del catalogo. project_id top-level + correlation_id + timestamp." },
      { "event": "catalogo.actualizado",  "description": "Catalogo completo actualizado desde menu o carta. Consumido por pedidos/comandero para refrescar cache. project_id top-level + correlation_id + timestamp." },
      { "event": "menu.generado",         "description": "Re-emitido tras carga inicial desde disco para que categorias se popule (source=disk_load)." },
      { "event": "project.get.request",   "description": "Request a project-manager para resolver base_path. Correlacionado por request_id." }
    ],
    "subscribes": [
      { "event": "carta.actualizada",     "handler": "onCartaGenerada",      "description": "Carta creada o modificada — auto-sync al catalogo de productos." },
      { "event": "menu.generado",         "handler": "onMenuGenerado",       "description": "Menu generado por IA — guarda en menusPendientes esperando validacion." },
      { "event": "menu.validado",         "handler": "onMenuValidado",       "description": "Menu validado — sync al catalogo y persiste a disco." },
      { "event": "project.activated",     "handler": "onProjectActivated",   "description": "Cache base_path del proyecto + auto-load cartas desde disco." },
      { "event": "project.get.response",  "handler": "onProjectGetResponse", "description": "Resolves pending project path resolve por request_id." }
    ]
  },
  "ui_handlers": [
    { "domain": "productos", "action": "list",            "handler": "handleListProductos",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "get",             "handler": "handleGetProducto",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "search",          "handler": "handleSearchProductos", "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "update",          "handler": "handleUpdateProducto",  "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "delete",          "handler": "handleDeleteProducto",  "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "categorias",      "handler": "handleListCategorias",  "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "ingredientes",    "handler": "handleListIngredientes","type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "pizzas",          "handler": "handleListPizzas",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "stats",           "handler": "handleGetStats",        "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "health",          "handler": "handleHealthCheck",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "metrics",         "handler": "handleGetMetrics",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "load_carta",      "handler": "handleLoadCarta",       "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "productos", "action": "carta_completa",  "handler": "handleCartaCompleta",   "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [],
  "dependencies": ["project-manager", "ingredientes"],
  "tracing": {
    "propaga_correlation_id": true
  },
  "config": {
    "persistence": {
      "type": "json-file-per-project",
      "owner": "ProductosModule (Map productosPerProject + Map categoriasPerProject + Map menusPendientes)",
      "paths": [
        "{project.base_path}/storage/pizzepos/cartas/*.json (read+write)",
        "{project.base_path}/storage/pizzepos/cartas/catalogo_activo.json (write atomic on update/delete)"
      ],
      "restart_resilient": true,
      "concurrency": "single-writer-per-project",
      "lost_on_restart": ["menusPendientes", "pendingProjectRequests"]
    }
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "producto.creado.total",
        "producto.actualizado.total",
        "producto.eliminado.total",
        "catalogo.actualizado.total",
        "productos.errors"
      ],
      "gauges": [
        "producto.activos.count",
        "producto.por_categoria.count"
      ],
      "timings": [
        "producto.list.duration",
        "producto.search.duration",
        "catalogo.sync.duration"
      ]
    }
  }
}
