  "identidad": {
    "name": "chat-io",
    "version": "1.0.0",
    "description_oficial": "Entrada y salida del chat. Recibe mensajes del frontend (ui/request/conversation/send), persiste conversaciones y mensajes en SQLite por proyecto, aplica FIFO de contexto, y reenvía la respuesta del LLM al frontend por MQTT (conversation/{id}/message).",
    "author": "Event Core Team",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": false,
    "en_disabled_de_config": false,
