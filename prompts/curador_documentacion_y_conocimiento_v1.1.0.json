            "path": "/docs/v1/architecture/event_flow.mmd",
            "description": "Flujo de eventos entre módulos con W3C tracing"
          }
        ]
      }
    },
    "onboarding_guide": {
      "path": "docs/v1/onboarding.md",
      "description": "Guía progresiva con TTFV < 5min y quick wins",
      "schema": {
        "type": "object",
        "properties": {
          "target_ttfv_seconds": { "type": "integer", "maximum": 300 },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "step": { "type": "integer" },
                "title": { "type": "string" },
                "duration_seconds": { "type": "integer" },
                "commands": { "type": "array", "items": { "type": "string" } },
                "expected_output": { "type": "string" },
                "troubleshooting": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "issue": { "type": "string" },
                      "solution": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                },
                "quick_win": { "type": "string" }
              },
              "required": ["step", "title", "duration_seconds"],
              "additionalProperties": false
            }
          },
          "progressive_disclosure": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
                "content_path": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "required": ["target_ttfv_seconds", "steps"],
        "additionalProperties": false
      },
      "example": {
        "target_ttfv_seconds": 240,
        "steps": [
          {
            "step": 1,
            "title": "Clonar repositorio",
            "duration_seconds": 30,
            "commands": ["git clone https://github.com/user/project.git", "cd project"],
            "expected_output": "Repositorio clonado exitosamente",
            "quick_win": "✅ Código descargado"
          },
          {
            "step": 2,
            "title": "Configurar credenciales",
            "duration_seconds": 60,
            "commands": ["cp .env.example .env", "make setup-credentials"],
            "expected_output": "Credenciales configuradas en vault",
            "troubleshooting": [
              {
                "issue": "Error: vault no encontrado",
                "solution": "Ejecutar: make install-vault"
