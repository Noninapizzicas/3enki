      {"metodo": "GET", "path": "/cobros", "descripcion": "Listar cobros"},
      {"metodo": "POST", "path": "/cobros/:id/confirmar", "descripcion": "Confirmar cobro"},
      {"metodo": "POST", "path": "/cobros/:id/reembolsar", "descripcion": "Reembolsar cobro"},
      {"metodo": "GET", "path": "/metodos-pago", "descripcion": "Metodos de pago disponibles"}
    ],

    "comandero": [
      {"metodo": "GET", "path": "/pedido/:cuenta_id", "descripcion": "Obtener pedido de cuenta"},
      {"metodo": "POST", "path": "/pedido/:cuenta_id/items", "descripcion": "Anadir item"},
