{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pizzepos.com/schemas/mesa-events.json",
  "title": "Mesa Events Schema",
  "description": "Esquemas de eventos de mesas",

  "definitions": {
    "mesa_abierta": {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {"const": "mesa.abierta"},
        "payload": {
          "type": "object",
          "required": ["cuenta_id", "numero_mesa", "zona", "hora_apertura"],
          "properties": {
            "cuenta_id": {"type": "string"},
            "numero_mesa": {"type": "integer", "minimum": 1, "maximum": 100},
            "zona": {
              "type": "string",
              "enum": ["terraza", "interior", "vip"]
            },
            "capacidad": {"type": "integer"},
            "comensales": {"type": "integer"},
            "camarero": {"type": "string"},
            "hora_apertura": {"type": "string", "format": "date-time"}
          }
        },
        "correlation_id": {"type": "string"}
      }
    },

    "mesa_camarero_asignado": {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {"const": "mesa.camarero_asignado"},
        "payload": {
          "type": "object",
          "required": ["cuenta_id", "numero_mesa", "camarero"],
          "properties": {
            "cuenta_id": {"type": "string"},
            "numero_mesa": {"type": "integer"},
            "camarero": {"type": "string"},
            "camarero_anterior": {"type": "string"}
          }
        },
        "correlation_id": {"type": "string"}
      }
    },

    "mesa_cerrada": {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {"const": "mesa.cerrada"},
        "payload": {
          "type": "object",
          "required": ["cuenta_id", "numero_mesa", "total", "tiempo_ocupada"],
          "properties": {
            "cuenta_id": {"type": "string"},
            "numero_mesa": {"type": "integer"},
            "total": {"type": "number"},
            "tiempo_ocupada": {"type": "integer"},
            "hora_cierre": {"type": "string", "format": "date-time"}
          }
        },
        "correlation_id": {"type": "string"}
      }
    },

    "cuenta_creada": {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {"const": "cuenta.creada"},
        "payload": {
          "type": "object",
          "required": ["cuenta_id", "tipo", "origen"],
          "properties": {
            "cuenta_id": {"type": "string"},
            "tipo": {"const": "mesa"},
            "origen": {"const": "cuentas-mesa"},
            "numero_mesa": {"type": "integer"},
            "total": {"type": "number"},
            "metadata": {"type": "object"}
          }
        },
        "correlation_id": {"type": "string"}
      }
    },

    "cuenta_cerrada": {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {"const": "cuenta.cerrada"},
        "payload": {
          "type": "object",
          "required": ["cuenta_id", "tipo", "total"],
          "properties": {
            "cuenta_id": {"type": "string"},
            "tipo": {"const": "mesa"},
            "total": {"type": "number"},
            "metadata": {"type": "object"}
          }
        },
        "correlation_id": {"type": "string"}
      }
    }
  }
}
