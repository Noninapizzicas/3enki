      "pseudo_code": [
        { "type": "pseudo_step", "action": "branch", "target": "if_action_fetch_archivo", "condition": "step.action === 'fetch' && step.target_es_path", "value": null },
        { "type": "pseudo_step", "action": "call", "target": "Read", "condition": null, "value": "{ file_path: step.target }" },
        { "type": "pseudo_step", "action": "branch", "target": "if_action_fetch_variable", "condition": "step.action === 'fetch' && step.target_es_var", "value": null },
