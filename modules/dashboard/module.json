{
  "name": "dashboard",
  "version": "3.0.0",
  "description": "Observability Dashboard - Web UI bus-driven para monitorear todos los cores en la red en tiempo real (active cores via discovery, logs streaming SSE, events streaming SSE, metrics agregadas). Buffers in-memory (logBuffer, eventBuffer) populados por suscripcion al bus (core/+/logs/#, core/+/events/#).",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",
  "tracing": {
    "propaga_correlation_id": true
  },
  "events": {
    "publishes": [],
    "subscribes": []
  },
  "ui_handlers": [
    { "domain": "dashboard", "action": "cores",       "handler": "handleCores",      "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "dashboard", "action": "core-detail", "handler": "handleCoreDetail", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "dashboard", "action": "logs",        "handler": "handleLogs",       "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "dashboard", "action": "events",      "handler": "handleEvents",     "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "dashboard", "action": "metrics",     "handler": "handleMetrics",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "dashboard", "action": "health",      "handler": "handleHealth",     "type": "system_panel", "zone": "lateral_derecha" }
  ],
  "tools": [],
  "dependencies": [],
  "subscribes": [
    "core/+/logs/#",
    "core/+/events/#",
    "core/+/metrics/#"
  ],
  "requires": {
    "core": ">=0.5.0"
  },
  "config": {
    "max_buffer_size": 1000,
    "persistence": {
      "type": "in-memory",
      "owner": "DashboardModule (logBuffer + eventBuffer + Sets de SSE clients + ref a discovery)",
      "restart_resilient": false,
      "concurrency": "single-instance",
      "lost_on_restart": ["logBuffer", "eventBuffer", "sseClients", "discovery"]
    }
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "dashboard.errors"
      ]
    }
  }
}
