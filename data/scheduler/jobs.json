[
  {
    "id": "time-pulse",
    "name": "Pulso de tiempo (cada minuto)",
    "description": "Emite schedule.time cada minuto con metadatos de tiempo completos",
    "enabled": true,
    "trigger": {
      "type": "interval",
      "value": 1,
      "unit": "m"
    },
    "action": {
      "type": "mqtt",
      "topic": "schedule.time"
    },
    "options": {
      "maxRetries": 0,
      "timeout": 5000
    },
    "metadata": {
      "category": "time",
      "system": true
    }
  },
