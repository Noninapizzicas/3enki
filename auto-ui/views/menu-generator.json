{
  "name": "menu-generator",
  "version": "2.0.0",
  "type": "ai-workspace",
  "description": "Vista completa para generación de menús con IA: chat, prompts, upload de archivos, preview y edición",
  "author": "Event Core Team",
  "generated_at": "2024-11-30",

  "permissions": ["admin", "user"],

  "config": {
    "title": "Generador de Menús",
    "icon": "🍽️",
    "layout": "mobile-first",
    "fullscreen": true,
    "preventScroll": true
  },

  "layout": {
    "type": "stack",
    "direction": "vertical",
    "config": {
      "height": "100vh",
      "overflow": "hidden"
    }
  },

  "sections": [
    {
      "id": "header",
      "type": "fixed",
      "position": "top",
      "height": "auto",
      "component": "header-bar",
      "props": {
        "title": "🍽️ Menu Generator",
        "showBack": true,
        "backAction": "navigate",
        "backTarget": "/auto-ui",
        "actions": [
          {
            "id": "credentials",
            "component": "credential-indicator",
            "props": {
              "variant": "badge",
              "provider": "@state.aiConfig.provider",
              "showLevel": true,
              "showStatus": true,
              "enableQuickAdd": true,
              "endpoint": "/modules/credential-manager/credentials"
            },
            "action": "open-panel",
            "panel": {
              "id": "credentials-panel",
              "size": "medium",
              "title": "Gestionar Credenciales"
            }
          },
          {
            "id": "new-chat",
            "emoji": "➕",
            "label": "Nueva conversación",
            "action": "emit",
            "event": "menu-generator.new-conversation"
          },
          {
            "id": "history",
            "emoji": "📜",
            "label": "Historial",
            "action": "open-panel",
            "panel": {
              "id": "history-panel",
              "size": "medium",
              "title": "Historial de Menús"
            }
          }
        ]
      }
    },

    {
      "id": "main-content",
      "type": "flex",
      "flex": 1,
      "overflow": "hidden",
      "sections": [
        {
          "id": "chat-area",
          "type": "flex",
          "flex": 1,
          "direction": "column",
          "overflow": "hidden",

          "sections": [
            {
              "id": "conversation",
              "type": "flex",
              "flex": 1,
              "overflow": "auto",
              "component": "conversation-panel",
              "props": {
                "variant": "ai-chat",
                "size": "fullscreen",
                "conversationId": "@state.currentConversationId",
                "endpoint": "/modules/menu-generator/conversations/@state.currentConversationId/messages",
                "streamingEndpoint": "/modules/menu-generator/stream",
                "enableMarkdown": true,
                "enableAttachments": true,
                "enableVoice": false,
                "placeholder": "Describe el menú que quieres generar...",
                "sendIcon": "🚀",
                "aiProvider": "deepseek",
                "showTypingIndicator": true,
                "maxMessageLength": 4000,
                "showTimestamps": true,
                "showAvatars": true,
                "enableCommands": true,
                "mqttEnabled": true,
                "mqttTopics": [
                  "menu-generator.message.sent",
                  "menu-generator.message.received",
                  "menu-generator.menu.generated",
                  "menu-generator.menu.updated"
                ]
              }
            },

            {
              "id": "result-preview",
              "type": "conditional",
              "condition": "@state.hasGeneratedMenu",
              "collapsible": true,
              "collapsed": false,
              "maxHeight": "40vh",
              "component": "result-preview-card",
              "props": {
                "variant": "menu-preview",
                "status": "@state.menuStatus",
                "dataFormat": "cards",
                "endpoint": "/modules/menu-generator/menus/@state.currentMenuId",
                "title": "Menú Generado",
                "showActions": true,
                "actions": [
                  {
                    "id": "validate",
                    "label": "Validar",
                    "icon": "✅",
                    "action": "emit",
                    "event": "menu-generator.validate-menu"
                  },
                  {
                    "id": "edit",
                    "label": "Editar",
                    "icon": "✏️",
                    "action": "open-panel",
                    "panel": {
                      "id": "edit-menu-panel",
                      "size": "full",
                      "title": "Editar Menú"
                    }
                  },
                  {
                    "id": "export",
                    "label": "Exportar",
                    "icon": "📤",
                    "action": "emit",
                    "event": "menu-generator.export-menu"
                  },
                  {
                    "id": "regenerate",
                    "label": "Regenerar",
                    "icon": "🔄",
                    "action": "emit",
                    "event": "menu-generator.regenerate-menu"
                  }
                ],
                "expandable": true,
                "expanded": false,
                "highlightChanges": true
              }
            }
          ]
        }
      ]
    },

    {
      "id": "input-area",
      "type": "fixed",
      "position": "bottom",
      "component": "chat-input",
      "props": {
        "variant": "default",
        "size": "md",
        "placeholder": "Describe el menú que quieres generar...",
        "multiline": true,
        "maxRows": 5,
        "maxLength": 4000,
        "showCharCount": false,
        "showTokenCount": true,
        "streaming": true,
        "endpoint": "/modules/menu-generator/conversations/@state.currentConversationId/messages",
        "hapticFeedback": true,
        "submitOnEnter": true,
        "clearOnSubmit": true,

        "topBar": {
          "enabled": true,
          "collapsible": true,
          "collapsed": false,
          "buttons": [
            {
              "id": "ai-provider",
              "emoji": "🤖",
              "label": "Proveedor AI",
              "action": "open-panel",
              "panel": {
                "id": "ai-settings-panel",
                "size": "small",
                "title": "Configuración AI"
              }
            },
            {
              "id": "prompts",
              "emoji": "📝",
              "label": "Prompts",
              "action": "open-panel",
              "panel": {
                "id": "prompts-panel",
                "size": "medium",
                "title": "Prompts Guardados"
              }
            },
            {
              "id": "templates",
              "emoji": "📋",
              "label": "Plantillas",
              "action": "open-panel",
              "panel": {
                "id": "templates-panel",
                "size": "medium",
                "title": "Plantillas de Menú"
              }
            },
            {
              "id": "style",
              "emoji": "🎨",
              "label": "Estilo",
              "action": "open-panel",
              "panel": {
                "id": "style-panel",
                "size": "small",
                "title": "Estilo del Menú"
              }
            }
          ]
        },

        "bottomBar": {
          "enabled": true,
          "collapsible": true,
          "collapsed": false,
          "buttons": [
            {
              "id": "upload-image",
              "emoji": "📷",
              "label": "Foto de carta",
              "action": "open-panel",
              "panel": {
                "id": "upload-panel",
                "size": "medium",
                "title": "Subir Carta de Menú"
              }
            },
            {
              "id": "attach-file",
              "emoji": "📎",
              "label": "Adjuntar",
              "action": "emit",
              "event": "menu-generator.attach-file"
            },
            {
              "id": "voice",
              "emoji": "🎤",
              "label": "Voz",
              "action": "emit",
              "event": "menu-generator.voice-input"
            },
            {
              "id": "examples",
              "emoji": "💡",
              "label": "Ejemplos",
              "action": "open-panel",
              "panel": {
                "id": "examples-panel",
                "size": "medium",
                "title": "Ejemplos de Prompts"
              }
            }
          ]
        },

        "sendButton": {
          "emoji": "🚀",
          "label": "Generar",
          "position": "right",
          "holdAction": {
            "emoji": "⚡",
            "label": "Generación rápida",
            "event": "menu-generator.quick-generate"
          }
        }
      }
    }
  ],

  "panels": {
    "ai-settings-panel": {
      "component": "floating-panel",
      "variant": "default",
      "size": "small",
      "props": {
        "title": "⚙️ Configuración AI",
        "showHandle": true,
        "showCloseButton": true,
        "draggable": true,
        "swipeToClose": true,
        "backdropClose": true,
        "backdrop": true,
        "backdropBlur": true
      },
      "content": {
        "component": "ai-control-bar",
        "props": {
          "variant": "full",
          "position": "floating",
          "showProvider": true,
          "showModel": true,
          "showTemperature": true,
          "showMaxTokens": true,
          "showPrompts": false,
          "showCredentials": true,
          "providers": ["deepseek", "openai", "claude", "ollama"],
          "defaultProvider": "deepseek",
          "defaultTemperature": 0.7,
          "defaultMaxTokens": 2000,
          "collapsible": false
        }
      }
    },

    "prompts-panel": {
      "component": "floating-panel",
      "variant": "default",
      "size": "medium",
      "props": {
        "title": "📝 Prompts Guardados",
        "showHandle": true,
        "showCloseButton": true,
        "draggable": true,
        "swipeToClose": true,
        "backdropClose": true
      },
      "content": {
        "component": "prompt-selector",
        "props": {
          "variant": "panel",
          "endpoint": "/modules/prompt-manager/prompts",
          "scope": "all",
          "categories": ["menu", "restaurant", "food", "general"],
          "showVersioning": true,
          "enableCreate": true,
          "enableEdit": true,
          "showPreview": true,
          "searchEnabled": true
        }
      },
      "actions": [
        {
          "label": "Cancelar",
          "variant": "secondary",
          "action": "close"
        },
        {
          "label": "Usar Prompt",
          "variant": "primary",
          "action": "emit",
          "event": "menu-generator.use-prompt"
        }
      ]
    },

    "templates-panel": {
      "component": "floating-panel",
      "variant": "default",
      "size": "medium",
      "props": {
        "title": "📋 Plantillas de Menú",
        "showHandle": true,
        "showCloseButton": true,
        "draggable": true,
        "swipeToClose": true
      },
      "content": {
        "type": "list",
        "dataSource": "@api:/modules/menu-generator/templates",
        "template": "menu-template-card",
        "emptyMessage": "No hay plantillas disponibles"
      },
      "actions": [
        {
          "label": "Cerrar",
          "variant": "secondary",
          "action": "close"
        }
      ]
    },

    "style-panel": {
      "component": "floating-panel",
      "variant": "default",
      "size": "small",
      "props": {
        "title": "🎨 Estilo del Menú",
        "showHandle": true,
        "showCloseButton": true
      },
      "content": {
        "type": "form",
        "fields": [
          {
            "name": "menuType",
            "component": "radio-group",
            "props": {
              "label": "Tipo de Menú",
              "layout": "vertical",
              "options": [
                {"value": "restaurant", "label": "🍽️ Restaurante"},
                {"value": "cafe", "label": "☕ Cafetería"},
                {"value": "bar", "label": "🍸 Bar"},
                {"value": "fast-food", "label": "🍔 Comida rápida"},
                {"value": "fine-dining", "label": "🥂 Fine dining"}
              ],
              "default": "restaurant"
            }
          },
          {
            "name": "language",
            "component": "select",
            "props": {
              "label": "Idioma",
              "options": [
                {"value": "es", "label": "🇪🇸 Español"},
                {"value": "en", "label": "🇬🇧 English"},
                {"value": "ca", "label": "Català"},
                {"value": "eu", "label": "Euskara"}
              ],
              "default": "es"
            }
          },
          {
            "name": "includeDescriptions",
            "component": "checkbox",
            "props": {
              "label": "Incluir descripciones de platos",
              "default": true
            }
          },
          {
            "name": "includeAllergens",
            "component": "checkbox",
            "props": {
              "label": "Incluir alérgenos",
              "default": true
            }
          },
          {
            "name": "includePrices",
            "component": "checkbox",
            "props": {
              "label": "Incluir precios",
              "default": true
            }
          }
        ]
      },
      "actions": [
        {
          "label": "Aplicar",
          "variant": "primary",
          "action": "emit",
          "event": "menu-generator.apply-style"
        }
      ]
    },

    "upload-panel": {
      "component": "floating-panel",
      "variant": "default",
      "size": "medium",
      "props": {
        "title": "📷 Subir Carta de Menú",
        "showHandle": true,
        "showCloseButton": true,
        "draggable": true,
        "swipeToClose": true
      },
      "content": {
        "component": "file-drop-zone",
        "props": {
          "variant": "image-only",
          "size": "md",
          "maxFiles": 5,
          "maxFileSize": 10485760,
          "captureMode": "environment",
          "showPreview": true,
          "enablePaste": true,
          "enableCrop": true,
          "compressionEnabled": true,
          "compressionQuality": 0.8,
          "endpoint": "/modules/menu-generator/upload",
          "uploadOnSelect": false,
          "dropMessage": "📸 Arrastra fotos de la carta o haz click para capturar",
          "icon": "🍽️",
          "metadata": {
            "module": "menu-generator",
            "type": "menu-card-image"
          }
        }
      },
      "actions": [
        {
          "label": "Cancelar",
          "variant": "secondary",
          "action": "close"
        },
        {
          "label": "Analizar Carta",
          "variant": "primary",
          "icon": "🔍",
          "action": "emit",
          "event": "menu-generator.analyze-images"
        }
      ]
    },

    "examples-panel": {
      "component": "floating-panel",
      "variant": "default",
      "size": "medium",
      "props": {
        "title": "💡 Ejemplos de Prompts",
        "showHandle": true,
        "showCloseButton": true
      },
      "content": {
        "type": "list",
        "items": [
          {
            "emoji": "🍝",
            "title": "Menú italiano",
            "prompt": "Genera un menú para restaurante italiano con entrantes, pasta, pizzas y postres. Incluye opciones vegetarianas."
          },
          {
            "emoji": "🍣",
            "title": "Menú japonés",
            "prompt": "Crea un menú de restaurante japonés con sushi, ramen, tempura y platos especiales del chef."
          },
          {
            "emoji": "🥗",
            "title": "Menú saludable",
            "prompt": "Diseña un menú saludable con opciones bajas en calorías, ensaladas, bowls y smoothies."
          },
          {
            "emoji": "🍖",
            "title": "Menú de parrilla",
            "prompt": "Genera un menú de asador con carnes a la brasa, entrantes, guarniciones y postres caseros."
          },
          {
            "emoji": "☕",
            "title": "Carta de cafetería",
            "prompt": "Crea una carta de cafetería con desayunos, brunch, sándwiches, tartas y bebidas calientes y frías."
          }
        ],
        "template": "example-prompt-card",
        "onItemClick": "useExample"
      }
    },

    "edit-menu-panel": {
      "component": "floating-panel",
      "variant": "fullscreen",
      "size": "full",
      "props": {
        "title": "✏️ Editar Menú",
        "showHandle": false,
        "showCloseButton": true,
        "draggable": false,
        "swipeToClose": false
      },
      "content": {
        "type": "menu-editor",
        "dataSource": "@state.currentMenu",
        "features": {
          "addCategory": true,
          "editCategory": true,
          "deleteCategory": true,
          "addItem": true,
          "editItem": true,
          "deleteItem": true,
          "reorderItems": true,
          "editPrices": true,
          "editDescriptions": true,
          "editAllergens": true
        }
      },
      "actions": [
        {
          "label": "Cancelar",
          "variant": "secondary",
          "action": "close"
        },
        {
          "label": "Guardar Cambios",
          "variant": "primary",
          "icon": "💾",
          "action": "emit",
          "event": "menu-generator.save-menu"
        }
      ]
    },

    "history-panel": {
      "component": "floating-panel",
      "variant": "default",
      "size": "medium",
      "props": {
        "title": "📜 Historial de Menús",
        "showHandle": true,
        "showCloseButton": true
      },
      "content": {
        "type": "list",
        "dataSource": "@api:/modules/menu-generator/history",
        "template": "menu-history-card",
        "pagination": true,
        "pageSize": 10,
        "emptyMessage": "No hay menús en el historial"
      }
    },

    "credentials-panel": {
      "component": "floating-panel",
      "variant": "default",
      "size": "medium",
      "props": {
        "title": "🔑 Gestionar Credenciales",
        "showHandle": true,
        "showCloseButton": true,
        "draggable": true,
        "swipeToClose": true,
        "backdropClose": true
      },
      "content": {
        "type": "stack",
        "direction": "vertical",
        "gap": "16px",
        "sections": [
          {
            "id": "current-status",
            "component": "credential-indicator",
            "props": {
              "variant": "detailed",
              "provider": "@state.aiConfig.provider",
              "showLevel": true,
              "showStatus": true,
              "enableQuickAdd": true,
              "endpoint": "/modules/credential-manager/credentials",
              "checkOnInit": true
            }
          },
          {
            "id": "providers-list",
            "type": "list",
            "title": "Credenciales por Proveedor",
            "items": [
              {
                "provider": "deepseek",
                "component": "credential-indicator",
                "props": {
                  "variant": "inline",
                  "provider": "deepseek",
                  "showLevel": true,
                  "enableQuickAdd": true
                }
              },
              {
                "provider": "openai",
                "component": "credential-indicator",
                "props": {
                  "variant": "inline",
                  "provider": "openai",
                  "showLevel": true,
                  "enableQuickAdd": true
                }
              },
              {
                "provider": "claude",
                "component": "credential-indicator",
                "props": {
                  "variant": "inline",
                  "provider": "claude",
                  "showLevel": true,
                  "enableQuickAdd": true
                }
              },
              {
                "provider": "ollama",
                "component": "credential-indicator",
                "props": {
                  "variant": "inline",
                  "provider": "ollama",
                  "showLevel": true,
                  "enableQuickAdd": true
                }
              }
            ]
          },
          {
            "id": "add-credential-form",
            "type": "form",
            "title": "Añadir Credencial",
            "collapsed": true,
            "fields": [
              {
                "name": "provider",
                "component": "select",
                "props": {
                  "label": "Proveedor",
                  "options": [
                    {"value": "deepseek", "label": "🔥 DeepSeek"},
                    {"value": "openai", "label": "🟢 OpenAI"},
                    {"value": "claude", "label": "🟣 Claude"},
                    {"value": "ollama", "label": "🦙 Ollama"}
                  ],
                  "required": true
                }
              },
              {
                "name": "level",
                "component": "select",
                "props": {
                  "label": "Nivel",
                  "options": [
                    {"value": "CUSTOM", "label": "🟣 Custom (solo esta sesión)"},
                    {"value": "CLIENT", "label": "🔵 Cliente"},
                    {"value": "PROJECT", "label": "🟢 Proyecto"},
                    {"value": "GLOBAL", "label": "⚪ Global"}
                  ],
                  "default": "PROJECT"
                }
              },
              {
                "name": "apiKey",
                "component": "input",
                "props": {
                  "label": "API Key",
                  "type": "password",
                  "placeholder": "sk-...",
                  "required": true
                }
              }
            ]
          }
        ]
      },
      "actions": [
        {
          "label": "Cerrar",
          "variant": "secondary",
          "action": "close"
        },
        {
          "label": "Guardar Credencial",
          "variant": "primary",
          "icon": "💾",
          "action": "emit",
          "event": "menu-generator.save-credential"
        }
      ]
    }
  },

  "state": {
    "currentConversationId": {
      "type": "string",
      "default": null,
      "persist": true
    },
    "currentMenuId": {
      "type": "string",
      "default": null
    },
    "hasGeneratedMenu": {
      "type": "boolean",
      "default": false
    },
    "menuStatus": {
      "type": "enum",
      "values": ["pending", "processing", "completed", "error"],
      "default": "pending"
    },
    "currentMenu": {
      "type": "object",
      "default": null
    },
    "aiConfig": {
      "type": "object",
      "default": {
        "provider": "deepseek",
        "model": "",
        "temperature": 0.7,
        "maxTokens": 2000
      },
      "persist": true
    },
    "styleConfig": {
      "type": "object",
      "default": {
        "menuType": "restaurant",
        "language": "es",
        "includeDescriptions": true,
        "includeAllergens": true,
        "includePrices": true
      },
      "persist": true
    }
  },

  "events": {
    "subscribe": [
      "menu-generator.new-conversation",
      "menu-generator.message.sent",
      "menu-generator.message.received",
      "menu-generator.menu.generated",
      "menu-generator.menu.updated",
      "menu-generator.validate-menu",
      "menu-generator.export-menu",
      "menu-generator.regenerate-menu",
      "menu-generator.attach-file",
      "menu-generator.voice-input",
      "menu-generator.use-prompt",
      "menu-generator.apply-style",
      "menu-generator.analyze-images",
      "menu-generator.save-menu",
      "menu-generator.quick-generate",
      "menu-generator.save-credential",
      "credential-manager.credential.updated"
    ],
    "publish": [
      "menu-generator.conversation.created",
      "menu-generator.menu.created",
      "menu-generator.menu.saved",
      "menu-generator.menu.exported"
    ]
  },

  "mqtt": {
    "enabled": true,
    "topics": [
      "menu-generator.+",
      "ai-gateway.response.menu-generator"
    ],
    "auto_refresh": true
  },

  "accessibility": {
    "role": "application",
    "ariaLabel": "Generador de menús con inteligencia artificial",
    "keyboard": true,
    "focusable": true,
    "screenReader": true,
    "announcements": {
      "menuGenerating": "Generando menú, por favor espere...",
      "menuGenerated": "Menú generado correctamente",
      "menuError": "Error al generar el menú"
    }
  }
}
