{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://2enki/arquitectura/auditoria/_schemas/modulo-completo.schema.json",
  "title": "Módulo Completo (parcela modulo-completo v1.0.0)",
  "description": "Captura comprehensiva por módulo. Schema estricto, additionalProperties:false en todos los niveles. Descriptivo, no prescriptivo.",

  "type": "object",
  "additionalProperties": false,
  "required": ["_meta", "identidad", "estado_en_sistema", "eventos", "tools", "ui_handlers", "apis_http", "estado", "configuracion", "lifecycle", "dependencias_implicitas", "modos_de_fallo", "observabilidad", "archivos_hermanos", "version_archivada", "codigo_intencion", "metricas_fisicas", "outliers_capturados", "quirks"],

  "properties": {
    "_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modulo", "ubicacion", "auditado_en", "parcela", "parcela_version", "manifest_referencia"],
      "properties": {
        "modulo":              { "type": "string", "minLength": 1 },
        "ubicacion":           { "type": "string", "pattern": "^modules/" },
        "auditado_en":         { "type": "string", "format": "date" },
        "parcela":             { "const": "modulo-completo" },
        "parcela_version":     { "const": "1.0.0" },
        "manifest_referencia": { "type": "string", "pattern": "^arquitectura/auditoria/_outputs/manifest-completo/" }
      }
    },

    "identidad": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "description_oficial", "author", "main_declarado", "main_real", "tags"],
      "properties": {
        "name":                { "type": "string", "minLength": 1 },
        "version":             { "type": ["string", "null"] },
        "description_oficial": { "type": ["string", "null"] },
        "author":              { "type": ["string", "null"] },
        "main_declarado":      { "type": ["string", "null"] },
        "main_real":           { "type": "string" },
        "tags":                { "type": "array", "items": { "type": "string" } }
      }
    },

    "estado_en_sistema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["habilitado_en_config", "en_disabled_de_config", "estado_modulo", "tier_carga_inferido", "tier_declarado", "dev_only_declarado", "enabled_declarado"],
      "properties": {
        "habilitado_en_config":   { "type": "boolean" },
        "en_disabled_de_config":  { "type": "boolean" },
        "estado_modulo":          { "enum": ["vivo", "dormido_por_diseno", "candidato_a_retirada", "fantasma"] },
        "tier_carga_inferido":    { "type": ["string", "null"] },
        "tier_declarado":         { "type": ["string", "null"] },
        "dev_only_declarado":     { "type": "boolean" },
        "enabled_declarado":      { "type": ["boolean", "null"] }
      }
    },

    "eventos": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publica", "subscribes", "consistencia_con_manifest"],
      "properties": {
        "publica": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nombre", "ubicacion", "metodo_contenedor", "es_handler_de", "bloque_logico", "payload", "canal", "es_await", "es_return", "snippet", "declarado_en_manifest"],
            "properties": {
              "nombre": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tipo", "valor", "variables_referenciadas"],
                "properties": {
                  "tipo":                    { "enum": ["literal", "dynamic_template", "variable", "otro"] },
                  "valor":                   { "type": "string", "minLength": 1 },
                  "variables_referenciadas": { "type": "array", "items": { "type": "string" } }
                }
              },
              "ubicacion":         { "type": "string", "pattern": "^modules/.*:[0-9]+$" },
              "metodo_contenedor": { "type": ["string", "null"] },
              "es_handler_de":     { "type": ["string", "null"] },
              "bloque_logico":     { "type": ["string", "null"] },
              "payload": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tipo", "campos_visibles", "tiene_request_id", "tiene_correlation_id", "tiene_project_id", "campos_con_template_literal"],
                "properties": {
                  "tipo":                          { "enum": ["object_literal", "spread", "variable", "sin_payload", "mixto"] },
                  "campos_visibles":               { "type": "array", "items": { "type": "string" } },
                  "tiene_request_id":              { "type": "boolean" },
                  "tiene_correlation_id":          { "type": "boolean" },
                  "tiene_project_id":              { "type": "boolean" },
                  "campos_con_template_literal":   { "type": "array", "items": { "type": "string" } }
                }
              },
              "canal": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tipo", "expresion_usada"],
                "properties": {
                  "tipo":            { "enum": ["eventBus", "mqtt_directo", "otro"] },
                  "expresion_usada": { "type": "string", "minLength": 1 }
                }
              },
              "es_await":              { "type": "boolean" },
              "es_return":             { "type": "boolean" },
              "snippet":               { "type": "string", "minLength": 1 },
              "declarado_en_manifest": { "type": "boolean" }
            }
          }
        },
        "subscribes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nombre", "tipo_nombre", "handler", "handler_ubicacion", "comportamiento_si_falla", "evidencia_comportamiento", "auto_wired", "subscripcion_dinamica", "declarado_en_manifest"],
            "properties": {
              "nombre":                 { "type": "string", "minLength": 1 },
              "tipo_nombre":            { "enum": ["literal", "dynamic", "wildcard"] },
              "handler":                { "type": ["string", "null"] },
              "handler_ubicacion":      { "type": ["string", "null"] },
              "comportamiento_si_falla":{ "enum": ["log_y_sigue", "throw", "retry", "rejecta_promise_pending", "no_observable", "otro"] },
              "evidencia_comportamiento":{ "type": ["string", "null"] },
              "auto_wired":             { "type": "boolean" },
              "subscripcion_dinamica":  { "type": "boolean" },
              "declarado_en_manifest":  { "type": "boolean" }
            }
          }
        },
        "consistencia_con_manifest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["publica_declarados_en_manifest", "publica_literales_en_codigo", "publica_patrones_dinamicos", "publica_declarados_no_emitidos", "publica_emitidos_no_declarados", "subscribes_declarados_en_manifest", "subscribes_realmente_registrados", "subscribes_dinamicos"],
          "properties": {
            "publica_declarados_en_manifest":   { "type": "array", "items": { "type": "string" } },
            "publica_literales_en_codigo":      { "type": "array", "items": { "type": "string" } },
            "publica_patrones_dinamicos":       { "type": "array", "items": { "type": "string" } },
            "publica_declarados_no_emitidos":   { "type": "array", "items": { "type": "string" } },
            "publica_emitidos_no_declarados":   { "type": "array", "items": { "type": "string" } },
            "subscribes_declarados_en_manifest":{ "type": "array", "items": { "type": "string" } },
            "subscribes_realmente_registrados": { "type": "array", "items": { "type": "string" } },
            "subscribes_dinamicos":             { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description_para_llm", "parameters_required", "parameters_property_names", "parameters_size_chars", "handler_metodo", "handler_ubicacion", "retorno", "errores_conocidos"],
        "properties": {
          "name":                       { "type": "string", "minLength": 1 },
          "description_para_llm":       { "type": ["string", "null"] },
          "parameters_required":        { "type": "array", "items": { "type": "string" } },
          "parameters_property_names":  { "type": "array", "items": { "type": "string" } },
          "parameters_size_chars":      { "type": "integer", "minimum": 0 },
          "handler_metodo":             { "type": ["string", "null"] },
          "handler_ubicacion":          { "type": ["string", "null"] },
          "retorno": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tipo", "shape_inferido", "es_markdown_formateado", "ejemplos_observados", "publica_eventos_de_dominio"],
            "properties": {
              "tipo":                       { "enum": ["object", "string", "array", "mixto", "desconocido"] },
              "shape_inferido":             { "type": "object" },
              "es_markdown_formateado":     { "type": "boolean" },
              "ejemplos_observados":        { "type": "array", "items": { "type": "string" } },
              "publica_eventos_de_dominio": { "type": "array", "items": { "type": "string" } }
            }
          },
          "errores_conocidos": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["condicion", "respuesta_shape", "ubicacion"],
              "properties": {
                "condicion":       { "type": "string" },
                "respuesta_shape": { "type": ["object", "string", "null"] },
                "ubicacion":       { "type": "string" }
              }
            }
          }
        }
      }
    },

    "ui_handlers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["domain", "action", "handler_metodo", "handler_ubicacion", "input_validado", "codigos_error", "output_shape", "campo_origen_manifest"],
        "properties": {
          "domain":              { "type": "string" },
          "action":              { "type": "string" },
          "handler_metodo":      { "type": ["string", "null"] },
          "handler_ubicacion":   { "type": ["string", "null"] },
          "input_validado":      { "type": "array", "items": { "type": "string" } },
          "codigos_error":       { "type": "array", "items": { "type": "string" } },
          "output_shape": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status_success", "data_keys", "status_error"],
            "properties": {
              "status_success": { "type": ["integer", "null"] },
              "data_keys":      { "type": "array", "items": { "type": "string" } },
              "status_error":   { "type": ["integer", "null"] }
            }
          },
          "campo_origen_manifest": { "enum": ["ui_handlers", "handlers", null] }
        }
      }
    },

    "apis_http": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method", "path", "handler_metodo", "handler_ubicacion", "auth_observada", "request_body_keys", "response_keys"],
        "properties": {
          "method":             { "type": "string" },
          "path":               { "type": "string" },
          "handler_metodo":     { "type": ["string", "null"] },
          "handler_ubicacion":  { "type": ["string", "null"] },
          "auth_observada":     { "enum": ["ninguna", "mTLS", "session", "basic", "otra", "no_observable"] },
          "request_body_keys":  { "type": "array", "items": { "type": "string" } },
          "response_keys":      { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "estado": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memoria", "persistencia"],
      "properties": {
        "memoria": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["campo", "tipo", "ubicacion_init", "se_invalida_con", "leak_potencial"],
            "properties": {
              "campo":            { "type": "string" },
              "tipo":             { "enum": ["Map", "Set", "Object", "Array", "WeakMap", "WeakSet", "primitivo", "otro"] },
              "ubicacion_init":   { "type": "string" },
              "se_invalida_con":  { "type": "string" },
              "leak_potencial":   { "type": "boolean" }
            }
          }
        },
        "persistencia": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sqlite_tablas", "archivos", "notas_concurrencia"],
          "properties": {
            "sqlite_tablas": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["nombre", "scope_db", "campos", "indices", "creada_por", "ubicacion_create", "migraciones_suaves", "ttl_o_housekeeping"],
                "properties": {
                  "nombre":               { "type": "string" },
                  "scope_db":             { "enum": ["system", "project", "_prompts", "otro"] },
                  "campos":               { "type": "array", "items": { "type": "string" } },
                  "indices":              { "type": "array", "items": { "type": "string" } },
                  "creada_por":           { "type": ["string", "null"] },
                  "ubicacion_create":     { "type": "string" },
                  "migraciones_suaves":   { "type": ["string", "null"] },
                  "ttl_o_housekeeping":   { "type": ["string", "null"] }
                }
              }
            },
            "archivos": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path_pattern", "formato", "operaciones", "via_evento", "atomicidad"],
                "properties": {
                  "path_pattern":  { "type": "string" },
                  "formato":       { "enum": ["json", "jsonl", "raw", "binario", "html", "csv", "otro"] },
                  "operaciones":   { "type": "array", "items": { "enum": ["read", "write", "append", "delete"] } },
                  "via_evento":    { "type": ["string", "null"] },
                  "atomicidad":    { "enum": ["transaccional", "read-then-write", "append-only", "desconocido"] }
                }
              }
            },
            "notas_concurrencia": { "type": ["string", "null"] }
          }
        }
      }
    },

    "configuracion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["env_vars", "module_json_config_keys", "paths_proyecto_referenciados", "valores_hardcoded_observables"],
      "properties": {
        "env_vars": { "type": "array", "items": { "type": "string" } },
        "module_json_config_keys": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "tipo", "default_si_primitivo"],
            "properties": {
              "key":                  { "type": "string" },
              "tipo":                 { "type": "string" },
              "default_si_primitivo": {}
            }
          }
        },
        "paths_proyecto_referenciados": { "type": "array", "items": { "type": "string" } },
        "valores_hardcoded_observables": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["valor", "ubicacion", "naturaleza"],
            "properties": {
              "valor":      { "type": "string" },
              "ubicacion":  { "type": "string" },
              "naturaleza": { "enum": ["timeout", "path", "url", "modelo_llm", "limit", "tamano", "otro"] }
            }
          }
        }
      }
    },

    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["onLoad", "onUnload", "auto_wired_subscribes", "subscribes_dinamicos_en_lifecycle"],
      "properties": {
        "onLoad": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ubicacion", "acciones", "guarda_referencias_externas", "puede_fallar_silenciosamente"],
          "properties": {
            "ubicacion":                     { "type": ["string", "null"] },
            "acciones":                      { "type": "array", "items": { "type": "string" } },
            "guarda_referencias_externas":   { "type": "array", "items": { "type": "string" } },
            "puede_fallar_silenciosamente":  { "type": "boolean" }
          }
        },
        "onUnload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ubicacion", "acciones", "estado_no_limpiado"],
          "properties": {
            "ubicacion":          { "type": ["string", "null"] },
            "acciones":           { "type": "array", "items": { "type": "string" } },
            "estado_no_limpiado": { "type": "array", "items": { "type": "string" } }
          }
        },
        "auto_wired_subscribes":            { "type": "boolean" },
        "subscribes_dinamicos_en_lifecycle":{ "type": "array", "items": { "type": "string" } }
      }
    },

    "dependencias_implicitas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["modulo_dependido", "via_evento", "obligatorio_en", "ubicacion_uso", "es_cross_vertical"],
        "properties": {
          "modulo_dependido":    { "type": "string" },
          "via_evento":          { "type": "string" },
          "obligatorio_en":      { "enum": ["onLoad", "runtime", "ambos"] },
          "ubicacion_uso":       { "type": "string" },
          "es_cross_vertical":   { "type": "boolean" }
        }
      }
    },

    "modos_de_fallo": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dependencia", "que_pasa_si_cae", "evidencia"],
        "properties": {
          "dependencia":     { "type": "string" },
          "que_pasa_si_cae": { "type": "string" },
          "evidencia":       { "type": "string" }
        }
      }
    },

    "observabilidad": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logger", "metricas_emitidas", "metricas_drift_vs_manifest", "tracing"],
      "properties": {
        "logger": {
          "type": "object",
          "additionalProperties": false,
          "required": ["estilo", "firma_dominante", "campos_estructurados_observados", "ejemplos"],
          "properties": {
            "estilo":                          { "enum": ["structured_json", "string_concat", "mixto", "otro", "no_observable"] },
            "firma_dominante":                 { "type": ["string", "null"] },
            "campos_estructurados_observados": { "type": "array", "items": { "type": "string" } },
            "ejemplos": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["snippet", "ubicacion"],
                "properties": {
                  "snippet":   { "type": "string" },
                  "ubicacion": { "type": "string" }
                }
              }
            }
          }
        },
        "metricas_emitidas": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tipo", "nombre", "ubicacion"],
            "properties": {
              "tipo":      { "enum": ["counter", "gauge", "timing", "histogram"] },
              "nombre":    { "type": "string" },
              "ubicacion": { "type": "string" }
            }
          }
        },
        "metricas_drift_vs_manifest": { "type": "array", "items": { "type": "string" } },
        "tracing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["propaga_correlation_id", "evidencia"],
          "properties": {
            "propaga_correlation_id": { "type": "boolean" },
            "evidencia":              { "type": "string" }
          }
        }
      }
    },

    "archivos_hermanos": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agents", "schemas", "prompts", "context_json_existe", "prompt_json_existe", "readme_existe", "tests_propios_existen"],
      "properties": {
        "agents":                { "type": "array", "items": { "type": "string" } },
        "schemas":               { "type": "array", "items": { "type": "string" } },
        "prompts":               { "type": "array", "items": { "type": "string" } },
        "context_json_existe":   { "type": "boolean" },
        "prompt_json_existe":    { "type": "boolean" },
        "readme_existe":         { "type": "boolean" },
        "tests_propios_existen": { "type": "boolean" }
      }
    },

    "version_archivada": {
      "type": "object",
      "additionalProperties": false,
      "required": ["existe", "ubicacion", "diferencia_aproximada"],
      "properties": {
        "existe":                { "type": "boolean" },
        "ubicacion":             { "type": ["string", "null"] },
        "diferencia_aproximada": { "type": ["string", "null"] }
      }
    },

    "codigo_intencion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["todos", "comentarios_porque", "workarounds_detectados"],
      "properties": {
        "todos": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ubicacion", "tipo", "texto"],
            "properties": {
              "ubicacion": { "type": "string" },
              "tipo":      { "enum": ["TODO", "FIXME", "XXX", "HACK"] },
              "texto":     { "type": "string" }
            }
          }
        },
        "comentarios_porque": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ubicacion", "comentario_literal", "contexto"],
            "properties": {
              "ubicacion":          { "type": "string" },
              "comentario_literal": { "type": "string" },
              "contexto":           { "type": "string" }
            }
          }
        },
        "workarounds_detectados": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ubicacion", "descripcion"],
            "properties": {
              "ubicacion":   { "type": "string" },
              "descripcion": { "type": "string" }
            }
          }
        }
      }
    },

    "metricas_fisicas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineas_index_js", "lineas_lib_total", "lineas_services_total", "archivos_codigo_count", "ultimo_commit"],
      "properties": {
        "lineas_index_js":       { "type": "integer", "minimum": 0 },
        "lineas_lib_total":      { "type": "integer", "minimum": 0 },
        "lineas_services_total": { "type": "integer", "minimum": 0 },
        "archivos_codigo_count": { "type": "integer", "minimum": 0 },
        "ultimo_commit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sha", "fecha", "subject"],
          "properties": {
            "sha":     { "type": ["string", "null"] },
            "fecha":   { "type": ["string", "null"] },
            "subject": { "type": ["string", "null"] }
          }
        }
      }
    },

    "outliers_capturados": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campos_no_canonicos_en_manifest", "patrones_no_canonicos_en_codigo"],
      "properties": {
        "campos_no_canonicos_en_manifest": { "type": "array", "items": { "type": "string" } },
        "patrones_no_canonicos_en_codigo": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["patron", "ejemplo", "rareza"],
            "properties": {
              "patron":  { "type": "string" },
              "ejemplo": { "type": "string" },
