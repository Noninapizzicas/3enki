{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/database-manager/events.json",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": { "type": "string", "format": "uuid" },
        "event_type": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "producer": { "type": "string", "const": "database-manager" },
        "schema_version": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "db_created": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "db.created" },
            "payload": {
              "type": "object",
              "required": ["project_id", "created_at"],
              "properties": {
                "project_id": { "type": "string" },
                "created_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "db_deleted": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "db.deleted" },
            "payload": {
              "type": "object",
              "required": ["project_id", "deleted_at"],
              "properties": {
                "project_id": { "type": "string" },
                "deleted_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "db_query_executed": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "db.query.executed" },
            "payload": {
              "type": "object",
              "required": ["project_id", "result_count", "read_only", "duration"],
              "properties": {
                "project_id": { "type": "string" },
                "result_count": { "type": "integer", "minimum": 0 },
                "read_only": { "type": "boolean" },
                "duration": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "db_schema_initialized": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "db.schema.initialized" },
            "payload": {
              "type": "object",
              "required": ["project_id", "initialized_at"],
              "properties": {
                "project_id": { "type": "string" },
                "initialized_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "db_query_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "db.query.response" },
            "payload": {
              "type": "object",
              "required": ["success", "project_id", "request_id"],
              "properties": {
                "success": { "type": "boolean" },
                "project_id": { "type": "string" },
                "request_id": { "type": "string" },
                "data": { "type": "array" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "db_schema_init_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "db.schema.init.response" },
            "payload": {
              "type": "object",
              "required": ["success", "project_id", "request_id"],
              "properties": {
                "success": { "type": "boolean" },
                "project_id": { "type": "string" },
                "request_id": { "type": "string" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
