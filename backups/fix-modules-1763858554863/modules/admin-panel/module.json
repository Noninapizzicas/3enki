{
  "name": "admin-panel",
  "version": "1.0.0",
  "description": "Web-based admin panel for managing Event Core system",
  "dependencies": ["ui-renderer"],
  "apis": {
    "ui": {
      "method": "GET",
      "path": "/"
    },
    "dashboard_data": {
      "method": "GET",
      "path": "/api/dashboard"
    },
    "list_modules": {
      "method": "GET",
      "path": "/api/modules"
    },
    "list_plugins": {
      "method": "GET",
      "path": "/api/plugins"
    },
    "toggle_plugin": {
      "method": "POST",
      "path": "/api/plugins/:name/toggle"
    },
    "list_agents": {
      "method": "GET",
      "path": "/api/agents"
    },
    "create_agent": {
      "method": "POST",
      "path": "/api/agents"
    },
    "delete_agent": {
      "method": "DELETE",
      "path": "/api/agents/:id"
    },
    "list_prompts": {
      "method": "GET",
      "path": "/api/prompts"
    },
    "get_prompt": {
      "method": "GET",
      "path": "/api/prompts/:name"
    },
    "create_prompt": {
      "method": "POST",
      "path": "/api/prompts"
    },
    "update_prompt": {
      "method": "PUT",
      "path": "/api/prompts/:name"
    }
  },
  "events": {
    "publishes": ["admin.action"],
    "subscribes": ["plugin.loaded", "ui.component.loaded"]
  }
}
