{
  "name": "{{name}}",
  "category": "{{category}}",
  "description": "{{description}}",
  "version": "2.0.0",
  "author": "{{author}}",
  "generated_at": "{{currentDate}}",

  "variants": {
    {{#if hasVariants}}
    "primary": {
      "description": "Primary variant",
      "className": "{{name}}--primary"
    },
    "secondary": {
      "description": "Secondary variant",
      "className": "{{name}}--secondary"
    },
    "success": {
      "description": "Success variant",
      "className": "{{name}}--success"
    },
    "warning": {
      "description": "Warning variant",
      "className": "{{name}}--warning"
    },
    "danger": {
      "description": "Danger variant",
      "className": "{{name}}--danger"
    }
    {{else}}
    "default": {
      "description": "Default variant",
      "className": "{{name}}"
    }
    {{/if}}
  },

  "sizes": {
    "sm": {
      "description": "Small size",
      "className": "{{name}}--sm"
    },
    "md": {
      "description": "Medium size (default)",
      "className": "{{name}}--md"
    },
    "lg": {
      "description": "Large size",
      "className": "{{name}}--lg"
    }
  },

  "props": {
    "variant": {
      "type": "enum",
      "values": [{{#if hasVariants}}"primary", "secondary", "success", "warning", "danger"{{else}}"default"{{/if}}],
      "default": {{#if hasVariants}}"primary"{{else}}"default"{{/if}},
      "required": false,
      "description": "Visual variant of the component"
    },
    "size": {
      "type": "enum",
      "values": ["sm", "md", "lg"],
      "default": "md",
      "required": false,
      "description": "Size of the component"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Whether the component is disabled"
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional CSS classes"
    },
    {{#if (eq category 'form')}}
    "name": {
      "type": "string",
      "required": true,
      "description": "Form field name"
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Field label"
    },
    "value": {
      "type": "any",
      "required": false,
      "description": "Field value"
    },
    "required": {
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Whether the field is required"
    },
    "helpText": {
      "type": "string",
      "required": false,
      "description": "Help text for the field"
    },
    "errorText": {
      "type": "string",
      "required": false,
      "description": "Error message"
    },
    {{/if}}
    {{#if (eq category 'core')}}
    "label": {
      "type": "string",
      "required": false,
      "description": "Component label"
    },
    "icon": {
      "type": "string",
      "required": false,
      "description": "Icon to display"
    },
    "loading": {
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Whether the component is in loading state"
    },
    {{/if}}
    "ariaLabel": {
      "type": "string",
      "required": false,
      "description": "ARIA label for accessibility"
    }
  },

  "features": [
    {{#if (eq category 'core')}}
    "Multiple variants (primary, secondary, success, warning, danger)",
    "Three sizes (sm, md, lg)",
    "Disabled state support",
    "Loading state support",
    "Icon support",
    "Keyboard accessible"
    {{else if (eq category 'form')}}
    "Built-in validation",
    "Error states",
    "Help text support",
    "Required field indicator",
    "Accessible labels",
    "Disabled state"
    {{else if (eq category 'data')}}
    "Responsive design",
    "Data binding support",
    "Loading states",
    "Empty states",
    "Sorting and filtering",
    "Pagination support"
    {{else if (eq category 'navigation')}}
    "Responsive behavior",
    "Active state tracking",
    "Keyboard navigation",
    "ARIA attributes",
    "Mobile-friendly",
    "Icon support"
    {{else if (eq category 'feedback')}}
    "Auto-dismiss option",
    "Manual close",
    "Icon support",
    "Multiple variants",
    "Animation support",
    "Accessible announcements"
    {{else}}
    "Responsive design",
    "Multiple variants",
    "Accessible",
    "Customizable"
    {{/if}}
  ],

  "accessibility": {
    "role": "{{#if (eq category 'core')}}button{{else if (eq category 'form')}}{{name}}{{else if (eq category 'navigation')}}navigation{{else if (eq category 'feedback')}}status{{else}}region{{/if}}",
    "ariaLabel": true,
    "keyboard": true,
    "focusable": true,
    "screenReader": true
  },

  "example": {
    "component": "{{name}}",
    {{#if hasVariants}}
    "variant": "primary",
    {{else}}
    "variant": "default",
    {{/if}}
    "size": "md",
    "props": {
      {{#if (eq category 'core')}}
      "label": "Click me",
      "icon": "🚀",
      "disabled": false
      {{else if (eq category 'form')}}
      "name": "{{name}}_field",
      "label": "Field Label",
      "required": true,
      "helpText": "Enter a value"
      {{else if (eq category 'data')}}
      "data": "@data.items",
      "columns": "auto"
      {{else if (eq category 'navigation')}}
      "items": [
        {"label": "Home", "url": "/", "active": true}
      ]
      {{else if (eq category 'feedback')}}
      "message": "Operation completed successfully",
      "closable": true
      {{else}}
      "content": "Component content"
      {{/if}}
    }
  }
}
