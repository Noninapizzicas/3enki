{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/credential.json",

  "definitions": {
    "provider": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[A-Z_]+$",
      "description": "Provider name in uppercase (OPENAI, DEEPSEEK, ANTHROPIC)"
    },

    "level": {
      "type": "string",
      "enum": ["GLOBAL", "PROJECT", "CLIENT", "CUSTOM"],
      "description": "Credential priority level"
    },

    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "Level-specific identifier"
    },

    "credential_key": {
      "type": "string",
      "pattern": "^[A-Z_]+_API_KEY_(GLOBAL|PROJECT_[a-zA-Z0-9_-]+|CLIENT_[a-zA-Z0-9_-]+|CUSTOM_[a-zA-Z0-9_-]+)$",
      "description": "Full credential key in .env format"
    },

    "save_request": {
      "type": "object",
      "required": ["provider", "level", "api_key"],
      "properties": {
        "provider": { "$ref": "#/definitions/provider" },
        "level": { "$ref": "#/definitions/level" },
        "identifier": { "$ref": "#/definitions/identifier" },
        "api_key": {
          "type": "string",
          "minLength": 1,
          "description": "The API key value"
        }
      },
      "additionalProperties": false
    },

    "save_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "credential": {
          "type": "object",
          "properties": {
            "key": { "$ref": "#/definitions/credential_key" },
            "provider": { "$ref": "#/definitions/provider" },
            "level": { "$ref": "#/definitions/level" },
            "identifier": { "$ref": "#/definitions/identifier" },
            "created": { "type": "boolean" },
            "updated": { "type": "boolean" }
          }
        },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "resolve_response": {
      "type": "object",
      "required": ["success", "found"],
      "properties": {
        "success": { "type": "boolean" },
        "found": { "type": "boolean" },
        "credential": {
          "type": "object",
          "properties": {
            "provider": { "$ref": "#/definitions/provider" },
            "level": { "$ref": "#/definitions/level" },
            "identifier": { "$ref": "#/definitions/identifier" },
            "api_key": { "type": "string" },
            "key": { "$ref": "#/definitions/credential_key" }
          }
        },
        "resolved_from": { "$ref": "#/definitions/level" },
        "attempts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "error": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },

    "list_response": {
      "type": "object",
      "required": ["success", "credentials", "total"],
      "properties": {
        "success": { "type": "boolean" },
        "credentials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "$ref": "#/definitions/credential_key" },
              "provider": { "$ref": "#/definitions/provider" },
              "level": { "$ref": "#/definitions/level" },
              "identifier": { "$ref": "#/definitions/identifier" },
              "api_key_preview": { "type": "string" }
            }
          }
        },
        "total": { "type": "integer", "minimum": 0 },
        "filters": { "type": "object" }
      },
      "additionalProperties": false
    },

    "update_request": {
      "type": "object",
      "required": ["api_key"],
      "properties": {
        "api_key": {
          "type": "string",
          "minLength": 1,
          "description": "New API key value"
        }
      },
      "additionalProperties": false
    },

    "update_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "key": { "$ref": "#/definitions/credential_key" },
        "updated": { "type": "boolean" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },

    "delete_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "key": { "$ref": "#/definitions/credential_key" },
        "deleted": { "type": "boolean" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
