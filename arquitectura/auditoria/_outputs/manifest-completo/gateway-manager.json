{
  "_meta": {
    "modulo": "gateway-manager",
    "ubicacion": "modules/gateway-manager",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "gateway-manager",
    "version": "1.0.0",
    "description_oficial": "Ciclo de vida de gateways software que traducen MQTT a protocolos nativos (TCP, BLE, USB, CMD)",
    "author": "Enki",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": null,
    "tier_declarado": "tier_2_platform",
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "gateway.started",      "description": "Gateway arrancado y operativo" },
      { "event": "gateway.stopped",      "description": "Gateway detenido" },
      { "event": "gateway.device_found", "description": "Dispositivo descubierto por un gateway" },
      { "event": "gateway.device_lost",  "description": "Dispositivo perdido por un gateway" },
      { "event": "gateway.error",        "description": "Error en un gateway" }
    ],
    "subscribes": [],
    "provides_eventos": [
      "gateway.started",
      "gateway.stopped",
      "gateway.device_found",
      "gateway.device_lost",
      "gateway.error"
    ]
  },

  "tools": [],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "gateways", "action": "list",     "handler": "handleList" },
      { "domain": "gateways", "action": "status",   "handler": "handleStatus" },
      { "domain": "gateways", "action": "restart",  "handler": "handleRestart" },
      { "domain": "gateways", "action": "discover", "handler": "handleDiscover" }
    ]
  },

  "apis_http": [],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      {
        "key": "gateways.tcp",
        "tipo": "object",
        "valor_default": { "enabled": false, "autodiscovery": true, "manual_devices": [] }
      },
      {
        "key": "gateways.ble",
        "tipo": "object",
        "valor_default": { "enabled": false, "manual_devices": [] }
      },
      {
        "key": "gateways.usb",
        "tipo": "object",
        "valor_default": { "enabled": false, "manual_devices": [] }
      },
      {
        "key": "gateways.cmd",
        "tipo": "object",
        "valor_default": { "enabled": false, "manual_devices": [] }
      }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "gateway.started.total",
        "gateway.devices_found.total",
        "gateway.commands_processed.total",
        "gateway.errors.total"
      ],
      "gauges": [],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": [],
    "prompts": [],
    "context": false,
    "prompt_module": false,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": false,
    "ui_handlers_field_name": "ui_handlers",
    "module_json_bytes": 1915,
    "module_json_lineas": 70,
    "tiene_main_no_estandar": false,
    "warnings": [
      "provides.events duplica los mismos 5 eventos de events.publishes — redundancia informativa sin impacto funcional",
      "tier='tier_2_platform' declarado en module.json pero no aparece en ningún array de system.json module_load_order.tiers — tier_carga_inferido=null",
      "Sin tools[], sin apis_http[], sin subscribes — módulo solo emite eventos, no escucha nada del bus"
    ]
  }
}
