{
  "_meta": {
    "modulo": "pizzepos/carta-impresion",
    "ubicacion": "modules/pizzepos/carta-impresion",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "carta-impresion",
    "version": "2.0.0",
    "description_oficial": "Genera versiones imprimibles de cartas en HTML print-ready. Los agentes deciden layout y generan con criterio adaptado a cada carta y marca.",
    "author": "Pizzepos Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_6_ui",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "carta.impresion.lista", "description": "HTML imprimible generado y guardado" }
    ],
    "subscribes": [
      { "event": "project.activated",   "handler": "onProjectActivated",   "extras": {} },
      { "event": "project.deactivated", "handler": "onProjectDeactivated", "extras": {} },
      { "event": "carta.actualizada",   "handler": "onCartaActualizada",   "extras": {} }
    ],
    "provides_eventos": []
  },

  "tools": [
    {
      "name": "impresion.get",
      "description": "Obtiene la versión imprimible HTML de una carta si existe. Si no, devuelve 404.",
      "parameters_required": ["project_id", "carta_id"],
      "parameters_property_names": ["project_id", "carta_id"],
      "parameters_size_chars": 129,
      "parameters_full_path_hint": "modules/pizzepos/carta-impresion/module.json → tools[0].parameters"
    },
    {
      "name": "impresion.generar",
      "description": "Inicia la generación de la versión imprimible de una carta. Dispara al architect y builder.",
      "parameters_required": ["project_id", "carta_id"],
      "parameters_property_names": ["project_id", "carta_id"],
      "parameters_size_chars": 129,
      "parameters_full_path_hint": "modules/pizzepos/carta-impresion/module.json → tools[1].parameters"
    },
    {
      "name": "impresion.save_html",
      "description": "Guarda el HTML generado por el builder. Usado por el agente impresion-builder al terminar.",
      "parameters_required": ["project_id", "carta_id", "html"],
      "parameters_property_names": ["project_id", "carta_id", "html", "layout", "brand_applied"],
      "parameters_size_chars": 360,
      "parameters_full_path_hint": "modules/pizzepos/carta-impresion/module.json → tools[2].parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "carta-impresion", "action": "get",     "handler": "handleGet" },
      { "domain": "carta-impresion", "action": "generar",  "handler": "handleGenerar" },
      { "domain": "carta-impresion", "action": "health",  "handler": "handleHealth" }
    ]
  },

