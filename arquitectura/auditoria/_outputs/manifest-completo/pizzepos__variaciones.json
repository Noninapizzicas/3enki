{
  "_meta": {
    "modulo": "pizzepos/variaciones",
    "ubicacion": "modules/pizzepos/variaciones",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "variaciones",
    "version": "3.0.0",
    "description_oficial": "Gestión de variaciones de productos (quitar/añadir ingredientes)",
    "author": "Pizzepos Team",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_5_domain_pizzepos",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      {
        "event": "variacion.validada",
        "description": "Variación validada correctamente"
      },
      {
        "event": "variacion.rechazada",
        "description": "Variación rechazada (no permitida)"
      }
    ],
    "subscribes": [
      {
        "event": "producto.creado",
        "handler": "onProductoCreado",
        "extras": { "description": "Producto creado - registrar variaciones permitidas" }
      },
      {
        "event": "comandero.item_agregado",
        "handler": "onComanderoItemAgregado",
        "extras": { "description": "Item agregado al buffer del comandero - validar variaciones" }
      }
    ],
    "provides_eventos": [
      "variacion.validada",
      "variacion.rechazada"
    ]
  },

  "tools": [],

  "ui_handlers": {
    "campo_origen": null,
    "items": []
  },

  "apis_http": [
    {
      "method": "GET",
      "path": "/productos/:producto_id/variaciones",
      "handler": "handleGetVariacionesProducto",
      "description": "Obtener variaciones permitidas para un producto",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/validar",
      "handler": "handleValidarVariacion",
      "description": "Validar si una variación es permitida",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/calcular-precio",
      "handler": "handleCalcularPrecio",
      "description": "Calcular precio final con variaciones",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Métricas del módulo",
      "request_schema_ref": null,
      "response_schema_ref": null
    }
  ],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": []
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "variacion.validada.total",
        "variacion.rechazada.total"
      ],
      "gauges": [
        "variacion.productos_configurados.count"
      ],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
