  "patrones_eventos": {
    "request_response": {
      "patron": "{servicio}.{funcion}.request → {servicio}.{funcion}.response",
      "ejemplos": [
        "tesseract.extract.request → tesseract.extract.response",
        "gmail.send.request → gmail.send.response",
        "ai.chat.request → ai.chat.response"
      ]
    },
    "ui": {
      "patron": "ui/request/{domain}/{action} → ui/response/{request_id}",
      "ejemplos": [
        "ui/request/project/list → ui/response/req_123",
        "ui/request/scheduler/create → ui/response/req_456"
      ]
    },
    "lifecycle": {
      "patron": "{entidad}.{accion}",
      "ejemplos": [
        "project.created", "project.updated", "project.deleted",
        "flow.started", "flow.completed", "flow.failed",
        "scheduler.job.triggered", "scheduler.job.completed"
      ]
    },
    "core_interno": {
      "patron": "core/{core-id}/events/{module}/{evento}",
      "ejemplos": [
        "core/core-a/events/project/created",
        "core/core-a/events/scheduler/job-triggered"
      ]
    }
  },

  "puertos": {
    "http": 3000,
    "mqtt": 1883,
    "websocket": 9001
  },

  "configuracion_global": {
    "logging": {
      "formato": "JSON estructurado",
      "campos_requeridos": ["module", "action", "outcome", "correlationId"],
      "niveles": ["debug", "info", "warn", "error"]
    },
    "metricas": {
      "tipos": ["counters", "gauges", "histograms", "timings"],
      "intervalo_flush_s": 60
    },
    "persistencia": {
      "tipo": "SQLite (sql.js) o archivos JSON",
      "ubicacion_datos": "./data/"
    }
  },

