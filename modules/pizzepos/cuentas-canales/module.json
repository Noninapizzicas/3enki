{
  "name": "cuentas-canales",
  "version": "5.0.0",
  "description": "Sistema unificado de canales de venta pizzepos con patron Strategy: mesa, telefono, llevar, glovo, whatsapp, llevadoo. Cada strategy registra ui_handlers especificos del canal y se subscribe a sus eventos. El modulo base orquesta cobro.procesado → detectarCanal → strategy.onCobroProcesado, gestiona reseteo diario de contadores y emite cuenta.{creada,cerrada} canonicos.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "tracing": {
    "propaga_correlation_id": true
  },
  "replaces": [
    "cuentas-mesa",
    "cuentas-telefono",
    "cuentas-llevar"
  ],
  "provides": {
    "events": [
      "mesa.abierta",
      "mesa.camarero_asignado",
      "mesa.cerrada",
      "mesa.renombrada",
      "telefono.llamada_detectada",
      "telefono.contacto_identificado",
      "telefono.pedido_creado",
      "telefono.listo_para_recoger",
      "llevar.ticket_creado",
      "llevar.ticket_listo",
      "llevar.ticket_entregado",
      "glovo.pedido_recibido",
      "glovo.pedido_aceptado",
      "glovo.pedido_rechazado",
      "glovo.pedido_listo",
      "glovo.pedido_recogido",
      "whatsapp.mensaje_recibido",
      "whatsapp.pedido_creado",
      "whatsapp.pedido_confirmado",
      "whatsapp.pedido_listo",
      "llevadoo.pedido_recibido",
      "llevadoo.pedido_aceptado",
      "llevadoo.para_recoger",
      "llevadoo.pedido_listo",
      "llevadoo.pedido_entregado",
      "cuenta.creada",
      "cuenta.cerrada"
    ],
    "queries": [
      "mesas.activas",
      "canales.list",
      "canales.health",
      "canales.metrics"
    ]
  },
  "events": {
    "publishes": [
      {
        "event": "cuenta.creada",
        "description": "Cuenta creada en cualquier canal (mesa/telefono/llevar/glovo/whatsapp)",
        "schema": {
          "type": "object",
          "required": [
            "cuenta_id",
            "tipo",
            "origen"
          ]
        }
      },
      {
        "event": "cuenta.cerrada",
        "description": "Cuenta cerrada en cualquier canal",
        "schema": {
          "type": "object",
          "required": [
            "cuenta_id",
            "tipo",
            "total"
          ]
        }
      },
      {
        "event": "mesa.abierta",
        "description": "Mesa abierta para servicio",
        "schema": {
          "$ref": "./schemas/mesa-events.json#/definitions/mesa_abierta"
        }
      },
      {
        "event": "mesa.cerrada",
        "description": "Mesa cerrada y liberada",
        "schema": {
          "$ref": "./schemas/mesa-events.json#/definitions/mesa_cerrada"
        }
      },
      {
        "event": "telefono.pedido_creado",
        "description": "Pedido telefónico creado",
        "schema": {
          "$ref": "./schemas/telefono-events.json#/definitions/telefono_pedido_creado"
        }
      },
      {
        "event": "llevar.ticket_creado",
        "description": "Ticket para llevar creado",
        "schema": {
          "$ref": "./schemas/llevar-events.json#/definitions/llevar_ticket_creado"
        }
      },
      {
        "event": "glovo.pedido_recibido",
        "description": "Pedido Glovo recibido desde la plataforma",
        "schema": {
          "$ref": "./schemas/glovo-events.json#/definitions/glovo_pedido_recibido"
        }
      },
      {
        "event": "glovo.pedido_aceptado",
        "description": "Pedido Glovo aceptado por el restaurante",
        "schema": {
          "$ref": "./schemas/glovo-events.json#/definitions/glovo_pedido_aceptado"
        }
      },
      {
        "event": "glovo.pedido_listo",
        "description": "Pedido Glovo listo para rider",
        "schema": {
          "$ref": "./schemas/glovo-events.json#/definitions/glovo_pedido_listo"
        }
      },
      {
        "event": "whatsapp.pedido_creado",
        "description": "Pedido creado desde conversación WhatsApp",
        "schema": {
          "$ref": "./schemas/whatsapp-events.json#/definitions/whatsapp_pedido_creado"
        }
      },
      {
        "event": "whatsapp.pedido_listo",
        "description": "Pedido WhatsApp listo, cliente notificado",
        "schema": {
          "$ref": "./schemas/whatsapp-events.json#/definitions/whatsapp_pedido_listo"
        }
      }
    ],
    "subscribes": [
      {
        "event": "cobro.procesado",
        "description": "Cobro completado — cierra cuenta en el canal correspondiente por prefijo",
        "handler": "onCobroProcesado"
      },
      {
        "event": "pedido.creado",
        "description": "Pedido creado para mesa — actualiza total",
        "handler": "MesaStrategy.onPedidoCreado"
      },
      {
        "event": "cocina.pedido_listo",
        "description": "Pedido listo en cocina — notifica canal telefono/llevar/glovo/whatsapp",
        "handler": "TelefonoStrategy/LlevarStrategy/GlovoStrategy/WhatsAppStrategy.onCocinaPedidoListo"
      }
    ]
  },
  "strategies": {
    "mesa": {
      "description": "Servicio en mesa — mesas dinámicas, nombre libre, métricas de tiempo",
      "prefijo": "mesa_",
      "ui_domain": "mesa",
      "actions": [
        "abrir",
        "cerrar",
        "renombrar",
        "asignar_camarero",
        "get",
        "activas",
        "list",
        "health",
        "metrics"
      ]
    },
    "telefono": {
      "description": "Pedidos telefónicos — caller ID, CRM, WhatsApp notification",
      "prefijo": "tel_",
      "ui_domain": "telefono",
      "actions": [
        "llamada",
        "crear_pedido",
        "pendientes",
        "get",
        "marcar_listo",
        "contactos",
        "guardar_contacto",
        "health",
        "metrics"
      ]
    },
    "llevar": {
      "description": "Pedidos para llevar — tickets con display SSE",
      "prefijo": "llevar_",
      "ui_domain": "llevar",
      "actions": [
        "crear",
        "marcar_listo",
        "entregar",
        "activos",
        "listos",
        "get",
        "health",
        "metrics"
      ]
    },
    "glovo": {
      "description": "Delivery via Glovo — aceptar/rechazar, notificar rider",
      "prefijo": "glovo_",
      "ui_domain": "glovo",
      "actions": [
        "recibir",
        "aceptar",
        "rechazar",
        "marcar_listo",
        "activos",
        "get",
        "historial",
        "health",
        "metrics"
      ]
    },
    "whatsapp": {
      "description": "Pedidos vía WhatsApp Business API — conversaciones, auto-reply, confirmación",
      "prefijo": "wa_",
      "ui_domain": "whatsapp",
      "actions": [
        "mensaje",
        "crear_pedido",
        "confirmar",
        "marcar_listo",
        "activos",
        "get",
        "conversaciones",
        "enviar",
        "health",
        "metrics"
      ]
    }
  },
  "config": {
    "mesas": {
      "auto_nombre_prefijo": "Mesa",
      "descripcion": "Mesas dinámicas — sin config fija, nombre libre en tiempo de ejecución"
    },
    "whatsapp": {
      "enabled": false,
      "template_listo": "¡Hola {{nombre}}! Tu pedido #{{numero}} está listo para recoger. Te esperamos."
    },
    "whatsapp_bot": {
      "auto_reply": true,
      "phone_number_id": "",
      "access_token": "",
      "saludo": "Hola! Bienvenido a nuestra pizzería. Puedes hacernos tu pedido por aquí.",
      "template_confirmacion": "Hemos recibido tu pedido #{{numero}}. Total estimado: {{total}}EUR. Te confirmaremos en breve.",
      "template_confirmado": "Tu pedido #{{numero}} ha sido confirmado! Total: {{total}}EUR. Te avisamos cuando esté listo.",
      "template_listo": "Tu pedido #{{numero}} está listo! {{modo}} Total: {{total}}EUR",
      "template_gracias": "Gracias por tu pedido! Esperamos que lo disfrutes."
    },
    "glovo": {
      "api_key": "",
      "store_id": ""
    },
    "display": {
      "max_numeros_mostrar": 10
    },
    "reseteo_diario": true,
    "caller_id": {
      "enabled": false
    },
    "persistence": {
      "type": "in-memory",
      "owner": "CuentasCanalesModule (delegacion a 6 strategies, contadores in-memory + tracking de tiempos)",
      "delegated_to": "cuentas (owner unico de cuentas via moduleRegistry.get('cuentas').instance)",
      "restart_resilient": false,
      "concurrency": "single-instance",
      "lost_on_restart": ["_timeArrays", "fechaActual"]
    }
  },
  "ui_handlers": [
    { "domain": "canales", "action": "list",    "handler": "handleGetCanales",  "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "canales", "action": "health",  "handler": "handleHealthCheck", "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "canales", "action": "metrics", "handler": "handleGetMetrics",  "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [
    {
      "name": "canales.list",
      "description": "Lista los canales registrados con sus prefijos, ui_domain y acciones declaradas.",
      "parameters": { "type": "object", "properties": {}, "additionalProperties": false },
      "handler": "handleGetCanales",
      "errores_conocidos": ["UNKNOWN_ERROR"]
    },
    {
      "name": "canales.health",
      "description": "Health check agregado del modulo cuentas-canales (strategies activas, canales registrados).",
      "parameters": { "type": "object", "properties": {}, "additionalProperties": false },
      "handler": "handleHealthCheck",
      "errores_conocidos": []
    },
    {
      "name": "canales.metrics",
      "description": "Metricas agregadas de los canales (counters, gauges y tiempos).",
      "parameters": { "type": "object", "properties": {}, "additionalProperties": false },
      "handler": "handleGetMetrics",
      "errores_conocidos": []
    },

    { "name": "mesa.abrir",            "description": "Abre una mesa para servicio (canal mesa: dinamica con nombre libre).",                "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.mesa.handleAbrirMesa",         "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "mesa.cerrar",           "description": "Cierra una mesa abierta. Emite mesa.cerrada y cuenta.cerrada.",                       "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.mesa.handleCerrarMesa",        "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "mesa.renombrar",        "description": "Cambia el nombre legible de una mesa activa.",                                        "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.mesa.handleRenombrarMesa",     "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "mesa.asignar_camarero", "description": "Asigna un camarero a una mesa activa. Emite mesa.camarero_asignado.",                 "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.mesa.handleAsignarCamarero",   "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "mesa.get",              "description": "Obtiene los datos de una mesa por cuenta_id.",                                        "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.mesa.handleGetMesa",           "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "mesa.activas",          "description": "Lista las mesas activas en este momento.",                                            "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.mesa.handleGetActivas",        "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "mesa.list",             "description": "Lista todas las mesas (activas + historico del dia).",                                "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.mesa.handleListAll",           "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "mesa.health",           "description": "Health check del canal mesa.",                                                        "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.mesa.handleHealthCheck",      "errores_conocidos": [] },
    { "name": "mesa.metrics",          "description": "Metricas del canal mesa (mesas abiertas/cerradas, ingresos, tiempos).",               "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.mesa.handleGetMetrics",       "errores_conocidos": [] },

    { "name": "telefono.llamada",          "description": "Notifica una llamada entrante con caller-id. Crea pedido pendiente vinculado.",              "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.telefono.handleLlamadaEntrante",  "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "telefono.crear_pedido",     "description": "Crea un pedido telefonico explicito (sin haber detectado llamada).",                          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.telefono.handleCrearPedido",      "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "telefono.pendientes",       "description": "Lista pedidos telefonicos pendientes (creados, esperando confirmacion o cocina).",          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.telefono.handleGetPendientes",    "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "telefono.get",              "description": "Obtiene un pedido telefonico por cuenta_id.",                                                 "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.telefono.handleGetPedido",        "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "telefono.marcar_listo",     "description": "Marca un pedido telefonico como listo para recoger. Emite telefono.listo_para_recoger.",     "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.telefono.handleMarcarListo",      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "telefono.marcar_recogido",  "description": "Marca un pedido telefonico como recogido por el cliente. Emite cuenta.cerrada.",            "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.telefono.handleMarcarRecogido",   "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "telefono.contactos",        "description": "Lista contactos del CRM telefonico (caller-id historico).",                                 "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.telefono.handleGetContactos",     "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "telefono.guardar_contacto", "description": "Guarda o actualiza un contacto del CRM telefonico.",                                          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.telefono.handleGuardarContacto",  "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "telefono.health",           "description": "Health check del canal telefono.",                                                            "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.telefono.handleHealthCheck",     "errores_conocidos": [] },
    { "name": "telefono.metrics",          "description": "Metricas del canal telefono.",                                                                "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.telefono.handleGetMetrics",      "errores_conocidos": [] },

    { "name": "llevar.crear",        "description": "Crea un ticket para llevar (cliente recoge en mostrador). Emite llevar.ticket_creado.",      "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.llevar.handleCrearTicket",   "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "llevar.marcar_listo", "description": "Marca un ticket para llevar como listo. Emite llevar.ticket_listo.",                          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.llevar.handleMarcarListo",   "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "llevar.entregar",     "description": "Marca un ticket para llevar como entregado al cliente. Emite llevar.ticket_entregado.",      "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.llevar.handleEntregar",      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "llevar.activos",      "description": "Lista tickets para llevar activos (creados o listos pero no entregados).",                    "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.llevar.handleGetActivos",    "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "llevar.listos",       "description": "Lista tickets para llevar marcados como listos esperando recogida.",                          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.llevar.handleGetListos",     "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "llevar.get",          "description": "Obtiene un ticket para llevar por cuenta_id.",                                                "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.llevar.handleGetTicket",     "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "llevar.health",       "description": "Health check del canal llevar.",                                                              "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.llevar.handleHealthCheck",  "errores_conocidos": [] },
    { "name": "llevar.metrics",      "description": "Metricas del canal llevar.",                                                                  "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.llevar.handleGetMetrics",   "errores_conocidos": [] },

    { "name": "glovo.recibir",         "description": "Recibe un pedido entrante de Glovo desde la plataforma. Emite glovo.pedido_recibido.",          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handleRecibirPedido",   "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "glovo.aceptar",         "description": "Acepta un pedido de Glovo pendiente. Emite glovo.pedido_aceptado.",                              "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handleAceptarPedido",   "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "glovo.rechazar",        "description": "Rechaza un pedido de Glovo. Emite glovo.pedido_rechazado.",                                      "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handleRechazarPedido",  "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "glovo.marcar_listo",    "description": "Marca un pedido de Glovo como listo para rider. Emite glovo.pedido_listo.",                       "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handleMarcarListo",     "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "glovo.marcar_recogido", "description": "Marca un pedido de Glovo como recogido por rider. Emite glovo.pedido_recogido y cuenta.cerrada.","parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handleMarcarRecogido",  "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "glovo.activos",         "description": "Lista pedidos de Glovo activos (aceptados, no entregados aun).",                                  "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handleGetActivos",      "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "glovo.get",             "description": "Obtiene un pedido de Glovo por cuenta_id.",                                                       "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handleGetPedido",       "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "glovo.historial",       "description": "Historial de pedidos de Glovo del dia.",                                                          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handleGetHistorial",    "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "glovo.poll",            "description": "Trigger manual del poll a la API de Glovo (debug/operativo).",                                    "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.glovo.handlePoll",            "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "glovo.health",          "description": "Health check del canal glovo.",                                                                   "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.glovo.handleHealthCheck",    "errores_conocidos": [] },
    { "name": "glovo.metrics",         "description": "Metricas del canal glovo.",                                                                       "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.glovo.handleGetMetrics",     "errores_conocidos": [] },

    { "name": "whatsapp.mensaje",        "description": "Notifica un mensaje entrante por WhatsApp Business API. Detecta intent y responde.",          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.whatsapp.handleMensajeRecibido",  "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "whatsapp.crear_pedido",   "description": "Crea un pedido en una conversacion de WhatsApp. Emite whatsapp.pedido_creado.",                "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.whatsapp.handleCrearPedido",      "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "whatsapp.confirmar",      "description": "Confirma un pedido WhatsApp tras revisar productos. Emite whatsapp.pedido_confirmado.",       "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.whatsapp.handleConfirmarPedido",  "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "whatsapp.marcar_listo",   "description": "Marca un pedido WhatsApp como listo. Notifica al cliente con plantilla.",                       "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.whatsapp.handleMarcarListo",      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "whatsapp.activos",        "description": "Lista pedidos WhatsApp activos.",                                                                "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.whatsapp.handleGetActivos",       "errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "whatsapp.get",            "description": "Obtiene un pedido WhatsApp por cuenta_id.",                                                      "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.whatsapp.handleGetPedido",        "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"] },
    { "name": "whatsapp.conversaciones", "description": "Lista conversaciones de WhatsApp con resumen de cada una.",                                      "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.whatsapp.handleGetConversaciones","errores_conocidos": ["UNKNOWN_ERROR"] },
    { "name": "whatsapp.enviar",         "description": "Envia un mensaje saliente por WhatsApp Business API.",                                          "parameters": { "type": "object", "additionalProperties": true }, "handler": "strategies.whatsapp.handleEnviarMensaje",    "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"] },
    { "name": "whatsapp.health",         "description": "Health check del canal whatsapp.",                                                              "parameters": { "type": "object", "additionalProperties": false }, "handler": "strategies.whatsapp.handleHealthCheck",     "errores_conocidos": [] },
