{
  "name": "carta-manager",
  "version": "1.1.0",
  "description": "Dueño de datos de cartas — CRUD, persistencia, versionado, búsqueda, estadísticas",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "events": {
    "publishes": [
      {
        "event": "carta.actualizada",
        "description": "Carta modificada (legacy — compatible con nuevos eventos .completada)"
      },
      {
        "event": "carta.listada",
        "description": "Respuesta a carta.listar.solicitada"
      },
      {
        "event": "carta.editada",
        "description": "Respuesta a carta.editar.solicitada"
      },
      {
        "event": "carta.borrada",
        "description": "Respuesta a carta.borrar.solicitada"
      },
      {
        "event": "carta.listar.fallida"
      },
      {
        "event": "carta.editar.fallida"
      },
      {
        "event": "carta.borrar.fallida"
      }
    ],
    "subscribes": [
      {
        "event": "project.activated",
        "handler": "onProjectActivated"
      },
      {
        "event": "project.deactivated",
        "handler": "onProjectDeactivated"
      },
      {
        "event": "carta.listar.solicitada",
        "handler": "onCartaListarSolicitada"
      },
      {
        "event": "carta.editar.solicitada",
        "handler": "onCartaEditarSolicitada"
      },
      {
        "event": "carta.borrar.solicitada",
        "handler": "onCartaBorrarSolicitada"
      }
    ]
  },
  "ui_handlers": [
    {
      "domain": "carta-manager",
      "action": "list",
      "handler": "handleList",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "carta-manager",
      "action": "get",
      "handler": "handleGet",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "carta-manager",
      "action": "health",
      "handler": "handleHealth",
      "type": "system_panel",
      "zone": "lateral_derecha"
    }
  ],
  "tools": [
    {
      "name": "carta.save",
      "description": "Guarda carta a disco. Acepta carta_id (existente), carta (objeto completo), o nombre (nueva vacía).",
      "handler": "toolSave",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          },
          "nombre": {
            "type": "string"
          },
          "carta": {
            "type": "object"
          },
          "project_id": {
            "type": "string",
            "description": "ID del proyecto (obligatorio)"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "name": "carta.get",
      "description": "Obtiene carta completa por ID",
      "handler": "toolGet",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          }
        },
        "required": [
          "carta_id"
        ]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    },
    {
      "name": "carta.list",
      "description": "Lista todas las cartas con resumen",
      "handler": "toolList",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "errores_conocidos": ["INVALID_INPUT"]
    },
    {
      "name": "carta.delete",
      "description": "Elimina carta (guarda versión antes)",
      "handler": "toolDelete",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          }
        },
        "required": [
          "carta_id"
        ]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    },
    {
      "name": "carta.add_product",
      "description": "Añade producto a carta",
      "handler": "toolAddProduct",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          },
          "nombre": {
            "type": "string"
          },
          "categoria": {
            "type": "string"
          },
          "precio": {
            "type": "number"
          },
          "ingredientes": {
            "type": "array"
          }
        },
        "required": [
          "carta_id",
          "nombre",
          "categoria",
          "precio"
        ]
      }
    },
    {
      "name": "carta.remove_product",
      "description": "Elimina producto de carta",
      "handler": "toolRemoveProduct",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          },
          "producto_id": {
            "type": "string"
          }
        },
        "required": [
          "carta_id",
          "producto_id"
        ]
      }
    },
    {
      "name": "carta.update_product",
      "description": "Actualiza producto (nombre, precio, categoría, ingredientes)",
      "handler": "toolUpdateProduct",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          },
          "producto_id": {
            "type": "string"
          },
          "nombre": {
            "type": "string"
          },
          "precio": {
            "type": "number"
          },
          "categoria": {
            "type": "string"
          },
          "ingredientes": {
            "type": "array"
          }
        },
        "required": [
          "carta_id",
          "producto_id"
        ]
      }
    },
    {
      "name": "carta.add_category",
      "description": "Añade categoría a carta",
      "handler": "toolAddCategory",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          },
          "nombre": {
            "type": "string"
          }
        },
        "required": [
          "carta_id",
          "nombre"
        ]
      }
    },
    {
      "name": "carta.update_prices",
      "description": "Ajusta precios (porcentaje global, por categoría, o individuales)",
      "handler": "toolUpdatePrices",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          },
          "porcentaje": {
            "type": "number"
          },
          "categoria": {
            "type": "string"
          },
          "precios": {
            "type": "object"
          }
        },
        "required": [
          "carta_id"
        ]
      }
    },
    {
      "name": "carta.search",
      "description": "Busca productos por nombre o ingrediente",
      "handler": "toolSearch",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          },
          "query": {
            "type": "string"
          }
        },
        "required": [
          "carta_id",
          "query"
        ]
      }
    },
    {
      "name": "carta.stats",
      "description": "Estadísticas de carta",
      "handler": "toolStats",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          }
        },
        "required": [
          "carta_id"
        ]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    },
    {
      "name": "carta.versions",
      "description": "Historial de versiones (max 50)",
      "handler": "toolVersions",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          }
        },
        "required": [
          "carta_id"
        ]
      },
      "errores_conocidos": ["INVALID_INPUT"]
    },
    {
      "name": "carta.restore",
      "description": "Restaura carta a versión anterior",
      "handler": "toolRestore",
      "parameters": {
        "type": "object",
        "properties": {
          "carta_id": {
            "type": "string"
          },
          "version_file": {
            "type": "string"
          }
        },
        "required": [
          "carta_id",
          "version_file"
        ]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"]
    }
  ],
  "config": {
    "persistence": {
      "pattern": "json_files",
      "path_pattern": "data/projects/{slug}/storage/pizzepos/cartas/{carta_id}.json",
      "versioning": true
    }
  },
  "observability": {
    "metrics": {
      "counters": [
        "carta-manager.carta.saved",
        "carta-manager.carta.deleted",
        "carta-manager.carta.product.added",
        "carta-manager.carta.product.removed",
        "carta-manager.carta.prices.updated",
        "carta-manager.error"
      ]
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  }
}
