      "pizzepos",
      "telegram-service",
      "text-editor",
      "asesoria",
      "fuentes",
      "carta-digital",
      "carta-design",
      "carta-impresion",
      "channel-manager",
      "composition-manager",
      "context-manager",
      "facturas",
      "impresion",
      "perifericos",
      "device-registry",
      "device-shadow",
      "gateway-manager",
      "firmware-manager",
      "device-health",
      "firmware-builder",
      "esp32-flasher",
