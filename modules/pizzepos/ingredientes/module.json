{
  "name": "ingredientes",
  "version": "5.0.0",
  "description": "Catalogo de ingredientes organizado por GRUPO (categoria de producto). Fuente unica de precios (precio_extra). Sincronizado desde carta.actualizada y producto.creado.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "provides": {
    "events": [
      "ingrediente.creado",
      "ingrediente.actualizado"
    ]
  },
  "events": {
    "publishes": [
      { "event": "ingrediente.creado",      "description": "Nuevo ingrediente creado desde carta o producto. Lleva project_id top-level + correlation_id + timestamp." },
      { "event": "ingrediente.actualizado", "description": "Ingrediente modificado (nombre, emoji, precio_extra, grupos, es_alergeno, etc) con diff." }
    ],
    "subscribes": [
      { "event": "project.activated",       "handler": "onProjectActivated",            "description": "Set storagePath y carga catalogo desde disco." },
      { "event": "carta.actualizada",       "handler": "onCartaActualizada",            "description": "Sincroniza ingredientes_catalogo + extrae de productos.ingredientes_base." },
      { "event": "producto.creado",         "handler": "onProductoCreado",              "description": "Registra ingredientes del producto en su grupo (categoria)." },
      { "event": "ingrediente.actualizado", "handler": "onIngredienteActualizadoExterno","description": "Sync desde menu-generator. Loop-safe via comparacion de valores." }
    ]
  },
  "ui_handlers": [
    { "domain": "ingredientes", "action": "list",            "handler": "handleListIngredientes",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "ingredientes", "action": "get",             "handler": "handleGetIngrediente",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "ingredientes", "action": "get_precio",      "handler": "handleGetPrecio",          "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "ingredientes", "action": "search",          "handler": "handleSearchIngredientes", "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "ingredientes", "action": "alergenos",       "handler": "handleListAlergenos",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "ingredientes", "action": "update",          "handler": "handleUpdateIngrediente",  "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "ingredientes", "action": "update_precios",  "handler": "handleUpdatePrecios",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "ingredientes", "action": "health",          "handler": "handleHealthCheck",        "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "ingredientes", "action": "metrics",         "handler": "handleGetMetrics",         "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [],
  "config": {
    "persistence": {
      "type":   "json-file",
      "atomic": true,
      "paths": [
        "data/projects/<projectId>/storage/pizzepos/ingredientes.json"
      ],
      "concurrency": "single-instance-per-process",
      "owner":       "modules/pizzepos/ingredientes"
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "ingrediente.creado.total",
        "ingrediente.actualizado.total",
        "ingredientes.errors"
      ],
      "gauges": [
        "ingrediente.total.count",
        "ingrediente.alergenos.count"
      ],
      "timings": [
        "ingrediente.sync.duration"
      ]
    }
  }
}
