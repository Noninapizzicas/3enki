      "modules/firmware-manager/schemas/events.json",
      "modules/firmware-manager/schemas/firmware.json"
    ],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

