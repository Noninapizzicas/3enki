{
  "prompt_name": "orquestador_implementacion_modulos",
  "version": "1.1.0",
  "changelog": [
    {
      "version": "1.1.0",
      "date": "2025-10-04",
      "changes": [
        {
          "type": "CRITICAL",
          "description": "Añadido changelog completo con historial de cambios versionado"
        },
        {
          "type": "CRITICAL",
          "description": "Añadido execution_context con triggers, consumes_from y produces_for para integración completa"
        },
        {
          "type": "CRITICAL",
          "description": "Convertido tasks a implementation_pipeline con 18 pasos estructurados y ordenados"
        },
        {
          "type": "CRITICAL",
          "description": "Todos los schemas ahora incluyen additionalProperties: false para validación estricta"
        },
        {
          "type": "HIGH",
