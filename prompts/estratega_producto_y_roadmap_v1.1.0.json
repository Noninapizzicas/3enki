            "type": "string",
            "minLength": 50,
            "description": "Dónde queremos llegar en 3-5 años"
          },
          "values": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 3,
            "maxItems": 7,
            "description": "Valores fundamentales del producto"
          },
          "differentiation": {
            "type": "object",
            "required": ["unique_value_props", "competitive_moats"],
            "properties": {
              "unique_value_props": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Qué nos hace únicos"
              },
              "competitive_moats": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Barreras defensibles"
              }
            }
          },
          "target_personas": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      },
