{
  "name": "channel-manager",
  "version": "1.0.0",
  "description": "Registry de canales externos: mapea identificadores externos (chat_id, email, telefono) a proyectos y propositos internos",
  "author": "Event-Core Team",
  "main": "index.js",

  "dependencies": ["database-manager"],

  "provides": {
    "events": [
      "channel.registered",
      "channel.updated",
      "channel.removed",
      "channel.resolved"
    ],
    "queries": [
      "channel.resolve.request"
    ]
  },

  "events": {
    "publishes": [
      {
        "event": "channel.registered",
        "description": "Nuevo canal vinculado a un proyecto",
        "schema": { "$ref": "./schemas/events.json#/definitions/channel_registered" }
      },
      {
        "event": "channel.updated",
        "description": "Canal actualizado",
        "schema": { "$ref": "./schemas/events.json#/definitions/channel_updated" }
      },
      {
        "event": "channel.removed",
        "description": "Canal desvinculado",
        "schema": { "$ref": "./schemas/events.json#/definitions/channel_removed" }
      },
      {
        "event": "channel.resolved",
        "description": "Canal resuelto exitosamente a proyecto+proposito",
        "schema": { "$ref": "./schemas/events.json#/definitions/channel_resolved" }
      },
      {
        "event": "channel.resolve.response",
        "description": "Respuesta a channel.resolve.request",
        "schema": { "$ref": "./schemas/events.json#/definitions/channel_resolve_response" }
      }
    ],
    "subscribes": [
      {
        "event": "channel.resolve.request",
        "description": "Otro modulo pide resolver un identificador externo a proyecto+proposito",
        "handler": "onResolveRequest"
      }
    ]
  },

  "handlers": [
    { "domain": "channel", "action": "register", "handler": "handleRegister" },
    { "domain": "channel", "action": "update", "handler": "handleUpdate" },
    { "domain": "channel", "action": "remove", "handler": "handleRemove" },
    { "domain": "channel", "action": "resolve", "handler": "handleResolve" },
    { "domain": "channel", "action": "list", "handler": "handleList" },
    { "domain": "channel", "action": "list-by-project", "handler": "handleListByProject" }
  ],

  "tools": [
    {
      "name": "channel.resolve",
      "description": "Resuelve un identificador externo (chat_id, email, telefono) al proyecto y proposito al que pertenece.",
      "handler": "handleToolResolve",
      "parameters": {
        "type": "object",
        "properties": {
          "channel_type": {
            "type": "string",
            "enum": ["telegram", "gmail", "whatsapp", "glovo", "web"],
            "description": "Tipo de canal externo"
          },
          "external_id": {
            "type": "string",
            "description": "Identificador externo (ej: 'mibot:12345', 'cuenta@gmail.com', '+34600123456')"
          }
        },
        "required": ["channel_type", "external_id"]
      }
    },
    {
      "name": "channel.list",
      "description": "Lista todos los canales registrados, opcionalmente filtrados por proyecto o tipo.",
      "handler": "handleToolList",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "description": "Filtrar por proyecto (opcional)"
          },
          "channel_type": {
            "type": "string",
            "description": "Filtrar por tipo de canal (opcional)"
          }
        },
        "required": []
      }
    }
  ],

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "channel.registered.total",
        "channel.resolved.total",
        "channel.resolve.failed.total",
        "channel.removed.total"
      ],
      "gauges": [
        "channel.count.total",
        "channel.count.by_type"
      ],
      "timings": [
        "channel.resolve.duration"
      ]
    }
  },

  "config": {
    "db_project_id": "system",
    "table_name": "channels"
  }
}
