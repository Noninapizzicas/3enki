{
  "id": "entrada-gmail",
  "name": "Entrada Facturas Gmail",
  "description": "Recoge facturas desde Gmail y las guarda en inbox para procesamiento nocturno",
  "version": "1.0.0",
  "enabled": true,

  "schedule": {
    "cron": "0 3 * * *",
    "timezone": "Europe/Madrid"
  },

  "steps": [
    {
      "id": "crear-inbox",
      "type": "service",
      "service": "fs",
      "action": "mkdir",
      "path": "@/projects/facturas-nonina/inbox",
      "onError": "continue"
    },
    {
      "id": "buscar-emails",
      "type": "service",
      "service": "gmail",
      "action": "search",
      "query": "has:attachment is:unread",
      "maxResults": 50
    },
    {
      "id": "verificar-emails",
      "type": "condition",
      "if": "{{ count(steps.buscar-emails.data.messages) }} > 0",
      "then": "procesar-emails",
      "else": "log-sin-emails"
    },
    {
      "id": "log-sin-emails",
      "type": "log",
      "level": "info",
      "message": "No hay emails nuevos con adjuntos"
    },
    {
      "id": "procesar-emails",
      "type": "log",
      "level": "info",
      "message": "Procesando {{ count(steps.buscar-emails.data.messages) }} emails con adjuntos"
    },
    {
      "id": "descargar-adjuntos",
      "type": "service",
      "service": "gmail",
      "action": "attachments.download",
      "messageIds": "{{ steps.buscar-emails.data.messages }}",
      "outputDir": "@/projects/facturas-nonina/inbox",
      "mimeTypes": ["image/jpeg", "image/png", "application/pdf"],
      "markAsRead": true
    },
    {
      "id": "log-resultado",
      "type": "log",
      "level": "info",
      "message": "Adjuntos descargados: {{ default(steps.descargar-adjuntos.data.count, 0) }}"
    }
  ]
}
