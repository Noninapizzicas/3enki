{
  "name": "send_message",
  "description": "Enviar mensaje de texto a un chat",
  "event": "telegram.send_message.request",
  "method": "POST",
  "endpoint": "/bot{{bot_token}}/sendMessage",
  "headers": {
    "Content-Type": "application/json"
  },
  "input": {
    "bot_token": {
      "type": "string",
      "description": "Token del bot",
      "required": true
    },
    "chat_id": {
      "type": "number",
      "description": "ID del chat destino",
      "required": true
    },
    "text": {
      "type": "string",
      "description": "Mensaje a enviar",
      "required": true
    },
    "parse_mode": {
      "type": "string",
      "enum": ["HTML", "Markdown", "MarkdownV2"],
      "description": "Modo de parseo del mensaje"
    },
    "reply_markup": {
      "type": "object",
      "description": "Teclado inline opcional"
    }
  },
  "request_template": {
    "chat_id": "{{chat_id}}",
    "text": "{{text}}",
    "parse_mode": "{{parse_mode}}",
    "reply_markup": "{{reply_markup}}"
  },
  "output": {
    "message_id": {
      "type": "number",
      "description": "ID del mensaje enviado"
    }
  },
  "response_path": "result.message_id"
}
