{
  "framework": "SvelteKit",
  "typescript": true,
  "layout": {
    "type": "single-page with floating panels",
    "zones": {
      "work-bar": "Left sidebar - main module buttons",
      "chat-config": "Right sidebar - configuration panels",
      "chat-tools": "Bottom - tool panels",
      "main": "Center - primary content area"
    },
    "principles": [
      "1 click = 1 panel (no double-click, no long-press)",
      "Single screen (no traditional navigation)",
      "Panels are floating and self-contained",
      "Data via MQTT (no REST /ui/state endpoints)"
    ]
  },
  "component_structure": {
    "pattern": "{Module}Button.svelte + {Module}Panel.svelte",
    "location": "frontend/src/lib/components/{domain}/",
    "panel_features": ["tabs if needed", "loading states", "error handling"]
  },
  "ui_modules": {
    "location": "frontend/src/lib/modules/",
    "loader": "frontend/src/lib/modules/loader.ts",
    "discovery": "automatic (scans */manifest.json using import.meta.glob)",
    "module_structure": {
      "required_files": {
        "manifest.json": "Module metadata (id, zone, icon, label, order, dependencies)",
        "index.ts": "UIModule with manifest, PanelComponent, getIcon(), getBadge()"
      },
      "optional_files": {
        "{Name}Panel.svelte": "Panel component"
      }
    },
    "manifest_schema": {
      "id": "string",
      "name": "string",
      "version": "string (semver)",
      "zone": "work-bar|chat-config|chat-tools|system-bar",
      "order": "number (optional)",
      "icon": "emoji",
      "label": "string",
      "dependencies": ["module-id"] ,
      "critical": "boolean (preload on startup)",
      "heavy": "boolean (load in background)"
    },
    "active_modules": ["project", "files", "provider", "prompts", "credentials"]
  },
  "stores": {
    "location": "frontend/src/lib/stores/",
    "pattern": "Svelte writable stores + async functions",
    "examples": {
      "projects.ts": {
        "store": "projectsStore",
        "functions": ["loadProjects()", "createProject()", "updateProject()", "deleteProject()"]
      },
      "credentials.ts": {
        "store": "credentialsStore",
        "functions": ["loadCredentials()", "createCredential()", "updateCredential()", "deleteCredential()"]
      }
    }
  },
  "mqtt_integration": {
    "client_location": "frontend/src/lib/ui-core/mqtt.ts",
    "request_utility": "frontend/src/lib/ui-core/mqtt-request.ts",
    "connection": "WebSocket on port 9001",
    "auto_reconnect": true
  },
  "css": {
    "approach": "Tailwind CSS",
    "dark_mode": "supported",
    "responsive": "mobile-first",
    "migration": {
      "status": "pending",
      "current_state": "CSS custom con variables (--color-*, --_*)",
      "target_state": "Tailwind utility classes",
      "script": "scripts/migrate-to-tailwind.js",
      "script_options": {
        "--install": "Instala Tailwind, PostCSS, crea config y app.css",
        "--report": "Analiza archivos y genera reporte de migración",
        "--migrate": "Ejecuta migración automática con backup",
        "--dry-run": "Preview de cambios sin aplicar"
      },
      "variables_to_migrate": {
        "--_text": "text-neutral-200",
        "--_text-muted": "text-neutral-400",
        "--_bg": "bg-neutral-900",
        "--_bg-surface": "bg-white/5",
        "--_border": "border-white/10",
        "--_primary": "text-blue-500",
        "--_success": "text-green-500",
        "--_danger": "text-red-500",
        "--_radius": "rounded-lg"
      },
      "files_affected": 33,
      "priority_files": [
        "lib/modules/credentials/CredentialsPanel.svelte (738 líneas)",
        "lib/modules/prompts/PromptsPanel.svelte (714 líneas)",
        "lib/modules/files/FilesPanel.svelte (445 líneas)"
      ]
    }
  },
  "generation_rules": [
    "Never invent UX not defined in backend",
    "Never add screens or flows not specified",
    "Read module.json to understand capabilities",
    "Use mqttRequest() for all CRUD operations",
    "Keep state minimal",
    "New UI modules: create folder in modules/, add manifest.json + index.ts",
    "No manual registration needed - loader auto-discovers via import.meta.glob"
  ]
}
