  "observability": {
    "logging": {
      "level": "info",
      "outputs": ["console"],
      "structured": true
    },
    "tracing": {
      "enabled": true,
      "sample_rate": 1.0
    },
    "metrics": {
      "enabled": true,
      "flush_interval": 60000
    }
  },
  "security": {
    "encryption": {
      "enabled": true,
      "algorithm": "aes-256-gcm"
    },
    "p2p": {
      "key_rotation_days": 90,
      "trust_on_first_use": false
