{
  "name": "certificate-authority",
  "version": "2.0.0",
  "description": "Internal Certificate Authority for Event Core. Issues, revokes and verifies X.509 client certificates (clientes del portal de facturacion + dispositivos de trabajo). Hook beforeRequest para autenticacion mTLS transparente cuando config.mtls_enabled. Persiste certificados + CRL en filesystem (CAManager).",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",
  "tracing": {
    "propaga_correlation_id": true
  },
  "events": {
    "publishes": [
      { "event": "certificate.issued",   "description": "Nuevo certificado emitido (cliente o dispositivo). project_id top-level + correlation_id + timestamp." },
      { "event": "certificate.revoked",  "description": "Certificado revocado (compromised, lost device, etc.). project_id top-level + correlation_id + timestamp." },
      { "event": "certificate.renewed",  "description": "Certificado renovado (revoca el viejo, emite uno nuevo). project_id top-level + correlation_id + timestamp." },
      { "event": "certificate.expired",  "description": "Certificado alcanzo fecha de expiracion. project_id top-level + correlation_id + timestamp." }
    ],
    "subscribes": []
  },
  "ui_handlers": [
    { "domain": "certificate-authority", "action": "status",       "handler": "handleStatus",            "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "ca-cert",      "handler": "handleGetCACert",         "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "issue",        "handler": "handleIssueCertificate",  "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "enroll",       "handler": "handleEnrollFromPublicKey", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "sign-invitation", "handler": "handleSignInvitation", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "bootstrap-status", "handler": "handleBootstrapStatus", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "claim-admin", "handler": "handleClaimAdmin", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "revoke",       "handler": "handleRevokeCertificate", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "renew",        "handler": "handleRenewCertificate",  "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "list",         "handler": "handleListCertificates",  "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "verify",       "handler": "handleVerifyCertificate", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "crl",          "handler": "handleGetCRL",            "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "download-p12", "handler": "handleDownloadP12",       "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "stats",        "handler": "handleStatus",            "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "nginx-config", "handler": "handleGetNginxConfig",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "certificate-authority", "action": "health",       "handler": "handleHealthCheck",       "type": "system_panel", "zone": "lateral_derecha" }
  ],
  "tools": [],
  "dependencies": [],
  "provides": {
    "hooks": ["beforeRequest"]
  },
  "config": {
    "mtls_enabled": false,
    "mtls_mode": "proxy",
    "cert_header": "x-client-cert",
    "allow_unauthenticated": true,
    "ca_cn": "Event Core Internal CA",
    "ca_org": "Event Core",
    "ca_validity_days": 3650,
    "cert_validity_days": 365,
    "key_size": 2048,
    "persistence": {
      "type": "filesystem",
      "owner": "CAManager (CA cert + private key + emitted certs + CRL en disk)",
      "paths": [
        "{config.storagePath}/ca.crt",
        "{config.storagePath}/ca.key",
        "{config.storagePath}/issued/<serialNumber>.{crt,p12,json}",
        "{config.storagePath}/crl.json"
      ],
      "restart_resilient": true,
      "concurrency": "single-instance",
      "lost_on_restart": ["mtlsMiddleware.requestStats"]
    }
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "certificate-authority.certificates_issued",
        "certificate-authority.certificates_revoked",
        "certificate-authority.certificates_renewed",
        "certificate-authority.verification_requests",
        "certificate-authority.errors",
        "mtls.authenticated",
        "mtls.rejected",
        "mtls.bypassed",
        "mtls.errors"
      ]
    }
  }
}
