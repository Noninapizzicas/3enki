{
  "name": "storage-manager",
  "version": "1.0.0",
  "description": "Event-driven file storage management with project isolation",
  "author": "Aichat Team",
  "main": "index.js",

  "provides": {
    "events": [
      "file.uploaded",
      "file.deleted",
      "storage.created",
      "storage.deleted",
      "storage.cleaned"
    ],
    "queries": [
      "file.list.request",
      "file.get.request",
      "storage.info.request"
    ]
  },

  "events": {
    "publishes": [
      {
        "event": "storage.created",
        "description": "Project storage structure created",
        "schema": { "$ref": "./schemas/events.json#/definitions/storage_created" }
      },
      {
        "event": "storage.deleted",
        "description": "Project storage deleted",
        "schema": { "$ref": "./schemas/events.json#/definitions/storage_deleted" }
      },
      {
        "event": "storage.cleaned",
        "description": "Temporary files cleaned",
        "schema": { "$ref": "./schemas/events.json#/definitions/storage_cleaned" }
      },
      {
        "event": "file.uploaded",
        "description": "File uploaded successfully",
        "schema": { "$ref": "./schemas/events.json#/definitions/file_uploaded" }
      },
      {
        "event": "file.deleted",
        "description": "File deleted",
        "schema": { "$ref": "./schemas/events.json#/definitions/file_deleted" }
      },
      {
        "event": "file.list.response",
        "description": "Response with files list",
        "schema": { "$ref": "./schemas/events.json#/definitions/file_list_response" }
      },
      {
        "event": "file.get.response",
        "description": "Response with file metadata",
        "schema": { "$ref": "./schemas/events.json#/definitions/file_get_response" }
      },
      {
        "event": "storage.info.response",
        "description": "Response with storage information",
        "schema": { "$ref": "./schemas/events.json#/definitions/storage_info_response" }
      }
    ],
    "subscribes": [
      {
        "event": "project.created",
        "description": "Auto-create storage when project created",
        "handler": "onProjectCreated"
      },
      {
        "event": "project.deleted",
        "description": "Auto-delete storage when project deleted",
        "handler": "onProjectDeleted"
      },
      {
        "event": "file.list.request",
        "description": "List files in project storage",
        "handler": "onFileListRequest"
      },
      {
        "event": "file.get.request",
        "description": "Get file metadata",
        "handler": "onFileGetRequest"
      },
      {
        "event": "storage.info.request",
        "description": "Get storage usage info",
        "handler": "onStorageInfoRequest"
      }
    ]
  },

  "apis": [
    {
      "method": "POST",
      "path": "/storage/:projectId/upload",
      "handler": "handleUploadFile",
      "description": "Upload file to project storage (publishes file.uploaded)",
      "response_schema": { "$ref": "./schemas/storage.json#/definitions/upload_response" }
    },
    {
      "method": "GET",
      "path": "/storage/:projectId/files",
      "handler": "handleListFiles",
      "description": "List files in project storage",
      "response_schema": { "$ref": "./schemas/storage.json#/definitions/list_response" }
    },
    {
      "method": "GET",
      "path": "/storage/:projectId/files/:fileId",
      "handler": "handleGetFile",
      "description": "Get file metadata",
      "response_schema": { "$ref": "./schemas/storage.json#/definitions/file_response" }
    },
    {
      "method": "GET",
      "path": "/storage/:projectId/download/:fileId",
      "handler": "handleDownloadFile",
      "description": "Download file"
    },
    {
      "method": "DELETE",
      "path": "/storage/:projectId/files/:fileId",
      "handler": "handleDeleteFile",
      "description": "Delete file (publishes file.deleted)",
      "response_schema": { "$ref": "./schemas/storage.json#/definitions/delete_response" }
    },
    {
      "method": "POST",
      "path": "/storage/:projectId/cleanup",
      "handler": "handleCleanupTemp",
      "description": "Cleanup temporary files (publishes storage.cleaned)",
      "response_schema": { "$ref": "./schemas/storage.json#/definitions/cleanup_response" }
    },
    {
      "method": "GET",
      "path": "/storage/:projectId/info",
      "handler": "handleGetStorageInfo",
      "description": "Get storage usage information",
      "response_schema": { "$ref": "./schemas/storage.json#/definitions/info_response" }
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check endpoint"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Module metrics"
    }
  ],

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "storage.created.total",
        "storage.deleted.total",
        "file.uploaded.total",
        "file.downloaded.total",
        "file.deleted.total",
        "storage.cleanup.total",
        "storage.error.total"
      ],
      "gauges": [
        "storage.projects.count",
        "storage.total.bytes",
        "storage.files.count"
      ],
      "timings": [
        "file.upload.duration",
        "file.download.duration",
        "storage.cleanup.duration"
      ]
    }
  },

  "config": {
    "basePath": "data/storage",
    "maxFileSize": 104857600,
    "allowedMimeTypes": ["image/*", "application/pdf", "text/*", "application/json"],
    "tempCleanupAfterHours": 24,
    "directories": {
      "uploads": "uploads",
      "exports": "exports",
      "temp": "temp",
      "files": "files"
    }
  }
}
