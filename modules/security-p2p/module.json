{
  "name": "security-p2p",
  "version": "1.0.0",
  "description": "P2P Security module with capability-based permissions and encrypted communication",
  "author": "Event Core Team",
  "provides": {
    "apis": [
      {
        "name": "status",
        "method": "GET",
        "path": "/status",
        "description": "Get security status (public key, trusted peers)"
      },
      {
        "name": "publicKey",
        "method": "GET",
        "path": "/public-key",
        "description": "Get public key for this core"
      },
      {
        "name": "trustPeer",
        "method": "POST",
        "path": "/trust-peer",
        "description": "Trust a peer by public key"
      },
      {
        "name": "untrustPeer",
        "method": "POST",
        "path": "/untrust-peer",
        "description": "Remove peer from trusted list"
      },
      {
        "name": "listPeers",
        "method": "GET",
        "path": "/peers",
        "description": "List all trusted peers"
      }
    ],
    "hooks": ["beforeEventPublish", "afterEventReceive"]
  },
  "subscribes": [
    "core/+/security/handshake/#"
  ],
  "requires": {
    "core": ">=0.1.0"
  },
  "config": {
    "encryption_enabled": true,
    "auto_trust": false,
    "key_rotation_days": 90
  }
}
