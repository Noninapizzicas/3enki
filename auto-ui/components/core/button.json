{
  "name": "button",
  "version": "1.0.0",
  "type": "core",
  "description": "Botón con múltiples modos de interacción",

  "variants": {
    "primary": {
      "bg": "var(--primary)",
      "text": "white",
      "border": "var(--primary)"
    },
    "secondary": {
      "bg": "var(--bg-card)",
      "text": "var(--text)",
      "border": "var(--border)"
    },
    "success": {
      "bg": "var(--success)",
      "text": "white",
      "border": "var(--success)"
    },
    "warning": {
      "bg": "var(--warning)",
      "text": "var(--bg)",
      "border": "var(--warning)"
    },
    "danger": {
      "bg": "var(--danger)",
      "text": "white",
      "border": "var(--danger)"
    },
    "ghost": {
      "bg": "transparent",
      "text": "var(--primary)",
      "border": "transparent"
    },
    "outline": {
      "bg": "transparent",
      "text": "var(--primary)",
      "border": "var(--primary)"
    }
  },

  "sizes": {
    "sm": {
      "padding": "var(--space-xs) var(--space-sm)",
      "fontSize": "var(--size-sm)"
    },
    "md": {
      "padding": "var(--space-sm) var(--space-md)",
      "fontSize": "var(--size-base)"
    },
    "lg": {
      "padding": "var(--space-md) var(--space-lg)",
      "fontSize": "var(--size-lg)"
    }
  },

  "interactions": {
    "click": {
      "enabled": true,
      "debounce": 0
    },
    "dblclick": {
      "enabled": true,
      "delay": 300
    },
    "hold": {
      "enabled": true,
      "duration": 2000,
      "feedback": "progress-ring"
    }
  },

  "states": {
    "default": {},
    "hover": {
      "transform": "translateY(-1px)",
      "shadow": "var(--shadow-md)"
    },
    "active": {
      "transform": "translateY(0)",
      "shadow": "var(--shadow-sm)"
    },
    "disabled": {
      "opacity": 0.5,
      "cursor": "not-allowed"
    },
    "loading": {
      "cursor": "wait"
    }
  },

  "accessibility": {
    "role": "button",
    "tabIndex": 0,
    "ariaLabel": "button"
  }
}
