  "estado": {
    "memoria": [
      { "campo": "pendingDb",          "tipo": "Map", "ubicacion_init": "modules/conversacion/chat-io/index.js:62", "se_invalida_con": "respuesta db.query.response (clearTimeout + delete) | timeout 10s (delete + reject) | onUnload (clearTimeout sobre todos + clear)",                       "leak_potencial": false },
