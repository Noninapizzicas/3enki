{
  "name": "textarea",
  "category": "form",
  "description": "Área de texto multilinea con contador de caracteres",
  "version": "2.0.0",

  "variants": {
    "default": {
      "description": "Textarea estándar",
      "className": "form-textarea"
    },
    "code": {
      "description": "Textarea para código (monospace)",
      "className": "form-textarea form-textarea-code"
    },
    "autosize": {
      "description": "Altura automática según contenido",
      "className": "form-textarea form-textarea-autosize"
    }
  },

  "sizes": {
    "sm": {
      "description": "Textarea pequeño",
      "className": "form-textarea-sm",
      "rows": 2
    },
    "md": {
      "description": "Textarea mediano (default)",
      "className": "",
      "rows": 4
    },
    "lg": {
      "description": "Textarea grande",
      "className": "form-textarea-lg",
      "rows": 8
    }
  },

  "props": {
    "label": {
      "type": "string",
      "description": "Etiqueta del campo"
    },
    "name": {
      "type": "string",
      "required": true,
      "description": "Nombre del campo"
    },
    "placeholder": {
      "type": "string",
      "description": "Texto de placeholder"
    },
    "value": {
      "type": "string",
      "description": "Valor del textarea"
    },
    "rows": {
      "type": "number",
      "default": 4,
      "description": "Número de filas"
    },
    "minRows": {
      "type": "number",
      "description": "Mínimo de filas (autosize)"
    },
    "maxRows": {
      "type": "number",
      "description": "Máximo de filas (autosize)"
    },
    "required": {
      "type": "boolean",
      "default": false,
      "description": "Campo requerido"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Campo deshabilitado"
    },
    "readonly": {
      "type": "boolean",
      "default": false,
      "description": "Campo de solo lectura"
    },
    "minLength": {
      "type": "number",
      "description": "Longitud mínima"
    },
    "maxLength": {
      "type": "number",
      "description": "Longitud máxima"
    },
    "showCounter": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar contador de caracteres"
    },
    "helpText": {
      "type": "string",
      "description": "Texto de ayuda"
    },
    "errorText": {
      "type": "string",
      "description": "Mensaje de error"
    },
    "resize": {
      "type": "string",
      "enum": ["none", "vertical", "horizontal", "both"],
      "default": "vertical",
      "description": "Tipo de resize"
    }
  },

  "features": {
    "autosize": {
      "enabled": false,
      "minHeight": "80px",
      "maxHeight": "400px"
    },
    "counter": {
      "enabled": false,
      "showRemaining": true,
      "warnAt": 0.9
    },
    "markdown": {
      "enabled": false,
      "preview": true,
      "toolbar": true
    }
  },

  "states": {
    "default": "Estado normal",
    "focus": "Textarea enfocado",
    "error": "Textarea con error",
    "disabled": "Textarea deshabilitado",
    "readonly": "Textarea de solo lectura"
  },

  "accessibility": {
    "ariaLabel": true,
    "ariaDescribedBy": true,
    "ariaInvalid": true,
    "ariaRequired": true
  },

  "example": {
    "component": "textarea",
    "variant": "autosize",
    "size": "md",
    "props": {
      "label": "Comentarios",
      "name": "comments",
      "placeholder": "Escribe tus comentarios aquí...",
      "minRows": 3,
      "maxRows": 10,
      "maxLength": 500,
      "showCounter": true,
      "helpText": "Comparte tus opiniones o sugerencias",
      "resize": "none"
    }
  }
}
