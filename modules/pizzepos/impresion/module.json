{
  "name": "impresion",
  "version": "4.0.0",
  "description": "Formateo ESC/POS y envio directo a impresoras ESP32 via MQTT. Autodescubrimiento de impresoras. Sin capas intermedias.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "provides": {
    "events": [
      "impresion.comanda_generada",
      "impresion.error",
      "impresion.ticket_venta_generado",
      "impresion.ticket_pieza_generado"
    ]
  },
  "events": {
    "publishes": [
      { "event": "impresion.comanda_generada",      "description": "Comanda formateada y enviada al ESP32 via MQTT (lleva project_id top-level + correlation_id + timestamp)." },
      { "event": "impresion.error",                 "description": "Error reportado por el ESP32 firmware (incluye error_code, error_detail, attempts, bt_mode, etc)." },
      { "event": "impresion.ticket_venta_generado", "description": "Ticket de venta (recibo cliente) formateado y enviado." },
      { "event": "impresion.ticket_pieza_generado", "description": "Ticket de pieza individual formateado y enviado (uno por item de cocina)." }
    ],
    "subscribes": [
      { "event": "cocina.item_ticket",   "handler": "onItemTicket",          "description": "Imprimir ticket de pieza individual cuando horno marca item como salido." },
      { "event": "cuenta.creada",        "handler": "onCuentaCreada",        "description": "Cachear ref_display canonico para impresion de tickets." },
      { "event": "mesa.abierta",         "handler": "onMesaAbierta",         "description": "Cachear nombre de mesa (legacy)." },
      { "event": "mesa.renombrada",      "handler": "onMesaRenombrada",      "description": "Actualizar nombre de mesa cuando se renombra." },
      { "event": "cuenta.eliminada",     "handler": "onCuentaEliminada",     "description": "Limpiar cache de ref_display al eliminar cuenta." },
      { "event": "mesa.cerrada",         "handler": "onMesaCerrada",         "description": "Limpiar cache de nombre al cerrar mesa." },
      { "event": "llevar.ticket_creado", "handler": "onLlevarTicketCreado",  "description": "Cachear nombre de ticket llevar (legacy)." },
      { "event": "cuenta.actualizada",   "handler": "onCuentaActualizada",   "description": "Actualizar ref_display en cache cuando se renombra cualquier cuenta." },
      { "event": "caja.cerrada",         "handler": "onCajaCerrada",         "description": "Cierre de caja — limpiar caches y historial + reset metricas." },
      { "event": "dia.iniciado",         "handler": "onDiaIniciado",         "description": "Nuevo dia — limpiar caches." }
    ]
  },
  "ui_handlers": [
    { "domain": "impresion", "action": "ticket",       "handler": "handleImprimirComanda",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "impresion", "action": "ticket-venta", "handler": "handleImprimirTicketVenta", "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "impresion", "action": "estado",       "handler": "handleGetEstado",           "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "impresion", "action": "historial",    "handler": "handleGetHistorial",        "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "impresion", "action": "health",       "handler": "handleHealthCheck",         "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "impresion", "action": "metrics",      "handler": "handleGetMetrics",          "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "impresion", "action": "impresoras",   "handler": "handleListarImpresoras",    "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [],
  "config": {
    "ancho":           "58mm",
    "destino_default": "",
    "persistence": {
      "type":  "in-memory + mqtt-passthrough",
      "notes": "El modulo NO persiste a disco — los tickets se generan en memoria y se envian via MQTT directo a ESP32. El historial es ring buffer en memoria (last 100). Caches se limpian en caja.cerrada / dia.iniciado."
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "impresion.comanda.total",
        "impresion.reimpresion.total",
        "impresion.error.total",
        "impresion.impresoras.descubiertas",
        "impresion.errors"
      ]
    }
  }
}
