{
  "name": "{{name}}",
  "version": "1.0.0",
  "description": "Tema {{name}} para Auto-UI",
  "base": "{{base}}",

  "colors": {
    {{#if (eq base "dark")}}
    "bg": "#0f1216",
    "bg-card": "#1a1d24",
    "bg-hover": "#252a33",
    "bg-input": "#0d0f12",
    "text": "#ffffff",
    "text-muted": "#9ca3af",
    "text-disabled": "#6b7280",
    "primary": "#3b82f6",
    "primary-hover": "#2563eb",
    "success": "#22c55e",
    "success-hover": "#16a34a",
    "warning": "#f59e0b",
    "warning-hover": "#d97706",
    "danger": "#ef4444",
    "danger-hover": "#dc2626",
    "info": "#06b6d4",
    "border": "#374151",
    "border-focus": "#3b82f6",
    "overlay": "rgba(0,0,0,0.7)"
    {{else if (eq base "light")}}
    "bg": "#ffffff",
    "bg-card": "#f9fafb",
    "bg-hover": "#f3f4f6",
    "bg-input": "#ffffff",
    "text": "#111827",
    "text-muted": "#6b7280",
    "text-disabled": "#9ca3af",
    "primary": "#2563eb",
    "primary-hover": "#1d4ed8",
    "success": "#16a34a",
    "success-hover": "#15803d",
    "warning": "#d97706",
    "warning-hover": "#b45309",
    "danger": "#dc2626",
    "danger-hover": "#b91c1c",
    "info": "#0891b2",
    "border": "#e5e7eb",
    "border-focus": "#2563eb",
    "overlay": "rgba(0,0,0,0.5)"
    {{else if (eq base "high-contrast")}}
    "bg": "#000000",
    "bg-card": "#1a1a1a",
    "bg-hover": "#333333",
    "bg-input": "#000000",
    "text": "#ffffff",
    "text-muted": "#cccccc",
    "text-disabled": "#666666",
    "primary": "#00ff00",
    "primary-hover": "#00cc00",
    "success": "#00ff00",
    "success-hover": "#00cc00",
    "warning": "#ffff00",
    "warning-hover": "#cccc00",
    "danger": "#ff0000",
    "danger-hover": "#cc0000",
    "info": "#00ffff",
    "border": "#ffffff",
    "border-focus": "#00ff00",
    "overlay": "rgba(0,0,0,0.9)"
    {{else}}
    "bg": "#0f1216",
    "bg-card": "#1a1d24",
    "bg-hover": "#252a33",
    "bg-input": "#0d0f12",
    "text": "#ffffff",
    "text-muted": "#9ca3af",
    "text-disabled": "#6b7280",
    "primary": "#3b82f6",
    "primary-hover": "#2563eb",
    "success": "#22c55e",
    "success-hover": "#16a34a",
    "warning": "#f59e0b",
    "warning-hover": "#d97706",
    "danger": "#ef4444",
    "danger-hover": "#dc2626",
    "info": "#06b6d4",
    "border": "#374151",
    "border-focus": "#3b82f6",
    "overlay": "rgba(0,0,0,0.7)"
    {{/if}}
  },

  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px"
  },

  "radius": {
    "none": "0",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "full": "9999px"
  },

  "typography": {
    "font": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "font-mono": "'JetBrains Mono', 'Fira Code', monospace",
    "size-xs": "0.75rem",
    "size-sm": "0.875rem",
    "size-base": "1rem",
    "size-lg": "1.25rem",
    "size-xl": "1.5rem",
    "size-2xl": "2rem",
    "weight-normal": "400",
    "weight-medium": "500",
    "weight-semibold": "600",
    "weight-bold": "700",
    "line-height": "1.5"
  },

  "shadows": {
    "none": "none",
    {{#if (eq base "light")}}
    "sm": "0 1px 2px rgba(0,0,0,0.05)",
    "md": "0 4px 6px rgba(0,0,0,0.1)",
    "lg": "0 10px 15px rgba(0,0,0,0.15)",
    "xl": "0 20px 25px rgba(0,0,0,0.2)"
    {{else}}
    "sm": "0 1px 2px rgba(0,0,0,0.3)",
    "md": "0 4px 6px rgba(0,0,0,0.4)",
    "lg": "0 10px 15px rgba(0,0,0,0.5)",
    "xl": "0 20px 25px rgba(0,0,0,0.6)"
    {{/if}}
  },

  "transitions": {
    "fast": "150ms ease",
    "normal": "250ms ease",
    "slow": "350ms ease"
  },

  "components": {
    "button": {
      "padding": "0.5rem 1rem",
      "padding-sm": "0.25rem 0.5rem",
      "padding-lg": "0.75rem 1.5rem",
      "font-weight": "500",
      "border-radius": "var(--radius-md)"
    },
    "input": {
      "padding": "0.5rem 0.75rem",
      "border-width": "1px",
      "border-radius": "var(--radius-md)"
    },
    "card": {
      "padding": "1rem",
      "border-width": "1px",
      "border-radius": "var(--radius-lg)"
    },
    "table": {
      "header-bg": "rgba({{#if (eq base "light")}}0,0,0{{else}}255,255,255{{/if}},0.05)",
      "row-hover": "rgba({{#if (eq base "light")}}0,0,0{{else}}255,255,255{{/if}},0.02)",
      "cell-padding": "0.75rem 1rem"
    },
    "modal": {
      "backdrop": "var(--overlay)",
      "max-width": "500px",
      "border-radius": "var(--radius-xl)"
    }
  },

  "meta": {
    "generated_at": "{{currentDate}}",
    "generator": "plop ui-theme"
  }
}
