      "parameters_size_chars": 135,
      "parameters_full_path_hint": "modules/pizzepos/carta-scheduler/module.json → tools[3].parameters"
    },
    {
      "name": "scheduler.proximos_cambios",
      "description": "Lista cambios pendientes de confirmación (triggered pero esperando al usuario)",
      "parameters_required": ["project_id"],
      "parameters_property_names": ["project_id"],
      "parameters_size_chars": 89,
      "parameters_full_path_hint": "modules/pizzepos/carta-scheduler/module.json → tools[4].parameters"
    },
    {
      "name": "scheduler.confirmar",
      "description": "Usuario confirma un cambio pendiente. Aplica los cambios via tarifas.assign.",
      "parameters_required": ["project_id", "pendiente_id"],
      "parameters_property_names": ["project_id", "pendiente_id"],
      "parameters_size_chars": 137,
      "parameters_full_path_hint": "modules/pizzepos/carta-scheduler/module.json → tools[5].parameters"
    },
    {
      "name": "scheduler.rechazar",
      "description": "Usuario rechaza un cambio pendiente. No se aplica.",
      "parameters_required": ["project_id", "pendiente_id"],
      "parameters_property_names": ["project_id", "pendiente_id", "razon"],
      "parameters_size_chars": 163,
      "parameters_full_path_hint": "modules/pizzepos/carta-scheduler/module.json → tools[6].parameters"
    }
