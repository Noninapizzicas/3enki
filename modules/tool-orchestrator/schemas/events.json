{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/tool-orchestrator/events.json",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": { "type": "string", "format": "uuid" },
        "event_type": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "producer": { "type": "string", "const": "tool-orchestrator" },
        "schema_version": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "tool_registered": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "tool.registered" },
            "payload": {
              "type": "object",
              "required": ["full_name", "module_name", "tool_name", "registered_at"],
              "properties": {
                "full_name": { "type": "string" },
                "module_name": { "type": "string" },
                "tool_name": { "type": "string" },
                "description": { "type": "string" },
                "has_schema": { "type": "boolean" },
                "registered_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "tool_unregistered": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "tool.unregistered" },
            "payload": {
              "type": "object",
              "required": ["full_name", "unregistered_at"],
              "properties": {
                "full_name": { "type": "string" },
                "unregistered_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "tool_call_success": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "tool.call.success" },
            "payload": {
              "type": "object",
              "required": ["full_name", "duration"],
              "properties": {
                "full_name": { "type": "string" },
                "request_id": { "type": "string" },
                "duration": { "type": "integer" },
                "has_result": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "tool_call_failed": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "tool.call.failed" },
            "payload": {
              "type": "object",
              "required": ["full_name", "error", "reason"],
              "properties": {
                "full_name": { "type": "string" },
                "request_id": { "type": "string" },
                "error": { "type": "string" },
                "reason": { "type": "string", "enum": ["not_found", "invalid_arguments", "execution_error", "timeout"] }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "tool_call_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "tool.call.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "result": {},
                "duration": { "type": "integer" },
                "error": { "type": "string" },
                "details": { "type": "array" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "tool_list_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "tool.list.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success", "tools", "count"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "tools": { "type": "array" },
                "count": { "type": "integer" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "tool_get_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "tool.get.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "tool": { "type": "object" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
