        "apis": ["Ver", "Extraer texto", "Metadata", "Listar PDFs"],
        "tools": ["pdf.list", "pdf.metadata", "pdf.extract"],
        "config": {
          "cache_ttl_h": 1,
          "max_file_mb": 50
        }
      },
      "notas": {
        "version": "1.0.0",
        "descripcion": "Notas rápidas con eventos en tiempo real",
        "apis": ["CRUD notas", "Pin/unpin"],
        "eventos_publica": ["nota.creada", "nota.actualizada", "nota.eliminada"],
        "caracteristicas": ["Codificación por color", "Filtrado de notas fijadas"]
      }
