{
  "name": "plugin-manager",
  "version": "2.1.0",
  "description": "Descubre y gestiona plugins JSON con funciones ejecutables. Plugins viven en <pluginsPath>/<plugin-name>/<plugin-name>.functions.json. Expone par request/response via bus + 5 endpoints HTTP.",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",

  "events": {
    "publishes": [
      { "event": "plugin.loaded",        "description": "Plugin cargado correctamente desde fs. Payload: { name, definition, version, description, functions, function_count, timestamp, correlation_id }.", "schema": { "$ref": "./schemas/events.json#/definitions/plugin_loaded" } },
      { "event": "plugin.unloaded",      "description": "Plugin removido (en onUnload). Payload: { name, timestamp, correlation_id }.", "schema": { "$ref": "./schemas/events.json#/definitions/plugin_unloaded" } },
      { "event": "plugin.error",         "description": "Error de discovery o load. Payload: { error, context: 'discovery'|'load', file?, timestamp, correlation_id }.", "schema": { "$ref": "./schemas/events.json#/definitions/plugin_error" } },
      { "event": "plugin.reloaded",      "description": "Reload completo. Payload: { count, loaded, errors, timestamp, correlation_id }.", "schema": { "$ref": "./schemas/events.json#/definitions/plugin_reloaded" } },
      { "event": "plugin.get.response",  "description": "Response a plugin.get.request correlacionada por request_id. Payload: { request_id, success, plugin? | error?, error_code?, timestamp, correlation_id }.", "schema": { "$ref": "./schemas/events.json#/definitions/plugin_get_response" } },
      { "event": "plugin.list.response", "description": "Response a plugin.list.request correlacionada por request_id. Payload: { request_id, success, plugins, count, timestamp, correlation_id }.", "schema": { "$ref": "./schemas/events.json#/definitions/plugin_list_response" } }
    ],
    "subscribes": [
      { "event": "plugin.get.request",  "handler": "onGetPluginRequest",   "description": "Get plugin definition by name. Publica plugin.get.response." },
      { "event": "plugin.list.request", "handler": "onListPluginsRequest", "description": "List all loaded plugins. Publica plugin.list.response." }
    ]
  },

  "ui_handlers": [
    { "domain": "plugin-manager", "action": "get",     "handler": "handleGetPlugin",     "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "plugin-manager", "action": "list",    "handler": "handleListPlugins",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "plugin-manager", "action": "reload",  "handler": "handleReloadPlugins", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "plugin-manager", "action": "health",  "handler": "handleHealthCheck",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "plugin-manager", "action": "metrics", "handler": "handleGetMetrics",    "type": "system_panel", "zone": "lateral_derecha" }
  ],

  "tools": [],
  "dependencies": [],

  "tracing": {
    "propaga_correlation_id": true
  },

  "config": {
    "pluginsPath": "../../plugins",
    "autoReload": false,
    "watchInterval": 5000,
    "validateSchema": true,
    "persistence": {
      "pattern": "filesystem-readonly",
      "restart_resilient": true,
      "concurrency": "single-writer",
      "lost_on_restart": ["plugins", "watchInterval", "internalCounters"]
    }
  },

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "tracing": {
      "propaga_correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "plugin-manager.plugin.loaded",
        "plugin-manager.reload.success",
        "plugin-manager.request.success",
        "plugin-manager.errors"
      ],
      "gauges": [
        "plugin-manager.plugins_count",
        "plugin-manager.functions_count"
      ]
    }
  }
}
