{
  "system": {
    "location": "modules/",
    "loader": "core/modules/loader.js",
    "discovery": "automatic (scans modules/ directory, recursive into subdirectories)",
    "subdirectory_scanning": {
      "descripcion": "Si un directorio en modules/ no tiene module.json, el loader escanea sus subdirectorios buscando módulos",
      "ejemplo": "modules/pizzepos/ no tiene module.json → escanea modules/pizzepos/pedidos/, modules/pizzepos/cobros/, etc.",
      "uso": "Permite agrupar módulos por vertical/dominio sin modificar el loader"
    }
  },
  "module_structure": {
    "required_files": {
      "module.json": "Module metadata, APIs, events",
      "index.js": "Module class with lifecycle hooks"
    },
    "optional_files": {
      "README.md": "Human documentation",
      "static/": "Static files served at /modules/{name}/"
    }
  },
  "module_json_schema": {
    "name": "string (kebab-case)",
    "version": "string (semver)",
    "description": "string",
    "apis": [
      {
        "name": "string",
        "method": "GET|POST|PUT|DELETE",
        "path": "string (e.g., /items)",
        "handler": "string (method name)"
      }
    ],
    "events": {
      "publishes": ["event.name"],
      "subscribes": ["event.name"]
    },
    "tools": [
      {
        "name": "string (module.action)",
        "description": "string",
        "handler": "string (method name)",
        "parameters": "JSON Schema object"
      }
    ],
    "ui": {
      "zone": "work-bar|chat-config|chat-tools",
      "icon": "emoji"
    }
  },
  "lifecycle_hooks": {
    "onLoad": {
      "signature": "async onLoad(context)",
      "context_properties": [
        "eventBus",
        "logger",
        "metrics",
        "uiHandler",
        "config"
      ],
      "purpose": "Initialize module, register handlers"
    },
    "onUnload": {
      "signature": "async onUnload()",
      "purpose": "Cleanup resources"
    }
  },
  "ui_handler_registration": {
    "in_onLoad": true,
    "pattern": "context.uiHandler.register('domain', 'action', this.handler.bind(this))",
    "handler_return": "{ status: number, data?: any, error?: string }"
  },
  "active_modules": [
    "admin-panel",
    "ai-agent-framework",
    "ai-gateway",
    "calling-generator",
    "chat-ai-bridge",
    "chat-session",
    "credential-manager",
    "dashboard",
    "database-manager",
    "filesystem",
    "flow-engine",
    "log-manager",
    "menu-generator",
    "metricas",
    "notas",
    "plugin-manager",
    "project-manager",
    "prompt-composer",
    "prompt-manager",
    "scheduler",
    "system-inspector",
    "telegram-service",
    "ui-designer",
    "pizzepos/cuentas-canales",
    "pizzepos/pedidos",
    "pizzepos/cobros",
    "pizzepos/cocina",
    "pizzepos/comandero",
    "pizzepos/productos",
    "pizzepos/categorias",
    "pizzepos/ingredientes",
    "pizzepos/variaciones",
    "pizzepos/menu-generator",
    "pizzepos/persistencia-comandero",
    "pizzepos/cuentas"
  ],
  "module_categories": {
    "ai": {
      "description": "Módulos de inteligencia artificial",
      "modules": ["ai-gateway", "ai-agent-framework", "menu-generator", "calling-generator"]
    },
    "chat": {
      "description": "Módulos del stack de chat/conversaciones",
      "modules": ["chat-session", "chat-ai-bridge", "prompt-composer"]
    },
    "project": {
      "description": "Módulos de gestión de proyectos y composición",
      "modules": ["project-manager"]
    },
    "communication": {
      "description": "Módulos de comunicación externa",
      "modules": ["telegram-service"]
    },
    "processing": {
      "description": "Módulos de procesamiento de datos",
      "modules": ["pdf-viewer"]
    },
    "storage": {
      "description": "Módulos de almacenamiento",
      "modules": ["database-manager", "filesystem", "credential-manager"]
    },
    "ui": {
      "description": "Módulos de interfaz de usuario",
      "modules": ["admin-panel", "dashboard", "ui-designer", "notas"]
    },
    "system": {
      "description": "Módulos del sistema",
      "modules": ["log-manager", "system-inspector", "plugin-manager", "metricas", "scheduler", "flow-engine"]
    },
    "pizzepos": {
      "description": "Vertical POS pizzería — 12 módulos en modules/pizzepos/. Ver contexto/pizzepos.json para documentación completa",
      "location": "modules/pizzepos/",
      "modules": [
        "cuentas-canales (5 canales: mesa, telefono, llevar, glovo, whatsapp)",
        "pedidos", "cobros", "cocina", "comandero",
        "productos", "categorias", "ingredientes", "variaciones",
        "menu-generator", "persistencia-comandero", "cuentas"
      ]
    }
  },
  "key_modules": {
    "telegram-service": {
      "version": "3.0.0",
      "description": "Bot de Telegram multi-instancia",
      "events": {
        "publishes": [
          "telegram.text.received",
          "telegram.photo.received",
          "telegram.document.received",
          "telegram.video.received",
          "telegram.audio.received",
          "telegram.voice.received",
          "telegram.location.received",
          "telegram.contact.received",
          "telegram.command.received",
          "telegram.callback.received",
          "telegram.message.sent",
          "telegram.bot.started",
          "telegram.bot.stopped"
        ],
        "subscribes": [
          "credential.saved",
          "credential.deleted"
        ]
      },
      "key_apis": [
        "POST /send - Enviar mensaje",
        "GET /file/:fileId - Obtener archivo",
        "GET /bots - Listar bots activos"
      ]
    },
    "ai-agent-framework": {
      "version": "1.0.0",
      "description": "Framework para agentes AI event-driven",
      "components": ["Agent", "ContextManager", "ToolManager"],
      "builtin_tools": ["http_request", "publish_event", "read_file", "write_file"],
      "events": {
        "publishes": [
          "agent.{name}.started",
          "agent.{name}.completed",
          "agent.{name}.failed"
        ]
      },
      "key_apis": [
        "POST /agents - Crear agente",
        "GET /agents - Listar agentes",
        "POST /agents/:id/trigger - Ejecutar agente manualmente"
      ]
    },
    "ai-gateway": {
      "version": "1.0.0",
      "description": "Gateway unificado para LLMs",
      "providers": {
        "deepseek": { "priority": 1, "models": ["deepseek-chat", "deepseek-coder"] },
        "anthropic": { "priority": 2, "models": ["claude-3-5-sonnet", "claude-3-haiku"] },
        "openai": { "priority": 3, "models": ["gpt-4o", "gpt-4o-mini"] },
        "ollama": { "priority": 4, "models": ["llama2", "mistral"] }
      },
      "key_apis": [
        "POST /chat - Chat completion",
        "GET /providers - Listar providers"
      ]
    },
    "prompt-manager": {
      "version": "1.0.0",
      "description": "Gestión de prompts con versionado",
      "storage": "SQLite",
      "slot_types": ["system", "context", "prefix", "suffix", "format"],
      "key_apis": [
        "POST /prompts - Crear prompt",
        "GET /prompts - Listar prompts",
        "POST /prompts/:id/render - Renderizar con variables"
      ]
    },
    "project-manager": {
      "version": "2.0.0",
      "description": "Gestión de proyectos con composición progresiva (links, dependencias, sistemas, contexto compartido)",
      "features": {
        "core": "CRUD de proyectos, activación, sesiones, AI config",
        "composition": {
          "links": "Relacionar proyectos entre sí (inspired_by, related_to, evolved_from)",
          "dependencies": "Declarar dependencias (data, code, api, context)",
          "systems": "Agrupar proyectos en sistemas/contenedores lógicos",
          "shared_context": "Compartir conversaciones entre proyectos",
          "inherited_context": "Contexto automático para prompts AI"
        }
      },
      "tables": ["projects", "systems", "project_links", "project_dependencies", "shared_context"],
      "events": {
        "publishes": [
          "project.created", "project.updated", "project.deleted", "project.activated",
          "project.linked", "project.unlinked",
          "project.dependency.added", "project.dependency.removed",
          "system.created", "system.updated", "system.deleted",
          "project.joined_system", "project.left_system",
          "context.imported", "context.removed",
          "context.full.response"
        ],
        "subscribes": [
          "project.get.request", "project.list.request", "project.active.request",
          "context.full.request"
        ]
      },
      "ui_handlers": {
        "project": ["list", "get", "create", "update", "delete", "activate", "link", "unlink", "getLinks", "addDependency", "removeDependency", "getDependencies", "getDependents"],
        "system": ["create", "list", "get", "update", "delete", "addProject", "removeProject", "getUnassigned"],
        "context": ["import", "remove", "getShared", "getExported", "getAvailableSources", "getFullProjectContext"]
      }
    },
    "prompt-composer": {
      "version": "1.1.0",
      "description": "Composición de system prompts con contexto heredado de proyectos",
      "features": [
        "Composición de system prompts con templates",
        "Sustitución de variables {{variable}}",
        "Contexto heredado automático de proyectos relacionados"
      ],
      "inherited_context_sections": [
        "## System Context - sistema al que pertenece el proyecto",
        "## Dependencies - proyectos de los que depende",
        "## Related Projects - proyectos relacionados",
        "## Inherited Knowledge - summaries de conversaciones importadas"
      ],
      "events": {
        "publishes": ["prompt.compose.response", "context.full.request"],
        "subscribes": ["prompt.compose.request", "context.full.response"]
      },
      "usage": {
        "with_inherited_context": "eventBus.publish('prompt.compose.request', { project_id, include_inherited_context: true })"
      }
    },
    "chat-session": {
      "version": "1.0.0",
      "description": "Persistencia CRUD de conversaciones y mensajes",
      "responsibilities": [
        "CRUD de conversaciones en SQLite",
        "CRUD de mensajes",
        "Context FIFO management",
        "Schema management por proyecto"
      ],
      "events": {
        "publishes": ["session.*.response", "conversation.created", "message.saved"],
        "subscribes": ["session.*.request"]
      }
    },
    "chat-ai-bridge": {
      "version": "1.0.0",
      "description": "Orquestador de flujo entre chat y ai-gateway",
      "responsibilities": [
        "Coordinar flujo: session → prompt → ai-gateway",
        "Manejar respuesta y guardar mensaje",
        "Flow state tracking con stages"
      ],
      "events": {
        "publishes": ["chat.send.response", "ai.chat.request", "session.save.request", "prompt.compose.request"],
        "subscribes": ["chat.send.request", "ai.chat.response", "session.save.response", "prompt.compose.response"]
      }
    },
    "scheduler": {
      "version": "1.0.0",
      "description": "Sistema avanzado de scheduling con múltiples tipos de triggers",
      "trigger_types": {
        "cron": "Expresiones cron estándar (0 3 * * *)",
        "interval": "Intervalos fijos (30s, 5m, 1h)",
        "datetime": "Fecha/hora específica con repetición (once, daily, weekly, monthly, yearly)",
        "event": "Basado en eventos MQTT con condiciones y debounce",
        "condition": "Evaluación periódica de condiciones JS",
        "composite": "Combinación con lógica AND/OR/XOR"
      },
      "action_types": {
        "mqtt": "Publicar evento MQTT",
        "http": "Llamada HTTP externa",
        "module": "Llamar método de módulo via eventos"
      },
      "features": [
        "Templates en topics y payloads ({{now}}, {{job.id}}, {{event.payload}})",
        "Persistencia en JSON (data/scheduler/jobs.json)",
        "Retry con backoff configurable",
        "Historial de ejecuciones",
        "AI tools para gestión de jobs"
      ],
      "events": {
        "publishes": [
          "scheduler.job.created",
          "scheduler.job.updated",
          "scheduler.job.deleted",
          "scheduler.job.enabled",
          "scheduler.job.disabled",
          "scheduler.job.triggered",
          "scheduler.job.completed",
          "scheduler.job.failed"
        ]
      },
      "key_apis": [
        "GET /jobs - Listar jobs",
        "POST /jobs - Crear job",
        "POST /jobs/:id/trigger - Disparar manualmente",
        "GET /triggers/types - Tipos de triggers disponibles"
      ],
      "ui_handlers": {
        "scheduler": ["list", "get", "create", "update", "delete", "enable", "disable", "trigger", "triggers", "stats", "executions"]
      }
    },
    "flow-engine": {
      "version": "2.0.0",
      "description": "Motor de flujos declarativos event-driven con ejecución de pasos",
      "arquitectura": {
        "flow-registry": "Gestión y validación de definiciones de flujos",
        "flow-executor": "Ejecución de pasos con contexto y variables",
        "step-handlers": "Handlers para cada tipo de step (service, http, transform, condition, etc.)",
        "variable-resolver": "Resolución de templates {{ }} con funciones extensibles",
        "flow-validator": "Validación JSON Schema de flujos",
        "scheduler": "Facade que delega al módulo scheduler"
      },
      "step_types": {
        "service": "Llama a un servicio via eventos (service + function)",
        "http": "Petición HTTP externa",
        "transform": "Transforma datos con mapping/template",
        "condition": "Ejecución condicional (if/then/else)",
        "parallel": "Ejecución paralela de branches",
        "loop": "Iteración sobre arrays",
        "wait": "Pausa temporal",
        "emit": "Publica evento MQTT",
        "set": "Establece variables en contexto",
        "agent": "Modo dual: named agent o inline AI (model/prompt/system)"
      },
      "features": [
        "Triggers por evento MQTT con filtros",
        "Scheduling delegado a módulo scheduler",
        "Variable resolver con 25+ funciones (string, math, object, conversion)",
        "Operadores lógicos en condiciones (&&, ||, !)",
        "JSON Schema validation en registro",
        "Retry con exponential backoff",
        "Persistencia de historial de ejecuciones",
        "Soporte multi-proyecto con templates"
      ],
      "events": {
        "publishes": [
          "flow.started",
          "flow.completed",
          "flow.failed",
          "flow.step.started",
          "flow.step.completed",
          "flow.step.failed"
        ],
        "subscribes": [
          "flow.trigger",
          "ai.chat.response",
          "agent.execute.response",
          "scheduler.job.triggered",
          "scheduler.job.created"
        ]
      },
      "key_apis": [
        "GET /flows - Listar flujos",
        "POST /flows - Registrar flujo",
        "POST /flows/:id/execute - Ejecutar flujo",
        "GET /flows/:id/history - Historial de ejecuciones",
        "POST /flows/validate - Validar flujo sin registrar",
        "GET /flows/schema - Obtener JSON Schema"
      ],
      "ui_handlers": {
        "flow": ["list", "get", "create", "update", "delete", "execute", "history", "validate", "schema"]
      },
      "integraciones": {
        "scheduler": "Delega scheduling via eventos ui.request",
        "ai-gateway": "Inline AI mode usa ai.chat.request/response",
        "ai-agent-framework": "Named agent mode usa agent.execute.request/response"
      }
    }
  },
  "integration_patterns": {
    "telegram_ocr_response": {
      "description": "Procesar imagen de Telegram con OCR y responder",
      "trigger": "telegram.photo.received",
      "flow": [
        "1. Recibir evento telegram.photo.received",
        "2. GET /modules/telegram-service/file/{fileId}?download=true",
        "3. Usar services/providers/local/tesseract: tesseractService.extract({ image: base64 })",
        "4. POST /modules/telegram-service/send {chatId, text}"
      ]
    },
    "agent_creation": {
      "description": "Crear agente via Arquitecto",
      "flow": [
        "1. create_prompt con instrucciones del agente",
        "2. create_agent con prompt_id y subscribes",
        "3. Agente comienza a escuchar eventos"
      ]
    },
    "project_composition": {
      "description": "Configurar composición de proyectos para contexto heredado",
      "flow": [
        "1. Crear sistema: mqttRequest('system', 'create', { name, description })",
        "2. Añadir proyectos: mqttRequest('system', 'addProject', { system_id, project_id, role })",
        "3. Crear dependencias: mqttRequest('project', 'addDependency', { project_id, depends_on_project_id, type })",
        "4. Importar contexto: mqttRequest('context', 'import', { to_project_id, from_project_id, conversation_id, reason })",
        "5. Usar en prompts: eventBus.publish('prompt.compose.request', { project_id, include_inherited_context: true })"
      ],
      "result": "El AI recibe contexto automático de proyectos relacionados"
    },
    "chat_flow": {
      "description": "Flujo de mensaje de chat (sin facade, handlers directos)",
      "entry_points": {
        "conversation.send": "chat-ai-bridge (UI handler directo)",
        "conversation.load|create|list|get|update|delete|toggleContext|contextStats": "chat-session (UI handlers directos)"
      },
      "send_flow": [
        "1. Frontend: mqttRequest('conversation', 'send', { conversationId, content })",
        "2. UIRequestHandler → chat-ai-bridge.handleConversationSend()",
        "3. chat-ai-bridge obtiene proyecto activo (project.active.request)",
        "4. chat-ai-bridge crea conversación si no existe (session.create.request → chat-session)",
        "5. chat-ai-bridge guarda mensaje usuario (session.save.request → chat-session)",
        "6. chat-ai-bridge compone prompt (prompt.compose.request → prompt-composer)",
        "7. chat-ai-bridge llama AI (ai.chat.request → ai-gateway, con agentic loop)",
        "8. chat-ai-bridge guarda respuesta + safety-net MQTT QoS 1",
        "9. UIRequestHandler devuelve resultado al frontend"
      ]
    }
  }
}
