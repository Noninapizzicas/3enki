{
  "name": "admin-panel",
  "version": "1.0.0",
  "description": "Web-based admin panel for managing Event Core system",
  "dependencies": [
    "ui-renderer"
  ],
  "apis": [
    {
      "method": "GET",
      "path": "/",
      "handler": "handleUi"
    },
    {
      "method": "GET",
      "path": "/api/dashboard",
      "handler": "handleDashboardData"
    },
    {
      "method": "GET",
      "path": "/api/modules",
      "handler": "handleListModules"
    },
    {
      "method": "GET",
      "path": "/api/plugins",
      "handler": "handleListPlugins"
    },
    {
      "method": "POST",
      "path": "/api/plugins/:name/toggle",
      "handler": "handleTogglePlugin"
    },
    {
      "method": "GET",
      "path": "/api/agents",
      "handler": "handleListAgents"
    },
    {
      "method": "POST",
      "path": "/api/agents",
      "handler": "handleCreateAgent"
    },
    {
      "method": "DELETE",
      "path": "/api/agents/:id",
      "handler": "handleDeleteAgent"
    },
    {
      "method": "GET",
      "path": "/api/prompts",
      "handler": "handleListPrompts"
    },
    {
      "method": "GET",
      "path": "/api/prompts/:name",
      "handler": "handleGetPrompt"
    },
    {
      "method": "POST",
      "path": "/api/prompts",
      "handler": "handleCreatePrompt"
    },
    {
      "method": "PUT",
      "path": "/api/prompts/:name",
      "handler": "handleUpdatePrompt"
    }
  ],
  "events": {
    "publishes": [
      "admin.action"
    ],
    "subscribes": [
      {
        "event": "plugin.loaded",
        "handler": "onPluginLoaded"
      }
    ]
  },

  "ui": {
    "enabled": true,
    "title": "Admin Panel",
    "icon": "⚙️",
    "description": "System administration and monitoring"
  },

  "schema": {
    "id": {
      "type": "string",
      "label": "ID"
    },
    "module_name": {
      "type": "string",
      "label": "Module",
      "required": true
    },
    "status": {
      "type": "enum",
      "label": "Status",
      "enum": ["active", "inactive", "error"],
      "required": true
    },
    "version": {
      "type": "string",
      "label": "Version"
    },
    "type": {
      "type": "enum",
      "label": "Type",
      "enum": ["module", "plugin", "agent", "prompt"]
    },
    "description": {
      "type": "text",
      "label": "Description"
    },
    "created_at": {
      "type": "datetime",
      "label": "Created"
    },
    "updated_at": {
      "type": "datetime",
      "label": "Updated"
    }
  }
}