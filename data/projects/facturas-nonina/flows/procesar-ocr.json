{
  "id": "procesar-ocr",
  "name": "Procesar OCR con Google Vision",
  "description": "Extrae texto de documentos recibidos usando Google Vision OCR",
  "version": "1.1.0",
  "enabled": true,

  "trigger": {
    "event": "facturas-nonina.documento.pendiente",
    "filter": {
      "mimeType": {
        "$in": ["image/jpeg", "image/png", "image/webp"]
      }
    }
  },

  "steps": [
    {
      "id": "log-inicio",
      "type": "log",
      "level": "info",
      "message": "Iniciando OCR para: {{ trigger.archivo }}"
    },
    {
      "id": "extraer-texto",
      "type": "service",
      "service": "local.google-vision",
      "action": "extract",
      "image": "{{ trigger.archivo }}",
      "hint": "DOCUMENT_TEXT_DETECTION",
      "languageHints": ["es", "en"],
      "onError": "notificar-error-ocr"
    },
    {
      "id": "verificar-resultado",
      "type": "condition",
      "if": "{{ steps.extraer-texto.success }} == true",
      "then": "guardar-texto",
      "else": "notificar-error-ocr"
    },
    {
      "id": "guardar-texto",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "{{ trigger.archivo }}.ocr.txt",
      "content": "{{ steps.extraer-texto.data.text }}",
      "onError": "continue"
    },
    {
      "id": "preparar-resultado-ocr",
      "type": "transform",
      "operation": "map",
      "config": {
        "mapping": {
          "archivo": "{{ trigger.archivo }}",
          "procesado": "{{ now }}",
          "exito": true,
          "confianza": "{{ steps.extraer-texto.data.confidence }}",
          "idioma": "{{ steps.extraer-texto.data.locale }}",
          "bloques": "{{ steps.extraer-texto.data.blocks }}",
          "caracteresTexto": "{{ steps.extraer-texto.data.textLength }}",
          "hint": "{{ steps.extraer-texto.data.hint }}"
        }
      }
    },
    {
      "id": "guardar-resultado-ocr",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "{{ trigger.archivo }}.ocr.json",
      "content": "{{ json(steps.preparar-resultado-ocr) }}",
      "onError": "continue"
    },
    {
      "id": "notificar-exito",
      "type": "service",
      "service": "telegram",
      "action": "send_message",
      "chatId": "{{ trigger.chatId }}",
      "text": "OCR completado ({{ steps.extraer-texto.data.confidence }}% confianza).\nTexto extraido: {{ steps.extraer-texto.data.textLength }} caracteres.",
      "onError": "continue"
    },
    {
      "id": "log-exito",
      "type": "log",
      "level": "info",
      "message": "OCR completado: {{ trigger.archivo }} - {{ steps.extraer-texto.data.textLength }} chars, {{ steps.extraer-texto.data.confidence }}% confianza"
    },
    {
      "id": "emitir-ocr-completado",
      "type": "emit",
      "event": "facturas-nonina.ocr.completado",
      "data": {
        "archivo": "{{ trigger.archivo }}",
        "botName": "{{ trigger.botName }}",
        "success": true,
        "textLength": "{{ steps.extraer-texto.data.textLength }}",
        "confidence": "{{ steps.extraer-texto.data.confidence }}",
        "chatId": "{{ trigger.chatId }}",
        "username": "{{ trigger.username }}"
      }
    },
    {
      "id": "notificar-error-ocr",
      "type": "service",
      "service": "telegram",
      "action": "send_message",
      "chatId": "{{ trigger.chatId }}",
      "text": "Error en OCR: {{ default(steps.extraer-texto.error, 'Error desconocido') }}",
      "onError": "continue"
    },
    {
      "id": "log-error",
      "type": "log",
      "level": "error",
      "message": "Error OCR {{ trigger.archivo }}: {{ default(steps.extraer-texto.error, error.message) }}"
    }
  ]
}
