{
  "name": "agent-bridge",
  "version": "1.0.0",
  "description": "Capa de traducción entre el contrato de eventos de conversación (agent.execute) y el ai-agent-framework (agent.execute.request). Añade conversation_id al ciclo de vida del agente y persiste ejecuciones en SQLite.",
  "author": "Event Core Team",
  "main": "index.js",

  "subscribes": [
    { "event": "agent.execute",        "handler": "onAgentExecute" },
    { "event": "chat.message.routed",  "handler": "onChatMessageRouted" },
    { "event": "db.query.response",    "handler": "onDbQueryResponse" },
    { "event": "project.activated",    "handler": "onProjectActivated" },
    { "event": "project.deactivated",  "handler": "onProjectDeactivated" }
  ],

  "publishes": [
    "agent.execute.request",
    "agent.completed",
    "agent.failed",
    "agent.progress",
    "agent.user_reply",
    "agent.active"
  ],

  "observability": {
    "metrics": {
      "counters": [
        "agent_bridge.dispatched",
        "agent_bridge.completed",
        "agent_bridge.failed",
        "agent_bridge.timeout"
      ]
    }
  },

  "config": {
    "execution_timeout_ms": 0,
    "db_timeout_ms": 10000
  }
}
