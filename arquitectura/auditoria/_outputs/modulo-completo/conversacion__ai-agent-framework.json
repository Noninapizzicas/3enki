  "lifecycle": {
    "onLoad": {
      "ubicacion": "modules/conversacion/ai-agent-framework/index.js:36",
      "acciones": [
        "guarda this.logger = context.logger",
        "guarda this.eventBus = context.eventBus",
        "guarda this.moduleLoader = context.moduleLoader || null",
        "_loadBasePrompt() — fs.readFileSync base.prompt.json a this.basePromptText",
