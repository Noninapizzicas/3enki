{
  "name": "{{name}}",
  "version": "1.0.0",
  "description": "{{description}}",
  "author": "{{author}}",

  "provides": {
    "events": [{{#each publishEvents}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}],
    "queries": []
  },

  "events": {
    "publishes": [
      {{#each publishEvents}}
      {
        "event": "{{this}}",
        "description": "Evento {{this}}",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/{{snakeCase this}}"
        }
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ],

    "subscribes": [
      {{#each subscriptions}}
      {
        "event": "{{this.event}}",
        "description": "Escucha evento {{this.event}}",
        "handler": "{{this.handler}}"
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ]
  },

  "apis": [
    {{#each apis}}
    {
      "method": "{{this.method}}",
      "path": "{{this.path}}",
      "handler": "{{this.handler}}",
      "description": "{{this.description}}"{{#if this.params}},
      "params": {{json this.params}}{{/if}}
    },
    {{/each}}
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check del módulo"
    }
  ],

  {{#if ui}}
  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "{{titleCase name}}",
    "icon": "{{icon}}",
    "description": "{{description}}",

    "views": {
      "main": {
        "type": "dashboard",
        "permissions": ["admin", "user"],

        "layout": {
          "type": "two-column",
          "config": {
            "leftWidth": "65%",
            "rightWidth": "35%",
            "gap": "var(--space-lg)"
          }
        },

        "sections": [
          {
            "id": "stats",
            "widget": "stat-card",
            "config": {
              "label": "Total",
              "value": "@compute.count(@data.items)",
              "icon": "📊",
              "color": "primary",
              "trend": "+12%",
              "trendDirection": "up"
            }
          },
          {
            "id": "stats_status",
            "widget": "stat-card",
            "config": {
              "label": "Estado",
              "value": "Activo",
              "icon": "✓",
              "color": "success"
            }
          },
          {
            "id": "main_table",
            "widget": "table-advanced",
            "config": {
              "dataSource": "@data.items",
              "columns": "auto",
              "sortable": true,
              "filterable": true,
              "paginated": true,
              "actions": [
                {
                  "label": "Editar",
                  "icon": "✏️",
                  "action": "edit",
                  "permissions": ["admin"]
                },
                {
                  "label": "Eliminar",
                  "icon": "🗑️",
                  "action": "delete",
                  "permissions": ["admin"],
                  "confirm": true
                }
              ]
            }
          },
          {
            "id": "info_panel",
            "widget": "card",
            "config": {
              "title": "ℹ️ Información",
              "content": {
                "type": "info",
                "items": [
                  {
                    "label": "Versión",
                    "value": "1.0.0",
                    "icon": "🏷️"
                  },
                  {
                    "label": "Estado",
                    "value": "Activo",
                    "color": "#22c55e"
                  }
                ]
              }
            }
          }
        ]
      },

      "create": {
        "type": "form",
        "permissions": ["admin"],
        "config": {
          "title": "Crear {{titleCase name}}",
          "endpoint": "/modules/{{name}}/items",
          "method": "POST",
          "validation": true,
          "fields": "auto"
        }
      }
    },

    "mqtt": {
      "enabled": true,
      "topics": [
        "{{name}}.created",
        "{{name}}.updated",
        "{{name}}.deleted"
      ],
      "auto_refresh": true
    }
  },
  {{/if}}

  "schema": {
    "id": {
      "type": "string",
      "label": "ID",
      "format": "hidden"
    },
    "name": {
      "type": "string",
      "label": "Nombre",
      "required": true,
      "minLength": 3,
      "maxLength": 100
    },
    "status": {
      "type": "enum",
      "label": "Estado",
      "enum": ["active", "inactive"],
      "default": "active"
    }
  },

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true
    }
  },

  "config": {
    {{#if persistence}}
    "persist_interval_ms": 60000,
    {{/if}}
    "enabled": true
  }
}
