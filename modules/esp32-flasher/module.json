{
  "name": "esp32-flasher",
  "version": "1.0.0",
  "description": "Flash de firmware a ESP32 via serial (esptool/platformio) y monitor serial en tiempo real",
  "author": "Enki",
  "language": "en",
  "tier": "tier_3_core",
  "provides": {
    "events": [
      "flash.started",
      "flash.progress",
      "flash.completed",
      "flash.failed",
      "flash.serial_output"
    ]
  },
  "events": {
    "subscribes": [
      {
        "event": "firmware.build_completed",
        "handler": "onBuildCompleted",
        "description": "Notifica que hay un binario listo para flashear"
      }
    ],
    "publishes": [
      {
        "event": "flash.started",
        "description": "Flash iniciado en un puerto serial",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/flash_started"
        }
      },
      {
        "event": "flash.progress",
        "description": "Progreso de flash (porcentaje, etapa)",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/flash_progress"
        }
      },
      {
        "event": "flash.completed",
        "description": "Flash completado exitosamente",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/flash_completed"
        }
      },
      {
        "event": "flash.failed",
        "description": "Flash falló",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/flash_failed"
        }
      },
      {
        "event": "flash.serial_output",
        "description": "Línea de salida del monitor serial",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/serial_output"
        }
      }
    ]
  },
  "ui_handlers": [
    {
      "domain": "flash",
      "action": "list-ports",
      "handler": "handleListPorts"
    },
    {
      "domain": "flash",
      "action": "start",
      "handler": "handleStart",
      "schema": {
        "$ref": "./schemas/flash.json#/definitions/start_request"
      }
    },
    {
      "domain": "flash",
      "action": "status",
      "handler": "handleStatus"
    },
    {
      "domain": "flash",
      "action": "cancel",
      "handler": "handleCancel",
      "schema": {
        "$ref": "./schemas/flash.json#/definitions/cancel_request"
      }
    },
    {
      "domain": "flash",
      "action": "monitor-start",
      "handler": "handleMonitorStart",
      "schema": {
        "$ref": "./schemas/flash.json#/definitions/monitor_start_request"
      }
    },
    {
      "domain": "flash",
      "action": "monitor-stop",
      "handler": "handleMonitorStop",
      "schema": {
        "$ref": "./schemas/flash.json#/definitions/monitor_stop_request"
      }
    },
    {
      "domain": "flash",
      "action": "monitor-send",
      "handler": "handleMonitorSend",
      "schema": {
        "$ref": "./schemas/flash.json#/definitions/monitor_send_request"
      }
    },
    {
      "domain": "flash",
      "action": "history",
      "handler": "handleHistory"
    }
  ],
  "apis": [
    {
      "method": "POST",
      "path": "/debug-control",
      "handler": "handleDebugControl",
      "description": "Activar/desactivar debug remoto de un ESP32 via MQTT"
    },
    {
      "method": "GET",
      "path": "/debug-stream",
      "handler": "handleDebugStream",
      "description": "Long-poll para recibir líneas de debug de un ESP32"
    },
    {
      "method": "POST",
      "path": "/serial-relay",
      "handler": "handleSerialRelay",
      "description": "Recibe output serial del CLI local y lo publica como evento"
    },
    {
      "method": "GET",
      "path": "/cli-download",
      "handler": "handleCliDownload",
      "description": "Descarga el script enki-esp32.js para usar localmente"
    }
  ],
  "tools": [
    {
      "name": "flash.list_ports",
      "description": "Detecta puertos serial conectados (USB) donde puede haber un ESP32",
      "handler": "handleListPorts",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "flash.start",
      "description": "Flashea un firmware.bin a un ESP32 conectado por USB. Asíncrono con eventos de progreso.",
      "handler": "handleStart",
      "parameters": {
        "type": "object",
        "properties": {
          "port": {
            "type": "string",
            "description": "Puerto serial (ej: /dev/ttyUSB0)"
          },
          "binary_path": {
            "type": "string",
            "description": "Ruta al archivo .bin"
          },
          "baud": {
            "type": "number",
            "description": "Baud rate (default 460800)"
          }
        },
        "required": [
          "port",
          "binary_path"
        ]
      }
    },
    {
      "name": "flash.status",
      "description": "Estado de las operaciones de flash activas y puertos detectados",
      "handler": "handleStatus",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "flash.history",
      "description": "Historial de operaciones de flash realizadas",
      "handler": "handleHistory",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "flash.monitor_start",
      "description": "Inicia monitor serial en tiempo real en un puerto. Las líneas se publican como eventos flash.serial_output.",
      "handler": "handleMonitorStart",
      "parameters": {
        "type": "object",
        "properties": {
          "port": {
            "type": "string",
            "description": "Puerto serial (ej: /dev/ttyUSB0)"
          },
          "baud": {
            "type": "number",
            "description": "Baud rate (default 115200)"
          }
        },
        "required": [
          "port"
        ]
      }
    },
    {
      "name": "flash.monitor_stop",
      "description": "Detiene el monitor serial de un puerto",
      "handler": "handleMonitorStop",
      "parameters": {
        "type": "object",
        "properties": {
          "port": {
            "type": "string",
            "description": "Puerto serial"
          }
        },
        "required": [
          "port"
        ]
      }
    }
  ],
  "config": {
    "esptool_path": "esptool",
    "platformio_path": "platformio",
    "default_baud": 115200,
    "flash_baud": 460800,
    "monitor_baud": 115200,
    "flash_timeout_ms": 120000,
    "serial_patterns": [
      "/dev/ttyUSB*",
      "/dev/ttyACM*"
    ],
    "max_monitor_buffer": 5000,
    "max_history": 200
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "flash.started.total",
        "flash.completed.total",
        "flash.failed.total",
        "flash.cancelled.total",
        "flash.monitor_started.total"
      ],
      "gauges": [
        "flash.active.count",
        "flash.monitors.count",
        "flash.ports_detected.count"
      ],
      "timings": [
        "flash.duration"
      ]
    }
  }
}
