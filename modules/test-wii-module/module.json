{
  "name": "test-wii-module",
  "version": "1.0.0",
  "description": "Módulo de prueba para validar templates WII",
  "author": "Event Core Team",

  "provides": {
    "events": ["item.created", "item.updated"],
    "queries": []
  },

  "events": {
    "publishes": [
      {
        "event": "item.created",
        "description": "Evento item.created",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/item_created"
        }
      },
      {
        "event": "item.updated",
        "description": "Evento item.updated",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/item_updated"
        }
      }
    ],

    "subscribes": [
      {
        "event": "*.created",
        "description": "Escucha evento *.created",
        "handler": "onAnyCreated"
      }
    ]
  },

  "apis": [
    {
      "method": "GET",
      "path": "/items",
      "handler": "handleGetItems",
      "description": "GET /items"
    },
    {
      "method": "POST",
      "path": "/items",
      "handler": "handlePostItems",
      "description": "POST /items"
    },
    {
      "method": "DELETE",
      "path": "/items/:id",
      "handler": "handleDeleteItemsId",
      "description": "DELETE /items/:id"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check del módulo"
    }
  ],

  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "Test Wii Module",
    "icon": "🧪",
    "description": "Módulo de prueba para validar templates WII",

    "views": {
      "main": {
        "type": "dashboard",
        "permissions": ["admin", "user"],

        "layout": {
          "type": "two-column",
          "config": {
            "leftWidth": "65%",
            "rightWidth": "35%",
            "gap": "var(--space-lg)"
          }
        },

        "sections": [
          {
            "id": "stats",
            "widget": "stat-card",
            "config": {
              "label": "Total",
              "value": "@compute.count(@data.items)",
              "icon": "📊",
              "color": "primary",
              "trend": "+12%",
              "trendDirection": "up"
            }
          },
          {
            "id": "stats_status",
            "widget": "stat-card",
            "config": {
              "label": "Estado",
              "value": "Activo",
              "icon": "✓",
              "color": "success"
            }
          },
          {
            "id": "main_table",
            "widget": "table-advanced",
            "config": {
              "dataSource": "@data.items",
              "columns": "auto",
              "sortable": true,
              "filterable": true,
              "paginated": true,
              "actions": [
                {
                  "label": "Editar",
                  "icon": "✏️",
                  "action": "edit",
                  "permissions": ["admin"]
                },
                {
                  "label": "Eliminar",
                  "icon": "🗑️",
                  "action": "delete",
                  "permissions": ["admin"],
                  "confirm": true
                }
              ]
            }
          },
          {
            "id": "info_panel",
            "widget": "card",
            "config": {
              "title": "ℹ️ Información",
              "content": {
                "type": "info",
                "items": [
                  {
                    "label": "Versión",
                    "value": "1.0.0",
                    "icon": "🏷️"
                  },
                  {
                    "label": "Estado",
                    "value": "Activo",
                    "color": "#22c55e"
                  }
                ]
              }
            }
          }
        ]
      },

      "create": {
        "type": "form",
        "permissions": ["admin"],
        "config": {
          "title": "Crear Test Wii Module",
          "endpoint": "/modules/test-wii-module/items",
          "method": "POST",
          "validation": true,
          "fields": "auto"
        }
      }
    },

    "mqtt": {
      "enabled": true,
      "topics": [
        "test-wii-module.created",
        "test-wii-module.updated",
        "test-wii-module.deleted"
      ],
      "auto_refresh": true
    }
  },

  "schema": {
    "id": {
      "type": "string",
      "label": "ID",
      "format": "hidden"
    },
    "name": {
      "type": "string",
      "label": "Nombre",
      "required": true,
      "minLength": 3,
      "maxLength": 100
    },
    "status": {
      "type": "enum",
      "label": "Estado",
      "enum": ["active", "inactive"],
      "default": "active"
    }
  },

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true
    }
  },

  "config": {
    "enabled": true
  }
}
