    "roadmap": {
      "path": "strategy/v1/roadmap.json",
      "schema": {
        "type": "object",
        "required": ["roadmap_version", "vision", "timeframe_months", "themes", "now_next_later", "releases"],
        "properties": {
          "roadmap_version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
          "created_at": {"type": "string", "format": "date-time"},
          "last_updated": {"type": "string", "format": "date-time"},
          "vision": {"$ref": "vision.json#/"},
          "timeframe_months": {"type": "integer", "minimum": 6, "maximum": 24},
          "themes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["theme", "description", "aligned_okrs"],
              "properties": {
                "theme": {"type": "string"},
                "description": {"type": "string"},
                "aligned_okrs": {"type": "array", "items": {"type": "string"}},
                "duration": {"type": "string"}
              }
            }
          },
          "now_next_later": {
            "type": "object",
            "required": ["now", "next", "later"],
            "properties": {
              "now": {
                "type": "object",
                "properties": {
                  "timeframe": {"type": "string", "const": "0-3 months"},
                  "focus": {"type": "array", "items": {"type": "string"}},
                  "releases": {"type": "array", "items": {"type": "string"}}
                }
              },
              "next": {
                "type": "object",
                "properties": {
                  "timeframe": {"type": "string", "const": "3-6 months"},
                  "focus": {"type": "array", "items": {"type": "string"}},
                  "releases": {"type": "array", "items": {"type": "string"}}
                }
              },
              "later": {
                "type": "object",
                "properties": {
                  "timeframe": {"type": "string", "const": "6-12 months"},
                  "focus": {"type": "array", "items": {"type": "string"}},
                  "releases": {"type": "array", "items": {"type": "string"}}
                }
              }
            }
          },
          "releases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["release_id", "version", "target_date", "status", "goals", "kpis", "items", "capacity"],
              "properties": {
                "release_id": {"type": "string"},
                "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
                "codename": {"type": "string"},
                "target_date": {"type": "string", "format": "date"},
                "confidence": {
                  "type": "string",
                  "enum": ["low", "medium", "high"],
                  "description": "Confianza en cumplir fecha"
                },
                "status": {
                  "type": "string",
                  "enum": ["planned", "in_progress", "testing", "released", "cancelled"]
                },
                "theme": {"type": "string"},
                "goals": {
                  "type": "array",
                  "items": {"type": "string"},
                  "minItems": 1,
                  "maxItems": 3
                },
                "kpis": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "baseline": {"type": "number"},
                      "target": {"type": "number"}
                    }
                  }
                },
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["title", "type", "priority", "status"],
                    "properties": {
                      "title": {"type": "string"},
                      "description": {"type": "string"},
                      "type": {
                        "type": "string",
                        "enum": ["feature", "improvement", "fix", "deprecation", "tech_debt"]
                      },
                      "priority": {"type": "string", "enum": ["P0", "P1", "P2"]},
                      "status": {"type": "string", "enum": ["planned", "in_progress", "done", "blocked"]},
                      "effort_story_points": {"type": "number"},
                      "assigned_team": {"type": "string"},
                      "dependencies": {"type": "array", "items": {"type": "string"}},
                      "risks": {"type": "array", "items": {"type": "string"}},
                      "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
                      "mvp_classification": {
                        "type": "string",
                        "enum": ["core", "nice_to_have"],
                        "description": "Core = must have for release, nice_to_have = puede postponerse"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "capacity": {
                  "type": "object",
                  "properties": {
                    "allocated_story_points": {"type": "number"},
                    "team_assigned": {"type": "string"},
                    "estimated_sprints": {"type": "integer"}
                  }
                },
                "go_no_go_criteria": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "rollback_plan": {"type": "string"},
                "assumptions": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "user_stories": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              },
              "additionalProperties": false
            }
          },
          "budget_allocation": {
            "type": "object",
            "properties": {
              "total_eur": {"type": "number"},
              "by_theme": {
                "type": "object",
                "additionalProperties": {"type": "number"}
              }
            }
          }
        },
        "additionalProperties": false
      },
      "example": {
        "roadmap_version": "2.0",
        "created_at": "2025-01-01T00:00:00Z",
        "last_updated": "2025-01-20T12:00:00Z",
        "vision": {
          "$ref": "vision.json#/example"
        },
