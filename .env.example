# Event Core Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's already in .gitignore)

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Core ID (unique identifier for this instance)
EVENT_CORE_ID=core-a

# Environment (development, staging, production)
EVENT_CORE_ENV=development

# =============================================================================
# HTTP GATEWAY
# =============================================================================

# HTTP server port
EVENT_CORE_PORT=3000

# HTTP server host (0.0.0.0 = listen on all interfaces)
EVENT_CORE_HTTP_HOST=0.0.0.0

# =============================================================================
# MQTT BROKER
# =============================================================================

# MQTT broker port (for embedded broker)
EVENT_CORE_BROKER_PORT=1883

# MQTT broker host (for embedded broker)
EVENT_CORE_BROKER_HOST=0.0.0.0

# External MQTT broker URL (if using external broker like Mosquitto)
# Format: mqtt://username:password@host:port
# Examples:
#   - Local: mqtt://localhost:1883
#   - With auth: mqtt://event-core:MySecurePassword123@192.168.1.100:1883
#   - Secure: mqtts://event-core:MySecurePassword123@broker.example.com:8883
EVENT_CORE_BROKER_URL=mqtt://localhost:1883

# =============================================================================
# MODULES
# =============================================================================

# Path to modules directory
EVENT_CORE_MODULES_PATH=./modules

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Log level (debug, info, warn, error)
EVENT_CORE_LOG_LEVEL=info

# Enable tracing (true, false)
EVENT_CORE_TRACING_ENABLED=true

# Enable metrics (true, false)
EVENT_CORE_METRICS_ENABLED=true

# =============================================================================
# SECURITY
# =============================================================================

# Enable P2P encryption (true, false)
EVENT_CORE_ENCRYPTION_ENABLED=true

# =============================================================================
# EXTERNAL SERVICES (Examples)
# =============================================================================
# Add your own external service credentials here

# Weather API
# WEATHER_API_KEY=your-api-key-here

# OpenAI API
# OPENAI_API_KEY=sk-proj-your-key-here

# Database
# DATABASE_URL=postgresql://user:password@localhost:5432/eventcore

# Redis
# REDIS_URL=redis://user:password@localhost:6379

# Webhook secrets
# WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# NOTES
# =============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in your actual credentials in .env
#
# 3. NEVER commit .env to git
#
# 4. For production, use environment variables directly instead of .env file:
#    export EVENT_CORE_BROKER_URL=mqtt://user:pass@host:1883
#    node index.js
#
# 5. Priority (highest to lowest):
#    CLI args > ENV vars (.env) > config.{env}.json > config.json
#
