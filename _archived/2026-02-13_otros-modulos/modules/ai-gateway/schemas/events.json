{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pizzepos.com/schemas/ai-gateway-events.json",
  "title": "AI Gateway Events Schema",
  "description": "Esquemas de eventos del módulo ai-gateway",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": {
          "type": "string",
          "format": "uuid"
        },
        "event_type": {
          "type": "string",
          "pattern": "^[a-z]+\\.[a-z_]+$"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "payload": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },

    "ai_response": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "ai.response"},
            "payload": {
              "type": "object",
              "required": ["request_id", "status", "data"],
              "properties": {
                "request_id": {
                  "type": "string",
                  "description": "ID de la solicitud original"
                },
                "status": {
                  "type": "string",
                  "enum": ["success"],
                  "const": "success"
                },
                "data": {
                  "type": "object",
                  "description": "Respuesta parseada según el tipo de request"
                },
                "provider": {
                  "type": "string",
                  "description": "Proveedor que procesó la solicitud"
                },
                "model": {
                  "type": "string",
                  "description": "Modelo usado"
                },
                "usage": {
                  "type": "object",
                  "properties": {
                    "prompt_tokens": {"type": "integer"},
                    "completion_tokens": {"type": "integer"},
                    "total_tokens": {"type": "integer"},
                    "cost": {"type": "number"}
                  }
                },
                "duration_ms": {
                  "type": "integer",
                  "description": "Duración del procesamiento"
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "ai_error": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "ai.error"},
            "payload": {
              "type": "object",
              "required": ["request_id", "error_type", "message"],
              "properties": {
                "request_id": {
                  "type": "string"
                },
                "error_type": {
                  "type": "string",
                  "enum": [
                    "provider_unavailable",
                    "rate_limit_exceeded",
                    "invalid_request",
                    "timeout",
                    "processing_failed"
                  ]
                },
                "message": {
                  "type": "string"
                },
                "provider": {
                  "type": "string",
                  "description": "Proveedor que falló (si aplica)"
                },
                "details": {
                  "type": "object",
                  "description": "Detalles adicionales del error"
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
