{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/storage-manager/events.json",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": { "type": "string", "format": "uuid" },
        "event_type": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "producer": { "type": "string", "const": "storage-manager" },
        "schema_version": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "storage_created": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "storage.created" },
            "payload": {
              "type": "object",
              "required": ["project_id"],
              "properties": {
                "project_id": { "type": "string" },
                "directories": { "type": "array" },
                "created_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "storage_deleted": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "storage.deleted" },
            "payload": {
              "type": "object",
              "required": ["project_id"],
              "properties": {
                "project_id": { "type": "string" },
                "files_deleted": { "type": "integer" },
                "bytes_freed": { "type": "integer" },
                "deleted_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "storage_cleaned": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "storage.cleaned" },
            "payload": {
              "type": "object",
              "required": ["project_id", "files_deleted", "bytes_freed"],
              "properties": {
                "project_id": { "type": "string" },
                "files_deleted": { "type": "integer" },
                "bytes_freed": { "type": "integer" },
                "cleaned_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "file_uploaded": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "file.uploaded" },
            "payload": {
              "type": "object",
              "required": ["file_id", "project_id", "filename", "size"],
              "properties": {
                "file_id": { "type": "string" },
                "project_id": { "type": "string" },
                "filename": { "type": "string" },
                "size": { "type": "integer" },
                "category": { "type": "string" },
                "mime_type": { "type": "string" },
                "uploaded_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "file_deleted": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "file.deleted" },
            "payload": {
              "type": "object",
              "required": ["file_id", "project_id"],
              "properties": {
                "file_id": { "type": "string" },
                "project_id": { "type": "string" },
                "filename": { "type": "string" },
                "size": { "type": "integer" },
                "deleted_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "file_list_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "file.list.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success", "files", "count"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "project_id": { "type": "string" },
                "files": { "type": "array" },
                "count": { "type": "integer" },
                "total_size": { "type": "integer" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "file_get_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "file.get.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "file": { "type": "object" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "storage_info_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "storage.info.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "storage": { "type": "object" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
