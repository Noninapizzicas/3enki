{
  "_meta": {
    "modulo": "pizzepos/impresion",
    "ubicacion": "modules/pizzepos/impresion",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "impresion",
    "version": "3.0.0",
    "description_oficial": "Formateo ESC/POS y envío directo a impresoras ESP32 via MQTT. Autodescubrimiento de impresoras. Sin capas intermedias.",
    "author": "Pizzepos Team",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_5_domain_pizzepos",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      {
        "event": "impresion.comanda_generada",
        "description": "Comanda formateada y enviada directamente al ESP32 via MQTT"
      },
      {
        "event": "impresion.error",
        "description": "Error al generar o enviar impresión"
      },
      {
        "event": "impresion.ticket_venta_generado",
        "description": "Ticket de venta formateado y enviado"
      },
      {
        "event": "impresion.ticket_pieza_generado",
        "description": "Ticket de pieza individual formateado y enviado"
      }
    ],
    "subscribes": [
      {
        "event": "cocina.item_ticket",
        "handler": "onItemTicket",
        "extras": {}
      },
      {
        "event": "cuenta.creada",
        "handler": "onCuentaCreada",
        "extras": {}
      },
      {
        "event": "mesa.abierta",
        "handler": "onMesaAbierta",
        "extras": {}
      },
      {
        "event": "mesa.renombrada",
        "handler": "onMesaRenombrada",
        "extras": {}
      },
      {
        "event": "cuenta.eliminada",
        "handler": "onCuentaEliminada",
        "extras": {}
      },
      {
        "event": "mesa.cerrada",
        "handler": "onMesaCerrada",
        "extras": {}
      },
      {
        "event": "llevar.ticket_creado",
        "handler": "onLlevarTicketCreado",
        "extras": {}
      },
      {
        "event": "cuenta.actualizada",
        "handler": "onCuentaActualizada",
        "extras": {}
      },
      {
        "event": "caja.cerrada",
        "handler": "onCajaCerrada",
        "extras": {}
      },
      {
        "event": "dia.iniciado",
        "handler": "onDiaIniciado",
        "extras": {}
      }
    ],
    "provides_eventos": [
      "impresion.comanda_generada",
      "impresion.error",
      "impresion.ticket_venta_generado",
      "impresion.ticket_pieza_generado"
    ]
  },

  "tools": [],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "impresion", "action": "ticket",        "handler": "handleImprimirComanda" },
      { "domain": "impresion", "action": "ticket-venta",  "handler": "handleImprimirTicketVenta" },
      { "domain": "impresion", "action": "estado",        "handler": "handleGetEstado" },
      { "domain": "impresion", "action": "historial",     "handler": "handleGetHistorial" },
      { "domain": "impresion", "action": "health",        "handler": "handleHealthCheck" },
      { "domain": "impresion", "action": "metrics",       "handler": "handleGetMetrics" },
      { "domain": "impresion", "action": "impresoras",    "handler": "handleListarImpresoras" }
    ]
  },

  "apis_http": [
    {
      "method": "POST",
      "path": "/ticket",
      "handler": "handleImprimirComanda",
      "description": "Reimprimir comanda manualmente. Body: { cuenta_id, items, destino?, project_id? }",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/ticket-venta",
      "handler": "handleImprimirTicketVenta",
      "description": "Imprimir ticket de venta (recibo cliente con precios, total, metodo pago)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/estado",
      "handler": "handleGetEstado",
      "description": "Estado actual del módulo de impresión y impresoras descubiertas",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/historial",
      "handler": "handleGetHistorial",
      "description": "Historial de comandas impresas",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check — reporta impresoras listas",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Metricas del modulo",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/impresoras",
      "handler": "handleListarImpresoras",
      "description": "Lista impresoras ESP32 descubiertas via autodescubrimiento MQTT",
      "request_schema_ref": null,
      "response_schema_ref": null
    }
  ],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "ancho",           "tipo": "string",  "valor_default": "58mm" },
      { "key": "destino_default", "tipo": "string",  "valor_default": "" }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "impresion.comanda.total",
        "impresion.reimpresion.total",
        "impresion.error.total",
        "impresion.impresoras.descubiertas"
      ],
      "gauges": [],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": ["events.json"],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": false,
    "ui_handlers_field_name": "ui_handlers",
    "module_json_bytes": 5040,
    "module_json_lineas": 165,
    "tiene_main_no_estandar": false,
    "warnings": [
      "provides.events duplica events.publishes — lista identica, campo redundante",
      "observability.logging.correlation_id=true no capturado en schema observability_declarada (campo extra ignorado en extraccion)",
      "prompt.json existe en directorio pero no tiene campo 'main' declarado en module.json"
    ]
  }
}
