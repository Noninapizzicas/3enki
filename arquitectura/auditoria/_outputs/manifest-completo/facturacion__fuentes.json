      { "domain": "fuentes", "action": "get-config",  "handler": "handleGetConfig" },
      { "domain": "fuentes", "action": "save-config", "handler": "handleSaveConfig" },
      { "domain": "fuentes", "action": "check-gmail", "handler": "handleCheckGmail" }
    ]
  },

  "apis_http": [],

