{
  "name": "impresion",
  "version": "2.0.0",
  "description": "Formateo ESC/POS para impresión térmica (58mm/80mm). Comandas cocina, tickets pieza, tickets venta. Envío delegado a módulo perifericos.",
  "author": "Pizzepos Team",

  "provides": {
    "events": [
      "impresion.comanda_generada",
      "impresion.error",
      "impresion.ticket_venta_generado"
    ]
  },

  "events": {
    "publishes": [
      {
        "event": "impresion.comanda_generada",
        "description": "Comanda formateada y enviada via periferico.imprimir",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/impresion_comanda_generada"
        }
      },
      {
        "event": "impresion.error",
        "description": "Error al generar comanda",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/impresion_error"
        }
      },
      {
        "event": "periferico.imprimir",
        "description": "Datos ESC/POS enviados al servicio de periféricos para impresión"
      }
    ],
    "subscribes": [
      {
        "event": "pedido.enviado_cocina",
        "description": "Generar e imprimir comanda cuando pedido se envia a cocina",
        "handler": "onPedidoEnviadoCocina"
      },
      {
        "event": "cocina.item_ticket",
        "description": "Imprimir ticket de pieza individual al completar item en estación con impresión",
        "handler": "onItemTicket"
      }
    ]
  },

  "ui_handlers": [
    { "domain": "impresion", "action": "ticket", "handler": "handleImprimirComanda" },
    { "domain": "impresion", "action": "ticket-venta", "handler": "handleImprimirTicketVenta" },
    { "domain": "impresion", "action": "estado", "handler": "handleGetEstado" },
    { "domain": "impresion", "action": "historial", "handler": "handleGetHistorial" },
    { "domain": "impresion", "action": "health", "handler": "handleHealthCheck" },
    { "domain": "impresion", "action": "metrics", "handler": "handleGetMetrics" }
  ],

  "apis": [
    {
      "method": "POST",
      "path": "/ticket",
      "handler": "handleImprimirComanda",
      "description": "Reimprimir comanda manualmente. Body: { cuenta_id, items, destino? }"
    },
    {
      "method": "POST",
      "path": "/ticket-venta",
      "handler": "handleImprimirTicketVenta",
      "description": "Imprimir ticket de venta (recibo cliente con precios, total, metodo pago)"
    },
    {
      "method": "GET",
      "path": "/estado",
      "handler": "handleGetEstado",
      "description": "Estado actual del módulo de impresión"
    },
    {
      "method": "GET",
      "path": "/historial",
      "handler": "handleGetHistorial",
      "description": "Historial de comandas impresas"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Metricas del modulo"
    }
  ],

  "config": {
    "ancho": "58mm",
    "destino_default": "cocina"
  },

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "impresion.comanda.total",
        "impresion.reimpresion.total",
        "impresion.error.total"
      ]
    }
  }
}
