          }
        },
        "additionalProperties": false
      }
    },
    "business_goals": {
      "description": "Objetivos de negocio SMART",
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["goal", "metric", "baseline", "target", "deadline"],
          "properties": {
            "goal": {"type": "string"},
            "metric": {"type": "string"},
            "baseline": {"type": "number"},
            "target": {"type": "number"},
            "deadline": {"type": "string", "format": "date"},
            "category": {"type": "string", "enum": ["growth", "efficiency", "retention", "revenue", "quality"]}
