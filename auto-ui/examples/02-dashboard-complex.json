{
  "name": "analytics",
  "version": "2.0.0",
  "description": "Complex dashboard with multiple widgets and layouts",

  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "Analytics Dashboard",
    "icon": "📊",

    "views": {
      "main": {
        "type": "dashboard",
        "layout": "two-column",

        "permissions": ["admin", "analyst"],

        "header": {
          "component": "page-header",
          "props": {
            "title": "📊 Analytics Dashboard",
            "subtitle": "Real-time insights and metrics"
          }
        },

        "columns": [
          {
            "width": "70%",
            "sections": [
              {
                "layout": "grid",
                "config": {
                  "columns": 3,
                  "minWidth": "200px"
                },
                "sections": [
                  {
                    "widget": "stat-card",
                    "config": {
                      "label": "Total Users",
                      "value": "@compute:count(data.users)",
                      "change": "+12.5",
                      "trend": "up",
                      "icon": "👥",
                      "color": "var(--primary)"
                    }
                  },
                  {
                    "widget": "stat-card",
                    "config": {
                      "label": "Revenue",
                      "value": "@compute:sum(data.sales.amount)",
                      "change": "+8.2",
                      "trend": "up",
                      "icon": "💰",
                      "color": "var(--success)"
                    }
                  },
                  {
                    "widget": "stat-card",
                    "config": {
                      "label": "Conversion Rate",
                      "value": "@compute:percent(data.conversions, data.visits)",
                      "change": "-2.1",
                      "trend": "down",
                      "icon": "📈",
                      "color": "var(--warning)"
                    }
                  }
                ]
              },
              {
                "widget": "chart",
                "config": {
                  "type": "line",
                  "dataSource": "@api:/modules/analytics/chart-data",
                  "title": "Revenue Trend",
                  "height": "300px"
                }
              },
              {
                "widget": "table-advanced",
                "config": {
                  "dataSource": "@api:/modules/analytics/top-products",
                  "title": "Top Products",
                  "columns": [
                    { "key": "name", "label": "Product" },
                    { "key": "sales", "label": "Sales", "format": "number" },
                    { "key": "revenue", "label": "Revenue", "format": "currency" }
                  ],
                  "pagination": false
                }
              }
            ]
          },
          {
            "width": "30%",
            "sections": [
              {
                "widget": "progress-bar",
                "config": {
                  "label": "Monthly Goal",
                  "value": "@data.progress.current",
                  "max": "@data.progress.target",
                  "showPercent": true,
                  "color": "var(--primary)"
                }
              },
              {
                "component": "card",
                "props": {
                  "header": "Quick Stats",
                  "variant": "default"
                },
                "children": [
                  {
                    "widget": "list",
                    "config": {
                      "data": [
                        { "label": "Active Users", "value": "@metrics.users.active" },
                        { "label": "New Signups", "value": "@metrics.users.new" },
                        { "label": "Churn Rate", "value": "@metrics.users.churn" }
                      ],
                      "template": "{{label}}: <strong>{{value}}</strong>"
                    }
                  }
                ]
              },
              {
                "widget": "activity-feed",
                "config": {
                  "dataSource": "@api:/modules/analytics/recent-activity",
                  "limit": 10
                }
              }
            ]
          }
        ]
      },

      "reports": {
        "type": "dashboard",
        "layout": "tabs",

        "permissions": ["admin"],

        "tabs": [
          {
            "label": "Sales Report",
            "icon": "💰",
            "sections": [
              {
                "widget": "chart",
                "config": {
                  "type": "bar",
                  "dataSource": "@api:/modules/analytics/sales-report"
                }
              }
            ]
          },
          {
            "label": "User Report",
            "icon": "👥",
            "sections": [
              {
                "widget": "chart",
                "config": {
                  "type": "pie",
                  "dataSource": "@api:/modules/analytics/user-report"
                }
              }
            ]
          }
        ]
      }
    }
  },

  "apis": [
    {
      "method": "GET",
      "path": "/chart-data",
      "handler": "handleChartData"
    },
    {
      "method": "GET",
      "path": "/top-products",
      "handler": "handleTopProducts"
    },
    {
      "method": "GET",
      "path": "/recent-activity",
      "handler": "handleRecentActivity"
    }
  ]
}
