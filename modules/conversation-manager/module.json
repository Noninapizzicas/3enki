{
  "name": "conversation-manager",
  "version": "2.0.0",
  "description": "Facade/Coordinator que mantiene compatibilidad con frontend existente, delegando a chat-session, prompt-composer y chat-ai-bridge",
  "author": "Event Core Team",
  "main": "index.js",
  "deprecated": true,
  "deprecationNote": "Use chat-session, prompt-composer, chat-ai-bridge directly for new development",

  "events": {
    "publishes": [],
    "subscribes": [
      {
        "event": "chat.send.response",
        "description": "Response from chat-ai-bridge",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.create.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.list.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.get.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.update.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.delete.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.messages.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.context.load.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.context.toggle.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.context.stats.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "project.active.response",
        "description": "Response from project-manager",
        "handler": "onDelegatedResponse"
      }
    ]
  },

  "apis": [
    {
      "method": "POST",
      "path": "/conversations",
      "handler": "handleCreateConversation",
      "description": "Create conversation (delegates to chat-session)"
    },
    {
      "method": "GET",
      "path": "/conversations",
      "handler": "handleListConversations",
      "description": "List conversations (delegates to chat-session)"
    },
    {
      "method": "GET",
      "path": "/conversations/:id",
      "handler": "handleGetConversation",
      "description": "Get conversation with messages (delegates to chat-session)"
    },
    {
      "method": "PUT",
      "path": "/conversations/:id",
      "handler": "handleUpdateConversation",
      "description": "Update conversation (delegates to chat-session)"
    },
    {
      "method": "DELETE",
      "path": "/conversations/:id",
      "handler": "handleDeleteConversation",
      "description": "Delete conversation (delegates to chat-session)"
    },
    {
      "method": "POST",
      "path": "/conversations/:id/messages",
      "handler": "handleSendMessage",
      "description": "Send message and get AI response (delegates to chat-ai-bridge)"
    },
    {
      "method": "GET",
      "path": "/conversations/:id/messages",
      "handler": "handleGetMessages",
      "description": "Get conversation messages (delegates to chat-session)"
    },
    {
      "method": "GET",
      "path": "/conversations/:id/context",
      "handler": "handleGetContext",
      "description": "Get conversation context (delegates to chat-session)"
    },
    {
      "method": "GET",
      "path": "/ui/state",
      "handler": "handleUIState",
      "description": "UI-ready state for conversation management"
    },
    {
      "method": "PUT",
      "path": "/messages/:id/context",
      "handler": "handleToggleContext",
      "description": "Toggle message context inclusion (delegates to chat-session)"
    },
    {
      "method": "GET",
      "path": "/conversations/:id/context-stats",
      "handler": "handleContextStats",
      "description": "Get context statistics (delegates to chat-session)"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check endpoint"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Module metrics"
    }
  ],

  "ui": {
    "zone": "chat",
    "icon": "💬",
    "handlers": {
      "domain": "conversation",
      "actions": ["send", "load", "create", "list", "get", "update", "delete", "toggleContext", "contextStats"]
    }
  },

  "dependencies": [
    "chat-session",
    "chat-ai-bridge",
    "project-manager"
  ],

  "config": {
    "requestTimeout": 30000,
    "chatTimeout": 180000
  }
}
