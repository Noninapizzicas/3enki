    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [],
    "subscribes": [
      { "event": "db.query.response", "handler": "_onDbQueryResponse", "extras": {} },
      { "event": "activity.logged",   "handler": null,                  "extras": {} },
      { "event": "agent.failed",      "handler": null,                  "extras": {} },
      { "event": "agent.completed",   "handler": null,                  "extras": {} }
