{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": "object",
      "required": ["results"],
      "properties": {
        "query": {
          "type": "string"
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "path", "type"],
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["file", "directory"]
              },
              "size": {
                "type": "number"
              },
              "modified": {
                "type": "string",
                "format": "date-time"
              },
              "match_type": {
                "type": "string",
                "enum": ["filename", "content"]
              }
            }
          }
        },
        "count": {
          "type": "number"
        }
      }
    },
    "error": {
      "type": "string"
    }
  }
}
