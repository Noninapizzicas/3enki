{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": "object",
      "required": ["file_path"],
      "properties": {
        "file_path": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["file", "directory"]
        },
        "created": {
          "type": "boolean"
        },
        "deleted": {
          "type": "boolean"
        }
      }
    },
    "error": {
      "type": "string"
    }
  }
}
