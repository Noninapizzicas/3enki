    "current_roadmap": {
      "description": "Roadmap previo si existe",
      "schema": {
        "type": "object",
        "properties": {
          "version": {"type": "string"},
          "last_updated": {"type": "string", "format": "date-time"}
        }
      }
    },
    "constraints": {
      "description": "Restricciones de recursos y tiempo",
      "schema": {
        "type": "object",
        "required": ["team_capacity", "budget", "timeline"],
        "properties": {
          "team_capacity": {
            "type": "object",
            "properties": {
              "total_story_points_per_quarter": {"type": "number"},
              "team_size": {"type": "integer"},
              "allocation_new_features_pct": {"type": "number", "minimum": 0, "maximum": 1}
            }
          },
          "budget": {
            "type": "object",
            "properties": {
              "total_eur": {"type": "number"},
              "allocated_to_product": {"type": "number"}
            }
          },
          "timeline": {
            "type": "object",
            "properties": {
              "planning_horizon_months": {"type": "integer", "default": 12},
              "release_frequency_weeks": {"type": "integer", "default": 4}
            }
          }
        },
        "additionalProperties": false
      }
    }
  },

  "roadmap_pipeline": [
    "Validar inputs: feedback_backlog ✅, kpis ✅, business_goals ✅",
    "Analizar backlog priorizado y métricas clave actuales",
    "Alinear features con business_goals y definir OKRs quarterly",
    "Ejecutar competitive analysis (benchmarking, gaps, differentiation)",
    "Mapear stakeholders (RACI matrix, decision makers, influencers)",
    "Ejecutar capacity planning (team size, velocity, availability)",
    "Crear feature prioritization matrix (impact vs effort quadrants)",
    "Definir vision statement estructurado (mission, values, differentiation)",
    "Elaborar roadmap con themes, now-next-later, releases planificados",
    "Marcar dependencias, riesgos y assumptions por release",
    "Definir MVP por release (core vs nice-to-have features)",
    "Planificar deprecaciones con timeline y migration support",
    "Generar criterios de éxito (KPI targets) por release",
    "Crear risk register con mitigation plans",
    "Auto-generar release notes desde roadmap JSON",
    "Validar alignment OKRs ↔ roadmap ↔ capacity"
  ],

  "constraints": [
    "Todos los roadmap items con fecha tentativa y confidence level",
    "Cada release con KPIs asociados, baseline y targets SMART",
    "Deprecaciones planificadas explícitamente con sunset dates",
    "Formato JSON validable con additionalProperties: false",
    "Versionado /v1/ en todos los paths",
    "OKRs alineados con roadmap (trazabilidad completa)",
    "Capacity planning realista: no over-commit (max 80% capacity)",
    "Backward compatibility obligatoria (breaking changes requieren RFC)"
  ],

