{
  "_meta": {
    "modulo": "device-health",
    "ubicacion": "modules/device-health",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "device-health",
    "version": "1.0.0",
    "description_oficial": "Monitorización de liveness, uptime, alertas y métricas de la flota de dispositivos IoT",
    "author": "Enki",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": null,
    "tier_declarado": "tier_3_core",
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "health.alert.offline",        "description": "Dispositivo lleva más de N minutos offline" },
      { "event": "health.alert.reconnect_loop",  "description": "Dispositivo reconectando repetidamente" },
      { "event": "health.alert.ota_failed",      "description": "OTA falló para un dispositivo" },
      { "event": "health.report",                "description": "Reporte periódico de estado de la flota" }
    ],
    "subscribes": [
      {
        "event": "device.online",
        "handler": "onDeviceOnline",
        "extras": { "description": "Dispositivo conectado — registrar timestamp, resetear contador offline" }
      },
      {
        "event": "device.offline",
        "handler": "onDeviceOffline",
        "extras": { "description": "Dispositivo desconectado — iniciar conteo, verificar alertas" }
      },
      {
        "event": "firmware.ota_failed",
        "handler": "onOtaFailed",
        "extras": { "description": "OTA falló — generar alerta" }
      },
      {
        "event": "firmware.ota_completed",
        "handler": "onOtaCompleted",
        "extras": { "description": "OTA completada — registrar en historial" }
      }
    ],
    "provides_eventos": [
      "health.alert.offline",
      "health.alert.reconnect_loop",
      "health.alert.ota_failed",
      "health.report"
    ]
  },

  "tools": [
    {
      "name": "health.dashboard",
      "description": "Dashboard de salud del parque: dispositivos online/offline, uptime%, alertas activas, reconexiones",
      "parameters_required": [],
      "parameters_property_names": [],
      "parameters_size_chars": 36,
      "parameters_full_path_hint": "modules/device-health/module.json → tools[0].parameters"
    },
    {
      "name": "health.device_history",
      "description": "Historial de salud de un dispositivo: periodos offline, historial OTA, alertas específicas",
      "parameters_required": ["device_id"],
      "parameters_property_names": ["device_id"],
      "parameters_size_chars": 94,
      "parameters_full_path_hint": "modules/device-health/module.json → tools[1].parameters"
    },
    {
      "name": "health.alerts",
      "description": "Lista de alertas de salud: offline prolongado, reconnect loops, OTA fallidos",
      "parameters_required": [],
      "parameters_property_names": ["type", "device_id", "active_only"],
      "parameters_size_chars": 284,
      "parameters_full_path_hint": "modules/device-health/module.json → tools[2].parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "health", "action": "dashboard",      "handler": "handleDashboard" },
      { "domain": "health", "action": "device-history", "handler": "handleDeviceHistory" },
      { "domain": "health", "action": "alerts",         "handler": "handleAlerts" }
    ]
  },

  "apis_http": [],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "offline_threshold_min",        "tipo": "number",  "valor_default": 5 },
      { "key": "reconnect_loop_threshold",      "tipo": "number",  "valor_default": 5 },
      { "key": "reconnect_loop_window_min",     "tipo": "number",  "valor_default": 30 },
      { "key": "report_interval_min",           "tipo": "number",  "valor_default": 60 },
      { "key": "data_path",                     "tipo": "string",  "valor_default": "./data/devices" }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "health.alerts.total",
        "health.alerts.offline",
        "health.alerts.reconnect_loop",
        "health.alerts.ota_failed"
      ],
      "gauges": [],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": [],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": false,
    "ui_handlers_field_name": "ui_handlers",
    "module_json_bytes": 3508,
    "module_json_lineas": 111,
    "tiene_main_no_estandar": false,
    "warnings": [
      "main no declarado en module.json (null inferido)",
      "provides.events duplica events.publishes — mismos 4 eventos, provides es redundante",
      "tier_declarado 'tier_3_core' pero device-health no aparece en ningún tier de system.json.module_load_order.tiers",
      "observability.metrics no declara gauges ni timings (arrays ausentes en source, normalizados a [])"
    ]
  }
}
