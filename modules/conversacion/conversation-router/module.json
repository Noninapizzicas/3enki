{
  "name": "conversation-router",
  "version": "1.0.0",
  "description": "Enrutador de mensajes de usuario. Capa 2-3 de la arquitectura conversation-routing: decide si el mensaje va a un agente activo, a un tool call, o al LLM. Sin dependencias directas de otros módulos.",
  "author": "Event Core Team",
  "main": "index.js",

  "publishes": [
    "chat.message.routed"
  ],

  "subscribes": [
    { "event": "chat.message.saved",  "handler": "onChatMessageSaved" },
    { "event": "agent.execute",       "handler": "onAgentExecute" },
    { "event": "agent.active",        "handler": "onAgentActive" },
    { "event": "agent.completed",     "handler": "onAgentCompleted" },
    { "event": "agent.failed",        "handler": "onAgentFailed" }
  ],

  "observability": {
    "metrics": {
      "counters": [
        "router.path.tool_call",
        "router.path.agent",
        "router.path.forward_agent",
        "router.path.llm"
      ]
    }
  }
}
