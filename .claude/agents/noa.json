  "invariants": [
    { "type": "invariant", "expression": "this.fielLoaded !== null antes de ejecutar cualquier pseudo_step", "applies_to": "global" },
    { "type": "invariant", "expression": "this.planActual._observaciones_para_ana esta vacio o ausente antes de empezar a ejecutar", "applies_to": "verificarObservacionesCerradas" },
