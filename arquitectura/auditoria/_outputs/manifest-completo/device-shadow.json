{
  "_meta": {
    "modulo": "device-shadow",
    "ubicacion": "modules/device-shadow",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "device-shadow",
    "version": "1.0.0",
    "description_oficial": "Sincronización bidireccional de estado desired/reported/delta entre servidor y dispositivos IoT",
    "author": "Enki",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": null,
    "tier_declarado": "tier_2_platform",
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "shadow.updated", "description": "Estado reported de un dispositivo fue actualizado" },
      { "event": "shadow.delta",   "description": "Nuevo delta computado — desired difiere de reported" },
      { "event": "shadow.synced",  "description": "Delta vacío — dispositivo sincronizado con estado deseado" }
    ],
    "subscribes": [
      {
        "event": "shadow.set_desired",
        "handler": "onSetDesired",
        "extras": {}
      }
    ],
    "provides_eventos": [
      "shadow.updated",
      "shadow.delta",
      "shadow.synced"
    ]
  },

  "tools": [
    {
      "name": "shadow.get_full",
      "description": "Estado completo del shadow de un dispositivo: reported (lo que tiene), desired (lo que queremos), delta (diferencias)",
      "parameters_required": ["device_id"],
      "parameters_property_names": ["device_id"],
      "parameters_size_chars": 60,
      "parameters_full_path_hint": "modules/device-shadow/module.json#/tools/0/parameters"
    },
    {
      "name": "shadow.set_desired",
      "description": "Escribir estado deseado para un dispositivo. El delta se computa automáticamente y se envía por MQTT.",
      "parameters_required": ["device_id", "state"],
      "parameters_property_names": ["device_id", "project_id", "state"],
      "parameters_size_chars": 175,
      "parameters_full_path_hint": "modules/device-shadow/module.json#/tools/1/parameters"
    },
    {
      "name": "shadow.get_delta",
      "description": "Ver las diferencias entre lo deseado y lo reportado por el dispositivo",
      "parameters_required": ["device_id"],
      "parameters_property_names": ["device_id"],
      "parameters_size_chars": 60,
      "parameters_full_path_hint": "modules/device-shadow/module.json#/tools/2/parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "shadow", "action": "get-reported", "handler": "handleGetReported" },
      { "domain": "shadow", "action": "get-desired",  "handler": "handleGetDesired"  },
      { "domain": "shadow", "action": "get-delta",    "handler": "handleGetDelta"    },
      { "domain": "shadow", "action": "set-desired",  "handler": "handleSetDesired"  },
      { "domain": "shadow", "action": "get-full",     "handler": "handleGetFull"     }
    ]
  },

  "apis_http": [],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "persist_interval_ms", "tipo": "number",  "valor_default": 30000        },
      { "key": "data_path",           "tipo": "string",  "valor_default": "./data/devices" }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "shadow.reported_updates.total",
        "shadow.desired_updates.total",
        "shadow.deltas_computed.total",
        "shadow.synced.total"
      ],
      "gauges": [],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": [],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": true,
    "ui_handlers_field_name": "ui_handlers",
    "module_json_bytes": 3035,
    "module_json_lineas": 97,
    "tiene_main_no_estandar": false,
    "warnings": [
      "eventos_top_level=true: module.json usa AMBAS formas — provides.events (top-level) Y events.publishes (envuelto). provides_eventos capturado desde provides.events.",
      "events.subscribes items tienen campo 'description' en lugar de 'extras' — normalizado a extras:{}",
      "No tiene campo 'main' declarado en module.json — main=null",
      "tier_carga_inferido=null: 'device-shadow' no aparece en ningún tier de system.json.module_load_order.tiers (aparece en config.modules.enabled pero no en tiers)"
    ]
  }
}
