  "identidad": {
    "name": "staff-manager",
    "version": "1.0.0",
    "description_oficial": "Control de personal con tarjetas NFC (NTAG215) — jornada y distribución de llaves",
    "author": "Event Core Team",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": false,
