{
  "name": "ai-connector",
  "version": "2.0.0",
  "description": "Multi-provider AI connector using event-driven credential resolution",
  "author": "Aichat Team",
  "main": "index.js",

  "provides": {
    "events": [
      "ai.response.generated",
      "ai.response.failed"
    ],
    "queries": [
      "ai.generate.request"
    ]
  },

  "events": {
    "publishes": [
      {
        "event": "ai.response.generated",
        "description": "AI response successfully generated",
        "schema": { "$ref": "./schemas/events.json#/definitions/ai_response_generated" }
      },
      {
        "event": "ai.response.failed",
        "description": "AI generation failed",
        "schema": { "$ref": "./schemas/events.json#/definitions/ai_response_failed" }
      },
      {
        "event": "ai.generate.response",
        "description": "Response to AI generation request",
        "schema": { "$ref": "./schemas/events.json#/definitions/ai_generate_response" }
      }
    ],
    "subscribes": [
      {
        "event": "ai.generate.request",
        "description": "Handle AI generation requests from other modules",
        "handler": "onGenerateRequest"
      },
      {
        "event": "credential.resolve.response",
        "description": "Receive credential resolution responses",
        "handler": "onCredentialResponse"
      }
    ]
  },

  "apis": [
    {
      "method": "POST",
      "path": "/generate",
      "handler": "handleGenerate",
      "description": "Generate AI response (publishes ai.response.generated)",
      "request_schema": { "$ref": "./schemas/ai.json#/definitions/generate_request" },
      "response_schema": { "$ref": "./schemas/ai.json#/definitions/generate_response" }
    },
    {
      "method": "GET",
      "path": "/providers",
      "handler": "handleListProviders",
      "description": "List available AI providers"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check endpoint"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Module metrics"
    }
  ],

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "ai.request.total",
        "ai.request.success",
        "ai.request.failed",
        "ai.request.by_provider"
      ],
      "gauges": [
        "ai.pending.requests"
      ],
      "timings": [
        "ai.request.duration",
        "ai.credential.resolve.duration"
      ]
    }
  },

  "config": {
    "defaultProvider": "deepseek",
    "timeout": 30000,
    "retries": 2,
    "providers": {
      "deepseek": {
        "model": "deepseek-chat",
        "endpoint": "https://api.deepseek.com/chat/completions",
        "credentialProvider": "DEEPSEEK"
      },
      "openai": {
        "model": "gpt-4",
        "endpoint": "https://api.openai.com/v1/chat/completions",
        "credentialProvider": "OPENAI"
      },
      "anthropic": {
        "model": "claude-3-5-sonnet-20241022",
        "endpoint": "https://api.anthropic.com/v1/messages",
        "credentialProvider": "ANTHROPIC"
      }
    }
  }
}
