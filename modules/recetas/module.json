{
  "name": "recetas",
  "version": "4.0.0",
  "description": "Aggregate root del subsistema-recetario. Gestion de recetas + catalogo de ingredientes con almacenamiento JSON por proyecto (data/projects/{slug}/recetas.json). Cada receta tiene history interno (versionado), estado_operativo canonico (borrador/en_servicio/archivada), incompleta flag y campos_pendientes. Publica eventos canonicos del subsistema (receta.creada, .actualizada, .eliminada, .estado.actualizada, ingrediente.precio.actualizado) que los modulos satelite (escandallo, recetario-creativo, mise-en-place, pase-cocina) escuchan para producir sus capas derivadas.",
  "author": "Enki",
  "language": "es",
  "tier": "tier_4_dominio",

  "events": {
    "publishes": [
      {
        "event":               "receta.creada",
        "description":         "Receta nueva persistida en el JSON del proyecto.",
        "response_schema_ref": "arquitectura/decisiones/_schemas/subsistema-recetario/receta.creada.schema.json"
      },
      {
        "event":               "receta.actualizada",
        "description":         "Receta modificada (campos del shape). Tambien se emite al revertir a una version anterior (con motivo='revertir').",
        "response_schema_ref": "arquitectura/decisiones/_schemas/subsistema-recetario/receta.actualizada.schema.json"
      },
      {
        "event":               "receta.eliminada",
        "description":         "Receta archivada (estado='archivada'). NO se borra del archivo. Tambien se emite receta.estado.actualizada coordinadamente.",
        "response_schema_ref": "arquitectura/decisiones/_schemas/subsistema-recetario/receta.eliminada.schema.json"
      },
      {
        "event":               "receta.estado.actualizada",
        "description":         "Transicion de estado_operativo (borrador<->en_servicio<->archivada). Activa o desactiva capas enteras del subsistema (mise-en-place/pase-cocina solo trabajan con en_servicio).",
        "response_schema_ref": "arquitectura/decisiones/_schemas/subsistema-recetario/receta.estado.actualizada.schema.json"
      },
      {
        "event":               "ingrediente.precio.actualizado",
        "description":         "Precio de mercado de un ingrediente del catalogo actualizado o creado.",
        "response_schema_ref": "arquitectura/decisiones/_schemas/subsistema-recetario/ingrediente.precio.actualizado.schema.json"
      }
    ],
    "subscribes": [
      { "event": "project.activated",          "handler": "onProjectActivated",     "description": "Cachea base_path del proyecto activado." },
      { "event": "project.deactivated",        "handler": "onProjectDeactivated",   "description": "No-op (cache permanente; no hay manager que cerrar)." },
      { "event": "project.get.response",       "handler": "onProjectGetResponse",   "description": "Resuelve project.get pendiente por request_id." },
      { "event": "fs.read.response",           "handler": "onFsReadResponse",       "description": "Resuelve lectura pendiente por request_id." },
      { "event": "fs.write.response",          "handler": "onFsWriteResponse",      "description": "Resuelve escritura pendiente por request_id." },

      { "event": "recetas.crear",              "handler": "onCrear",                "description": "Tool LLM: crear receta nueva." },
      { "event": "recetas.listar",             "handler": "onListar",               "description": "Tool LLM: listar recetas del proyecto." },
      { "event": "recetas.obtener",            "handler": "onObtener",              "description": "Tool LLM: obtener receta por id o nombre." },
      { "event": "recetas.buscar",             "handler": "onBuscar",               "description": "Tool LLM: buscar recetas por criterios." },
      { "event": "recetas.actualizar",         "handler": "onActualizar",           "description": "Tool LLM: actualizar campos de receta." },
      { "event": "recetas.historial",          "handler": "onHistorial",            "description": "Tool LLM: leer historial de versiones." },
      { "event": "recetas.revertir",           "handler": "onRevertir",             "description": "Tool LLM: revertir a version anterior." },
      { "event": "recetas.eliminar",           "handler": "onEliminar",             "description": "Tool LLM: archivar receta (estado='archivada')." },
      { "event": "recetas.cambiar_estado",     "handler": "onCambiarEstado",        "description": "Tool LLM: transicionar estado_operativo con validacion." },
      { "event": "recetas.estadisticas",       "handler": "onEstadisticas",         "description": "Tool LLM: resumen del proyecto (totales, estados, ingredientes)." },
      { "event": "recetas.ingredientes",       "handler": "onIngredientes",         "description": "Tool LLM: listar catalogo de ingredientes." },
      { "event": "recetas.actualizar_precio",  "handler": "onActualizarPrecio",     "description": "Tool LLM: actualizar/crear precio de ingrediente." },
      { "event": "recetas.analizar",           "handler": "onAnalizar",             "description": "Tool LLM: analisis de coste de una receta." },
      { "event": "recetas.investigar_receta",  "handler": "onInvestigarReceta",     "description": "Tool LLM: comprobar si existe + propuesta del LLM." }
    ]
  },

  "apis": [],

  "tools": [
    {
      "name":        "recetas.crear",
      "description": "Guarda una receta nueva en el proyecto. Llamala en cuanto tengas nombre + ingredientes — aunque sean texto libre del usuario y falten otros campos, GUARDALA igualmente. Los campos que falten se marcaran como pendientes. NO PIDAS al usuario datos que no haya dado. Si la receta queda completa, arranca en estado_operativo='en_servicio'; si esta incompleta, arranca en 'borrador'.",
      "handler":     "onCrear",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":   { "type": "string", "description": "ID del proyecto activo" },
          "nombre":       { "type": "string", "description": "Nombre de la receta" },
          "descripcion":  { "type": "string" },
          "ingredientes": { "description": "Array de {nombre, cantidad, unidad, notas?} O texto libre. El backend lo normaliza." },
          "instrucciones":{ "description": "Array de pasos O texto libre con saltos de linea/puntos." },
          "porciones":    { "type": "number" },
          "tiempo_min":   { "type": "number" },
          "dificultad":   { "type": "number", "description": "1-10" },
          "categorias":   { "type": "array", "items": { "type": "string" } },
          "etiquetas":    { "type": "array", "items": { "type": "string" } },
          "fuente":       { "type": "string", "enum": ["manual", "investigada", "importada"] },
          "notas":        { "type": "string" },
          "user_id":      { "type": "string", "description": "ID del usuario que crea. Opcional." }
        },
        "required": ["project_id", "nombre"]
      },
      "errores_conocidos": ["INVALID_INPUT", "ALREADY_EXISTS", "UPSTREAM_TIMEOUT", "UPSTREAM_UNREACHABLE", "UNKNOWN_ERROR"]
    },
    {
      "name":        "recetas.listar",
      "description": "Lista las recetas del proyecto. Por defecto solo en_servicio (no archivadas). Filtros opcionales por estado o solo_incompletas.",
      "handler":     "onListar",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":      { "type": "string" },
          "estado":          { "type": "string", "enum": ["en_servicio", "archivada", "borrador"] },
          "solo_incompletas":{ "type": "boolean" },
          "limit":           { "type": "number", "default": 100 }
        },
        "required": ["project_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UPSTREAM_TIMEOUT", "UNKNOWN_ERROR"]
    },
    {
      "name":        "recetas.obtener",
      "description": "Devuelve una receta completa. Acepta receta_id (UUID) o nombre (exacto o parcial).",
      "handler":     "onObtener",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "receta_id":  { "type": "string", "description": "UUID de la receta" },
          "nombre":     { "type": "string", "description": "Nombre (alternativa a receta_id)" }
        },
        "required": ["project_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UPSTREAM_TIMEOUT"]
    },
    {
      "name":        "recetas.buscar",
      "description": "Busca recetas en_servicio por criterios combinables.",
      "handler":     "onBuscar",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":     { "type": "string" },
          "texto":          { "type": "string" },
          "ingrediente":    { "type": "string" },
          "categoria":      { "type": "string" },
          "etiqueta":       { "type": "string" },
          "dificultad_min": { "type": "number" },
          "dificultad_max": { "type": "number" },
          "tiempo_max":     { "type": "number" },
          "porciones":      { "type": "number" },
          "limit":          { "type": "number", "default": 50 }
        },
        "required": ["project_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UPSTREAM_TIMEOUT"]
    },
    {
      "name":        "recetas.actualizar",
      "description": "Modifica campos de una receta. Crea snapshot de la version anterior en history. Devuelve diff de cambios aplicados. Si tras actualizar la receta deja de estar incompleta, considera cambiar_estado a 'en_servicio'.",
      "handler":     "onActualizar",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":{ "type": "string" },
          "receta_id": { "type": "string" },
          "cambios":   { "type": "object", "description": "Solo los campos a cambiar. Mismo schema que recetas.crear." },
          "user_id":   { "type": "string" }
        },
        "required": ["project_id", "receta_id", "cambios"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UPSTREAM_TIMEOUT"]
    },
    {
      "name":        "recetas.historial",
      "description": "Devuelve las versiones anteriores de una receta.",
      "handler":     "onHistorial",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "receta_id":  { "type": "string" }
        },
        "required": ["project_id", "receta_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    },
    {
      "name":        "recetas.revertir",
      "description": "Restaura una version anterior. El estado actual se archiva en history (audit trail). Emite receta.actualizada con motivo='revertir'.",
      "handler":     "onRevertir",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":     { "type": "string" },
          "receta_id":      { "type": "string" },
          "target_version": { "type": "number" },
          "user_id":        { "type": "string" }
        },
        "required": ["project_id", "receta_id", "target_version"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    },
    {
      "name":        "recetas.eliminar",
      "description": "Archiva una receta (estado_operativo='archivada'). NO se borra del archivo. Emite receta.estado.actualizada (estado_anterior -> 'archivada') Y receta.eliminada.",
      "handler":     "onEliminar",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "receta_id":  { "type": "string" },
          "motivo":     { "type": "string", "description": "Razon opcional del archivado." },
          "user_id":    { "type": "string" }
        },
        "required": ["project_id", "receta_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    },
    {
      "name":        "recetas.cambiar_estado",
      "description": "Transiciona el estado_operativo de una receta con validacion canonica. Transiciones permitidas: borrador<->en_servicio, borrador->archivada, en_servicio->archivada. NO permitido: archivada->* (usar revertir para restaurar). Emite receta.estado.actualizada; si target=archivada, emite tambien receta.eliminada.",
      "handler":     "onCambiarEstado",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":    { "type": "string" },
          "receta_id":     { "type": "string" },
          "target_estado": { "type": "string", "enum": ["borrador", "en_servicio", "archivada"] },
          "motivo":        { "type": "string" },
          "user_id":       { "type": "string" }
        },
        "required": ["project_id", "receta_id", "target_estado"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PRECONDITION_FAILED"]
    },
    {
      "name":        "recetas.estadisticas",
      "description": "Resumen del proyecto: total recetas, distribucion por estado, incompletas, tamano del catalogo de ingredientes.",
      "handler":     "onEstadisticas",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" }
        },
        "required": ["project_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UPSTREAM_TIMEOUT"]
    },
    {
      "name":        "recetas.ingredientes",
      "description": "Lista el catalogo de ingredientes del proyecto.",
      "handler":     "onIngredientes",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "categoria":  { "type": "string" }
        },
        "required": ["project_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UPSTREAM_TIMEOUT"]
    },
    {
      "name":        "recetas.actualizar_precio",
      "description": "Actualiza (o crea) el precio_mercado de un ingrediente en el catalogo. Emite ingrediente.precio.actualizado.",
      "handler":     "onActualizarPrecio",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":    { "type": "string" },
          "nombre":        { "type": "string" },
          "precio_mercado":{ "type": "number" },
          "unidad":        { "type": "string" },
          "categoria":     { "type": "string" },
          "fuente":        { "type": "string", "enum": ["manual", "factura", "investigada", "scraper"] },
          "user_id":       { "type": "string" }
        },
        "required": ["project_id", "nombre", "precio_mercado"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UPSTREAM_TIMEOUT"]
    },
    {
      "name":        "recetas.analizar",
      "description": "Cruza ingredientes de la receta con el catalogo de precios. Devuelve coste_total, coste_por_porcion, coste_es_real.",
      "handler":     "onAnalizar",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "receta_id":  { "type": "string" }
        },
        "required": ["project_id", "receta_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PRECONDITION_FAILED"]
    },
    {
      "name":        "recetas.investigar_receta",
      "description": "Comprueba si una receta existe. Si existe, la devuelve. Si no, devuelve instruccion para que el LLM proponga una.",
      "handler":     "onInvestigarReceta",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":    { "type": "string" },
          "nombre_receta": { "type": "string" }
        },
        "required": ["project_id", "nombre_receta"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UPSTREAM_TIMEOUT"]
    }
  ],

  "config": {
    "data_file_pattern":        "data/projects/{slug}/recetas.json",
    "persistence":              "json-per-project",
    "campos_para_completa":     ["ingredientes", "porciones", "instrucciones"],
    "project_get_timeout_ms":   5000,
    "fs_request_timeout_ms":    8000,
    "default_listar_limit":     100,
    "default_buscar_limit":     50
  },

  "tracing": {
    "propaga_correlation_id": true
  },

  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "recetas.creada.total",
        "recetas.actualizada.total",
        "recetas.eliminada.total",
        "recetas.estado.actualizada.total",
        "recetas.ingrediente.precio.actualizado.total",
        "recetas.error",
        "recetas.publish_error"
      ],
      "gauges": [
        "recetas.total",
        "recetas.ingredientes_catalogo.total"
      ],
      "timings": []
    }
  }
}
