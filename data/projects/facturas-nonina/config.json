{
  "id": "facturas-nonina",
  "name": "Facturas Nonina Pizzicas",
  "description": "Procesamiento automático de facturas",

  "sources": {
    "telegram": {
      "botName": "facturas_asesoria_bot",
      "commands": {
        "/procesafacturas": "Revisa Gmail y procesa facturas nuevas",
        "/enviarfacturas": "Comprime y envía facturas a asesoría"
      }
    },
    "gmail": {
      "account": "noninapizzicas",
      "description": "Cuenta Gmail para facturas por correo"
    }
  },

  "processing": {
    "backend": "auto",
    "language": "es",
    "moveOriginal": true
  },

  "paths": {
    "procesadas": "./data/projects/facturas-nonina/procesadas",
    "pendientes": "./data/projects/facturas-nonina/pendientes",
    "envios": "./data/projects/facturas-nonina/envios"
  },

  "asesoria": {
    "email": "EMAIL_ASESORIA en .env",
    "formatos": ["ZIP con PDFs originales", "resumen.csv"]
  },

  "dependencies": {
    "npm": ["archiver"]
  }
}
