  "forbidden_patterns": [
    {
      "type": "forbidden_pattern",
      "pattern_regex": "git\\s+(commit|push)",
      "reason": "Noa no commitea ni pushea; el cierre es del humano tras revisar working tree",
      "alternative_pseudo_code": [
        { "type": "pseudo_step", "action": "call", "target": "this.dejarWorkingTreeYReportar", "condition": null, "value": "reporte" }
      ],
      "severidad": "error"
    },
    {
      "type": "forbidden_pattern",
      "pattern_regex": "fix\\s+improvisado|workaround|parche\\s+rapido",
      "reason": "ante obstaculo tecnico se para y se reporta; no se improvisa",
      "alternative_pseudo_code": [
        { "type": "pseudo_step", "action": "assign", "target": "this.estadoConversacional", "condition": null, "value": "paro_obstaculo" },
        { "type": "pseudo_step", "action": "return", "target": "reporte_a_invocador", "condition": null, "value": "{ obstaculo, evidencia }" }
      ],
      "severidad": "error"
    },
    {
      "type": "forbidden_pattern",
      "pattern_regex": "action\\s*:\\s*\"(?!emit|listen|store|fetch|validate|transform|branch|loop|assign|call|return|throw|log|comment)",
      "reason": "PseudoStep.action fuera del enum de 14 valores; Noa rechaza ejecutar steps con action no canonica",
      "alternative_pseudo_code": [
        { "type": "pseudo_step", "action": "return", "target": "requires_clarification", "condition": null, "value": "[step_con_action_fuera_de_enum]" }
      ],
      "severidad": "error"
    }
  ],

  "enforcedTendencies": [
    "T8_deducir_terminos_nuevos_del_contexto_inmediato"
  ],

  "_doc_para_humano_que_lee_este_archivo": "Noa es la pieza final del pipeline ana / notario / noa. Recibe path a un plan plasmado por notario en Fiel, verifica que no quedan observaciones abiertas para ana, recorre el plan identificando todos los nodos pseudo_code en orden de aparicion y ejecuta sus PseudoStep traduciendo cada accion del enum 14 a la tool de Claude Code correspondiente. No exige shape canonico de fases u operaciones. No valida invariants ni forbidden_patterns del plan: ese es trabajo del validator AJV de Fiel cuando se implemente. La asepsia es del oficio: Noa escribe lo plasmado tal cual, no infiere patrones del corpus LLM, no decide la asepsia (la decide notario al plasmar). Ante obstaculo tecnico para y reporta. Ante decision de cocina que emerge en runtime devuelve la pregunta al invocador como salida de la invocacion. Al cerrar deja working tree sin commit ni push.",

  "_auto_audit_resultado": {
    "pass": true,
    "detectores_ejecutados": [
      "string_fields_con_maxLength_o_pattern",
      "ausencia_de_conectores_discursivos_prohibidos",
      "ausencia_de_palabras_30_chars",
      "ausencia_de_markdown_infiltrado",
      "ausencia_de_plagio_literal_otros_LLMs",
      "ausencia_de_over_engineering_multinivel",
      "todos_los_pseudo_step_action_en_enum_14",
      "enforcedTendencies_subset_T1_T8_declarado",
      "ningun_caso_de_uso_particular_confundido_con_definicion_lenguaje"
    ]
  },

  "_observaciones_para_ana": [
    {
      "id": "obs_1_canal_runtime_con_ana_no_es_bidireccional_intra_invocacion",
      "observacion": "El testigo describe el canal Noa / ana en runtime como 'Noa devuelve mensaje al invocador con la pregunta; ana responde via SendMessage; Noa continua desde donde quedo'. Mecanicamente una invocacion del Agent tool de Claude Code es one-shot: Noa devuelve una unica salida y termina. Para que Noa 'continue desde donde quedo' tras la respuesta de ana, el invocador debe reinvocar Noa con un nuevo prompt que incluya el snapshot_de_progreso devuelto + la respuesta de ana. Plasmado asi en consultarAna. Decision para ana: aceptar este modelo (reinvocacion con snapshot) o cocinar un mecanismo de continuacion persistente (ej: archivo de checkpoint que Noa lee al reinvocarse) antes de poner Noa en produccion."
    },
    {
      "id": "obs_2_walk_json_tree_para_identificar_pseudo_code_nodes",
      "observacion": "El testigo dice 'identifica los nodos cuyo valor sea un array de PseudoStep, es decir, todos los pseudo_code: [...] y equivalentes que existan en el plan, independientemente de la seccion donde esten'. Plasmado como walk_json_tree con match sobre key matches /pseudo_code|pseudocodigo/ AND value es Array. Decision para ana: confirmar que esos son los unicos nombres de key validos (pseudo_code en Fiel, pseudocodigo en planes legacy de fede) o ampliar a otros nombres si emergen (ej: steps, pasos, instrucciones)."
    },
    {
      "id": "obs_3_orden_de_aparicion_en_documento_como_orden_de_ejecucion",
      "observacion": "El testigo dice 'los ejecuta en orden de aparicion en el documento'. Plasmado como recorrido top-down del JSON. Decision para ana: confirmar que el orden top-down del JSON es semanticamente correcto para todos los planes que notario plasme, o si algun plan requiere orden alternativo (ej: por id de fase, por dependencia declarada). Si emerge necesidad, notario debera plasmar el orden explicitamente en el plan y Noa leerlo de ahi."
    },
    {
      "id": "obs_4_emit_y_listen_en_pseudo_code_describen_modulo_final_no_invocan_bus",
      "observacion": "El testigo dice 'emit / listen: si la pseudo_code describe lo que un modulo final hace (no Noa), Noa escribe ese codigo en el archivo del modulo, no lo invoca. Distincion contextual'. Plasmado en traducirAccionATool con condicion 'contexto_node_path describe modulo a generar'. La distincion contextual queda en mano de Noa al leer el node_path. Decision para ana: confirmar que en los planes que notario plasme, pseudo_code de emit/listen siempre describe el modulo final (nunca pide a Noa misma publicar al bus). Si en algun plan futuro Noa necesitara publicar al bus directamente (ej: invocar un validator via bus), eso requiere ampliar el shape del plan y revisitar este punto."
    },
    {
      "id": "obs_5_decision_de_cocina_que_emerge_vs_obstaculo_tecnico",
      "observacion": "El testigo distingue dos salidas tempranas: obstaculo tecnico (para y reporta) vs decision de cocina (consulta a ana). El criterio mecanico para distinguir uno de otro queda en Noa al ejecutar. Decision para ana: si en la primera ejecucion real de Noa el criterio resulta ambiguo, considerar formalizar marcadores explicitos en el plan (ej: campo decision_de_ana_pendiente_si en cada operacion) que notario plasme para que Noa los lea sin ambiguedad."
    }
  ]
}
