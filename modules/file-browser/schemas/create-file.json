{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["project_id", "file_path"],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "file_path": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "type": {
      "type": "string",
      "enum": ["file", "directory"],
      "default": "file"
    }
  }
}
