{
  "name": "comandero",
  "version": "3.0.0",
  "description": "Buffer de pedido por cuenta del POS — items, variaciones, envio a cocina. Persistencia transitoria atomica.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "provides": {
    "events": [
      "comandero.item_agregado",
      "comandero.item_eliminado",
      "comandero.item_actualizado",
      "comandero.enviar_cocina"
    ]
  },
  "events": {
    "publishes": [
      { "event": "comandero.item_agregado",    "description": "Item añadido al buffer (lleva project_id top-level + correlation_id + timestamp)." },
      { "event": "comandero.item_eliminado",   "description": "Item eliminado del buffer (manual o por cantidad → 0)." },
      { "event": "comandero.item_actualizado", "description": "Cantidad o notas de item actualizado (incluye diff_cantidad y diff_precio)." },
      { "event": "comandero.enviar_cocina",    "description": "Pedido a cocina — pedidos crea pedido formal y cocina lo recibe." }
    ],
    "subscribes": [
      { "event": "cuenta.creada",        "handler": "onCuentaCreada",        "description": "Cachea ref_display canonico por cuenta." },
      { "event": "cuenta.actualizada",   "handler": "onCuentaActualizada",   "description": "Actualiza ref_display cuando se renombra la cuenta." },
      { "event": "caja.cerrada",         "handler": "onCajaCerrada",         "description": "Reset buffers al cerrar caja." },
      { "event": "dia.iniciado",         "handler": "onDiaIniciado",         "description": "Reset buffers al iniciar nuevo dia." },
      { "event": "catalogo.actualizado", "handler": "onCatalogoActualizado", "description": "Sincroniza cache general de productos (nombre, precio, categoria, estaciones)." },
      { "event": "producto.creado",      "handler": "onProductoActualizado", "description": "Cachea producto nuevo." },
      { "event": "producto.actualizado", "handler": "onProductoActualizado", "description": "Actualiza producto en cache." },
      { "event": "carta.actualizada",    "handler": "onCartaActualizada",    "description": "Cachea productos por carta (para resolver precio por canal de venta)." }
    ]
  },
  "ui_handlers": [
    { "domain": "comandero", "action": "get",          "handler": "handleGetPedido",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "comandero", "action": "add-item",     "handler": "handleAddItem",       "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "comandero", "action": "remove-item",  "handler": "handleRemoveItem",    "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "comandero", "action": "update-item",  "handler": "handleUpdateItem",    "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "comandero", "action": "send-kitchen", "handler": "handleEnviarCocina",  "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "comandero", "action": "buffers",      "handler": "handleListBuffers",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "comandero", "action": "health",       "handler": "handleHealthCheck",   "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [],
  "config": {
    "persistence": {
      "type":   "json-file",
      "atomic": true,
      "paths": [
        "data/current/comandero_buffers.json"
      ],
      "concurrency":   "single-instance-per-process (debounced 1s save)",
      "owner":         "modules/pizzepos/comandero",
      "notes":         "Buffer transitorio — solo items NO enviados a cocina. Los enviados estan en persistencia-comandero. Reset en caja.cerrada y dia.iniciado."
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "comandero.item_agregado.total",
        "comandero.item_eliminado.total",
        "comandero.enviado.total",
        "comandero.errors"
      ]
    }
  }
}
