/**
 * Módulo {{titleCase name}}
 *
 * {{description}}
 *
 * @module {{name}}
 * @version 1.0.0
 */

{{#if persistence}}
const fs = require('fs').promises;
const path = require('path');
{{/if}}

class {{pascalCase name}}Module {
  constructor() {
    this.name = '{{name}}';
    this.version = '1.0.0';

    // Estado interno
    {{#if persistence}}
    this.data = new Map();
    this.dataDir = path.join(process.cwd(), 'data');
    this.dataFile = path.join(this.dataDir, '{{name}}.json');
    {{/if}}

    // Configuración
    this.startTime = Date.now();

    // Dependencias (inyectadas en onLoad)
    this.logger = null;
    this.eventBus = null;
  }

  // ==========================================
  // Lifecycle
  // ==========================================

  async onLoad(core) {
    this.logger = core.logger;
    this.eventBus = core.eventBus;

    this.logger.info('{{name}}.loading', {
      module: this.name,
      version: this.version
    });

    {{#if persistence}}
    // Cargar datos persistidos (si existen)
    await this.loadFromJSON();
    {{/if}}

    {{#if hasSubscriptions}}
    // Suscribirse a eventos
    await this.subscribeToEvents();
    {{/if}}

    this.logger.info('{{name}}.loaded', {
      module: this.name
    });
  }

  async onUnload() {
    this.logger.info('{{name}}.unloading', {
      module: this.name
    });

    {{#if persistence}}
    // Persistir datos antes de cerrar
    await this.persistToJSON();
    {{/if}}

    this.logger.info('{{name}}.unloaded', {
      module: this.name
    });
  }

  {{#if hasSubscriptions}}
  // ==========================================
  // Event Subscriptions
  // ==========================================

  async subscribeToEvents() {
    {{#each subscriptions}}
    await this.eventBus.subscribe('{{this.event}}', this.{{this.handler}}.bind(this));
    {{/each}}

    this.logger.info('{{name}}.subscriptions.registered', {
      patterns: [{{#each subscriptions}}'{{this.event}}'{{#unless @last}}, {{/unless}}{{/each}}]
    });
  }

  // ==========================================
  // Event Handlers
  // ==========================================

  {{#each subscriptions}}
  async {{this.handler}}(envelope) {
    try {
      const eventType = envelope.event_type;

      this.logger.debug('{{../name}}.event.received', {
        event_type: eventType,
        event_id: envelope.event_id,
        correlation_id: envelope.metadata?.correlationId
      });

      // TODO: Implementar lógica del handler

    } catch (error) {
      this.logger.error('{{../name}}.{{this.handler}}.error', {
        error: error.message,
        event_id: envelope.event_id,
        stack: error.stack
      });
    }
  }

  {{/each}}
  {{/if}}
  // ==========================================
  // HTTP API Handlers
  // ==========================================

  {{#each apis}}
  async {{this.handler}}(req, context) {
    try {
      this.logger.info('{{../name}}.{{this.handler}}', {
        correlation_id: context.correlationId
      });

      // TODO: Implementar lógica del endpoint
      const data = {
        message: '{{this.method}} {{this.path}} - Not implemented yet',
        timestamp: new Date().toISOString()
      };

      return {
        status: 200,
        data
      };

    } catch (error) {
      this.logger.error('{{../name}}.{{this.handler}}.error', {
        error: error.message,
        correlation_id: context.correlationId
      });

      return {
        status: 500,
        data: { error: 'Error interno del servidor' }
      };
    }
  }

  {{/each}}
  async handleHealthCheck(req, context) {
    const uptime = (Date.now() - this.startTime) / 1000;

    return {
      status: 200,
      data: {
        status: 'healthy',
        module: this.name,
        version: this.version,
        uptime,
        timestamp: new Date().toISOString()
      }
    };
  }

  {{#if persistence}}
  // ==========================================
  // Persistencia JSON
  // ==========================================

  async loadFromJSON() {
    try {
      // Verificar si existe el directorio data/
      try {
        await fs.access(this.dataDir);
      } catch (error) {
        await fs.mkdir(this.dataDir, { recursive: true });
        this.logger.info('{{name}}.data_dir.created', {
          path: this.dataDir
        });
      }

      // Intentar cargar archivo
      try {
        await fs.access(this.dataFile);
      } catch (error) {
        this.logger.info('{{name}}.load.first_run', {
          message: 'No hay datos persistidos, iniciando desde cero'
        });
        return;
      }

      // Leer y parsear archivo
      const fileContent = await fs.readFile(this.dataFile, 'utf8');
      const parsed = JSON.parse(fileContent);

      // TODO: Cargar datos en estructuras internas
      if (parsed.data) {
        this.data = new Map(Object.entries(parsed.data));
      }

      this.logger.info('{{name}}.loaded_from_json', {
        file: this.dataFile,
        saved_at: parsed.metadata?.saved_at
      });

    } catch (error) {
      this.logger.error('{{name}}.load.error', {
        error: error.message,
        file: this.dataFile
      });
    }
  }

  async persistToJSON() {
    try {
      const snapshot = {
        version: this.version,
        data: Object.fromEntries(this.data),
        metadata: {
          saved_at: new Date().toISOString(),
          module_version: this.version,
          uptime: (Date.now() - this.startTime) / 1000
        }
      };

      // Escribir a archivo temporal
      const tempFile = `${this.dataFile}.tmp`;
      await fs.writeFile(tempFile, JSON.stringify(snapshot, null, 2), 'utf8');

      // Rename atómico
      await fs.rename(tempFile, this.dataFile);

      this.logger.debug('{{name}}.persisted_to_json', {
        file: this.dataFile
      });

    } catch (error) {
      this.logger.error('{{name}}.persist.error', {
        error: error.message,
        file: this.dataFile
      });
    }
  }
  {{/if}}
}

module.exports = {{pascalCase name}}Module;
