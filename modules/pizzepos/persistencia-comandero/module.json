{
  "name": "persistencia-comandero",
  "version": "4.0.0",
  "description": "Event-sourcing + jornada para pizzepos. Sustrato de persistencia: captura todos los eventos del bus pizzepos, mantiene snapshots de cuentas activas, registra ventas, orquesta cierre de caja diario, multi-proyecto.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "provides": {
    "events": [
      "caja.cerrada",
      "cuenta.cerrada_forzada",
      "dia.iniciado"
    ]
  },
  "events": {
    "publishes": [
      {
        "event":       "caja.cerrada",
        "description": "Cierre de caja completado — comandero debe resetear (lleva project_id + correlation_id + timestamp)."
      },
      {
        "event":       "cuenta.cerrada_forzada",
        "description": "Cuenta cerrada automaticamente durante cierre de caja (motivo: cierre_de_caja). Lleva snapshot completo."
      },
      {
        "event":       "dia.iniciado",
        "description": "Nuevo dia iniciado — sistema reseteado (eventosCache, ventasCache, cuentasActivasCache vacios)."
      }
    ],
    "subscribes": [
      { "event": "boton.pulsado",            "handler": "onEvento",                "description": "Registrar todas las pulsaciones de boton" },
      { "event": "ui.accion",                "handler": "onEvento",                "description": "Registrar acciones de UI" },
      { "event": "cuenta.creada",            "handler": "onCuentaCreada",          "description": "Guardar evento + registrar cuenta activa en cache" },
      { "event": "cuenta.cerrada",           "handler": "onCuentaCerrada",         "description": "Guardar evento + crear venta (busca cobro asociado)" },
      { "event": "cuenta.eliminada",         "handler": "onCuentaEliminada",       "description": "Limpiar cuenta de cache (safety net post-cobro)" },
      { "event": "cuenta.estado_cambiado",   "handler": "onCuentaEstadoCambiado",  "description": "Actualizar estado de cuenta activa en cache + disco" },
      { "event": "cuenta.actualizada",       "handler": "onCuentaActualizada",     "description": "Actualizar campos de cuenta activa (pagado, servido, total, items, estado, nombre, ref_display)" },
      { "event": "cobro.iniciado",           "handler": "onEvento",                "description": "Guardar evento de cobro iniciado" },
      { "event": "cobro.procesado",          "handler": "onEvento",                "description": "Guardar evento de cobro procesado (queda en eventosCache para crear venta luego)" },
      { "event": "cobro.reembolsado",        "handler": "onEvento",                "description": "Guardar evento de reembolso" },
      { "event": "pedido.creado",            "handler": "onPedidoCreado",          "description": "Asociar pedido a cuenta activa en cache" },
      { "event": "pedido.enviado_cocina",    "handler": "onEvento",                "description": "Guardar evento de pedido enviado a cocina" },
      { "event": "pedido.completado",        "handler": "onEvento",                "description": "Guardar evento de pedido completado" },
      { "event": "mesa.abierta",             "handler": "onEvento",                "description": "Guardar evento de mesa abierta" },
      { "event": "mesa.cerrada",             "handler": "onEvento",                "description": "Guardar evento de mesa cerrada" },
      { "event": "mesa.renombrada",          "handler": "onMesaRenombrada",        "description": "Actualizar nombre de mesa en cuenta activa" },
      { "event": "telefono.pedido_creado",   "handler": "onEvento",                "description": "Guardar evento de pedido telefonico" },
      { "event": "llevar.ticket_creado",     "handler": "onEvento",                "description": "Guardar evento de ticket llevar" },
      { "event": "comandero.item_agregado",  "handler": "onEvento",                "description": "Guardar evento de item agregado al buffer" },
      { "event": "comandero.item_eliminado", "handler": "onEvento",                "description": "Guardar evento de item eliminado del buffer" },
      { "event": "comandero.enviar_cocina",  "handler": "onEvento",                "description": "Guardar evento de envio a cocina" },
      { "event": "catalogo.actualizado",     "handler": "onEvento",                "description": "Guardar evento de catalogo actualizado" },
      { "event": "cocina.item_preparando",   "handler": "onEvento",                "description": "Item empieza a prepararse" },
      { "event": "cocina.item_preparado",    "handler": "onEvento",                "description": "Item terminado en estacion final" },
      { "event": "cocina.item_avanzado",     "handler": "onEvento",                "description": "Item avanza de estacion a estacion" },
      { "event": "cocina.pedido_listo",      "handler": "onEvento",                "description": "Pedido completado en cocina" }
    ]
  },
  "ui_handlers": [
    { "domain": "persistencia", "action": "cuentas_activas", "handler": "handleGetCuentasActivas",  "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "eventos",         "handler": "handleGetEventos",         "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "eventos_fecha",   "handler": "handleGetEventosFecha",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "ventas",          "handler": "handleGetVentas",          "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "ventas_fecha",    "handler": "handleGetVentasFecha",     "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "cuadre",          "handler": "handleCuadreCaja",         "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "cuadre_fecha",    "handler": "handleCuadreCajaFecha",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "cierre",          "handler": "handleCierreCaja",         "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "iniciar_dia",     "handler": "handleIniciarDia",         "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "backup",          "handler": "handleBackup",             "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "health",          "handler": "handleHealthCheck",        "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "persistencia", "action": "metrics",         "handler": "handleGetMetrics",         "type": "system_panel", "zone": "lateral_derecha" }
  ],
  "tools": [],
  "config": {
    "data_dir":     "./data",
    "eventos_dir":  "./data/eventos",
    "ventas_dir":   "./data/ventas",
    "current_dir":  "./data/current",
    "backup_dir":   "./data/backups",
    "persistence": {
      "type":        "json-file",
      "atomic":      true,
      "paths": [
        "data/current/{eventos,ventas,cuentas_activas,jornada}.json",
        "data/{eventos,ventas}/<fecha>.json",
        "data/backups/backup_<fecha>_<ts>/",
        "data/projects/<id>/persistencia/current/{eventos,ventas,cuentas_activas,jornada}.json",
        "data/projects/<id>/persistencia/{eventos,ventas}/<fecha>.json",
        "data/projects/<id>/persistencia/backups/backup_<fecha>_<ts>/",
        "data/projects/<id>/contabilidad/cierres/cierre_<fecha>.json"
      ],
      "concurrency": "single-instance-per-process (write queue serialized)"
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "persistencia.eventos.total",
        "persistencia.ventas.total",
        "persistencia.errores.total",
        "persistencia-comandero.errors"
      ]
    }
  }
}
