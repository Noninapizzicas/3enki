        { "type": "pseudo_step", "action": "validate", "target": "criterioDeCierre", "condition": "criterio_cumplido OR criterioDeCierre === null", "value": null },
        { "type": "pseudo_step", "action": "assign", "target": "reporte", "condition": null, "value": "{ archivos_tocados: [...], pseudoSteps_ejecutados: N, working_tree_status: 'dirty_sin_commit' }" },
        { "type": "pseudo_step", "action": "return", "target": "salida_de_invocacion", "condition": null, "value": "reporte" },
        { "type": "pseudo_step", "action": "comment", "target": null, "condition": null, "value": "no commit no push: decision del humano tras revisar working tree" }
