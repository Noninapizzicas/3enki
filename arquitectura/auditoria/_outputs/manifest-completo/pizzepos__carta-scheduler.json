      "parameters_required": ["project_id"],
      "parameters_property_names": ["project_id"],
      "parameters_size_chars": 89,
      "parameters_full_path_hint": "modules/pizzepos/carta-scheduler/module.json → tools[1].parameters"
    },
    {
      "name": "scheduler.eliminar_regla",
      "description": "Elimina una regla y su job en el scheduler",
