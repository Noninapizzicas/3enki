# config.mcp-enki.yaml.example — LOS OJOS de Hermes hacia Enki (dirección inversa).
#
# Bloque a AÑADIR al config.yaml de Hermes (/home/hermes/.hermes/config.yaml)
# CUANDO quieras que Hermes, mientras resuelve un encargo, pueda mirar y operar
# el mundo de Enki: Hermes es cliente MCP y el bridge de Enki
# (mcp/enki-mcp-server.js, stdio) le sirve las tools del sistema VÍA EL PORTAL.
#
# DOBLE REJA — ninguna de las dos se puentea:
#   1. La allowlist de ESTE bloque (tools.include): qué tools ve Hermes siquiera.
#   2. El guard del PORTAL de Enki: interruptor 'portal-mcp' (OFF por defecto,
#      lo manda el dueño desde el panel), scope por proyecto, mode read/write
#      ('portal-mcp-write'), y AUDIT portal.invocado → propiocepción.
#
# Con el interruptor del portal OFF, este bloque es INERTE: tools/list llega
# vacío y tools/call da 503. Pegarlo no abre nada — abre el dueño, en el panel.
#
# Tras editar el config: `/reload-mcp` en Hermes (o reiniciar hermes-gateway).

mcp_servers:
  enki:
    command: "node"
    args: ["/opt/enki/mcp/enki-mcp-server.js"]
    env:
      ENKI_BROKER_URL: "mqtt://localhost:1883"   # el broker de Enki en el mismo VPS
      ENKI_PROJECT: "CAMBIA-project-id"          # scope: Hermes ve UN proyecto, no el sistema
    tools:
      # Empieza estrecho (filosofía Hermes: "smallest useful surface";
      # filosofía Enki: el guard ya re-valida). Amplía cuando el uso lo pida.
      # Nombres reales del catálogo (los sirve el portal en tools/list):
      include:
        - "productos.list"
        - "productos.get"
        - "productos.search"
