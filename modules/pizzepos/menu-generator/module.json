{
  "name": "menu-generator",
  "version": "6.1.0",
  "description": "Genera cartas estructuradas en JSON desde cualquier input: fotos, PDF, texto. Pipeline OCR determinista (Google Vision) + agente IA para estructuración. Siempre pregunta el nombre.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "events": {
    "publishes": [
      {
        "event": "menu.generation.progress",
        "description": "Progreso del pipeline: extracting, structuring"
      },
      {
        "event": "menu.generation.failed",
        "description": "Error en el pipeline de generación"
      },
      {
        "event": "agent.execute.request",
        "response_schema_ref": "arquitectura/decisiones/_schemas/agent-flow/agent.execute.request.schema.json",
        "description": "Invoca agente menu-structurer para estructurar carta"
      },
      {
        "event": "carta.generar.iniciada",
        "description": "Aceptada carta.generar.solicitada — pipeline en marcha"
      },
      {
        "event": "carta.generar.fallida",
        "description": "Fallo al iniciar generación"
      }
    ],
    "subscribes": [
      {
        "event": "carta.generar.solicitada",
        "handler": "onCartaGenerarSolicitada"
      }
    ]
  },
  "ui_handlers": [
    {
      "domain": "menu",
      "action": "generate",
      "handler": "handleGenerate"
    },
    {
      "domain": "menu",
      "action": "health",
      "handler": "handleHealth"
    }
  ],
  "tools": [
    {
      "name": "menu.generate",
      "description": "Genera una carta estructurada desde cualquier input. SIEMPRE requiere nombre — pregúntalo antes de llamar. Acepta texto (OCR, dictado, lista, JSON, recetas) o filePath (PDF/imagen). Si es archivo, extrae texto con Google Vision antes de estructurar.",
      "handler": "toolGenerate",
      "parameters": {
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string",
            "description": "Nombre de la carta (OBLIGATORIO — preguntar al usuario)"
          },
          "texto": {
            "type": "string",
            "description": "Contenido del menú en cualquier formato textual"
          },
          "filePath": {
            "type": "string",
            "description": "Ruta a archivo PDF o imagen (alternativa a texto)"
          },
          "project_id": {
            "type": "string",
            "description": "ID del proyecto (obligatorio)"
          }
        },
        "required": [
          "nombre",
          "project_id"
        ]
      }
    }
  ],
  "pipeline": {
    "extraction": {
      "description": "Pipeline OCR determinista (no usa LLM)",
      "steps": [
        "pdfjs.render (si PDF)",
        "sharp.prepare-ocr",
        "google-vision.extract"
      ],
      "provider": "Google Vision",
      "timeouts": {
        "pdfInfo": 15000,
        "pdfRender": 30000,
        "sharp": 15000,
        "ocr": 60000
      }
    },
    "structuring": {
      "description": "Agente IA que estructura el texto en carta JSON",
      "agent": "menu-structurer",
      "trigger": "menu.text.request"
    }
  },
  "observability": {
    "metrics": {
      "counters": [
        "menu.generate.requested",
        "menu.generate.extract_failed"
      ]
    }
  },
  "config": {
    "persistence": {
      "pattern":           "in-memory",
      "restart_resilient": false,
      "concurrency":       "single-writer",
      "lost_on_restart":   ["services"]
    }
  }
}
