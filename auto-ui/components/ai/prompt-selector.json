{
  "name": "prompt-selector",
  "category": "ai",
  "description": "Selector de prompts guardados con búsqueda, categorías, versioning y CRUD completo",
  "version": "1.0.0",
  "author": "Event Core Team",

  "variants": {
    "panel": {
      "description": "Panel completo con todas las features",
      "className": "prompt-selector--panel"
    },
    "dropdown": {
      "description": "Dropdown compacto",
      "className": "prompt-selector--dropdown"
    },
    "modal": {
      "description": "Modal fullscreen",
      "className": "prompt-selector--modal"
    }
  },

  "props": {
    "variant": {
      "type": "enum",
      "values": ["panel", "dropdown", "modal"],
      "default": "panel"
    },
    "endpoint": {
      "type": "string",
      "default": "/modules/prompt-manager/prompts",
      "description": "Endpoint para cargar prompts"
    },
    "scope": {
      "type": "enum",
      "values": ["global", "project", "user", "all"],
      "default": "all",
      "description": "Alcance de prompts a mostrar"
    },
    "categories": {
      "type": "array",
      "default": ["menu", "product", "support", "general"],
      "description": "Categorías de prompts"
    },
    "showVersioning": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar selector de versión"
    },
    "enableCreate": {
      "type": "boolean",
      "default": true,
      "description": "Permitir crear nuevos prompts"
    },
    "enableEdit": {
      "type": "boolean",
      "default": true,
      "description": "Permitir editar prompts"
    },
    "showPreview": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar preview del prompt seleccionado"
    },
    "searchEnabled": {
      "type": "boolean",
      "default": true,
      "description": "Habilitar búsqueda de prompts"
    }
  },

  "features": [
    "Lista de prompts por categoría",
    "Búsqueda y filtrado",
    "Preview de prompt con variables",
    "Versionado de prompts",
    "Crear/editar/eliminar prompts",
    "Reemplazo de variables {{var}}",
    "Scope: global/project/user",
    "Favoritos",
    "Historial de uso"
  ],

  "example": {
    "component": "prompt-selector",
    "variant": "panel",
    "props": {
      "endpoint": "/modules/prompt-manager/prompts",
      "scope": "all",
      "showVersioning": true,
      "enableCreate": true,
      "searchEnabled": true
    }
  }
}
