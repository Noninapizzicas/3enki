{
  "id": "receptor-facturas",
  "name": "receptor-facturas",
  "description": "Recibe facturas por Telegram y las guarda para procesar",
  "provider": "deepseek",
  "model": "deepseek-chat",
  "temperature": 0.1,
  "max_tokens": 1000,
  "prompt_file": "prompts/receptor-facturas-system.md",
  "subscribes": [
    "telegram.photo.received",
    "telegram.document.received"
  ],
  "tools": [
    "telegram.get_file",
    "telegram.send_message",
    "fs.copy",
    "fs.write",
    "db.execute"
  ],
  "context_enabled": false,
  "enabled": true,
  "metadata": {
    "type": "receiver",
    "project": "factura-asesoria",
    "version": "1.0.0",
    "created_at": "2026-01-05"
  }
}
