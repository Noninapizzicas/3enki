      { "campo": "knownConversations", "tipo": "Map", "ubicacion_init": "modules/conversacion/chat-io/index.js:64", "se_invalida_con": "handleDelete elimina (delete) | onUnload .clear()",                                                                                                       "leak_potencial": false }
    ],
    "persistencia": {
      "sqlite_tablas": [
        {
          "nombre": "conversations",
          "scope_db": "project",
          "campos": ["id TEXT PRIMARY KEY","project_id TEXT NOT NULL","title TEXT","context_window INTEGER NOT NULL DEFAULT 20","temperature REAL NOT NULL DEFAULT 0.7","max_tokens INTEGER NOT NULL DEFAULT 2000","prompt_id TEXT","created_at INTEGER NOT NULL","updated_at INTEGER NOT NULL"],
          "indices": ["idx_conversations_project ON (project_id, updated_at DESC)"],
          "creada_por": "_ensureSchema(project_id)",
          "ubicacion_create": "modules/conversacion/chat-io/index.js:21",
          "migraciones_suaves": "_migrateSchema (línea 119) usa PRAGMA table_info + ALTER TABLE ADD COLUMN para prompt_id, context_window, temperature, max_tokens en tablas heredadas. Commit 244cbfa.",
          "ttl_o_housekeeping": null
        },
        {
          "nombre": "messages",
          "scope_db": "project",
          "campos": ["id TEXT PRIMARY KEY","conversation_id TEXT NOT NULL","role TEXT NOT NULL CHECK(role IN ('user','assistant','system','tool'))","content TEXT NOT NULL","in_context INTEGER NOT NULL DEFAULT 1","manually_toggled INTEGER NOT NULL DEFAULT 0","tokens INTEGER","cost REAL","metadata TEXT","created_at INTEGER NOT NULL"],
          "indices": ["idx_messages_conv ON (conversation_id, created_at)","idx_messages_context ON (conversation_id, in_context)"],
          "creada_por": "_ensureSchema(project_id)",
          "ubicacion_create": "modules/conversacion/chat-io/index.js:34",
          "migraciones_suaves": "_migrateSchema añade in_context, manually_toggled, tokens, cost, metadata via ALTER TABLE.",
          "ttl_o_housekeeping": "FIFO suave por contexto (_applyContextFIFO marca in_context=0 los más antiguos cuando active >= context_window, respeta manually_toggled=1). NO borra filas. delete de conversación SI borra mensajes."
        }
      ],
      "archivos": [],
      "notas_concurrencia": "Sin transacciones explícitas. handleSend hace 4-5 _db calls secuenciales (insert, update, count, select, update in_context). Sin lock entre llamadas — race condition teórica si 2 mensajes paralelos al mismo conversation_id. this.pendingDb es Map — race timeout/respuesta protegida con clearTimeout."
    }
  },

