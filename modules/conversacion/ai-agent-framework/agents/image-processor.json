{
  "id": "image-processor",
  "name": "image-processor",
  "description": "Agente con VISIÓN que analiza imágenes y decide cómo optimizarlas para OCR",
  "version": "2.0.0",
  "enabled": true,
  "prompt_file": "prompts/image-processor.json",
  "subscribes": [
    "imagen.optimizar.request"
  ],
  "publishes": [
    "imagen.optimizada"
  ],
  "tools": [
    "sharp_crop",
    "sharp_trim",
    "sharp_resize",
    "sharp_prepare_ocr",
    "sharp_convert"
  ],
  "provider": "deepseek",
  "model": "deepseek-chat",
  "temperature": 0.1,
  "max_tokens": 2000,
  "vision": {
    "enabled": true,
    "image_field": "imageBase64",
    "format": "data:image/jpeg;base64,{image}",
    "max_size": 1500,
    "prompt_with_image": true
  },
  "context_enabled": false,
  "config": {
    "max_iterations": 3,
    "timeout_ms": 120000,
    "retry_on_low_confidence": true,
    "confidence_threshold": 50
  },
  "metadata": {
    "author": "Event Core",
    "created": "2026-01-29",
    "updated": "2026-01-29",
    "tags": [
      "image",
      "ocr",
      "preprocessing",
      "sharp",
      "vision",
      "deepseek"
    ]
  },
  "scope": [
    "*"
  ]
}
