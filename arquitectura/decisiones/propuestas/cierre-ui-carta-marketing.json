  "decisiones_ya_cerradas": [
    {
      "id": "D1_pattern_zonas_apiladas_no_browser",
      "decision": "UN perfil de marca por proyecto --no hay catalogo navegable. Patron zonas apiladas (similar a tarifas y carta-digital, NO Browser+Detail como carta-impresion).",
      "no_reabrir_sin": "que emerja necesidad de multiples perfiles (improbable)"
    },
    {
      "id": "D2_3_zonas_perfil_onboarding_actividad",
      "decision": "Tres zonas apiladas verticalmente: PerfilZone (vista de los campos + boton editar), OnboardingZone (estado + CTA destacado si !completado, confirmacion + revisitar si completado), ActividadZone (stub --muestra placeholder informativo hasta integrar agent-observer).",
      "no_reabrir_sin": "decision diferente sobre estructura visual"
    },
    {
      "id": "D3_postura_B_canonica",
      "decision": "Postura B integral: cero forms de mutacion. Editar perfil + iniciar onboarding via prefillChatInput.",
      "no_reabrir_sin": "caso real de form bulk"
    },
    {
      "id": "D4_store_solo_lectura_principio_6",
      "decision": "Store lee via fs.read.request del path canonico /storage/config/marca.json. NUNCA invoca tools del blueprint (principio 6).",
      "no_reabrir_sin": "cambio paradigma"
    },
    {
      "id": "D5_suscripciones_canonicas",
      "decision": "initCartaMarketingSubscriptions registra: (a) marketing.perfil.actualizado --recarga loadPerfilMarca; (b) marketing.onboarding.completado --recarga.",
      "no_reabrir_sin": "cambio eventos canonicos"
    },
    {
      "id": "D6_actividad_zona_stub_documentado",
      "decision": "ActividadZone muestra placeholder informativo 'Integracion con agent-observer pendiente' --coherente con el backend que tambien es stub. Cuando agent-observer se integre, ambos se actualizan en horizonte aparte.",
      "no_reabrir_sin": "integracion agent-observer disponible"
    },
    {
      "id": "D7_no_amplia_blueprint",
      "decision": "NO amplia el backend con operaciones nuevas. Las 4 existentes son suficientes (get_perfil + update_perfil + completar_onboarding + actividad).",
      "no_reabrir_sin": "necesidad operativa concreta"
    }
  ],

  "fases": [
    {
      "id": "F1",
      "nombre": "Crear store frontend/src/lib/stores/carta-marketing.ts",
      "esfuerzo_horas": 1,
      "ok_explicito_antes_de_continuar": true,
      "operaciones": [
        {
          "id": "F1.op0_verificar_legacy",
          "descripcion": "Si existe store legacy, leer y decidir",
          "pseudocodigo": [
            "ls frontend/src/lib/stores/carta-marketing.ts 2>/dev/null",
            "si existe: Read y reportar al humano. Si invoca tools, reemplazar."
          ]
        },
        {
          "id": "F1.op1_crear_archivo",
          "descripcion": "Crear store con shape canonico",
          "pseudocodigo": [
            "crear frontend/src/lib/stores/carta-marketing.ts",
            "imports:",
            "  import { writable, derived } from 'svelte/store'",
            "  import { mqttRequest } from '$lib/ui-core/mqtt-request'",
            "  import { subscribe as busSubscribe } from '$lib/ui-core/bus'",
            "constantes:",
            "  const PERFIL_PATH = '/storage/config/marca.json'",
            "tipos:",
            "  interface PerfilMarca {",
            "    _version?: string",
            "    _updated_at?: string",
            "    nombre_marca?: string",
            "    lema?: string",
            "    tono_voz?: string",
            "    valores?: string[]",
            "    publico_objetivo?: string",
            "    diferenciacion?: string",
            "    restricciones?: string",
            "    idiomas?: string[]",
            "    onboarding_completado?: boolean",
            "    [key: string]: any",
            "  }",
            "stores:",
            "  export const perfilMarcaStore = writable<PerfilMarca | null>(null)",
            "  export const perfilMarcaLoading = writable<boolean>(false)",
            "  export const perfilMarcaError = writable<string | null>(null)",
            "  export const onboardingCompletado = derived(perfilMarcaStore, $p => $p?.onboarding_completado === true)",
            "  export const perfilVacio = derived(perfilMarcaStore, $p => !$p || (!$p.nombre_marca && !$p.tono_voz && (!$p.valores || $p.valores.length === 0)))"
          ]
        },
        {
          "id": "F1.op2_loadPerfilMarca",
          "descripcion": "Funcion loadPerfilMarca",
          "pseudocodigo": [
            "export async function loadPerfilMarca() {",
            "  perfilMarcaLoading.set(true)",
            "  perfilMarcaError.set(null)",
            "  try {",
            "    const res = await mqttRequest('fs', 'read', { path: PERFIL_PATH })",
            "    if (res?.status === 404) {",
            "      perfilMarcaStore.set({",
            "        _version: '1.0',",
            "        _updated_at: null,",
            "        nombre_marca: '',",
            "        tono_voz: '',",
            "        valores: [],",
            "        publico_objetivo: '',",
            "        idiomas: ['es'],",
            "        onboarding_completado: false",
            "      })",
            "      return",
            "    }",
            "    if (res?.status >= 400) throw new Error('fs.read fallo status ' + res.status)",
            "    perfilMarcaStore.set(JSON.parse(res.data.content))",
            "  } catch (err) {",
            "    perfilMarcaError.set(err?.message || 'Error al cargar perfil de marca')",
            "  } finally {",
            "    perfilMarcaLoading.set(false)",
            "  }",
            "}"
          ]
        },
        {
          "id": "F1.op3_initSubscriptions",
          "descripcion": "initCartaMarketingSubscriptions",
          "pseudocodigo": [
            "export function initCartaMarketingSubscriptions(): () => void {",
            "  const unsubs: Array<() => void> = []",
            "  unsubs.push(busSubscribe('marketing.perfil.actualizado', () => loadPerfilMarca()))",
            "  unsubs.push(busSubscribe('marketing.onboarding.completado', () => loadPerfilMarca()))",
            "  return () => unsubs.forEach(u => u())",
            "}"
          ]
        },
        {
          "id": "F1.op4_exports",
          "descripcion": "Verificar exports",
          "pseudocodigo": [
            "Confirmar exports:",
            "  stores: perfilMarcaStore, perfilMarcaLoading, perfilMarcaError, onboardingCompletado, perfilVacio",
            "  funciones: loadPerfilMarca, initCartaMarketingSubscriptions",
            "NO exportar mutaciones."
          ]
        }
      ],
      "salida_esperada": {
        "archivos_creados": ["frontend/src/lib/stores/carta-marketing.ts (~120 lineas)"]
      }
    },
    {
      "id": "F2",
      "nombre": "Crear modulo frontend",
      "esfuerzo_horas": 3,
      "ok_explicito_antes_de_continuar": true,
      "depende_de": "DEP1",
      "operaciones": [
        {
          "id": "F2.op0_verificar_dep1",
          "pseudocodigo": [
            "comprobar chatInputDraft existe",
            "si NO: parar"
          ]
        },
        {
          "id": "F2.op1_CartaMarketingPanel",
          "descripcion": "Panel sin router con 3 zonas apiladas",
          "pseudocodigo": [
            "crear frontend/src/lib/modules/carta-marketing/CartaMarketingPanel.svelte",
            "  <script>",
            "    import { onMount, onDestroy } from 'svelte'",
            "    import PerfilZone from './PerfilZone.svelte'",
            "    import OnboardingZone from './OnboardingZone.svelte'",
            "    import ActividadZone from './ActividadZone.svelte'",
            "    import { loadPerfilMarca, initCartaMarketingSubscriptions, perfilMarcaLoading, perfilMarcaError } from '$lib/stores/carta-marketing'",
            "    let cleanupSubs: (() => void) | null = null",
            "    onMount(() => { loadPerfilMarca(); cleanupSubs = initCartaMarketingSubscriptions() })",
            "    onDestroy(() => { if (cleanupSubs) cleanupSubs() })",
            "  </script>",
            "  <div class='carta-marketing-panel'>",
            "    {#if $perfilMarcaError}<div class='error-banner'>{$perfilMarcaError}</div>{/if}",
            "    {#if $perfilMarcaLoading}",
            "      <div class='loading'>Cargando perfil de marca...</div>",
            "    {:else}",
            "      <OnboardingZone />",
            "      <PerfilZone />",
            "      <ActividadZone />",
            "    {/if}",
            "  </div>"
          ]
        },
        {
          "id": "F2.op2_OnboardingZone",
          "descripcion": "Zona Onboarding --estado + CTA segun onboarding_completado",
          "pseudocodigo": [
            "crear frontend/src/lib/modules/carta-marketing/OnboardingZone.svelte",
            "  <script>",
            "    import { onboardingCompletado, perfilVacio } from '$lib/stores/carta-marketing'",
            "    import { prefillChatInput } from '$lib/stores/chatInputDraft'",
            "    function iniciarOnboarding() {",
            "      prefillChatInput('Inicia el onboarding guiado de marketing. Quiero completar el perfil de marca paso a paso.')",
            "    }",
            "    function revisitarOnboarding() {",
            "      prefillChatInput('Quiero revisar y actualizar el perfil de marca completado.')",
            "    }",
            "  </script>",
            "  <section class='zona-onboarding'>",
            "    {#if !$onboardingCompletado}",
            "      <div class='cta-onboarding'>",
            "        <h2>📋 Onboarding pendiente</h2>",
            "        <p>Completa el perfil de marca con un onboarding guiado por el agente de marketing.</p>",
            "        <button class='primaria' on:click={iniciarOnboarding}>Iniciar onboarding guiado</button>",
            "      </div>",
            "    {:else}",
            "      <div class='estado-onboarding'>",
            "        <h2>✓ Onboarding completado</h2>",
            "        <p>El perfil de marca esta configurado. Puedes revisitarlo si quieres ajustar.</p>",
            "        <button on:click={revisitarOnboarding}>Revisitar perfil</button>",
            "      </div>",
            "    {/if}",
            "  </section>"
          ]
        },
        {
          "id": "F2.op3_PerfilZone",
          "descripcion": "Zona Perfil --vista de campos + boton editar",
          "pseudocodigo": [
            "crear frontend/src/lib/modules/carta-marketing/PerfilZone.svelte",
            "  <script>",
            "    import { perfilMarcaStore, perfilVacio } from '$lib/stores/carta-marketing'",
            "    import { prefillChatInput } from '$lib/stores/chatInputDraft'",
            "    function editarPerfil() {",
            "      prefillChatInput('Actualiza el perfil de marca: [describe cambios: nombre_marca, tono_voz, valores, publico_objetivo, diferenciacion, idiomas].')",
            "    }",
            "    function editarCampo(campo) {",
            "      prefillChatInput('Actualiza el campo ' + campo + ' del perfil de marca a: [nuevo valor].')",
            "    }",
            "  </script>",
            "  <section class='zona-perfil'>",
            "    <header class='zona-header'>",
            "      <h2>Perfil de marca</h2>",
            "      <button on:click={editarPerfil}>Editar perfil</button>",
            "    </header>",
            "    {#if $perfilVacio}",
            "      <div class='empty-perfil'>",
            "        <p>Perfil vacio. Completa el onboarding o edita los campos manualmente.</p>",
            "      </div>",
            "    {:else if $perfilMarcaStore}",
            "      <dl class='perfil-campos'>",
            "        {#if $perfilMarcaStore.nombre_marca}",
            "          <dt>Nombre de marca:</dt>",
            "          <dd>{$perfilMarcaStore.nombre_marca} <button class='editar-campo' on:click={() => editarCampo('nombre_marca')}>✏</button></dd>",
            "        {/if}",
            "        {#if $perfilMarcaStore.lema}",
            "          <dt>Lema:</dt>",
            "          <dd>{$perfilMarcaStore.lema} <button class='editar-campo' on:click={() => editarCampo('lema')}>✏</button></dd>",
            "        {/if}",
            "        {#if $perfilMarcaStore.tono_voz}",
            "          <dt>Tono de voz:</dt>",
            "          <dd>{$perfilMarcaStore.tono_voz} <button class='editar-campo' on:click={() => editarCampo('tono_voz')}>✏</button></dd>",
            "        {/if}",
            "        {#if $perfilMarcaStore.valores?.length > 0}",
            "          <dt>Valores:</dt>",
            "          <dd>",
            "            <ul class='lista-valores'>{#each $perfilMarcaStore.valores as v}<li>{v}</li>{/each}</ul>",
            "            <button class='editar-campo' on:click={() => editarCampo('valores')}>✏</button>",
            "          </dd>",
            "        {/if}",
            "        {#if $perfilMarcaStore.publico_objetivo}",
            "          <dt>Publico objetivo:</dt>",
            "          <dd>{$perfilMarcaStore.publico_objetivo} <button class='editar-campo' on:click={() => editarCampo('publico_objetivo')}>✏</button></dd>",
            "        {/if}",
            "        {#if $perfilMarcaStore.diferenciacion}",
            "          <dt>Diferenciacion:</dt>",
            "          <dd>{$perfilMarcaStore.diferenciacion} <button class='editar-campo' on:click={() => editarCampo('diferenciacion')}>✏</button></dd>",
            "        {/if}",
            "        {#if $perfilMarcaStore.restricciones}",
            "          <dt>Restricciones:</dt>",
            "          <dd>{$perfilMarcaStore.restricciones} <button class='editar-campo' on:click={() => editarCampo('restricciones')}>✏</button></dd>",
            "        {/if}",
            "        {#if $perfilMarcaStore.idiomas?.length > 0}",
            "          <dt>Idiomas:</dt>",
            "          <dd>{$perfilMarcaStore.idiomas.join(', ')} <button class='editar-campo' on:click={() => editarCampo('idiomas')}>✏</button></dd>",
            "        {/if}",
            "      </dl>",
            "      {#if $perfilMarcaStore._updated_at}",
            "        <div class='ts-update'>Actualizado: {$perfilMarcaStore._updated_at}</div>",
            "      {/if}",
            "    {/if}",
            "  </section>"
          ]
        },
        {
          "id": "F2.op4_ActividadZone",
          "descripcion": "Zona Actividad --placeholder informativo",
          "pseudocodigo": [
            "crear frontend/src/lib/modules/carta-marketing/ActividadZone.svelte",
            "  <section class='zona-actividad'>",
            "    <h2>Actividad reciente</h2>",
            "    <div class='placeholder-actividad'>",
            "      <p class='nota'>Integracion con agent-observer pendiente.</p>",
            "      <p class='hint'>Cuando este disponible, esta zona mostrara las ultimas invocaciones a los agentes de marketing (copywriter, strategist, brand-keeper, onboarding).</p>",
            "    </div>",
            "  </section>"
          ]
        },
        {
          "id": "F2.op5_manifest_e_index",
          "descripcion": "manifest.json + index.ts + registro",
