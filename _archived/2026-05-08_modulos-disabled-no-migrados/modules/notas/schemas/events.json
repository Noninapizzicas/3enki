{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://event-core.local/schemas/notas/events.json",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": { "type": "string", "format": "uuid" },
        "event_type": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "producer": { "type": "string" },
        "schema_version": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "nota_creada": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "nota.creada" },
            "payload": {
              "type": "object",
              "required": ["nota_id", "titulo", "color"],
              "properties": {
                "nota_id": { "type": "string" },
                "titulo": { "type": "string" },
                "contenido": { "type": "string" },
                "color": { "type": "string" },
                "pinned": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "nota_actualizada": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "nota.actualizada" },
            "payload": {
              "type": "object",
              "required": ["nota_id", "updates"],
              "properties": {
                "nota_id": { "type": "string" },
                "updates": { "type": "object" },
                "previous": { "type": "object" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "nota_eliminada": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "nota.eliminada" },
            "payload": {
              "type": "object",
              "required": ["nota_id"],
              "properties": {
                "nota_id": { "type": "string" },
                "titulo": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
