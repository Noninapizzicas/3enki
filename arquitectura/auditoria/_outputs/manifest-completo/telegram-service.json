  },

  "eventos": {
    "publica": [
      { "event": "telegram.text.received",     "description": "Text message received" },
      { "event": "telegram.photo.received",    "description": "Photo received" },
      { "event": "telegram.document.received", "description": "Document received" },
      { "event": "telegram.video.received",    "description": "Video received" },
      { "event": "telegram.audio.received",    "description": "Audio received" },
      { "event": "telegram.voice.received",    "description": "Voice message received" },
      { "event": "telegram.location.received", "description": "Location received" },
      { "event": "telegram.contact.received",  "description": "Contact received" },
      { "event": "telegram.command.received",  "description": "Bot command received" },
      { "event": "telegram.callback.received", "description": "Inline button callback" },
      { "event": "telegram.message.sent",      "description": "Message sent successfully" },
      { "event": "telegram.send.failed",       "description": "Message send failed" },
      { "event": "telegram.bot.started",       "description": "Bot started polling" },
      { "event": "telegram.bot.stopped",       "description": "Bot stopped" },
      { "event": "telegram.bot.error",         "description": "Bot error" },
      { "event": "telegram.queue.overflow",    "description": "Message queue overflow" }
    ],
    "subscribes": [
      { "event": "credential.saved",                    "handler": "onCredentialSaved",      "extras": {} },
      { "event": "credential.deleted",                  "handler": "onCredentialDeleted",    "extras": {} },
      { "event": "telegram.send_message.request",       "handler": "onSendMessageRequest",   "extras": {} },
      { "event": "telegram.get_file.request",           "handler": "onGetFileRequest",       "extras": {} },
      { "event": "telegram.send_photo.request",         "handler": "onSendPhotoRequest",     "extras": {} },
      { "event": "telegram.send_document.request",      "handler": "onSendDocumentRequest",  "extras": {} },
      { "event": "telegram.send_video.request",         "handler": "onSendVideoRequest",     "extras": {} },
      { "event": "telegram.send_location.request",      "handler": "onSendLocationRequest",  "extras": {} },
      { "event": "telegram.edit_message.request",       "handler": "onEditMessageRequest",   "extras": {} },
      { "event": "telegram.delete_message.request",     "handler": "onDeleteMessageRequest", "extras": {} },
      { "event": "telegram.answer_callback.request",    "handler": "onAnswerCallbackRequest","extras": {} },
      { "event": "telegram.get_chat.request",           "handler": "onGetChatRequest",       "extras": {} },
      { "event": "telegram.set_commands.request",       "handler": "onSetCommandsRequest",   "extras": {} },
      { "event": "telegram.list_bots.request",          "handler": "onListBotsRequest",      "extras": {} }
    ],
    "provides_eventos": [
      "telegram.text.received",
      "telegram.photo.received",
      "telegram.document.received",
      "telegram.video.received",
      "telegram.audio.received",
      "telegram.voice.received",
      "telegram.location.received",
      "telegram.contact.received",
      "telegram.command.received",
      "telegram.callback.received",
      "telegram.message.sent",
      "telegram.send.failed",
      "telegram.bot.started",
      "telegram.bot.stopped",
      "telegram.bot.error",
      "telegram.queue.overflow"
    ]
  },

