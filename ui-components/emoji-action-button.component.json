{
  "component": "emoji-action-button",
  "name": "Emoji Action Button",
  "description": "Botón compacto 10x10mm con emoji para móvil, soporta 3 tipos de interacción",
  "size": {
    "width_mm": 10,
    "height_mm": 10,
    "width_px": 38,
    "height_px": 38,
    "tap_area_px": 56,
    "note": "Tamaño visual 38px, área táctil expandida a 56px (invisible)"
  },
  "styling": {
    "border_width": "2px",
    "border_radius": "8px",
    "emoji_size": "20px",
    "frame_variants": {
      "default": {
        "border_color": "#6B7280",
        "background": "transparent"
      },
      "active": {
        "border_color": "#2FBF71",
        "background": "rgba(47, 191, 113, 0.1)"
      },
      "pressed": {
        "border_color": "#F5B700",
        "background": "rgba(245, 183, 0, 0.2)"
      },
      "critical": {
        "border_color": "#E63946",
        "background": "rgba(230, 57, 70, 0.2)"
      }
    }
  },
  "interactions": {
    "single_click": {
      "enabled": true,
      "delay_ms": 300,
      "feedback": {
        "visual": "pulse_border",
        "border_color": "#2FBF71",
        "duration_ms": 300
      }
    },
    "double_click": {
      "enabled": true,
      "max_delay_ms": 300,
      "feedback": {
        "visual": "double_pulse_border",
        "border_color": "#1D4ED8",
        "duration_ms": 600
      }
    },
    "long_press": {
      "enabled": true,
      "duration_ms": 3000,
      "feedback": {
        "visual": "progress_fill",
        "border_color": "#E63946",
        "fill_color": "rgba(230, 57, 70, 0.3)",
        "haptic": true
      }
    }
  },
  "emojis": {
    "common": [
      "🏠", "⚙️", "🔍", "➕", "✏️", "🗑️", "💾", "📤", "📥", "⭐",
      "❤️", "👤", "📱", "🔔", "📊", "🎯", "🔒", "🔓", "✅", "❌"
    ]
  },
  "examples": [
    {
      "emoji": "🏠",
      "single_click": "Ver home",
      "double_click": "Editar home",
      "long_press": "Resetear home"
    },
    {
      "emoji": "🗑️",
      "single_click": "Mover a papelera",
      "double_click": "Ver papelera",
      "long_press": "Eliminar permanentemente"
    }
  ]
}
