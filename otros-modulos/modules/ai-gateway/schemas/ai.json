{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pizzepos.com/schemas/ai-gateway.json",
  "title": "AI Gateway Schema",
  "description": "Esquemas de datos para ai-gateway",

  "definitions": {
    "chat_message": {
      "type": "object",
      "required": ["role", "content"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["system", "user", "assistant"]
        },
        "content": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },

    "chat_request": {
      "type": "object",
      "required": ["messages"],
      "properties": {
        "messages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/chat_message"
          },
          "minItems": 1
        },
        "provider": {
          "type": "string",
          "enum": ["deepseek", "anthropic", "openai", "ollama", "auto"],
          "description": "Proveedor específico o 'auto' para fallback"
        },
        "model": {
          "type": "string",
          "description": "Modelo específico del proveedor"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "default": 0.7
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16000,
          "default": 1000
        }
      },
      "additionalProperties": false
    },

    "chat_response": {
      "type": "object",
      "required": ["id", "provider", "model", "message", "usage"],
      "properties": {
        "id": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "message": {
          "$ref": "#/definitions/chat_message"
        },
        "usage": {
          "type": "object",
          "properties": {
            "prompt_tokens": {"type": "integer"},
            "completion_tokens": {"type": "integer"},
            "total_tokens": {"type": "integer"},
            "cost": {"type": "number"}
          }
        },
        "duration_ms": {
          "type": "integer"
        }
      }
    },

    "provider_info": {
      "type": "object",
      "required": ["name", "enabled", "available", "models"],
      "properties": {
        "name": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "available": {
          "type": "boolean"
        },
        "priority": {
          "type": "integer"
        },
        "models": {
          "type": "array",
          "items": {"type": "string"}
        },
        "default_model": {
          "type": "string"
        }
      }
    },

    "usage_stats": {
      "type": "object",
      "required": ["total_requests", "total_tokens", "total_cost", "by_provider"],
      "properties": {
        "total_requests": {"type": "integer"},
        "total_tokens": {"type": "integer"},
        "total_cost": {"type": "number"},
        "by_provider": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "requests": {"type": "integer"},
              "tokens": {"type": "integer"},
              "cost": {"type": "number"},
              "errors": {"type": "integer"}
            }
          }
        }
      }
    }
  }
}
