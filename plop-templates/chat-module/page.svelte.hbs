<script lang="ts">
  import { onMount } from 'svelte';
  import { MobileWorkspaceLayout } from '$components/layout';
  import { SelectList, ToggleList, ActionForm } from '$components/ui';
  import { FloatingPanel, Spinner } from '$components/feedback';
  import { ToolbarIcon } from '$components/navigation';
  import { subscribe, events } from '$stores/mqtt';
  import { toast } from '$stores/toast';
  import config from '$lib/config';
  import type { SelectItem, SelectGroup } from '$components/ui/SelectList.svelte';
  import type { ToggleItem, ToggleGroup } from '$components/ui/ToggleList.svelte';
  import type { FormField, FormAction } from '$components/ui/ActionForm.svelte';

  // API Base
  const apiBase = `${config.apiUrl}/modules/{{name}}`;
  const credentialsApi = `${config.apiUrl}/modules/credential-manager`;
  const aiGatewayApi = `${config.apiUrl}/modules/ai-gateway`;

  // ============================================================================
  // STATE
  // ============================================================================

  let loading = true;
  let chatLoading = false;

  // Panel state - cada panel tiene su propio estado open
  let openPanel: string | null = null;

  // ============================================================================
  // DATA SOURCES (from blueprint)
  // ============================================================================
{{#each dataSources}}

  // {{comment}}
  let {{name}}: {{type}}{{#if default}} = {{{default}}}{{/if}};
{{/each}}

  // ============================================================================
  // TOOLBAR ICONS (generated from blueprint)
  // ============================================================================

  // Top toolbar - módulo específico
  const topIcons = [
{{#each toolbars.top.icons}}
    {
      id: '{{id}}',
      icon: '{{icon}}',
      label: '{{label}}',
{{#if badge}}
      badge: '{{badge}}',
{{/if}}
      actions: {
{{#if actions.tap}}
        tap: { type: '{{actions.tap.type}}', target: '{{actions.tap.target}}' },
{{/if}}
{{#if actions.doubleTap}}
        doubleTap: { type: '{{actions.doubleTap.type}}', target: '{{actions.doubleTap.target}}' },
{{/if}}
{{#if actions.longPress}}
        longPress: { type: '{{actions.longPress.type}}', target: '{{actions.longPress.target}}' }
{{/if}}
      }
    },
{{/each}}
  ];

  // Right toolbar - ecosistema (fijo)
  const rightIcons = [
    { id: 'modulos', icon: '🧩', label: 'Módulos', actions: { tap: { type: 'panel', target: 'modulos-lista' } } },
    { id: 'config', icon: '⚙️', label: 'Sistema', actions: { tap: { type: 'panel', target: 'config-rapido' } } },
    { id: 'notificaciones', icon: '🔔', label: 'Alertas', actions: { tap: { type: 'panel', target: 'notificaciones-lista' } } },
    { id: 'usuario', icon: '👤', label: 'Perfil', actions: { tap: { type: 'panel', target: 'usuario-menu' } } }
  ];

  // Chat top toolbar
  const chatTopIcons = [
    { id: 'modelo', icon: '🤖', label: 'Modelo', actions: { tap: { type: 'panel', target: 'modelo-selector' }, doubleTap: { type: 'modal', target: 'modelo-config' } } },
    { id: 'credencial', icon: '🔑', label: 'API Key', actions: { tap: { type: 'panel', target: 'credencial-selector' }, doubleTap: { type: 'modal', target: 'credencial-crear' } } },
    { id: 'prompt', icon: '📝', label: 'Prompt', actions: { tap: { type: 'panel', target: 'prompts-rapidos' }, doubleTap: { type: 'modal', target: 'prompt-crear' } } },
    { id: 'historial', icon: '💬', label: 'Historial', actions: { tap: { type: 'panel', target: 'conversaciones' } } }
  ];

  // Chat bottom toolbar
  const chatBottomIcons = [
    { id: 'herramientas', icon: '🔧', label: 'Tools', actions: { tap: { type: 'panel', target: 'tools-disponibles' } } },
    { id: 'adjuntar', icon: '📎', label: 'Adjuntar', actions: { tap: { type: 'panel', target: 'adjuntar-archivo' } } },
    { id: 'contexto', icon: '📋', label: 'Contexto', actions: { tap: { type: 'panel', target: 'contexto-actual' } } },
    { id: 'plugins', icon: '🔌', label: 'Plugins', actions: { tap: { type: 'panel', target: 'plugins-activos' } } }
  ];

  // ============================================================================
  // HANDLERS
  // ============================================================================

  function handleIconAction(e: CustomEvent<{ id: string; action: string; target: string }>) {
    const { action, target } = e.detail;

    if (action === 'panel' || action === 'modal') {
      openPanel = target;
    } else if (action === 'navigate') {
      // goto(target)
    }
  }

  function closePanel() {
    openPanel = null;
  }

  // Panel event handlers
{{#each panels}}
{{#if events.select}}
  function handle{{pascalCase id}}Select(e: CustomEvent<{ item: SelectItem }>) {
    const { item } = e.detail;
    {{events.select}}(item);
    closePanel();
  }
{{/if}}
{{#if events.change}}
  function handle{{pascalCase id}}Change(e: CustomEvent<{ values: string[] }>) {
    const { values } = e.detail;
    {{events.change}}(values);
  }
{{/if}}
{{#if events.submit}}
  function handle{{pascalCase id}}Submit(e: CustomEvent<{ data: Record<string, unknown> }>) {
    const { data } = e.detail;
    {{events.submit}}(data);
    closePanel();
  }
{{/if}}
{{/each}}

  // Domain handlers (implement these)
{{#each eventHandlers}}
  function {{name}}({{#if param}}{{param}}: {{paramType}}{{/if}}) {
    // TODO: Implement {{name}}
    console.log('{{name}}', {{#if param}}{{param}}{{/if}});
{{#if toastMessage}}
    toast.success('{{toastMessage}}');
{{/if}}
  }
{{/each}}

  // ============================================================================
  // CHAT
  // ============================================================================

  interface ChatMessage {
    id: string;
    role: 'user' | 'assistant' | 'system';
    content: string;
    timestamp: Date;
    loading?: boolean;
    error?: boolean;
  }

  let chatMessages: ChatMessage[] = [];

  async function handleChatSubmit(e: CustomEvent<{ message: string }>) {
    const { message } = e.detail;
    if (!message.trim()) return;

    const userMessage: ChatMessage = {
      id: `msg-${Date.now()}`,
      role: 'user',
      content: message,
      timestamp: new Date()
    };
    chatMessages = [...chatMessages, userMessage];

    const assistantId = `msg-${Date.now() + 1}`;
    chatMessages = [...chatMessages, {
      id: assistantId,
      role: 'assistant',
      content: '',
      timestamp: new Date(),
      loading: true
    }];
    chatLoading = true;

    try {
      const res = await fetch(`${aiGatewayApi}/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          messages: [
            { role: 'system', content: 'Eres un asistente útil.' },
            ...chatMessages.filter(m => !m.loading).slice(-10).map(m => ({ role: m.role, content: m.content }))
          ],
          provider: 'auto',
          max_tokens: 1000,
          temperature: 0.7
        })
      });

      if (!res.ok) throw new Error(`Error ${res.status}`);
      const data = await res.json();

      chatMessages = chatMessages.map(m =>
        m.id === assistantId
          ? { ...m, content: data.content || 'Sin respuesta', loading: false }
          : m
      );
    } catch (err) {
      chatMessages = chatMessages.map(m =>
        m.id === assistantId
          ? { ...m, content: `Error: ${err instanceof Error ? err.message : 'Error'}`, loading: false, error: true }
          : m
      );
      toast.error('Error al enviar mensaje');
    } finally {
      chatLoading = false;
    }
  }

  // ============================================================================
  // API
  // ============================================================================

  async function loadAll() {
    loading = true;
    try {
      // Load data from APIs
{{#each apiCalls}}
      const {{responseVar}} = await fetch(`${{{apiBase}}}/{{endpoint}}`);
      if ({{responseVar}}.ok) {
        const data = await {{responseVar}}.json();
        {{targetVar}} = data.{{dataField}} || {{default}};
      }
{{/each}}
    } catch (err) {
      console.error('Error loading data:', err);
    }
    loading = false;
  }

  // ============================================================================
  // LIFECYCLE
  // ============================================================================

  onMount(() => {
    loadAll();
    subscribe(['core/+/events/{{name}}/#']);
  });
</script>

<svelte:head>
  <title>{{titleCase name}} - Event-Core</title>
</svelte:head>

<MobileWorkspaceLayout
  title="{{titleCase name}}"
  showChat={true}
  chatPlaceholder="{{chatPlaceholder}}"
  {chatLoading}
  on:chatSubmit={handleChatSubmit}
>
  <!-- Top Toolbar -->
  <svelte:fragment slot="toolbar-top">
    {#each topIcons as icon}
      <ToolbarIcon
        {icon}
        on:action={handleIconAction}
      />
    {/each}
  </svelte:fragment>

  <!-- Right Toolbar -->
  <svelte:fragment slot="toolbar-right">
    {#each rightIcons as icon}
      <ToolbarIcon
        {icon}
        on:action={handleIconAction}
      />
    {/each}
  </svelte:fragment>

  <!-- Chat Top Toolbar -->
  <svelte:fragment slot="chat-toolbar-top">
    {#each chatTopIcons as icon}
      <ToolbarIcon
        {icon}
        on:action={handleIconAction}
      />
    {/each}
  </svelte:fragment>

  <!-- Chat Bottom Toolbar -->
  <svelte:fragment slot="chat-toolbar-bottom">
    {#each chatBottomIcons as icon}
      <ToolbarIcon
        {icon}
        on:action={handleIconAction}
      />
    {/each}
  </svelte:fragment>

  <!-- Main Content -->
  {#if loading}
    <div class="flex items-center justify-center h-full">
      <Spinner size="lg" />
    </div>
  {:else}
    <div class="space-y-4 p-4">
      <slot name="content">
        <!-- Default content -->
        <p class="text-center text-text-muted text-sm">
          {{titleCase name}} - Usa el chat para interactuar
        </p>
      </slot>
    </div>
  {/if}
</MobileWorkspaceLayout>

<!-- ============================================================================ -->
<!-- PANELS (generated from blueprint) -->
<!-- ============================================================================ -->

{{#each panels}}
{{#if (eq component "SelectList")}}
<!-- Panel: {{id}} (SelectList) -->
<FloatingPanel bind:open={openPanel === '{{id}}'} on:close={closePanel}>
  <SelectList
    items={ {{selectList.itemsSource}} }
{{#if selectList.groupsSource}}
    groups={ {{selectList.groupsSource}} }
{{/if}}
{{#if selectList.valueField}}
    bind:value={ {{selectList.valueField}} }
{{/if}}
    on:select={handle{{pascalCase id}}Select}
  />
</FloatingPanel>

{{else if (eq component "ToggleList")}}
<!-- Panel: {{id}} (ToggleList) -->
<FloatingPanel bind:open={openPanel === '{{id}}'} on:close={closePanel}>
  <ToggleList
    items={ {{toggleList.itemsSource}} }
{{#if toggleList.groupsSource}}
    groups={ {{toggleList.groupsSource}} }
{{/if}}
    bind:values={ {{toggleList.valuesField}} }
{{#if toggleList.showSelectAll}}
    showSelectAll={true}
{{/if}}
{{#if toggleList.max}}
    max={ {{toggleList.max}} }
{{/if}}
    on:change={handle{{pascalCase id}}Change}
  />
</FloatingPanel>

{{else if (eq component "ActionForm")}}
<!-- Panel: {{id}} (ActionForm) -->
<FloatingPanel bind:open={openPanel === '{{id}}'} on:close={closePanel}>
  <ActionForm
    fields={[
{{#each actionForm.fields}}
      { name: '{{name}}', type: '{{type}}', label: '{{label}}'{{#if required}}, required: true{{/if}}{{#if placeholder}}, placeholder: '{{placeholder}}'{{/if}} },
{{/each}}
    ]}
    actions={[
{{#each actionForm.actions}}
      { label: '{{label}}', emit: '{{emit}}', variant: '{{variant}}'{{#if validate}}, validate: true{{/if}} },
{{/each}}
    ]}
    on:{{events.submit}}={handle{{pascalCase id}}Submit}
    on:cancel={closePanel}
  />
</FloatingPanel>

{{else}}
<!-- Panel: {{id}} (Custom) -->
<FloatingPanel bind:open={openPanel === '{{id}}'} on:close={closePanel}>
  <slot name="panel-{{id}}">
    <p class="text-center text-text-muted py-4">Panel: {{id}}</p>
  </slot>
</FloatingPanel>

{{/if}}
{{/each}}
