{
  "id": "procesar-pdf",
  "name": "Procesar PDF con OCR",
  "description": "Convierte PDF a imagen y extrae texto con Google Vision",
  "version": "1.4.0",
  "enabled": true,

  "trigger": {
    "event": "facturas-nonina.documento.pendiente",
    "filter": {
      "mimeType": "application/pdf"
    }
  },

  "steps": [
    {
      "id": "log-inicio",
      "type": "log",
      "level": "info",
      "message": "Procesando PDF: {{ trigger.archivo }}"
    },
    {
      "id": "convertir-pdf",
      "type": "service",
      "service": "local.pdf-to-png",
      "action": "convert",
      "pdf": "{{ trigger.archivo }}",
      "pages": [1],
      "scale": 1.5,
      "outputFolder": "{{ replace(trigger.archivo, last(split(trigger.archivo, '/')), '') }}",
      "timeout": 180000,
      "onError": "notificar-error"
    },
    {
      "id": "log-conversion",
      "type": "log",
      "level": "info",
      "message": "PDF convertido: path={{ steps.convertir-pdf.data.images[0].path }}"
    },
    {
      "id": "verificar-imagen",
      "type": "service",
      "service": "fs",
      "action": "exists",
      "path": "{{ steps.convertir-pdf.data.images[0].path }}",
      "onError": "notificar-error"
    },
    {
      "id": "check-imagen-existe",
      "type": "condition",
      "if": "{{ steps.verificar-imagen.data.exists }}",
      "then": "extraer-texto",
      "else": "notificar-error"
    },
    {
      "id": "extraer-texto",
      "type": "service",
      "service": "local.google-vision",
      "action": "extract",
      "image": "{{ steps.convertir-pdf.data.images[0].path }}",
      "hint": "DOCUMENT_TEXT_DETECTION",
      "languageHints": ["es", "en"],
      "timeout": 120000,
      "onError": "notificar-error"
    },
    {
      "id": "guardar-texto",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "{{ trigger.archivo }}.ocr.txt",
      "content": "{{ steps.extraer-texto.data.text }}",
      "onError": "continue"
    },
    {
      "id": "guardar-resultado-ocr",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "{{ trigger.archivo }}.ocr.json",
      "content": "{{ json({ archivo: trigger.archivo, imagenPNG: steps.convertir-pdf.data.images[0].path, procesado: now, exito: true, confianza: steps.extraer-texto.data.confidence, caracteresTexto: steps.extraer-texto.data.textLength }) }}",
      "onError": "continue"
    },
    {
      "id": "notificar-exito",
      "type": "service",
      "service": "telegram",
      "action": "send_message",
      "chatId": "{{ trigger.chatId }}",
      "text": "📄 PDF procesado ({{ steps.extraer-texto.data.confidence }}% confianza).\nTexto: {{ steps.extraer-texto.data.textLength }} chars.",
      "onError": "continue"
    },
    {
      "id": "notificar-error",
      "type": "service",
      "service": "telegram",
      "action": "send_message",
      "chatId": "{{ trigger.chatId }}",
      "text": "❌ Error procesando PDF: {{ default(error.message, 'Error desconocido') }}",
      "onError": "continue"
    }
  ]
}
