{
  "id": "consolidar-excel",
  "name": "Consolidar Facturas - Excel Semanal",
  "description": "Genera Excel con facturas procesadas para enviar a asesoría",
  "version": "1.0.0",
  "enabled": false,

  "schedule": {
    "cron": "0 6 * * 0",
    "timezone": "Europe/Madrid"
  },

  "trigger": {
    "event": "flow.trigger",
    "filter": {
      "flowId": "consolidar-excel"
    }
  },

  "config": {
    "proyecto": "facturas"
  },

  "steps": [
    {
      "id": "log-inicio",
      "type": "log",
      "level": "info",
      "message": "Iniciando consolidación semanal de facturas - {{ date }}"
    },
    {
      "id": "crear-directorio-exports",
      "type": "service",
      "service": "fs",
      "action": "mkdir",
      "path": "@/projects/facturas/storage/exports",
      "onError": "continue"
    },
    {
      "id": "obtener-semana",
      "type": "set",
      "variables": {
        "semana": "{{ date.substring(0, 4) }}-W{{ Math.ceil((new Date(date) - new Date(date.substring(0, 4) + '-01-01')) / 604800000).toString().padStart(2, '0') }}"
      }
    },
    {
      "id": "exportar-datos",
      "type": "service",
      "service": "local.facturas-db",
      "action": "exportar",
      "proyecto": "facturas",
      "timeout": 60000
    },
    {
      "id": "verificar-facturas",
      "type": "condition",
      "if": "{{ steps.exportar-datos.data.total > 0 }}",
      "then": "generar-excel",
      "else": "log-sin-facturas"
    },
    {
      "id": "log-sin-facturas",
      "type": "log",
      "level": "info",
      "message": "No hay facturas procesadas para exportar esta semana"
    },
    {
      "id": "generar-excel",
      "type": "service",
      "service": "local.xlsx",
      "action": "create",
      "sheets": [
        {
          "name": "Facturas Recibidas",
          "data": "{{ steps.exportar-datos.data.facturas }}",
          "columns": [
            "Nº Registro",
            "Fecha Factura",
            "Nº Factura",
            "NIF Proveedor",
            "Proveedor",
            "Concepto",
            "Categoría",
            "Base Imponible",
            "% IVA",
            "Cuota IVA",
            "Total",
            "Estado Pago",
            "Origen",
            "Archivo"
          ]
        }
      ],
      "filename": "facturas_{{ steps.exportar-datos.data.semana }}.xlsx",
      "timeout": 60000
    },
    {
      "id": "copiar-a-exports",
      "type": "service",
      "service": "fs",
      "action": "copy",
      "source": "{{ steps.generar-excel.path }}",
      "destination": "@/projects/facturas/storage/exports/facturas_{{ steps.exportar-datos.data.semana }}.xlsx",
      "timeout": 30000
    },
    {
      "id": "marcar-exportadas",
      "type": "service",
      "service": "local.facturas-db",
      "action": "marcarExportadas",
      "proyecto": "facturas",
      "ids": "{{ steps.exportar-datos.data.ids }}",
      "semana": "{{ steps.exportar-datos.data.semana }}",
      "timeout": 30000
    },
    {
      "id": "log-completado",
      "type": "log",
      "level": "info",
      "message": "Excel generado: facturas_{{ steps.exportar-datos.data.semana }}.xlsx - {{ steps.exportar-datos.data.total }} facturas exportadas"
    },
    {
      "id": "emitir-completado",
      "type": "emit",
      "event": "factura.completada",
      "data": {
        "tipo": "consolidacion-semanal",
        "semana": "{{ steps.exportar-datos.data.semana }}",
        "total": "{{ steps.exportar-datos.data.total }}",
        "archivo": "@/projects/facturas/storage/exports/facturas_{{ steps.exportar-datos.data.semana }}.xlsx"
      }
    }
  ]
}
