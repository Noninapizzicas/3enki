    "violaciones_corregidas": [],
    "terminos_verificados_contra_repo": ["drift_bypass_filesystem", "FS_WHITELIST_MODULES", "fs.*.request", "data_path", "validate:ci", "drift-baseline.json", "pizzepos/productos", "_pizzepos-productos-disciplina-via-notario.json"]
  }
