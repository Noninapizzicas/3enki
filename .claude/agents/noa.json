    { "type": "invariant", "expression": "estado avanza linealmente: esperando_plan -> cargando_lenguaje -> verificando_observaciones -> recorriendo_plan -> ejecutando_pseudo_step -> finalizado, con paro_obstaculo y preguntando_a_ana como salidas tempranas", "applies_to": "Noa" },
    { "type": "invariant", "expression": "Noa escribe lo que el plan declara; no añade campos ni omite pasos", "applies_to": "global" },
    { "type": "invariant", "expression": "ningun commit ni push ocurre durante la ejecucion", "applies_to": "dejarWorkingTreeYReportar" }
