{
  "component": "producto-button",
  "version": "1.0.0",
  "description": "Botón rectangular para productos - 30mm×12mm con marco de evento y emojis",
  "author": "Event Core Team",
  "created": "2025-01-15",
  "license": "MIT",

  "dimensions": {
    "width": "30mm",
    "height": "12mm",
    "width_px": 113,
    "height_px": 45,
    "border_width": "2px",
    "marco_thickness": "4mm",
    "marco_thickness_px": 15,
    "responsive": true,
    "minWidth": "110px",
    "minHeight": "42px"
  },

  "structure": {
    "layers": [
      {
        "id": "background",
        "description": "Fondo del botón según categoría de producto"
      },
      {
        "id": "marco",
        "description": "Marco de 4mm que cambia según evento",
        "thickness": "4mm",
        "inset": "0px"
      },
      {
        "id": "content-area",
        "description": "Área interior para nombre del producto",
        "inset": "4mm"
      }
    ],
    "corners": [
      {
        "id": "top-left",
        "position": { "top": "2px", "left": "2px" },
        "size": "14px",
        "description": "Emoji de evento principal"
      },
      {
        "id": "top-right",
        "position": { "top": "2px", "right": "2px" },
        "size": "14px",
        "description": "Emoji secundario"
      },
      {
        "id": "bottom-left",
        "position": { "bottom": "2px", "left": "2px" },
        "size": "14px",
        "description": "Emoji terciario"
      }
    ],
    "precio": {
      "position": { "bottom": "3px", "right": "4px" },
      "font_size": "11px",
      "font_weight": "700",
      "color": "#ffffff",
      "shadow": "0 1px 2px rgba(0, 0, 0, 0.5)"
    }
  },

  "props": {
    "required": [
      "id",
      "nombre",
      "precio",
      "categoria"
    ],
    "optional": [
      "evento",
      "emojis",
      "descripcion",
      "imagen",
      "disponible"
    ],
    "types": {
      "id": "string",
      "nombre": "string",
      "precio": "number",
      "categoria": "enum['pizzas','bebidas','entrantes','postres','ensaladas','pasta','carnes','pescados','otros']",
      "evento": "enum['normal','oferta','promocion','sin_stock','no_disponible','destacado','nuevo','vegano','picante']",
      "emojis": "object",
      "descripcion": "string",
      "imagen": "string",
      "disponible": "boolean"
    }
  },

  "categorias": {
    "pizzas": {
      "name": "Pizzas",
      "background": "linear-gradient(135deg, #f97316 0%, #ea580c 100%)",
      "shadow": "0 4px 12px rgba(249, 115, 22, 0.4)"
    },
    "bebidas": {
      "name": "Bebidas",
      "background": "linear-gradient(135deg, #06b6d4 0%, #0891b2 100%)",
      "shadow": "0 4px 12px rgba(6, 182, 212, 0.4)"
    },
    "entrantes": {
      "name": "Entrantes",
      "background": "linear-gradient(135deg, #22c55e 0%, #16a34a 100%)",
      "shadow": "0 4px 12px rgba(34, 197, 94, 0.4)"
    },
    "postres": {
      "name": "Postres",
      "background": "linear-gradient(135deg, #ec4899 0%, #db2777 100%)",
      "shadow": "0 4px 12px rgba(236, 72, 153, 0.4)"
    },
    "ensaladas": {
      "name": "Ensaladas",
      "background": "linear-gradient(135deg, #84cc16 0%, #65a30d 100%)",
      "shadow": "0 4px 12px rgba(132, 204, 22, 0.4)"
    },
    "pasta": {
      "name": "Pasta",
      "background": "linear-gradient(135deg, #f59e0b 0%, #d97706 100%)",
      "shadow": "0 4px 12px rgba(245, 158, 11, 0.4)"
    },
    "carnes": {
      "name": "Carnes",
      "background": "linear-gradient(135deg, #ef4444 0%, #dc2626 100%)",
      "shadow": "0 4px 12px rgba(239, 68, 68, 0.4)"
    },
    "pescados": {
      "name": "Pescados",
      "background": "linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)",
      "shadow": "0 4px 12px rgba(59, 130, 246, 0.4)"
    },
    "otros": {
      "name": "Otros",
      "background": "linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%)",
      "shadow": "0 4px 12px rgba(139, 92, 246, 0.4)"
    }
  },

  "eventos": {
    "normal": {
      "name": "Normal",
      "marco_color": "rgba(255, 255, 255, 0.2)",
      "emojis": {}
    },
    "oferta": {
      "name": "Oferta Especial",
      "marco_color": "#fbbf24",
      "marco_glow": "0 0 8px rgba(251, 191, 36, 0.6)",
      "emojis": { "top-left": "🔥" },
      "animation": "pulse"
    },
    "promocion": {
      "name": "Promoción",
      "marco_color": "#a855f7",
      "marco_glow": "0 0 8px rgba(168, 85, 247, 0.6)",
      "emojis": { "top-left": "⭐" },
      "animation": "pulse"
    },
    "sin_stock": {
      "name": "Sin Stock",
      "marco_color": "#ef4444",
      "marco_glow": "0 0 8px rgba(239, 68, 68, 0.6)",
      "emojis": { "top-left": "❌" },
      "overlay": "rgba(0, 0, 0, 0.5)",
      "disabled": true
    },
    "no_disponible": {
      "name": "No Disponible",
      "marco_color": "#6b7280",
      "emojis": { "top-left": "⛔" },
      "overlay": "rgba(0, 0, 0, 0.6)",
      "disabled": true
    },
    "destacado": {
      "name": "Destacado",
      "marco_color": "#22c55e",
      "marco_glow": "0 0 8px rgba(34, 197, 94, 0.6)",
      "emojis": { "top-left": "✨" },
      "animation": "shimmer"
    },
    "nuevo": {
      "name": "Nuevo",
      "marco_color": "#3b82f6",
      "marco_glow": "0 0 8px rgba(59, 130, 246, 0.6)",
      "emojis": { "top-left": "🆕" }
    },
    "vegano": {
      "name": "Vegano",
      "marco_color": "#84cc16",
      "emojis": { "top-right": "🌱" }
    },
    "picante": {
      "name": "Picante",
      "marco_color": "#ef4444",
      "emojis": { "top-right": "🌶️" }
    }
  },

  "estados": {
    "default": {
      "opacity": 1,
      "scale": 1,
      "border": "1px solid rgba(255, 255, 255, 0.2)"
    },
    "hover": {
      "opacity": 1,
      "scale": 1.05,
      "border": "1px solid rgba(255, 255, 255, 0.4)",
      "lift": "2px"
    },
    "active": {
      "opacity": 1,
      "scale": 0.98,
      "border": "2px solid rgba(255, 255, 255, 0.6)"
    },
    "disabled": {
      "opacity": 0.5,
      "scale": 1,
      "cursor": "not-allowed"
    }
  },

  "interactions": {
    "haptic": true,
    "ripple": true,
    "touch_zones": {
      "left": {
        "width": "30%",
        "action": "show-variations",
        "label": "Variaciones"
      },
      "right": {
        "width": "70%",
        "action": "add-to-order",
        "label": "Añadir"
      }
    },
    "long_press": {
      "enabled": false,
      "duration": 500,
      "action": "show-variations"
    }
  },

  "events": {
    "emits": [
      "producto:ready",
      "producto:click",
      "producto:add",
      "producto:variations",
      "producto:long-press"
    ],
    "listens": [
      "producto:update",
      "producto:price-change",
      "producto:stock-change"
    ]
  },

  "api": {
    "endpoints": [
      {
        "method": "GET",
        "path": "/api/productos/:id",
        "description": "Obtener datos del producto"
      },
      {
        "method": "GET",
        "path": "/api/productos/:id/variations",
        "description": "Obtener variaciones del producto"
      },
      {
        "method": "POST",
        "path": "/api/orders/add-item",
        "description": "Añadir producto a la orden"
      }
    ],
    "mqtt": [
      {
        "topic": "/events/productos/:id/stock",
        "description": "Actualización de stock en tiempo real"
      },
      {
        "topic": "/events/productos/:id/precio",
        "description": "Cambio de precio en tiempo real"
      },
      {
        "topic": "/events/productos/:id/evento",
        "description": "Cambio de evento (oferta, promoción, etc.)"
      }
    ]
  },

  "accessibility": {
    "aria": true,
    "keyboard": true,
    "screenReader": true,
    "minTouchTarget": "44px",
    "contrastRatio": "4.5:1"
  },

  "dependencies": [],
  "browser": {
    "modern": true,
    "ie11": false,
    "mobile": true
  },
  "performance": {
    "lazy": false,
    "bundle": "standalone"
  },

  "preset_productos": [
    {
      "id": "pizza-margarita",
      "nombre": "Margarita",
      "precio": 8.50,
      "categoria": "pizzas",
      "evento": "normal"
    },
    {
      "id": "pizza-carbonara",
      "nombre": "Carbonara",
      "precio": 10.50,
      "categoria": "pizzas",
      "evento": "destacado"
    },
    {
      "id": "pizza-vegetariana",
      "nombre": "Vegetariana",
      "precio": 9.50,
      "categoria": "pizzas",
      "evento": "vegano"
    },
    {
      "id": "coca-cola",
      "nombre": "Coca-Cola",
      "precio": 2.50,
      "categoria": "bebidas",
      "evento": "normal"
    },
    {
      "id": "ensalada-cesar",
      "nombre": "Ensalada César",
      "precio": 7.50,
      "categoria": "ensaladas",
      "evento": "oferta"
    },
    {
      "id": "tiramisu",
      "nombre": "Tiramisú",
      "precio": 4.50,
      "categoria": "postres",
      "evento": "nuevo"
    }
  ]
}
