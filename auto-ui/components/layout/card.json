{
  "name": "card",
  "version": "1.0.0",
  "type": "layout",
  "description": "Contenedor con header, body y footer opcionales",

  "variants": {
    "default": {
      "bg": "var(--bg-card)",
      "border": "var(--border)"
    },
    "elevated": {
      "bg": "var(--bg-card)",
      "border": "transparent",
      "shadow": "var(--shadow-md)"
    },
    "outlined": {
      "bg": "transparent",
      "border": "var(--border)"
    },
    "interactive": {
      "bg": "var(--bg-card)",
      "border": "var(--border)",
      "hover": {
        "border": "var(--primary)",
        "transform": "translateY(-2px)"
      }
    }
  },

  "sizes": {
    "sm": {
      "padding": "var(--space-sm)"
    },
    "md": {
      "padding": "var(--space-md)"
    },
    "lg": {
      "padding": "var(--space-lg)"
    }
  },

  "sections": {
    "header": {
      "enabled": true,
      "border": true
    },
    "body": {
      "enabled": true
    },
    "footer": {
      "enabled": true,
      "border": true
    }
  },

  "interactions": {
    "click": {
      "enabled": false
    },
    "swipe-left": {
      "enabled": false,
      "threshold": 50
    },
    "swipe-right": {
      "enabled": false,
      "threshold": 50
    }
  },

  "accessibility": {
    "role": "article",
    "tabIndex": -1
  }
}
