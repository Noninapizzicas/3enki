{
  "id": "viabilidad-receta-analyzer",
  "name": "viabilidad-receta-analyzer",
  "description": "Agente complementario al modulo viabilidad. El modulo cubre la dimension ECONOMICA (deterministica); este agente cubre las dimensiones CUALITATIVAS (riesgos, diferenciacion, encaje en oferta, recomendaciones). Se dispara cuando viabilidad.evaluacion.completada emerge y enriquece el expediente con analisis cualitativo via LLM.",
  "version": "2.0.0",
  "enabled": true,
  "prompt_file": "prompts/viabilidad-receta-analyzer.json",
  "tools": [
    "viabilidad.evaluar",
    "viabilidad.obtener",
    "viabilidad.listar"
  ],
  "provider": "auto",
  "temperature": 0.3,
  "max_tokens": 2000,
  "context_enabled": true,
  "timeout_ms": 120000,
  "max_retries": 1,
  "event_listener": {
    "event": "viabilidad.evaluacion.completada",
    "context_mapping": {
      "correlation_id": "$.correlation_id",
      "project_id": "$.project_id",
      "user_id": "$.user_id",
      "expediente_id": "$.expediente_id",
      "nombre_idea": "$.nombre_idea",
      "veredicto": "$.veredicto",
      "coste_total": "$.coste_total",
      "coste_por_porcion": "$.coste_por_porcion",
      "coste_es_real": "$.coste_es_real",
      "food_cost_pct": "$.food_cost_pct",
      "advertencias": "$.advertencias",
      "ingredientes_sin_precio": "$.ingredientes_sin_precio",
      "timestamp": "$.timestamp"
    }
  },
  "publish_on_success": {
    "event": "viabilidad.analisis.cualitativo.completado",
    "payload_template": {
      "correlation_id": "$.context.correlation_id",
      "project_id": "$.context.project_id",
      "user_id": "$.context.user_id",
      "expediente_id": "$.context.expediente_id",
      "nombre_idea": "$.context.nombre_idea",
      "analisis": "$.result.analisis",
      "riesgos": "$.result.riesgos",
      "recomendaciones": "$.result.recomendaciones",
      "timestamp": "$.timestamp"
    }
  },
  "publish_on_failure": {
    "event": "viabilidad.analisis.cualitativo.fallido",
    "payload_template": {
      "correlation_id": "$.context.correlation_id",
      "project_id": "$.context.project_id",
      "user_id": "$.context.user_id",
      "expediente_id": "$.context.expediente_id",
      "error": "$.error.message",
      "timestamp": "$.timestamp"
    }
  },
  "metadata": {
    "type": "pipeline-agent",
    "domain": "viabilidad",
    "pipeline_role": "viability-qualitative-analyzer",
    "author": "system",
    "created_at": "2026-04-15",
    "updated_at": "2026-05-17",
    "tags": [
      "viabilidad",
      "analisis-cualitativo",
      "riesgos",
      "recomendaciones"
    ]
  },
  "created_at": "2026-04-15T00:00:00.000Z",
  "updated_at": "2026-05-17T00:00:00.000Z",
  "stats": {
    "executions": 0,
    "successes": 0,
    "failures": 0,
    "total_tokens": 0,
    "total_cost": 0,
    "avg_latency_ms": 0,
    "last_execution": null
  },
  "scope": [
    "viabilidad",
    "recetas"
  ]
}
