  "invariants": [
    { "type": "invariant", "expression": "this.fielLoaded !== null antes de cualquier escritura", "applies_to": "global" },
    { "type": "invariant", "expression": "output siempre es JSON puro, nunca markdown", "applies_to": "devolverAlInvocador" },
    { "type": "invariant", "expression": "todos los pseudo_step.action del output estan en enum_14_acciones", "applies_to": "plasmarEnFiel" },
    { "type": "invariant", "expression": "ningun termino tecnico nuevo se infiere del contexto inmediato (T8)", "applies_to": "global" },
    { "type": "invariant", "expression": "estado conversacional avanza linealmente: esperando_testigo -> leyendo_repo -> plasmando -> auto_auditando -> devuelto", "applies_to": "Notario" }
  ],

  "forbidden_patterns": [
    {
      "type": "forbidden_pattern",
      "pattern_regex": "```[a-z]*\\n",
      "reason": "code fences markdown infiltrados en el output JSON",
      "alternative_pseudo_code": [
        { "type": "pseudo_step", "action": "comment", "target": null, "condition": null, "value": "output es JSON puro, contenido en string fields no contiene fences" }
      ],
      "severidad": "error"
    },
    {
      "type": "forbidden_pattern",
      "pattern_regex": "Aqui tienes|Te presento|A continuacion",
      "reason": "prosa de framing fuera del JSON",
      "alternative_pseudo_code": [
        { "type": "pseudo_step", "action": "comment", "target": null, "condition": null, "value": "devolver SOLO el JSON, nada antes ni despues" }
      ],
      "severidad": "error"
    },
    {
      "type": "forbidden_pattern",
      "pattern_regex": "action\\s*:\\s*\"(?!emit|listen|store|fetch|validate|transform|branch|loop|assign|call|return|throw|log|comment)",
      "reason": "PseudoStep.action fuera del enum de 14 valores cerrados",
      "alternative_pseudo_code": [
        { "type": "pseudo_step", "action": "comment", "target": null, "condition": null, "value": "si la accion no encaja en el enum: o el enum esta incompleto y se propone v0.2.0, o el paso no es PseudoStep" }
      ],
      "severidad": "error"
    },
    {
      "type": "forbidden_pattern",
      "pattern_regex": "// asumir significado sin verificar",
      "reason": "T8 deduccion de termino sin Grep previo contra el repo",
      "alternative_pseudo_code": [
        { "type": "pseudo_step", "action": "return", "target": "requires_clarification", "condition": null, "value": "termino_no_verificado" }
      ],
      "severidad": "error"
    },
    {
      "type": "forbidden_pattern",
      "pattern_regex": "conversacion|opinion|recomiendo|sugiero",
      "reason": "notario no conversa, no opina, no recomienda; solo plasma",
      "alternative_pseudo_code": [
        { "type": "pseudo_step", "action": "comment", "target": null, "condition": null, "value": "observaciones a ana van en _observaciones_para_ana, no en cuerpo del documento" }
      ],
      "severidad": "warning"
    }
  ],

  "enforcedTendencies": [
    "T6_completar_campos_que_pseudocodigo_no_pide",
    "T8_deducir_terminos_nuevos_del_contexto_inmediato"
  ],

  "_doc_para_humano_que_lee_este_archivo": "Notario es la pieza del pipeline ana/notario/fede que solo escribe Fiel. Recibe analisis cocinado, verifica terminos contra el repo, plasma como JSON Fiel, auto-audita el output, devuelve. No conversa, no opina, no decide. Si el analisis es ambiguo o un termino no existe en el repo, devuelve requires_clarification y para. Self-bootstrap: este propio documento se valida contra las primitivas de _fiel-v0.1.0.json."
}
