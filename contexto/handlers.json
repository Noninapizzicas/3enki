{
  "_VERSION": "2.0.0",
  "_CREATED": "2026-01-20",
  "_UPDATED": "2026-01-20",
  "_DESCRIPTION": "Sistema de Handlers - Orquestación de eventos con JavaScript directo",

  "_AI_INSTRUCTIONS": {
    "cuando_leer": "ANTES de crear cualquier handler",
    "principio_clave": "Handlers son JavaScript puro - NO inventar sintaxis especial",
    "CRITICO_ENVELOPE": "SIEMPRE usar 'const data = event.data || event;' - El EventBus envuelve datos",
    "CRITICO_EVENTOS": "Verificar nombres de eventos en /contexto/ antes de usar",
    "regla_credenciales": "La ubicación del handler determina qué credenciales usa",
    "simplicidad": "Si algo se puede hacer en JS, hazlo en JS - sin abstracciones innecesarias",
    "encadenamiento": "Usa emit() para conectar handlers entre sí"
  },

  "CRITICO_event_envelope": {
    "descripcion": "El EventBus envuelve los datos en event.data",
    "SIEMPRE_HACER": "const data = event.data || event;",
    "razon": "Los eventos llegan envueltos. Si accedes a event.content directamente, será undefined",
    "ejemplo_correcto": [
      "async handle(event, { logger }) {",
      "  const data = event.data || event;  // ✅ SIEMPRE primero",
      "  const content = data.content;       // ✅ Acceder via data",
      "  const account = data.account;       // ✅",
      "}"
    ],
    "ejemplo_incorrecto": [
      "async handle(event, { logger }) {",
      "  const content = event.content;  // ❌ MAL - será undefined",
      "  const account = event.account;  // ❌ MAL",
      "}"
    ]
  },

  "CRITICO_eventos_chat": {
    "descripcion": "Eventos del chat para handlers que escuchan mensajes",
    "evento_correcto": "chat.send.request",
    "campo_contenido": "data.content (NO data.text, NO data.message)",
    "ejemplo_filter": [
      "filter(event) {",
      "  const data = event.data || event;",
      "  const texto = data.content || '';  // ✅ content, no text",
      "  return texto.trim() === '/comando';",
      "}"
    ]
  },

  "overview": {
    "que_es": "Sistema de handlers para procesar eventos con JavaScript directo",
    "reemplaza": "flow-engine (JSONs con templates {{ }})",
    "ventajas": [
      "JavaScript nativo - debugging con stack traces",
      "Sin sintaxis especial - autocompletado funciona",
      "Credenciales automáticas por ubicación",
      "Hot-reload de handlers",
      "Encadenamiento via emit()",
      "Config del proyecto accesible",
      "Store persistente por handler"
    ]
  },

  "estructura": {
    "global": {
      "path": "handlers/*.js",
      "credenciales": "GLOBAL",
      "config": "config.json (raíz)",
      "store": "data/handler-store/{handlerName}.json",
      "uso": "Automatizaciones del sistema, sin proyecto específico"
    },
    "proyecto": {
      "path": "data/projects/{projectId}/handlers/*.js",
      "credenciales": "PROJECT_{projectId} → fallback GLOBAL",
      "config": "data/projects/{projectId}/config/*.json",
      "store": "data/projects/{projectId}/handler-store/{handlerName}.json",
      "uso": "Automatizaciones específicas de un proyecto"
    }
  },

  "context": {
    "descripcion": "Objeto que recibe la función handle(event, context)",
    "propiedades": {
      "services": {
        "tipo": "object",
        "descripcion": "Executor para llamar servicios",
        "metodo": "call(service, action, params)",
        "ejemplo": "await services.call('local.google-vision', 'extract', { image: path })",
        "nota": "project_id se inyecta automáticamente según ubicación del handler"
      },
      "logger": {
        "tipo": "object",
        "descripcion": "Logger estructurado del sistema",
        "metodos": ["debug", "info", "warn", "error"],
        "ejemplo": "logger.info('Procesando', { archivo: event.path })"
      },
      "projectId": {
        "tipo": "string|null",
        "descripcion": "ID del proyecto al que pertenece el handler",
        "valor": "null si es handler global"
      },
      "emit": {
        "tipo": "function",
        "descripcion": "Emitir eventos para encadenar con otros handlers",
        "firma": "emit(evento, data)",
        "ejemplo": "emit('documento.procesado', { texto, confianza })",
        "metadata": "Añade automáticamente _meta con source, projectId, correlationId, timestamp"
      },
      "config": {
        "tipo": "object",
        "descripcion": "Configuración del proyecto",
        "estructura": "{ nombreArchivo: contenido } para cada JSON en config/",
        "ejemplo": "config.facturas.ocr.provider → 'local.google-vision'"
      },
      "store": {
        "tipo": "object",
        "descripcion": "Key-value persistente para el handler",
        "metodos": ["get", "set", "delete", "increment", "has", "keys", "getAll", "clear"],
        "persistencia": "JSON file por handler",
        "ejemplo": "await store.increment('contador')"
      }
    }
  },

  "emit": {
    "descripcion": "Función para emitir eventos y encadenar handlers",
    "uso": "emit(evento, data)",
    "metadata_automatica": {
      "_meta.source": "Nombre del handler que emite",
      "_meta.projectId": "ID del proyecto (null si global)",
      "_meta.correlationId": "UUID para trazabilidad (se propaga)",
      "_meta.timestamp": "Timestamp en ms",
      "_meta.emittedAt": "ISO string del momento"
    },
    "ejemplo": {
      "codigo": "emit('factura.procesada', { proveedor: 'Acme', total: 100 })",
      "resultado": {
        "proveedor": "Acme",
        "total": 100,
        "_meta": {
          "source": "procesar-factura",
          "projectId": "mi-proyecto",
          "correlationId": "uuid...",
          "timestamp": 1705766400000,
          "emittedAt": "2026-01-20T12:00:00.000Z"
        }
      }
    },
    "buenas_practicas": [
      "Usar nombres descriptivos: {dominio}.{accion} (documento.validado, factura.extraida)",
      "Incluir datos necesarios para el siguiente handler",
      "No incluir datos sensibles innecesarios",
      "El correlationId se propaga automáticamente para trazabilidad"
    ]
  },

  "config": {
    "descripcion": "Configuración del proyecto accesible en el handler",
    "carga": "Automática al registrar handler, desde data/projects/{id}/config/*.json",
    "estructura": {
      "ejemplo_archivos": [
        "config/project.json → config.project",
        "config/facturas.json → config.facturas",
        "config/telegram.json → config.telegram"
      ]
    },
    "uso_en_handler": [
      "const provider = config.facturas?.ocr?.provider || 'local.tesseract';",
      "const email = config.facturas?.asesoria?.email;",
      "const campos = config.facturas?.campos_factura || [];"
    ],
    "cache": "Config se cachea por proyecto. Se invalida al recargar handlers."
  },

  "store": {
    "descripcion": "Key-value persistente para guardar estado entre ejecuciones",
    "ubicacion": {
      "proyecto": "data/projects/{projectId}/handler-store/{handlerName}.json",
      "global": "data/handler-store/{handlerName}.json"
    },
    "api": {
      "get": {
        "firma": "await store.get(key, defaultValue)",
        "ejemplo": "const count = await store.get('procesados', 0);"
      },
      "set": {
        "firma": "await store.set(key, value)",
        "ejemplo": "await store.set('ultimo_proceso', Date.now());"
      },
      "delete": {
        "firma": "await store.delete(key)",
        "retorna": "boolean - true si existía"
      },
      "increment": {
        "firma": "await store.increment(key, amount = 1)",
        "ejemplo": "const nuevo = await store.increment('facturas_procesadas');",
        "nota": "Crea la key con 0 si no existe"
      },
      "has": {
        "firma": "await store.has(key)",
        "retorna": "boolean"
      },
      "keys": {
        "firma": "await store.keys()",
        "retorna": "string[]"
      },
      "getAll": {
        "firma": "await store.getAll()",
        "retorna": "object - Copia de todos los datos"
      },
      "clear": {
        "firma": "await store.clear()",
        "nota": "Borra todo el store del handler"
      }
    },
    "limitaciones": [
      "Keys deben ser strings no vacíos (max 256 chars)",
      "Values deben ser serializables a JSON",
      "undefined se convierte a null",
      "No usar para datos grandes (usar fs o database-manager)"
    ]
  },

  "ejemplo_handler_completo": {
    "archivo": "data/projects/mi-proyecto/handlers/procesar-documento.js",
    "codigo": [
      "module.exports = {",
      "  name: 'procesar-documento',",
      "  description: 'Procesa documentos recibidos y extrae texto',",
      "  trigger: 'documento.recibido',",
      "  ",
      "  // Filtro opcional - solo procesar PDFs e imágenes",
      "  filter: (event) => {",
      "    const validTypes = ['application/pdf', 'image/jpeg', 'image/png'];",
      "    return validTypes.includes(event.mimeType);",
      "  },",
      "",
      "  async handle(event, { services, logger, emit, config, store }) {",
      "    logger.info('Procesando documento', { path: event.path });",
      "",
      "    // Usar config del proyecto",
      "    const ocrProvider = config.facturas?.ocr?.provider || 'local.google-vision';",
      "    const hint = config.facturas?.ocr?.hint || 'DOCUMENT_TEXT_DETECTION';",
      "",
      "    let imageContent = event.path;",
      "",
      "    // Si es PDF, convertir a imagen primero",
      "    if (event.mimeType === 'application/pdf') {",
      "      const png = await services.call('local.pdf-to-png', 'convert', {",
      "        pdf: event.path,",
      "        pages: [1]",
      "      });",
      "      imageContent = png.data.images[0].content;",
      "    }",
      "",
      "    // OCR",
      "    const ocr = await services.call(ocrProvider, 'extract', {",
      "      image: imageContent,",
      "      hint",
      "    });",
      "",
      "    // Guardar contador en store",
      "    const procesados = await store.increment('documentos_procesados');",
      "    await store.set(`doc:${event.id}:status`, 'ocr_completado');",
      "",
      "    logger.info('OCR completado', { ",
      "      confianza: ocr.data.confidence,",
      "      totalProcesados: procesados",
      "    });",
      "",
      "    // Emitir para siguiente handler",
      "    emit('texto.extraido', {",
      "      path: event.path,",
      "      texto: ocr.data.text,",
      "      confianza: ocr.data.confidence,",
      "      chatId: event.chatId  // Propagar datos del evento original",
      "    });",
      "  }",
      "};"
    ]
  },

  "ejemplo_encadenamiento": {
    "descripcion": "Pipeline de 3 handlers conectados via emit",
    "flujo": [
      "telegram.document.received → recibir-documento",
      "documento.recibido → procesar-ocr",
      "texto.extraido → extraer-datos"
    ],
    "handlers": {
      "recibir-documento": {
        "trigger": "telegram.document.received",
        "emite": "documento.recibido",
        "codigo": [
          "async handle(event, { emit, logger }) {",
          "  logger.info('Documento recibido de Telegram');",
          "  emit('documento.recibido', {",
          "    path: event.filePath,",
          "    mimeType: event.mimeType,",
          "    chatId: event.chatId",
          "  });",
          "}"
        ]
      },
      "procesar-ocr": {
        "trigger": "documento.recibido",
        "emite": "texto.extraido",
        "codigo": [
          "async handle(event, { services, emit }) {",
          "  const ocr = await services.call('local.google-vision', 'extract', {",
          "    image: event.path",
          "  });",
          "  emit('texto.extraido', {",
          "    ...event,",
          "    texto: ocr.data.text",
          "  });",
          "}"
        ]
      },
      "extraer-datos": {
        "trigger": "texto.extraido",
        "emite": "factura.procesada",
        "codigo": [
          "async handle(event, { services, emit, config }) {",
          "  const campos = config.facturas?.campos_factura || ['total', 'fecha'];",
          "  const ai = await services.call('ai-gateway', 'chat', {",
          "    messages: [{ role: 'user', content: `Extrae ${campos.join(', ')} de: ${event.texto}` }]",
          "  });",
          "  emit('factura.procesada', {",
          "    ...event,",
          "    datos: JSON.parse(ai.data.content)",
          "  });",
          "}"
        ]
      }
    }
  },

  "errores_comunes": {
    "filter_con_error": {
      "problema": "Filter lanza excepción y el handler no se ejecuta",
      "causa": "Acceder a propiedad de undefined en filter",
      "solucion": "Usar optional chaining: event.data?.mimeType",
      "ejemplo_malo": "filter: (e) => e.data.mimeType === 'pdf'",
      "ejemplo_bueno": "filter: (e) => e.data?.mimeType === 'pdf'"
    },
    "emit_sin_datos": {
      "problema": "Handler siguiente no recibe datos necesarios",
      "causa": "No propagar datos del evento original",
      "solucion": "Usar spread: emit('next', { ...event, nuevosDatos })",
      "ejemplo_malo": "emit('procesado', { resultado })",
      "ejemplo_bueno": "emit('procesado', { ...event, resultado })"
    },
    "store_key_invalida": {
      "problema": "Error 'Store key must be non-empty string'",
      "causa": "Usar variable undefined como key",
      "solucion": "Validar antes: if (id) await store.set(`doc:${id}`, value)",
      "ejemplo_malo": "await store.set(event.id, 'ok')  // event.id puede ser undefined",
      "ejemplo_bueno": "await store.set(`doc:${event.id || 'unknown'}`, 'ok')"
    },
    "config_undefined": {
      "problema": "Cannot read property 'x' of undefined",
      "causa": "Acceder a config sin verificar existencia",
      "solucion": "Usar optional chaining y defaults",
      "ejemplo_malo": "const x = config.facturas.ocr.provider",
      "ejemplo_bueno": "const x = config.facturas?.ocr?.provider || 'default'"
    },
    "services_timeout": {
      "problema": "Timeout en llamada a servicio",
      "causa": "Servicio tarda más de 60s (default)",
      "solucion": "Pasar timeout en options",
      "ejemplo": "await services.call('ai-gateway', 'chat', params, { timeout: 120000 })"
    },
    "circular_emit": {
      "problema": "Handler A emite evento que dispara Handler B que emite evento que dispara Handler A",
      "causa": "Ciclo de dependencias entre handlers",
      "solucion": "Diseñar flujo unidireccional, usar condiciones para romper ciclo",
      "prevencion": "Documentar qué emite cada handler antes de implementar"
    },
    "store_datos_grandes": {
      "problema": "Archivo JSON del store se vuelve muy grande",
      "causa": "Guardar arrays/objetos grandes en store",
      "solucion": "Usar filesystem o database-manager para datos grandes",
      "limite_recomendado": "Store para metadata, contadores, estados. No para documentos."
    },
    "handler_no_carga": {
      "problema": "Handler no se ejecuta aunque el evento se emite",
      "causas_posibles": [
        "Archivo empieza con _ (ignorado)",
        "enabled: false",
        "Error de sintaxis en el archivo",
        "trigger mal escrito",
        "filter siempre retorna false"
      ],
      "debug": "Revisar logs: handlers.loaded, handler.registered"
    }
  },

  "buenas_practicas": {
    "naming": {
      "handlers": "kebab-case.js (procesar-factura.js)",
      "eventos": "dominio.accion (documento.validado, factura.extraida)",
      "store_keys": "tipo:id:campo (doc:123:status)"
    },
    "estructura_handler": [
      "1. Validar input si es necesario",
      "2. Usar config con defaults",
      "3. Llamar servicios",
      "4. Actualizar store si aplica",
      "5. Emitir evento para siguiente paso",
      "6. Log de resultado"
    ],
    "trazabilidad": [
      "correlationId se propaga automáticamente entre handlers",
      "Usar logger con contexto: logger.info('msg', { correlationId, ... })",
      "En caso de error, el sistema emite {handlerName}.error automáticamente"
    ]
  },

  "archivos": {
    "core": [
      "core/handler-loader.js - Carga y gestiona handlers",
      "core/handler-store.js - Store key-value persistente",
      "core/service-executor.js - Ejecuta llamadas a servicios"
    ],
    "handlers_globales": "handlers/*.js",
    "handlers_proyecto": "data/projects/{projectId}/handlers/*.js",
    "config_proyecto": "data/projects/{projectId}/config/*.json",
    "store_proyecto": "data/projects/{projectId}/handler-store/",
    "store_global": "data/handler-store/"
  },

  "sistema_aprendizaje": {
    "_descripcion": "Sistema genérico de aprendizaje basado en experiencias",
    "_ver_detalle": "contexto/learning.json",
    "handlers_disponibles": {
      "aprendizaje-feedback.js": {
        "descripcion": "Captura feedback de cualquier proceso",
        "triggers": ["aprendizaje.feedback", "aprendizaje.exito", "aprendizaje.fallo"],
        "emite": ["aprendizaje.guardado"]
      },
      "aprendizaje-consulta.js": {
        "descripcion": "Consulta recomendaciones basadas en experiencias",
        "triggers": ["aprendizaje.consulta", "aprendizaje.recomendar", "aprendizaje.estadisticas"],
        "emite": ["aprendizaje.resultados", "aprendizaje.recomendacion", "aprendizaje.stats"]
      },
      "ocr-aprendizaje.js": {
        "descripcion": "Ejemplo: conecta OCR con sistema de aprendizaje",
        "triggers": ["documento.ocr.completado", "imagen.preparar.consultar", "comando.ocr.estadisticas"],
        "dominio": "ocr-imagenes"
      }
    },
    "uso_desde_cualquier_handler": {
      "guardar_exito": "emit('aprendizaje.exito', { dominio, contexto, accion, resultado, score, tags })",
      "guardar_fallo": "emit('aprendizaje.fallo', { dominio, contexto, accion, resultado, motivo, tags })",
      "consultar": "emit('aprendizaje.recomendar', { dominio, contexto, requestId })",
      "via_services": "await services.call('local.learning', 'best-action', { dominio, contexto })"
    }
  }
}
