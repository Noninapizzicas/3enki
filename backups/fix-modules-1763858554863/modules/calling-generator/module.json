{
  "name": "calling-generator",
  "version": "1.0.0",
  "description": "Generates executable JavaScript functions from plugin definitions with support for HTTP calls and local functions",
  "main": "index.js",
  "author": "event-core team",
  "license": "MIT",
  "provides": [
    "function-generation",
    "http-client",
    "local-function-calls"
  ],
  "dependencies": [
    "plugin-manager",
    "tool-orchestrator"
  ],
  "apis": {
    "list_functions": {
      "method": "GET",
      "path": "/functions",
      "description": "List all generated functions"
    },
    "get_function": {
      "method": "GET",
      "path": "/function/:name",
      "description": "Get metadata about a specific function"
    }
  },
  "events": {
    "publishes": [
      "function.generated",
      "function.generation.error"
    ],
    "subscribes": [
      "plugin.loaded"
    ]
  },
  "config": {
    "localFunctionTimeout": 5000,
    "httpTimeout": 30000,
    "maxRetries": 3,
    "retryDelay": 1000
  }
}
