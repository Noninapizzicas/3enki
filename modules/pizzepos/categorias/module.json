{
  "name": "categorias",
  "version": "3.0.0",
  "description": "Catalogo multi-tenant de categorias de productos. Sincronizado desde carta.actualizada (subgrafo cartas) + CRUD manual.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "provides": {
    "events": [
      "categoria.creada",
      "categoria.actualizada",
      "categoria.orden_actualizado"
    ]
  },
  "events": {
    "publishes": [
      { "event": "categoria.creada",            "description": "Nueva categoria creada (sync o manual). Lleva project_id top-level + correlation_id + timestamp." },
      { "event": "categoria.actualizada",       "description": "Categoria modificada con diff de cambios." },
      { "event": "categoria.orden_actualizado", "description": "Orden de categorias actualizado tras reorder." }
    ],
    "subscribes": [
      { "event": "carta.actualizada", "handler": "onCartaActualizada", "description": "Carta creada o modificada — sincronizar categorias desde carta-manager." }
    ]
  },
  "ui_handlers": [
    { "domain": "categorias", "action": "list",    "handler": "handleListCategorias",    "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "categorias", "action": "get",     "handler": "handleGetCategoria",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "categorias", "action": "create",  "handler": "handleCreateCategoria",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "categorias", "action": "update",  "handler": "handleUpdateCategoria",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "categorias", "action": "reorder", "handler": "handleReorderCategorias", "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "categorias", "action": "health",  "handler": "handleHealthCheck",       "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "categorias", "action": "metrics", "handler": "handleGetMetrics",        "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [],
  "config": {
    "persistence": {
      "type":  "in-memory",
      "notes": "Catalogo vive solo en memoria. Sync desde carta.actualizada repuebla el catalogo en cada arranque (la carta-manager es la fuente de verdad). Reset al reiniciar el modulo."
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "categoria.creada.total",
        "categoria.actualizada.total",
        "categorias.errors"
      ],
      "gauges": [
        "categoria.total.count",
        "categoria.activas.count"
      ]
    }
  }
}
