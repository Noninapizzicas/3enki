{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "content"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier for the prompt (kebab-case)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Human-readable title"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Description of what the prompt does"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50000,
      "description": "The prompt template content with {{variable}} placeholders"
    },
    "variables": {
      "type": "array",
      "description": "List of variables used in the template",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "array", "object"]
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "default": {
            "description": "Default value if not provided"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "description": "Tags for categorization"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Additional metadata (model preferences, temperature, etc.)"
    }
  }
}
