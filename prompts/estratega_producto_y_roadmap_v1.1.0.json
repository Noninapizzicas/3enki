    "release_notes": {
      "path": "strategy/v1/releases/vX.Y.Z/release_notes.json",
      "schema": {
        "type": "object",
        "required": ["version", "date", "highlights", "changes", "kpis_achieved"],
        "properties": {
          "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
          "date": {"type": "string", "format": "date"},
          "codename": {"type": "string"},
          "highlights": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 3,
            "maxItems": 5,
            "description": "Top 3-5 logros del release"
          },
          "changes": {
            "type": "object",
            "required": ["features", "improvements", "fixes"],
            "properties": {
              "features": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": {"type": "string"},
                    "description": {"type": "string"},
                    "pr": {"type": "string"}
                  }
                }
              },
              "improvements": {"type": "array", "items": {"type": "string"}},
              "fixes": {"type": "array", "items": {"type": "string"}},
              "breaking_changes": {"type": "array", "items": {"type": "string"}},
              "deprecations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "item": {"type": "string"},
                    "sunset_date": {"type": "string", "format": "date"},
                    "replacement": {"type": "string"}
                  }
                }
              }
            }
          },
          "kpis_achieved": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "before": {"type": "number"},
                "after": {"type": "number"},
                "improvement_pct": {"type": "number"}
              }
            }
          },
          "migration_guide_url": {"type": "string", "format": "uri"},
          "known_issues": {
            "type": "array",
            "items": {"type": "string"}
          },
          "contributors": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      },
      "markdown_template": "# Version {{version}} – {{codename}}\n\n**Released:** {{date}}\n\n## 🎉 Highlights\n\n{{#each highlights}}\n- {{this}}\n{{/each}}\n\n## 🚀 Features\n\n{{#each changes.features}}\n### {{title}}\n{{description}}\n{{#if pr}}([PR #{{pr}}]({{pr_url}})){{/if}}\n{{/each}}\n\n## ⚡ Improvements\n\n{{#each changes.improvements}}\n- {{this}}\n{{/each}}\n\n## 🐛 Fixes\n\n{{#each changes.fixes}}\n- {{this}}\n{{/each}}\n\n{{#if changes.breaking_changes}}\n## ⚠️ Breaking Changes\n\n{{#each changes.breaking_changes}}\n- {{this}}\n{{/each}}\n{{/if}}\n\n{{#if changes.deprecations}}\n## 📋 Deprecations\n\n{{#each changes.deprecations}}\n- **{{item}}** will be sunset on {{sunset_date}}. Migrate to {{replacement}}.\n{{/each}}\n{{/if}}\n\n## 📊 KPIs Achieved\n\n{{#each kpis_achieved}}\n- **{{@key}}**: {{before}} → {{after}} ({{improvement_pct}}% improvement)\n{{/each}}\n\n{{#if migration_guide_url}}\n## 📖 Migration Guide\n\n[View migration guide]({{migration_guide_url}})\n{{/if}}\n\n{{#if known_issues}}\n## ⚠️ Known Issues\n\n{{#each known_issues}}\n- {{this}}\n{{/each}}\n{{/if}}\n\n## 👏 Contributors\n\n{{#each contributors}}\n- @{{this}}\n{{/each}}\n",
      "example": {
        "version": "2.1.0",
        "date": "2025-04-15",
        "codename": "Velocity",
        "highlights": [
          "TTD reducido 51% (10.2min → 5.0min) 🚀",
          "Latency p95 optimizada 46% (185ms → 100ms) ⚡",
          "15 bugs críticos resueltos, sistema más estable 🐛",
          "Cache implementation aumentó throughput 25% 📈",
          "Termux support mejorado significativamente 📱"
        ],
        "changes": {
          "features": [
            {
              "title": "Cache LRU for /help/search",
              "description": "Implementado cache LRU con 5000 entries + índice invertido. Cache hit rate 78%. Reduce latency en 50%.",
              "pr": "456"
            }
          ],
          "improvements": [
            "Optimized async I/O worker pool (8 workers, batching 16 files)",
            "CLI UX improvements: better error messages, progress bars",
            "Documentation refresh con 25 nuevos ejemplos ejecutables"
          ],
          "fixes": [
            "Fixed Termux permission errors en 'make dev'",
            "Fixed race condition en event router bajo carga alta",
            "Fixed memory leak en trace logger (reducido 40% memory usage)"
          ],
          "breaking_changes": [],
          "deprecations": [
            {
              "item": "/help/search_v1 endpoint",
              "sunset_date": "2025-10-15",
              "replacement": "/help/search (v2)"
            }
          ]
        },
        "kpis_achieved": {
          "ttd_minutes": {"before": 10.2, "after": 5.0, "improvement_pct": 51},
          "latency_p95_ms": {"before": 185, "after": 100, "improvement_pct": 46},
          "critical_bugs_open": {"before": 15, "after": 0, "improvement_pct": 100}
        },
        "migration_guide_url": "https://docs.project.com/migration/v2.0-to-v2.1",
        "known_issues": [
          "Termux CI pipeline intermittent failures (15% fail rate) - fix in v2.1.1"
        ],
        "contributors": ["dev_team", "performance_team", "dx_team", "community_contributor_1"]
      }
    }
  },

