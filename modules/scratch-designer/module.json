{
  "name": "scratch-designer",
  "version": "2.0.0",
  "description": "Diseñador visual tipo Scratch - Bloques arrastrables que generan JSON",
  "author": "Event Core Team",
  "language": "en",
  "provides": {
    "events": [
      "scratch.design.created",
      "scratch.design.updated",
      "scratch.design.deleted",
      "scratch.design.exported"
    ],
    "queries": []
  },
  "events": {
    "publishes": [
      {
        "event": "scratch.design.created",
        "description": "Nuevo diseño creado",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/design_created"
        }
      },
      {
        "event": "scratch.design.updated",
        "description": "Diseño actualizado",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/design_updated"
        }
      },
      {
        "event": "scratch.design.deleted",
        "description": "Diseño eliminado",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/design_deleted"
        }
      },
      {
        "event": "scratch.design.exported",
        "description": "Diseño exportado a JSON",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/design_exported"
        }
      }
    ],
    "subscribes": []
  },
  "apis": [
    {
      "group": "Paleta de Bloques",
      "description": "Obtener bloques disponibles del sistema"
    },
    {
      "method": "GET",
      "path": "/blocks/all",
      "handler": "handleGetAllBlocks",
      "description": "Obtener todos los bloques disponibles organizados por categoria"
    },
    {
      "method": "GET",
      "path": "/blocks/modules",
      "handler": "handleGetModuleBlocks",
      "description": "Bloques de modulos del sistema"
    },
    {
      "method": "GET",
      "path": "/blocks/events",
      "handler": "handleGetEventBlocks",
      "description": "Bloques de eventos (publish/subscribe)"
    },
    {
      "method": "GET",
      "path": "/blocks/actions",
      "handler": "handleGetActionBlocks",
      "description": "Bloques de acciones (APIs, navegacion, UI)"
    },
    {
      "method": "GET",
      "path": "/blocks/components",
      "handler": "handleGetComponentBlocks",
      "description": "Bloques de componentes UI"
    },
    {
      "method": "GET",
      "path": "/blocks/containers",
      "handler": "handleGetContainerBlocks",
      "description": "Bloques contenedores (layouts, panels)"
    },
    {
      "method": "GET",
      "path": "/blocks/data",
      "handler": "handleGetDataBlocks",
      "description": "Bloques de datos (endpoints, variables)"
    },
    {
      "method": "GET",
      "path": "/blocks/conditions",
      "handler": "handleGetConditionBlocks",
      "description": "Bloques de logica (if, loops, comparaciones)"
    },
    {
      "group": "Diseños",
      "description": "CRUD de diseños"
    },
    {
      "method": "GET",
      "path": "/designs",
      "handler": "handleListDesigns",
      "description": "Listar todos los diseños guardados"
    },
    {
      "method": "POST",
      "path": "/designs",
      "handler": "handleCreateDesign",
      "description": "Crear nuevo diseño (publica scratch.design.created)",
      "request_schema": {
        "$ref": "./schemas/design.json#/definitions/create_request"
      }
    },
    {
      "method": "GET",
      "path": "/designs/:id",
      "handler": "handleGetDesign",
      "description": "Obtener diseño por ID"
    },
    {
      "method": "PUT",
      "path": "/designs/:id",
      "handler": "handleUpdateDesign",
      "description": "Actualizar diseño (publica scratch.design.updated)",
      "request_schema": {
        "$ref": "./schemas/design.json#/definitions/update_request"
      }
    },
    {
      "method": "DELETE",
      "path": "/designs/:id",
      "handler": "handleDeleteDesign",
      "description": "Eliminar diseño (publica scratch.design.deleted)"
    },
    {
      "method": "POST",
      "path": "/designs/:id/duplicate",
      "handler": "handleDuplicateDesign",
      "description": "Duplicar diseño existente"
    },
    {
      "group": "Validacion",
      "description": "Validar conexiones y estructura"
    },
    {
      "method": "POST",
      "path": "/validate/connection",
      "handler": "handleValidateConnection",
      "description": "Validar si dos bloques pueden conectarse"
    },
    {
      "method": "POST",
      "path": "/validate/design",
      "handler": "handleValidateDesign",
      "description": "Validar diseño completo"
    },
    {
      "group": "Export",
      "description": "Exportar diseños"
    },
    {
      "method": "POST",
      "path": "/export/json",
      "handler": "handleExportJSON",
      "description": "Exportar diseño como JSON para ui-renderer (publica scratch.design.exported)",
      "request_schema": {
        "$ref": "./schemas/design.json#/definitions/export_request"
      }
    },
    {
      "method": "POST",
      "path": "/export/module-ui",
      "handler": "handleExportModuleUI",
      "description": "Exportar como seccion UI de module.json",
      "request_schema": {
        "$ref": "./schemas/design.json#/definitions/export_request"
      }
    },
    {
      "group": "Observability",
      "description": "Health y metricas"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check del modulo"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Metricas del modulo"
    }
  ],
  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "Scratch Designer",
    "icon": "🧩",
    "description": "Diseñador visual de interfaces con bloques",
    "route": "/scratch-designer",
    "menu": {
      "label": "Scratch Designer",
      "icon": "🧩",
      "order": 4
    }
  },
  "config": {
    "autosave": true,
    "autosave_interval_ms": 30000,
    "max_designs": 100,
    "inventory_path": "../../INVENTARIO-SISTEMA.json"
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "design.created.total",
        "design.exported.total",
        "api.calls.total",
        "errors.total"
      ],
      "gauges": [
        "designs.active.count",
        "blocks.categories.count"
      ],
      "timings": [
        "design.created.duration",
        "design.updated.duration",
        "design.exported.duration"
      ]
    }
  }
}
