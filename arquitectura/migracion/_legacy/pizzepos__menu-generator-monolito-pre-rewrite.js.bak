/**
 * Menu Generator v7.0.0 — POC2 canonico.
 *
 * Generador puro: genera una carta estructurada en JSON desde cualquier input
 * (foto, PDF, texto, audio, dictado).
 *
 * Pipeline:
 *   Archivo → [PDF→render via pdfjs] → [sharp prepare-ocr] → [Google Vision OCR] → texto
 *   Texto → agente menu-structurer → carta.save → carta.actualizada
 *
 * La extraccion OCR es determinista (no usa LLM).
 * La estructuracion la hace el agente menu-structurer (si usa LLM).
 */

'use strict';

const path = require('path');
const crypto = require('crypto');
const ServiceExecutor = require('../../../core/service-executor');

const IMAGE_EXTENSIONS = ['.jpg', '.jpeg', '.png', '.webp', '.tiff', '.tif'];
const PDF_EXTENSIONS = ['.pdf'];

const TIMEOUTS = {
  pdfInfo: 15000,
  pdfRender: 30000,
  sharp: 15000,
  ocr: 60000,
  structurer: 90000
};

class MenuGeneratorModule {
  constructor() {
    this.name = 'menu-generator';
    this.version = '7.0.0';
    this.eventBus = null;
    this.logger = null;
    this.metrics = null;
    this.services = null;
  }

  async onLoad(context) {
    this.eventBus = context.eventBus;
    this.logger = context.logger;
    this.metrics = context.metrics;
    this.services = context.services || new ServiceExecutor(this.eventBus, this.logger);
    this.logger.info('module.loaded', { module: this.name, version: this.version });
  }

  async onUnload() {
    this.services = null;
    this.logger?.info?.('module.unloaded', { module: this.name });
  }

  // ==========================================
  // Helpers POC2
  // ==========================================

  _errorResponse(status, code, message, details) {
    const error = { code, message };
    if (details !== undefined) error.details = details;
    return { status, error };
  }

  _classifyHandlerError(err) {
    const msg = err?.message || String(err);
    const code = err?.code;
    if (code === 'ENOENT') return { status: 404, code: 'RESOURCE_NOT_FOUND' };
    if (/timeout/i.test(msg)) return { status: 504, code: 'TIMEOUT' };
    if (/required|invalid|missing|requerido/i.test(msg)) return { status: 400, code: 'INVALID_INPUT' };
    if (/not found|no encontrado|no soportado/i.test(msg)) return { status: 404, code: 'RESOURCE_NOT_FOUND' };
    return { status: 500, code: 'INTERNAL_ERROR' };
  }

  _handleHandlerError(logEvent, err, kind = 'handler') {
    const { status, code } = this._classifyHandlerError(err);
    this.logger?.error?.(logEvent, {
      kind,
      error_code: code,
      error_message: err?.message || String(err)
    });
    this.metrics?.increment?.('menu-generator.errors', { code, kind });
    return this._errorResponse(status, code, err?.message || 'Error interno');
  }

  async _publicarEvento(name, payload, sourcePayload) {
    const correlation_id =
      payload?.correlation_id ||
      sourcePayload?.correlation_id ||
      sourcePayload?.metadata?.correlationId ||
      crypto.randomUUID();
    const project_id =
      payload?.project_id ??
      sourcePayload?.project_id ??
      null;
    const enriched = {
      ...payload,
      correlation_id,
      timestamp: payload?.timestamp || new Date().toISOString()
    };
    if (project_id !== null && project_id !== undefined) enriched.project_id = project_id;
    await this.eventBus.publish(name, enriched);
    return enriched;
  }

  // ==========================================
  // Tool: menu.generate
  // ==========================================

  async toolGenerate({ nombre, texto, filePath, project_id, correlation_id }) {
    try {
      if (!nombre) {
        this.metrics?.increment?.('menu-generator.errors', { code: 'INVALID_INPUT', kind: 'generate' });
        this.logger.warn('menu.generate.missing', { field: 'nombre' });
        return this._errorResponse(400, 'INVALID_INPUT',
          'Se requiere nombre para la carta. Pregunta al usuario como quiere llamarla antes de generar.',
          { field: 'nombre' });
      }
      if (!texto && !filePath) {
        this.metrics?.increment?.('menu-generator.errors', { code: 'INVALID_INPUT', kind: 'generate' });
        this.logger.warn('menu.generate.missing', { fields: ['texto', 'filePath'] });
        return this._errorResponse(400, 'INVALID_INPUT',
          'Se requiere texto (contenido del menu) o filePath (ruta a PDF/imagen)',
          { fields: ['texto', 'filePath'] });
      }
      if (!project_id) {
        this.metrics?.increment?.('menu-generator.errors', { code: 'INVALID_INPUT', kind: 'generate' });
        this.logger.warn('menu.generate.missing', { field: 'project_id' });
        return this._errorResponse(400, 'INVALID_INPUT', 'Se requiere project_id', { field: 'project_id' });
      }

      this.metrics?.increment?.('menu.generate.requested');

      let extractedText = texto;
      let pipelineKind = 'text';

      if (filePath && !texto) {
        pipelineKind = 'document';
        this.logger.info('menu.generate.extracting', { filePath, project_id });

        await this._publicarEvento('menu.generation.progress', {
          project_id, nombre, step: 'extracting',
          message: 'Extrayendo texto del documento...'
        }, { correlation_id });

        const extraction = await this.extractText(filePath, project_id);

        if (!extraction.success) {
          this.metrics?.increment?.('menu.generate.extract_failed');
          await this._publicarEvento('menu.generation.failed', {
            project_id, nombre, step: 'extraction', error: extraction.error
          }, { correlation_id });
          return this._errorResponse(500, 'EXTRACTION_FAILED',
            `Error extrayendo texto: ${extraction.error}`,
            { filePath, error: extraction.error });
        }

        extractedText = extraction.text;
        this.logger.info('menu.generate.extracted', {
          project_id, ocr_provider: extraction.ocr_provider,
          pages: extraction.pages_processed, text_length: extractedText.length
        });
      }

      await this._publicarEvento('menu.generation.progress', {
        project_id, nombre, step: 'structuring',
        message: 'Estructurando carta con IA...'
      }, { correlation_id });

      await this._publicarEvento('agent.execute.request', {
        request_id: crypto.randomUUID(),
        user_id: 'system',
        agent_name: 'menu-structurer',
        project_id,
        context: { texto: extractedText, nombre },
        task: `Estructura este texto de carta de restaurante en JSON. Nombre: "${nombre}". Guarda con carta.save pasando project_id="${project_id}".`
      }, { correlation_id, project_id });

      this.logger.info('menu.generate.structuring', {
        project_id, nombre, texto_length: extractedText.length
      });

      return {
        status: 202,
        data: {
          nombre,
          pipeline: pipelineKind,
          message: `Generando carta "${nombre}". El agente structurer procesara el texto.`
        }
      };
    } catch (err) {
      return this._handleHandlerError('menu.generate.error', err);
    }
  }

  // ==========================================
  // Pipeline OCR determinista
  // ==========================================

  async extractText(filePath, projectId) {
    const ext = path.extname(filePath).toLowerCase();
    const isPDF = PDF_EXTENSIONS.includes(ext);
    const isImage = IMAGE_EXTENSIONS.includes(ext);

    if (!isPDF && !isImage) {
      return { success: false, error: `Formato no soportado: ${ext}. Acepta PDF, JPG, PNG, WebP, TIFF.` };
    }

    try {
      let images = [];

      if (isPDF) {
        images = await this.pdfToImages(filePath);
        if (images.length === 0) {
          return { success: false, error: 'No se pudieron renderizar paginas del PDF' };
        }
      } else {
        images = [{ image: filePath, page: 1, fromPath: true }];
      }

      const pageTexts = [];
      for (const img of images) {
        const prepared = await this.prepareImage(img.image, img.fromPath);
        if (!prepared.success) {
          this.logger.warn('menu.extract.sharp_failed', { page: img.page, error_message: prepared.error });
          continue;
        }
        const ocr = await this.ocrExtract(prepared.image);
        if (!ocr.success || !ocr.text) {
          this.logger.warn('menu.extract.ocr_failed', { page: img.page, error_message: ocr.error });
          continue;
        }
        pageTexts.push({ page: img.page, text: ocr.text, confidence: ocr.confidence });
      }

      if (pageTexts.length === 0) {
        return { success: false, error: 'No se pudo extraer texto de ninguna pagina' };
      }

      const fullText = pageTexts.length === 1
        ? pageTexts[0].text
        : pageTexts.map(p => p.text).join('\n\n');

      return {
        success: true,
        text: fullText,
        source_type: isPDF ? 'pdf' : 'image',
        pages_processed: pageTexts.length,
        ocr_provider: 'google_vision'
      };
    } catch (err) {
      this.logger.error('menu.extract.pipeline_error', {
        filePath, error_message: err.message
      });
      this.metrics?.increment?.('menu-generator.errors', { code: 'EXTRACTION_PIPELINE', kind: 'ocr' });
      return { success: false, error: err.message };
    }
  }

  async pdfToImages(filePath) {
    const infoResult = await this.services.call('local.pdfjs', 'info', {
      pdf: filePath
    }, { timeout: TIMEOUTS.pdfInfo });

    const info = infoResult.data || infoResult;
    const totalPages = info.pages || 1;

    const images = [];
    for (let page = 1; page <= totalPages; page++) {
      try {
        const renderResult = await this.services.call('local.pdfjs', 'render', {
          pdf: filePath, page, scale: 2.0
        }, { timeout: TIMEOUTS.pdfRender });

        const renderData = renderResult.data || renderResult;
        if (renderData.image) {
          images.push({ image: renderData.image, page, fromPath: false });
        }
      } catch (err) {
        this.logger.warn('menu.extract.pdf_render_failed', {
          page, error_message: err.message
        });
      }
    }
    return images;
  }

  async prepareImage(image, fromPath) {
    try {
      const result = await this.services.call('local.sharp', 'prepare-ocr', {
        image,
        options: { grayscale: true, normalize: true, sharpen: true }
      }, { timeout: TIMEOUTS.sharp });
      const data = result.data || result;
      return { success: true, image: data.image || image };
    } catch (err) {
      this.logger.warn('menu.extract.sharp_fallback', { error_message: err.message });
      return { success: true, image };
    }
  }

  async ocrExtract(image) {
    try {
      const result = await this.services.call('local.google-vision', 'extract', {
        image,
        hint: 'DOCUMENT_TEXT_DETECTION',
        languageHints: ['es', 'en']
      }, { timeout: TIMEOUTS.ocr });
      const data = result.data || result;
      return {
        success: true,
        text: data.text || '',
        confidence: data.confidence || 0
      };
    } catch (err) {
      return { success: false, error: err.message };
    }
  }

  // ==========================================
  // UI Handlers (canonical shape)
  // ==========================================

  async handleGenerate(data) {
    try {
      return await this.toolGenerate(data);
    } catch (err) {
      return this._handleHandlerError('menu-generator.ui.generate.error', err);
    }
  }

  async handleHealth() {
    return {
      status: 200,
      data: { status: 'healthy', module: this.name, version: this.version }
    };
  }

  // ==========================================
  // Domain event handler — carta.generar.solicitada
  // ==========================================

  async onCartaGenerarSolicitada(event) {
    try {
      const data = event?.data || event?.payload || event;
      const { project_id, nombre, filePath, texto, request_id, correlation_id } = data || {};
      const result = await this.toolGenerate({ project_id, nombre, filePath, texto, correlation_id });

      if (result.error) {
        await this._publicarEvento('carta.generar.fallida', {
          request_id, project_id, nombre,
          error: result.error
        }, { correlation_id, project_id });
        return;
      }
      await this._publicarEvento('carta.generar.iniciada', {
        request_id, project_id, nombre,
        pipeline: result.data?.pipeline,
        message: result.data?.message
      }, { correlation_id, project_id });
    } catch (err) {
      const data = event?.data || event;
      await this._publicarEvento('carta.generar.fallida', {
        request_id: data?.request_id,
        project_id: data?.project_id,
        nombre: data?.nombre,
        error: { code: 'INTERNAL_ERROR', message: err.message }
      }, { correlation_id: data?.correlation_id, project_id: data?.project_id });
      this._handleHandlerError('menu-generator.carta_generar.error', err, 'subscribe');
    }
  }
}

module.exports = MenuGeneratorModule;
