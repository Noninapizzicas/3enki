{
  "name": "device-shadow",
  "version": "2.0.0",
  "description": "Sincronización bidireccional de estado desired/reported/delta entre servidor y dispositivos IoT",
  "author": "Enki",
  "language": "en",
  "tier": "tier_2_platform",
  "provides": {
    "events": [
      "shadow.updated",
      "shadow.delta",
      "shadow.synced"
    ]
  },
  "events": {
    "subscribes": [
      {
        "event": "shadow.set_desired",
        "handler": "onSetDesired",
        "description": "Escribir estado deseado para un dispositivo"
      }
    ],
    "publishes": [
      {
        "event": "shadow.updated",
        "description": "Estado reported de un dispositivo fue actualizado"
      },
      {
        "event": "shadow.delta",
        "description": "Nuevo delta computado — desired difiere de reported"
      },
      {
        "event": "shadow.synced",
        "description": "Delta vacío — dispositivo sincronizado con estado deseado"
      }
    ]
  },
  "ui_handlers": [
    {
      "domain": "shadow",
      "action": "get-reported",
      "handler": "handleGetReported"
    },
    {
      "domain": "shadow",
      "action": "get-desired",
      "handler": "handleGetDesired"
    },
    {
      "domain": "shadow",
      "action": "get-delta",
      "handler": "handleGetDelta"
    },
    {
      "domain": "shadow",
      "action": "set-desired",
      "handler": "handleSetDesired"
    },
    {
      "domain": "shadow",
      "action": "get-full",
      "handler": "handleGetFull"
    }
  ],
  "tools": [
    {
      "name": "shadow.get_full",
      "description": "Estado completo del shadow de un dispositivo: reported (lo que tiene), desired (lo que queremos), delta (diferencias)",
      "handler": "handleGetFull",
      "parameters": {
        "type": "object",
        "properties": {
          "device_id": {
            "type": "string"
          }
        },
        "required": [
          "device_id"
        ]
      },
      "errores_conocidos": [
        "INVALID_INPUT",
        "RESOURCE_NOT_FOUND"
      ]
    },
    {
      "name": "shadow.set_desired",
      "description": "Escribir estado deseado para un dispositivo. El delta se computa automáticamente y se envía por MQTT.",
      "handler": "handleSetDesired",
      "parameters": {
        "type": "object",
        "properties": {
          "device_id": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "state": {
            "type": "object",
            "description": "Estado deseado (ej: {firmware: {version: '3.5.0', url: '...'}})"
          }
        },
        "required": [
          "device_id",
          "state"
        ]
      },
      "errores_conocidos": [
        "INVALID_INPUT"
      ]
    },
    {
      "name": "shadow.get_delta",
      "description": "Ver las diferencias entre lo deseado y lo reportado por el dispositivo",
      "handler": "handleGetDelta",
      "parameters": {
        "type": "object",
        "properties": {
          "device_id": {
            "type": "string"
          }
        },
        "required": [
          "device_id"
        ]
      },
      "errores_conocidos": [
        "INVALID_INPUT",
        "RESOURCE_NOT_FOUND"
      ]
    }
  ],
  "config": {
    "persist_interval_ms": 30000,
    "data_path": "./data/devices",
    "persistence": {
      "type": "json-file",
      "path": "data/devices/shadows.json",
      "atomic": true
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "shadow.reported_updates.total",
        "shadow.desired_updates.total",
        "shadow.deltas_computed.total",
        "shadow.synced.total",
        "device-shadow.errors"
      ]
    }
  }
}
