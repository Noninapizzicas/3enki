{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pizzepos.com/schemas/cocina-events.json",
  "title": "Cocina Events Schema",
  "description": "Esquemas de eventos de cocina",

  "definitions": {
    "cocina_item_preparado": {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {"const": "cocina.item_preparado"},
        "payload": {
          "type": "object",
          "required": ["pedido_id", "item_id", "producto_id", "nombre"],
          "properties": {
            "pedido_id": {"type": "string"},
            "item_id": {"type": "string"},
            "producto_id": {"type": "string"},
            "nombre": {"type": "string"},
            "cantidad": {"type": "integer"},
            "preparado_at": {"type": "string", "format": "date-time"}
          }
        },
        "correlation_id": {"type": "string"}
      }
    },

    "cocina_pedido_listo": {
      "type": "object",
      "required": ["event_type", "payload"],
      "properties": {
        "event_type": {"const": "cocina.pedido_listo"},
        "payload": {
          "type": "object",
          "required": ["pedido_id", "items_count", "listo_at"],
          "properties": {
            "pedido_id": {"type": "string"},
            "cuenta_id": {"type": "string"},
            "canal": {"type": "string", "enum": ["mesa", "telefono", "llevar", "glovo", "whatsapp"]},
            "items_count": {"type": "integer"},
            "tiempo_preparacion": {"type": "number"},
            "listo_at": {"type": "string", "format": "date-time"}
          }
        },
        "correlation_id": {"type": "string"}
      }
    }
  }
}
