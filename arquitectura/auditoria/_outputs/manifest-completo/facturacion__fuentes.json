    "subscribes": [
      { "event": "telegram.photo.received",    "handler": "onTelegramPhoto",    "extras": {} },
      { "event": "telegram.document.received", "handler": "onTelegramDocument", "extras": {} }
    ],
    "provides_eventos": []
  },

  "tools": [],

