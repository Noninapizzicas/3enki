{
  "name": "recetas",
  "version": "2.0.0",
  "description": "Gestión de recetas v2: búsqueda externa → ingestion multi-formato → análisis profundo → almacenamiento versionado. Base para viabilidad de negocios alimentarios.",
  "author": "Event Core Team",
  "main": "index.js",

  "provides": {
    "events": [
      "receta.ingestion.started",
      "receta.ingestion.completed",
      "receta.ingestion.failed",
      "receta.analysis.completed",
      "receta.analysis.failed",
      "receta.creada",
      "receta.actualizada",
      "receta.eliminada",
      "receta.versión.revertida",
      "ingrediente.precio.actualizado"
    ]
  },

  "events": {
    "publishes": [
      {
        "event": "receta.ingestion.started",
        "description": "Ingestion pipeline iniciado (URL, PDF, foto, JSON)"
      },
      {
        "event": "receta.ingestion.completed",
        "description": "Datos normalizados listos para análisis"
      },
      {
        "event": "receta.ingestion.failed",
        "description": "Error en ingestion con estado resumible"
      },
      {
        "event": "receta.analysis.completed",
        "description": "Análisis profundo completado (viabilidad, costes reales)"
      },
      {
        "event": "receta.creada",
        "description": "Receta nueva guardada en BD"
      },
      {
        "event": "receta.actualizada",
        "description": "Receta modificada (nueva versión)"
      },
      {
        "event": "receta.eliminada",
        "description": "Receta archivada"
      },
      {
        "event": "ingrediente.precio.actualizado",
        "description": "Precio de mercado de ingrediente actualizado"
      }
    ],
    "subscribes": [
      { "event": "project.activated", "handler": "onProjectActivated" },
      { "event": "project.deactivated", "handler": "onProjectDeactivated" },
      { "event": "factura.procesada", "handler": "onFacturaProcesada" }
    ]
  },

  "handlers": [
    { "domain": "recetas", "action": "ingestar", "method": "handleIngestar" },
    { "domain": "recetas", "action": "analizar", "method": "handleAnalizar" },
    { "domain": "recetas", "action": "buscar", "method": "handleBuscar" },
    { "domain": "recetas", "action": "listar", "method": "handleListar" },
    { "domain": "recetas", "action": "obtener", "method": "handleObtener" },
    { "domain": "recetas", "action": "crear", "method": "handleCrear" },
    { "domain": "recetas", "action": "actualizar", "method": "handleActualizar" },
    { "domain": "recetas", "action": "eliminar", "method": "handleEliminar" },
    { "domain": "recetas", "action": "historial", "method": "handleHistorial" },
    { "domain": "recetas", "action": "revertir", "method": "handleRevertir" },
    { "domain": "recetas", "action": "ingredientes", "method": "handleIngredientes" },
    { "domain": "recetas", "action": "actualizar_precio", "method": "handleActualizarPrecio" },
    { "domain": "recetas", "action": "estadisticas", "method": "handleEstadisticas" }
  ],

  "ui_handlers": [
    { "domain": "recetas", "action": "ingestar", "handler": "handleIngestar" },
    { "domain": "recetas", "action": "analizar", "handler": "handleAnalizar" },
    { "domain": "recetas", "action": "buscar", "handler": "handleBuscar" },
    { "domain": "recetas", "action": "listar", "handler": "handleListar" },
    { "domain": "recetas", "action": "obtener", "handler": "handleObtener" },
    { "domain": "recetas", "action": "crear", "handler": "handleCrear" },
    { "domain": "recetas", "action": "actualizar", "handler": "handleActualizar" },
    { "domain": "recetas", "action": "eliminar", "handler": "handleEliminar" },
    { "domain": "recetas", "action": "historial", "handler": "handleHistorial" },
    { "domain": "recetas", "action": "revertir", "handler": "handleRevertir" }
  ],

  "tools": [
    {
      "name": "recetas.ingestar",
      "description": "Ingesta receta desde URL web, PDF, foto, JSON o formulario manual. Pipeline determinista: descarga → parse → normalización → indexación. Retorna ingestion_id para tracking.",
      "handler": "toolIngestar",
      "parameters": {
        "type": "object",
        "properties": {
          "proyecto_id": {
            "type": "string",
            "description": "ID del proyecto"
          },
          "input": {
            "type": ["string", "object"],
            "description": "URL (string), ruta archivo (string), o datos JSON (object)"
          },
          "tipo": {
            "type": "string",
            "enum": ["url", "pdf", "imagen", "json", "manual", "auto"],
            "description": "Tipo de input. 'auto' para detección automática"
          },
          "fuente_referencia": {
            "type": "string",
            "description": "Referencia (URL original, nombre archivo, etc.)"
          }
        },
        "required": ["proyecto_id", "input"]
      }
    },
    {
      "name": "recetas.analizar",
      "description": "Análisis profundo de receta: viabilidad técnica, tiempos reales, costes precisos, dificultad real (1-10), alérgenos, sustituciones posibles, puntos débiles/fuertes, potencial de mejora. Usa Claude con tool calling para investigación.",
      "handler": "toolAnalizar",
      "parameters": {
        "type": "object",
        "properties": {
          "receta_id": {
            "type": "string",
            "description": "ID de la receta a analizar"
          },
          "proyecto_id": {
            "type": "string",
            "description": "ID del proyecto"
          },
          "profundidad": {
            "type": "string",
            "enum": ["rapida", "normal", "profunda"],
            "description": "Nivel de análisis (default: normal)"
          }
        },
        "required": ["receta_id", "proyecto_id"]
      }
    },
    {
      "name": "recetas.buscar",
      "description": "Búsqueda local en catálogo por 40+ criterios: ingredientes, métodos cocción, tipo plato, dificultad, tiempo, coste, alérgenos, características (vegetariano, sin_gluten), viabilidad, etiquetas. Retorna lista de recetas con match scores.",
      "handler": "toolBuscar",
      "parameters": {
        "type": "object",
        "properties": {
          "proyecto_id": {
            "type": "string",
            "description": "ID del proyecto"
          },
          "nombre": {
            "type": "string",
            "description": "Buscar por nombre (búsqueda parcial)"
          },
          "ingredientes": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Ingredientes que DEBE llevar"
          },
          "ingredientes_excluir": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Ingredientes que NO debe llevar"
          },
          "dificultad_min": {
            "type": "number",
            "description": "Dificultad mínima (1-10)"
          },
          "dificultad_max": {
            "type": "number",
            "description": "Dificultad máxima (1-10)"
          },
          "tiempo_min": {
            "type": "number",
            "description": "Tiempo mínimo en minutos"
          },
          "tiempo_max": {
            "type": "number",
            "description": "Tiempo máximo en minutos"
          },
          "coste_min": {
            "type": "number",
            "description": "Coste mínimo por porción (€)"
          },
          "coste_max": {
            "type": "number",
            "description": "Coste máximo por porción (€)"
          },
          "caracteristicas": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Características: vegetariano, sin_gluten, sin_lactosa, vegano, etc."
          },
          "alerge nos_excluir": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Alérgenos a excluir: huevo, cacahuete, crustáceos, etc."
          },
          "viabilidad": {
            "type": "string",
            "enum": ["baja", "media", "alta"],
            "description": "Nivel mínimo de viabilidad"
          },
          "limit": {
            "type": "number",
            "default": 20,
            "description": "Número máximo de resultados"
          }
        },
        "required": ["proyecto_id"]
      }
    },
    {
      "name": "recetas.crear",
      "description": "Crear receta manualmente con todos los detalles. Para ingestar desde fuentes externas, usa recetas.ingestar + recetas.analizar.",
      "handler": "toolCrear",
      "parameters": {
        "type": "object",
        "properties": {
          "proyecto_id": { "type": "string", "description": "ID del proyecto" },
          "nombre": { "type": "string", "description": "Nombre de la receta" },
          "descripcion": { "type": "string", "description": "Descripción breve" },
          "ingredientes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "nombre": { "type": "string" },
                "cantidad": { "type": "number" },
                "unidad": { "type": "string" },
                "precio_mercado": { "type": "number" },
                "notas": { "type": "string" }
              },
              "required": ["nombre", "cantidad", "unidad"]
            }
          },
          "instrucciones": { "type": "array", "items": { "type": "string" } },
          "tiempo_preparacion": { "type": "number", "description": "Minutos" },
          "porciones": { "type": "number" },
          "dificultad": { "type": "number", "description": "1-10" },
          "categorias": { "type": "array", "items": { "type": "string" } },
          "etiquetas": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["proyecto_id", "nombre", "ingredientes", "porciones"]
      }
    },
    {
      "name": "recetas.actualizar",
      "description": "Actualizar receta existente. Crea nueva versión automáticamente con auditoría de cambios.",
      "handler": "toolActualizar",
      "parameters": {
        "type": "object",
        "properties": {
          "receta_id": { "type": "string", "description": "ID de la receta" },
          "proyecto_id": { "type": "string", "description": "ID del proyecto" },
          "cambios": {
            "type": "object",
            "description": "Solo los campos a cambiar (merge con versión actual)"
          }
        },
        "required": ["receta_id", "proyecto_id"]
      }
    },
    {
      "name": "recetas.listar",
      "description": "Listar todas las recetas del proyecto con filtros opcionales",
      "handler": "toolListar",
      "parameters": {
        "type": "object",
        "properties": {
          "proyecto_id": { "type": "string", "description": "ID del proyecto" },
          "estado": { "type": "string", "enum": ["activa", "archivada", "todos"] },
          "limit": { "type": "number", "default": 50 }
        },
        "required": ["proyecto_id"]
      }
    },
    {
      "name": "recetas.obtener",
      "description": "Obtener receta completa (versión actual) con todos los detalles e ingredientes",
      "handler": "toolObtener",
      "parameters": {
        "type": "object",
        "properties": {
          "receta_id": { "type": "string", "description": "ID de la receta" }
        },
        "required": ["receta_id"]
      }
    },
    {
      "name": "recetas.eliminar",
      "description": "Archivar receta (no la borra, la marca como archivada para auditoría)",
      "handler": "toolEliminar",
      "parameters": {
        "type": "object",
        "properties": {
          "receta_id": { "type": "string" },
          "proyecto_id": { "type": "string" }
        },
        "required": ["receta_id", "proyecto_id"]
      }
    },
    {
      "name": "recetas.historial",
      "description": "Ver historial de cambios de una receta (versionado completo con diffs)",
      "handler": "toolHistorial",
      "parameters": {
        "type": "object",
        "properties": {
          "receta_id": { "type": "string" },
          "limit": { "type": "number", "default": 20 }
        },
        "required": ["receta_id"]
      }
    },
    {
      "name": "recetas.revertir",
      "description": "Revertir a una versión anterior de la receta",
      "handler": "toolRevertir",
      "parameters": {
        "type": "object",
        "properties": {
          "receta_id": { "type": "string" },
          "proyecto_id": { "type": "string" },
          "target_version": { "type": "number", "description": "Número de versión a restaurar" }
        },
        "required": ["receta_id", "proyecto_id", "target_version"]
      }
    },
    {
      "name": "recetas.ingredientes",
      "description": "Listar catálogo de ingredientes del proyecto con precios de mercado y compra",
      "handler": "toolIngredientes",
      "parameters": {
        "type": "object",
        "properties": {
          "proyecto_id": { "type": "string" },
          "categoria": { "type": "string", "description": "Filtrar por categoría (opcional)" }
        },
        "required": ["proyecto_id"]
      }
    },
    {
      "name": "recetas.actualizar_precio",
      "description": "Actualizar precio de mercado de un ingrediente",
      "handler": "toolActualizarPrecio",
      "parameters": {
        "type": "object",
        "properties": {
          "ingrediente_id": { "type": "string" },
          "proyecto_id": { "type": "string" },
          "precio_mercado": { "type": "number" },
          "fuente": { "type": "string", "description": "Fuente del precio (ej: mercadona.es)" }
        },
        "required": ["ingrediente_id", "proyecto_id", "precio_mercado"]
      }
    },
    {
      "name": "recetas.estadisticas",
      "description": "Estadísticas del proyecto: total recetas, ingredientes, costes promedio, etc.",
      "handler": "toolEstadisticas",
      "parameters": {
        "type": "object",
        "properties": {
          "proyecto_id": { "type": "string" }
        },
        "required": ["proyecto_id"]
      }
    }
  ],

  "pipeline": {
    "ingestion": {
      "description": "Pipeline multi-formato: intake → download/read → parse → normalize → index",
      "steps": [
        { "step": "intake", "description": "Validar input, registrar en BD" },
        { "step": "download_or_read", "description": "Fetch URL o read archivo local" },
        { "step": "parse", "description": "Detectar formato (HTML, PDF, IMG, JSON)" },
        { "step": "normalize", "description": "Extraer campos candidatos" },
        { "step": "index", "description": "Guardar estado intermedio para resume" }
      ],
      "resumable": true,
      "providers": {
        "url": "http client",
        "pdf": "local.pdfjs + local.sharp + local.google-vision",
        "image": "local.sharp + local.google-vision",
        "json": "json schema validator"
      }
    },
    "analysis": {
      "description": "Análisis profundo: estructuración IA → validación → análisis costes/tiempo",
      "agent": "receta-analyzer",
      "trigger": "receta.ingestion.completed"
    },
    "storage": {
      "description": "Persistencia + versionado: SQLite per-project con audit trail",
      "database": "SQLite",
      "location": "data/projects/{proyecto}/recetas.db",
      "versionado": true,
      "rollback": true
    }
  },

  "config": {
    "ingestion": {
      "timeout_url": 30000,
      "timeout_pdf": 60000,
      "timeout_ocr": 60000,
      "max_file_size": 50000000
    },
    "analysis": {
      "providers": ["anthropic", "deepseek", "openai", "gemini"],
      "temperature": 0.1,
      "maxTokens": 3000
    },
    "storage": {
      "sqlite_path_template": "data/projects/{proyecto}/recetas.db",
      "max_recetas_cache": 100
    }
  },

  "observability": {
    "metrics": {
      "counters": [
        "receta.ingestion.started",
        "receta.ingestion.completed",
        "receta.ingestion.failed",
        "receta.analysis.completed",
        "receta.analysis.failed",
        "receta.creada",
        "receta.actualizada",
        "receta.eliminada",
        "receta.buscada"
      ],
      "histograms": [
        "receta.ingestion.duration_ms",
        "receta.analysis.duration_ms",
        "receta.search.results_count"
      ]
    },
    "logging": {
      "level": "info",
      "structured": true
    }
  }
}
