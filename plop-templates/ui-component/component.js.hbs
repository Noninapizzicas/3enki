/**
 * {{pascalCase name}} Component - Client-side behavior
 * Auto-generated by plop ui-component
 */

(function() {
  'use strict';

  const COMPONENT_NAME = '{{name}}';
  const SELECTOR = `[data-component="${COMPONENT_NAME}"]`;

  /**
   * Initialize component instances
   */
  function init() {
    document.querySelectorAll(SELECTOR).forEach(el => {
      if (el.dataset.initialized) return;
      el.dataset.initialized = 'true';
      setupComponent(el);
    });
  }

  /**
   * Setup single component instance
   */
  function setupComponent(el) {
    {{#each interactions}}
    {{#if (eq this "click")}}
    // Click handler
    el.addEventListener('click', (e) => {
      if (el.disabled || el.dataset.loading === 'true') return;
      handleAction(el, 'click', e);
    });
    {{/if}}

    {{#if (eq this "double-click")}}
    // Double click handler
    el.addEventListener('dblclick', (e) => {
      if (el.disabled || el.dataset.loading === 'true') return;
      handleAction(el, 'dblclick', e);
    });
    {{/if}}

    {{#if (eq this "hold")}}
    // Hold (long press) handler
    let holdTimer = null;
    let holdProgress = null;

    el.addEventListener('mousedown', (e) => {
      if (el.disabled || el.dataset.loading === 'true') return;

      const config = JSON.parse(el.dataset.hold || '{}');
      const duration = config.duration || 2000;

      // Create progress indicator
      if (config.feedback === 'progress-ring') {
        holdProgress = createProgressRing(el, duration);
      }

      holdTimer = setTimeout(() => {
        handleAction(el, 'hold', e);
        cleanupHold();
      }, duration);
    });

    el.addEventListener('mouseup', cleanupHold);
    el.addEventListener('mouseleave', cleanupHold);

    function cleanupHold() {
      if (holdTimer) {
        clearTimeout(holdTimer);
        holdTimer = null;
      }
      if (holdProgress) {
        holdProgress.remove();
        holdProgress = null;
      }
    }
    {{/if}}

    {{#if (eq this "swipe")}}
    // Swipe handler
    let touchStartX = 0;
    let touchStartY = 0;

    el.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    el.addEventListener('touchend', (e) => {
      const deltaX = e.changedTouches[0].clientX - touchStartX;
      const deltaY = e.changedTouches[0].clientY - touchStartY;
      const threshold = 50;

      if (Math.abs(deltaX) > Math.abs(deltaY) && Math.abs(deltaX) > threshold) {
        handleAction(el, deltaX > 0 ? 'swipe-right' : 'swipe-left', e);
      } else if (Math.abs(deltaY) > threshold) {
        handleAction(el, deltaY > 0 ? 'swipe-down' : 'swipe-up', e);
      }
    }, { passive: true });
    {{/if}}

    {{#if (eq this "drag")}}
    // Drag handler
    el.draggable = true;

    el.addEventListener('dragstart', (e) => {
      el.classList.add('dragging');
      e.dataTransfer.setData('text/plain', el.dataset.id || '');
      handleAction(el, 'dragstart', e);
    });

    el.addEventListener('dragend', (e) => {
      el.classList.remove('dragging');
      handleAction(el, 'dragend', e);
    });
    {{/if}}
    {{/each}}

    // Keyboard accessibility
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        handleAction(el, 'click', e);
      }
    });
  }

  /**
   * Handle action from interaction
   */
  function handleAction(el, eventType, originalEvent) {
    const config = JSON.parse(el.dataset[eventType] || el.dataset.action || '{}');

    if (!config.action) return;

    // Emit UI event
    window.dispatchEvent(new CustomEvent('ui:action', {
      detail: {
        component: COMPONENT_NAME,
        element: el,
        eventType,
        action: config.action,
        params: config,
        originalEvent
      }
    }));

    // Execute action via global action handler
    if (window.AutoUI && window.AutoUI.executeAction) {
      window.AutoUI.executeAction(config.action, config, el);
    }
  }

  /**
   * Create progress ring for hold feedback
   */
  function createProgressRing(el, duration) {
    const ring = document.createElement('div');
    ring.className = 'hold-progress-ring';
    ring.style.cssText = `
      position: absolute;
      inset: 0;
      border: 2px solid var(--primary);
      border-radius: inherit;
      animation: hold-progress ${duration}ms linear forwards;
      pointer-events: none;
    `;
    el.style.position = 'relative';
    el.appendChild(ring);
    return ring;
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Re-initialize on htmx content swap
  document.addEventListener('htmx:afterSwap', init);

  // Export for manual initialization
  window.AutoUI = window.AutoUI || {};
  window.AutoUI.components = window.AutoUI.components || {};
  window.AutoUI.components['{{name}}'] = { init, setupComponent };

})();
