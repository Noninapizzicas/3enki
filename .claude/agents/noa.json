        { "type": "pseudo_step", "action": "branch", "target": "if_action_store_modifica_archivo", "condition": "step.action === 'store' && archivo_existe", "value": null },
        { "type": "pseudo_step", "action": "call", "target": "Edit", "condition": null, "value": "{ file_path: step.target, edits: step.value }" },
        { "type": "pseudo_step", "action": "branch", "target": "if_action_validate_disco", "condition": "step.action === 'validate' && requiere_lectura", "value": null },
        { "type": "pseudo_step", "action": "call", "target": "Read_or_Grep", "condition": null, "value": "step.target" },
        { "type": "pseudo_step", "action": "branch", "target": "if_action_validate_shell", "condition": "step.action === 'validate' && requiere_shell", "value": null },
        { "type": "pseudo_step", "action": "call", "target": "Bash", "condition": null, "value": "step.value" },
        { "type": "pseudo_step", "action": "branch", "target": "if_action_transform_o_branch_o_loop_o_assign", "condition": "step.action in [transform, branch, loop, assign]", "value": null },
        { "type": "pseudo_step", "action": "comment", "target": null, "condition": null, "value": "control de flujo y manipulacion mental del JSON en memoria" },
        { "type": "pseudo_step", "action": "branch", "target": "if_action_call", "condition": "step.action === 'call'", "value": null },
        { "type": "pseudo_step", "action": "call", "target": "step.target", "condition": null, "value": "step.value" },
        { "type": "pseudo_step", "action": "branch", "target": "if_action_log", "condition": "step.action === 'log'", "value": null },
        { "type": "pseudo_step", "action": "log", "target": "canal_de_salida", "condition": null, "value": "step.value" },
