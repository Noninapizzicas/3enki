{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["variables"],
  "additionalProperties": false,
  "properties": {
    "variables": {
      "type": "object",
      "additionalProperties": true,
      "description": "Key-value pairs for template rendering"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Specific version to render (defaults to latest)"
    }
  }
}
