{
  "id": "escandallo-analyzer",
  "name": "escandallo-analyzer",
  "description": "Validación de escandallos: coherencia de cálculos, detección de anomalías, evaluación de viabilidad de precio, recomendaciones automáticas.",
  "version": "1.0.0",
  "enabled": true,
  "prompt_file": "prompts/escandallo-analyzer.json",
  "tools": [
    "escandallo.calcular",
    "escandallo.ficha.tecnica",
    "escandallo.ingrediente.impacto"
  ],
  "provider": "auto",
  "temperature": 0.3,
  "max_tokens": 2000,
  "context_enabled": true,
  "timeout_ms": 120000,
  "max_retries": 1,
  "event_listener": {
    "event": "escandallo.calculado",
    "context_mapping": {
      "correlation_id": "$.correlation_id",
      "project_id": "$.project_id",
      "user_id": "$.user_id",
      "receta_id": "$.receta_id",
      "nombre": "$.nombre",
      "coste_total": "$.coste_total",
      "coste_por_porcion": "$.coste_por_porcion",
      "coste_es_real": "$.coste_es_real",
      "food_cost_pct": "$.food_cost_pct",
      "ingredientes_sin_precio": "$.ingredientes_sin_precio",
      "timestamp": "$.timestamp"
    }
  },
  "publish_on_success": {
    "event": "escandallo.analysis.completed",
    "payload_template": {
      "correlation_id": "$.context.correlation_id",
      "project_id": "$.context.project_id",
      "user_id": "$.context.user_id",
      "receta_id": "$.context.receta_id",
      "analisis": "$.result.analisis",
      "anomalias": "$.result.anomalias",
      "recomendaciones": "$.result.recomendaciones",
      "alertas_generadas": "$.result.alertas_generadas",
      "timestamp": "$.timestamp"
    }
  },
  "publish_on_failure": {
    "event": "escandallo.analysis.failed",
    "payload_template": {
      "correlation_id": "$.context.correlation_id",
      "project_id": "$.context.project_id",
      "user_id": "$.context.user_id",
      "receta_id": "$.context.receta_id",
      "error": "$.error.message",
      "timestamp": "$.timestamp"
    }
  },
  "metadata": {
    "type": "pipeline-agent",
    "domain": "escandallo",
    "pipeline_role": "step-1-analysis",
    "author": "system",
    "created_at": "2026-04-15",
    "tags": [
      "escandallo",
      "análisis",
      "validación",
      "anomalías"
    ]
  },
  "created_at": "2026-04-15T00:00:00.000Z",
  "updated_at": "2026-04-15T00:00:00.000Z",
  "stats": {
    "executions": 0,
    "successes": 0,
    "failures": 0,
    "total_tokens": 0,
    "total_cost": 0,
    "avg_latency_ms": 0,
    "last_execution": null
  },
  "scope": [
    "escandallo",
    "recetas"
  ]
}
