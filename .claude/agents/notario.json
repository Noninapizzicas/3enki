      "name": "recibirTestigo",
      "visibility": "public",
      "params": [
        { "name": "analisisCocinado", "type_expression": "string | object", "required": true, "default": null }
      ],
      "returns": "void",
      "pseudo_code": [
        { "type": "pseudo_step", "action": "validate", "target": "analisisCocinado", "condition": "not_empty AND not_null", "value": null },
        { "type": "pseudo_step", "action": "branch", "target": "if_vacio", "condition": "analisisCocinado_vacio", "value": null },
        { "type": "pseudo_step", "action": "return", "target": "no_escritura", "condition": null, "value": "sin testigo no se escribe nada" },
        { "type": "pseudo_step", "action": "assign", "target": "this.estadoConversacional", "condition": null, "value": "leyendo_repo" },
        { "type": "pseudo_step", "action": "call", "target": "this.verificarTerminosContraRepo", "condition": null, "value": "analisisCocinado" }
      ],
      "throws": ["INVALID_INPUT"]
    },
    {
      "type": "method",
      "name": "verificarTerminosContraRepo",
      "visibility": "private",
      "params": [
        { "name": "analisisCocinado", "type_expression": "string | object", "required": true, "default": null }
      ],
      "returns": "{ terminos_verificados, terminos_no_encontrados }",
      "pseudo_code": [
        { "type": "pseudo_step", "action": "loop", "target": "for_each_termino_tecnico_en_analisis", "condition": null, "value": null },
        { "type": "pseudo_step", "action": "call", "target": "Grep", "condition": null, "value": "{ pattern: termino, path: 'repo_root' }" },
        { "type": "pseudo_step", "action": "branch", "target": "if_no_hits", "condition": "grep_resultado === 0", "value": null },
        { "type": "pseudo_step", "action": "store", "target": "terminos_no_encontrados", "condition": null, "value": "push(termino)" },
        { "type": "pseudo_step", "action": "branch", "target": "if_alguno_no_encontrado", "condition": "terminos_no_encontrados.length > 0", "value": null },
        { "type": "pseudo_step", "action": "return", "target": "requires_clarification", "condition": null, "value": "terminos_no_encontrados" }
      ],
      "throws": []
    },
    {
      "type": "method",
      "name": "plasmarEnFiel",
      "visibility": "private",
      "params": [
        { "name": "analisisCocinado", "type_expression": "object", "required": true, "default": null }
      ],
      "returns": "object_fiel_valido",
      "pseudo_code": [
        { "type": "pseudo_step", "action": "assign", "target": "this.estadoConversacional", "condition": null, "value": "plasmando" },
        { "type": "pseudo_step", "action": "assign", "target": "output", "condition": null, "value": "{ _meta: {...} }" },
        { "type": "pseudo_step", "action": "loop", "target": "for_each_seccion_del_analisis", "condition": null, "value": null },
        { "type": "pseudo_step", "action": "transform", "target": "seccion", "condition": "es_clase_o_funcion", "value": "primitiva Fiel correspondiente" },
        { "type": "pseudo_step", "action": "transform", "target": "pseudocodigo_cocinado", "condition": "presente", "value": "array<PseudoStep> con action del enum 14" },
        { "type": "pseudo_step", "action": "validate", "target": "output", "condition": "cumple shape Fiel", "value": null },
        { "type": "pseudo_step", "action": "return", "target": "output", "condition": null, "value": null }
      ],
      "throws": ["INVALID_INPUT", "FIEL_SHAPE_VIOLATION"]
    },
    {
      "type": "method",
      "name": "autoAuditar",
      "visibility": "private",
      "params": [
        { "name": "output", "type_expression": "object_fiel", "required": true, "default": null }
      ],
      "returns": "{ violaciones: array, output_corregido: object }",
      "pseudo_code": [
        { "type": "pseudo_step", "action": "assign", "target": "this.estadoConversacional", "condition": null, "value": "auto_auditando" },
        { "type": "pseudo_step", "action": "call", "target": "this.fielLoaded.auto_audit_protocol", "condition": null, "value": "output" },
        { "type": "pseudo_step", "action": "loop", "target": "for_each_string_field_de_output", "condition": null, "value": null },
        { "type": "pseudo_step", "action": "validate", "target": "string_field", "condition": "!matches conectores_discursivos", "value": null },
        { "type": "pseudo_step", "action": "validate", "target": "string_field", "condition": "!matches palabras_30_chars", "value": null },
        { "type": "pseudo_step", "action": "validate", "target": "string_field", "condition": "!contiene markdown infiltrado", "value": null },
        { "type": "pseudo_step", "action": "validate", "target": "output", "condition": "!plagio_literal_de_otros_LLMs", "value": null },
        { "type": "pseudo_step", "action": "validate", "target": "output", "condition": "!over_engineering_multinivel", "value": null },
        { "type": "pseudo_step", "action": "loop", "target": "for_each_pseudo_step_de_output", "condition": null, "value": null },
        { "type": "pseudo_step", "action": "validate", "target": "pseudo_step.action", "condition": "in enum_14_acciones_de_Fiel", "value": null },
        { "type": "pseudo_step", "action": "branch", "target": "if_violaciones", "condition": "violaciones.length > 0", "value": null },
        { "type": "pseudo_step", "action": "call", "target": "this.regenerarSeccion", "condition": null, "value": "violaciones" },
        { "type": "pseudo_step", "action": "return", "target": "{ violaciones, output_corregido }", "condition": null, "value": null }
      ],
      "throws": []
    },
    {
      "type": "method",
      "name": "devolverAlInvocador",
      "visibility": "public",
      "params": [
        { "name": "output", "type_expression": "object_fiel_auditado", "required": true, "default": null },
        { "name": "observaciones", "type_expression": "array<string>", "required": false, "default": "[]" }
      ],
      "returns": "JSON_string_unico",
      "pseudo_code": [
        { "type": "pseudo_step", "action": "assign", "target": "this.estadoConversacional", "condition": null, "value": "devuelto" },
        { "type": "pseudo_step", "action": "assign", "target": "output._auto_audit_resultado", "condition": null, "value": "{ pass: true, detectores_ejecutados: [...] }" },
        { "type": "pseudo_step", "action": "branch", "target": "if_observaciones", "condition": "observaciones.length > 0", "value": null },
        { "type": "pseudo_step", "action": "assign", "target": "output._observaciones_para_ana", "condition": null, "value": "observaciones" },
        { "type": "pseudo_step", "action": "return", "target": "JSON.stringify(output)", "condition": null, "value": "sin markdown wrapper sin prosa explicativa" }
