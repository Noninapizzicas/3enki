{
  "name": "{{name}}",
  "version": "1.0.0",
  "description": "{{description}}",
  "author": "{{author}}",

  "provides": {
    "events": [{{#each publishEvents}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}],
    "queries": []
  },

  "events": {
    "publishes": [
      {{#each publishEvents}}
      {
        "event": "{{this}}",
        "description": "Evento {{this}}",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/{{snakeCase this}}"
        }
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ],

    "subscribes": [
      {{#each subscriptions}}
      {
        "event": "{{this.event}}",
        "description": "Escucha evento {{this.event}}",
        "handler": "{{this.handler}}"
      }{{#unless @last}},{{/unless}}
      {{/each}}
    ]
  },

  "apis": [
    {{#each apis}}
    {
      "method": "{{this.method}}",
      "path": "{{this.path}}",
      "handler": "{{this.handler}}",
      "description": "{{this.description}}"{{#if this.params}},
      "params": {{json this.params}}{{/if}}
    },
    {{/each}}
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check del módulo"
    }
  ],

  {{#if ui}}
  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "{{titleCase name}}",
    "icon": "{{icon}}",
    "description": "{{description}}",

    "views": {
      "main": {
        "type": "dashboard",
        "layout": {
          "type": "two-column",
          "left_width": "65%"
        },
        "sections": [
          {
            "id": "header",
            "type": "header",
            "title": "{{icon}} {{titleCase name}}",
            "subtitle": "{{description}}"
          },
          {
            "id": "stats",
            "column": "left",
            "type": "widget-group",
            "layout": "horizontal",
            "widgets": [
              {
                "type": "stat-card",
                "title": "Total",
                "value": "@data.stats.total",
                "icon": "📊",
                "color": "primary",
                "endpoint": "/modules/{{name}}/data",
                "mqtt_topic": "{{name}}.updated"
              },
              {
                "type": "stat-card",
                "title": "Status",
                "value": "Active",
                "icon": "✓",
                "color": "success"
              }
            ]
          },
          {
            "id": "main_content",
            "column": "left",
            "type": "card",
            "title": "Data",
            "content": {
              "type": "table-advanced",
              "endpoint": "/modules/{{name}}/data",
              "mqtt_topic": "{{name}}.updated",
              "refresh_on_event": true,
              "columns": "auto",
              "pagination": true,
              "search": true
            }
          },
          {
            "id": "info_panel",
            "column": "right",
            "type": "card",
            "title": "ℹ️ Information",
            "content": {
              "type": "info",
              "items": [
                {
                  "label": "Version",
                  "value": "1.0.0",
                  "icon": "🏷️"
                },
                {
                  "label": "Status",
                  "value": "Active",
                  "color": "#22c55e"
                }
              ]
            }
          }
        ]
      }
    }
  },
  {{/if}}

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true
    }
  },

  "config": {
    {{#if persistence}}
    "persist_interval_ms": 60000,
    {{/if}}
    "enabled": true
  }
}
