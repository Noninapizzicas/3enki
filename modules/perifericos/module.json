{
  "name": "perifericos",
  "version": "2.0.0",
  "description": "Servicio core de perifericos — descubrimiento, registro y routing de dispositivos hardware. Capacidades: imprimir, display, abrir-cajon. Auto-descubrimiento ESP32 via MQTT.",
  "author": "Event Core Team",
  "language": "es",
  "tier": "tier_2_platform",
  "provides": {
    "events": [
      "periferico.impreso",
      "periferico.displayed",
      "periferico.cajon-abierto",
      "periferico.error",
      "periferico.dispositivo.registrado",
      "periferico.dispositivo.desregistrado",
      "periferico.estado.respuesta",
      "periferico.listado"
    ]
  },
  "events": {
    "publishes": [
      { "event": "periferico.impreso",                  "description": "Datos enviados exitosamente a una impresora (lleva project_id top-level + correlation_id)" },
      { "event": "periferico.displayed",                "description": "Contenido enviado exitosamente a un display externo" },
      { "event": "periferico.cajon-abierto",            "description": "Cajon de dinero abierto exitosamente via comando ESC/POS" },
      { "event": "periferico.error",                    "description": "Error en envio/conexion a un dispositivo (kind + code canonico + contexto)" },
      { "event": "periferico.dispositivo.registrado",   "description": "Nuevo dispositivo registrado en el sistema (manual, UI o auto-descubierto)" },
      { "event": "periferico.dispositivo.desregistrado","description": "Dispositivo eliminado del registro" },
      { "event": "periferico.estado.respuesta",         "description": "Respuesta a consulta de estado de un dispositivo (par sync sobre pub/sub)" },
      { "event": "periferico.listado",                  "description": "Respuesta a consulta de listado de dispositivos" }
    ],
    "subscribes": [
      { "event": "periferico.imprimir",     "handler": "onImprimir",     "description": "Envia datos a una impresora (ESC/POS, texto, gcode)" },
      { "event": "periferico.display",      "handler": "onDisplay",      "description": "Envia contenido a una pantalla externa (TV cocina, LED barra, tablet fija)" },
      { "event": "periferico.abrir-cajon",  "handler": "onAbrirCajon",   "description": "Abre cajon de dinero via comando ESC/POS estandar" },
      { "event": "periferico.estado",       "handler": "onEstado",       "description": "Consulta estado de un dispositivo por nombre logico" },
      { "event": "periferico.listar",       "handler": "onListar",       "description": "Lista todos los dispositivos registrados" },
      { "event": "periferico.registrar",    "handler": "onRegistrar",    "description": "Registra un nuevo dispositivo" },
      { "event": "periferico.desregistrar", "handler": "onDesregistrar", "description": "Elimina un dispositivo del registro" }
    ]
  },
  "ui_handlers": [
    { "domain": "perifericos", "action": "list",                 "handler": "handleListar",             "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "perifericos", "action": "get",                  "handler": "handleGet",                "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "perifericos", "action": "create",               "handler": "handleRegistrar",          "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "perifericos", "action": "update",               "handler": "handleActualizar",         "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "perifericos", "action": "delete",               "handler": "handleDesregistrar",       "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "perifericos", "action": "test",                 "handler": "handleTestDispositivo",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "perifericos", "action": "status",               "handler": "handleEstado",             "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "perifericos", "action": "discover",             "handler": "handleDescubrir",          "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "perifericos", "action": "listar-por-capacidad", "handler": "handleListarPorCapacidad", "type": "system_panel", "zone": "lateral_derecha" }
  ],
  "tools": [],
  "dependencies": [],
  "config": {
    "dataPath": "./data/perifericos",
    "dispositivos": [],
    "health_check_interval_ms": 30000,
    "descubrimiento": { "esp32_auto": true },
    "persistence": {
      "type": "delegated",
      "owner": "services/providers/local/perifericos/registry.js",
      "note": "El modulo no persiste estado propio — el provider gestiona registry.json y transportes activos."
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "perifericos.envios.total",
        "perifericos.envios.ok",
        "perifericos.envios.error",
        "perifericos.registros.total",
        "perifericos.errors"
      ]
    }
  }
}
