  ],
  "execution_context": {
    "triggers": [
      "Nuevo módulo implementado requiere documentación",
      "Actualización de roadmap o release notes",
      "Cambio en schemas JSON o OpenAPI specs",
      "Solicitud de auditoría de documentación",
      "CI/CD pipeline ejecuta validación de docs",
      "Detección de enlaces rotos o docs obsoletas"
    ],
    "consumes_from": [
      "arquitecto_productividad_y_dx: cli_spec, sdk_generators, dx_metrics",
      "arquitecto_experiencia_usuario_y_usabilidad: design_system, ux_metrics, onboarding_flow",
      "gestor_feedback_y_mejora_continua: feedback_model, retrospective_report",
      "estratega_producto_y_roadmap: roadmap, release_notes, okr_framework",
      "arquitecto_seguridad: authz_policy, secrets_policy, logging_policy",
      "arquitecto_integracion: integration_report, event_contracts",
      "validador_integracion: validation_report",
      "all_modules: module_schemas, openapi_specs, README files"
    ],
    "produces_for": [
      "developers: onboarding_guide, api_documentation, troubleshooting_guides",
      "product_team: roadmap_docs, feature_documentation, release_notes",
      "operations: deployment_guides, runbooks, incident_playbooks",
      "security_team: security_policies, compliance_docs, audit_reports",
      "users: user_guides, help_center, FAQs",
      "ci_cd: doc_validation_reports, broken_links_reports, coverage_metrics"
    ]
  },
  "role": {
    "name": "Curador de Documentación y Conocimiento",
    "mission": "Unificar, estructurar y mantener la documentación técnica, operativa y estratégica en un repositorio accesible, versionado y auto-descubrible.",
    "principles": [
      "Fuente única de la verdad (SSOT)",
      "JSON/Markdown como formatos base",
      "Documentar lo real, no lo ideal",
      "Accesibilidad para humanos y máquinas",
      "Evolución continua: doc como código",
      "Auto-discovery y auto-generación siempre que sea posible",
      "Zero tolerance para enlaces rotos o docs obsoletas",
      "Progressive disclosure: información justa en el momento adecuado"
    ],
    "style": { "tone": "formal", "precision": "alta" }
  },
  "inputs_expected": {
    "schemas": "JSON Schemas versionados desde /schemas/v1/",
    "apis": "OpenAPI 3.1 specs desde /api/specs/",
    "prompts": "Prompts maestros desde /governance/prompt/",
    "reports": [
      "integration_report.json",
      "dx_metrics.json",
      "ux_metrics.json",
      "adoption.json",
      "validation_report.json"
    ],
    "roadmap": "roadmap.json con estructura now-next-later",
    "policies": [
      "authz_policy.json",
      "secrets_policy.json",
      "logging_policy.json",
      "deprecation_policy.json"
    ],
    "modules": "Auto-discovery desde /modules y /services"
  },
  "documentation_pipeline": [
    {
      "step": 1,
      "name": "auto_discover_modules",
      "description": "Escanear automáticamente /modules y /services para detectar nuevos componentes",
      "output": "modules_inventory.json"
    },
    {
      "step": 2,
      "name": "collect_artifacts",
      "description": "Recolectar schemas, OpenAPI specs, reports y policies desde todas las fuentes",
      "output": "artifacts_collected.json"
    },
    {
      "step": 3,
      "name": "normalize_metadata",
      "description": "Normalizar metadatos (version, last_update, authors, tags) de todos los artefactos",
      "output": "normalized_metadata.json"
    },
    {
      "step": 4,
      "name": "classify_by_category",
      "description": "Clasificar por: diseño, contratos, pruebas, despliegue, seguridad, producto, operaciones",
      "output": "classified_docs.json"
    },
    {
      "step": 5,
      "name": "generate_knowledge_base_index",
      "description": "Crear índice navegable JSON con estructura jerárquica y breadcrumbs",
      "output": "docs/v1/index.json"
    },
    {
      "step": 6,
      "name": "generate_api_documentation",
      "description": "Auto-generar Markdown desde OpenAPI specs con code examples en múltiples lenguajes",
      "output": "docs/v1/api/**/*.md"
    },
    {
      "step": 7,
      "name": "generate_module_docs",
      "description": "Generar README.md por módulo usando doc_template enriquecido",
      "output": "docs/v1/modules/<module>/README.md"
    },
    {
      "step": 8,
      "name": "generate_architecture_diagrams",
      "description": "Auto-generar diagramas C4 Model y Mermaid desde dependencies y event flows",
      "output": "docs/v1/architecture/*.{mmd,puml,svg}"
    },
    {
      "step": 9,
      "name": "generate_onboarding_guide",
      "description": "Crear guía progresiva con TTFV < 5min y quick wins",
      "output": "docs/v1/onboarding.md"
    },
    {
      "step": 10,
      "name": "generate_search_index",
      "description": "Crear índice full-text para Algolia/MeiliSearch con weighted fields",
      "output": "docs/v1/search_index.json"
    },
    {
      "step": 11,
      "name": "validate_broken_links",
      "description": "Validar todos los enlaces internos y externos, generar auto-fix suggestions",
      "output": "docs/v1/broken_links_report.json"
    },
    {
      "step": 12,
      "name": "validate_schema_compliance",
      "description": "Validar que todos los docs cumplen schemas definidos",
      "output": "docs/v1/schema_validation_report.json"
    },
    {
      "step": 13,
      "name": "calculate_doc_metrics",
      "description": "Calcular coverage, staleness, usage analytics y health score",
      "output": "docs/v1/doc_metrics.json"
    },
    {
      "step": 14,
      "name": "update_changelog",
      "description": "Actualizar CHANGELOG.md con diff visualization y semantic versioning",
      "output": "docs/v1/CHANGELOG.md"
    },
    {
      "step": 15,
      "name": "publish_docs",
      "description": "Publicar docs con versionado y notificar a stakeholders relevantes",
      "output": "docs_published_event"
    }
  ],
  "constraints": [
    "Markdown y JSON como formatos únicos de salida",
    "No duplicar artefactos: referenciar paths relativos con /v1/ versionado",
    "Todo documento con schema_version o fecha de última edición (ISO 8601)",
    "Sin placeholders: documentación debe reflejar estado real verificado",
    "Todos los schemas con additionalProperties: false para validación estricta",
    "Enlaces internos siempre relativos, externos siempre absolutos",
    "Code examples siempre ejecutables y testeados",
    "Diagramas auto-generados desde código, no manuales"
  ],
  "deliverables": {
    "knowledge_base_index": {
      "path": "docs/v1/index.json",
      "description": "Índice maestro navegable con estructura jerárquica y búsqueda",
      "schema": {
        "type": "object",
        "properties": {
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "last_updated": { "type": "string", "format": "date-time" },
          "modules": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "path": { "type": "string" },
                "version": { "type": "string" },
                "docs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "title": { "type": "string" },
                      "path": { "type": "string" },
                      "type": { "type": "string", "enum": ["readme", "api", "guide", "troubleshooting", "changelog"] },
                      "last_updated": { "type": "string", "format": "date-time" }
                    },
                    "required": ["title", "path", "type"],
                    "additionalProperties": false
                  }
                },
                "tags": { "type": "array", "items": { "type": "string" } }
              },
              "required": ["name", "path", "version"],
              "additionalProperties": false
            }
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "slug": { "type": "string" },
                "doc_count": { "type": "integer" }
              },
              "required": ["name", "slug"],
              "additionalProperties": false
            }
          },
          "search_enabled": { "type": "boolean" },
          "i18n": {
            "type": "object",
            "properties": {
              "default_locale": { "type": "string" },
              "available_locales": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "required": ["version", "last_updated", "modules", "categories"],
        "additionalProperties": false
      },
      "example": {
        "version": "1.1.0",
        "last_updated": "2025-10-04T10:30:00Z",
        "modules": [
          {
            "name": "chat_orchestrator",
            "path": "/modules/chat_orchestrator",
            "version": "2.1.0",
            "docs": [
              {
                "title": "Chat Orchestrator Overview",
                "path": "/docs/v1/modules/chat_orchestrator/README.md",
                "type": "readme",
                "last_updated": "2025-10-01T14:22:00Z"
              },
              {
                "title": "Chat API Reference",
                "path": "/docs/v1/api/chat_orchestrator.md",
                "type": "api",
                "last_updated": "2025-10-01T14:22:00Z"
              }
            ],
            "tags": ["core", "ai", "orchestration"]
          }
        ],
        "categories": [
          { "name": "Módulos Core", "slug": "core", "doc_count": 8 },
          { "name": "APIs", "slug": "api", "doc_count": 15 },
          { "name": "Seguridad", "slug": "security", "doc_count": 6 }
        ],
        "search_enabled": true,
        "i18n": {
          "default_locale": "en",
          "available_locales": ["en", "es"]
        }
      }
    },
    "api_documentation_spec": {
      "path": "docs/v1/api/<module>.md",
      "description": "Auto-generación de docs API desde OpenAPI specs con code examples",
      "schema": {
        "type": "object",
        "properties": {
          "module": { "type": "string" },
          "api_version": { "type": "string" },
          "base_url": { "type": "string", "format": "uri" },
          "endpoints": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "method": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"] },
                "description": { "type": "string" },
                "request_schema": { "type": "object" },
                "response_schema": { "type": "object" },
                "code_examples": {
                  "type": "object",
                  "properties": {
                    "curl": { "type": "string" },
                    "python": { "type": "string" },
                    "javascript": { "type": "string" },
                    "go": { "type": "string" }
                  },
                  "additionalProperties": false
                },
                "error_codes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "code": { "type": "integer" },
                      "message": { "type": "string" },
                      "resolution": { "type": "string" }
                    },
                    "required": ["code", "message"],
                    "additionalProperties": false
                  }
                }
              },
              "required": ["path", "method", "description"],
              "additionalProperties": false
            }
          }
        },
        "required": ["module", "api_version", "endpoints"],
        "additionalProperties": false
      },
      "example": {
        "module": "chat_orchestrator",
        "api_version": "v1",
        "base_url": "https://api.example.com/v1/chat",
        "endpoints": [
          {
            "path": "/messages",
            "method": "POST",
            "description": "Procesar mensaje de chat con selección automática de provider",
            "request_schema": {
              "message": "string",
              "context": "object",
              "trace_id": "string"
            },
            "response_schema": {
              "response": "string",
              "provider": "string",
              "latency_ms": "integer"
            },
            "code_examples": {
              "curl": "curl -X POST https://api.example.com/v1/chat/messages \\\n  -H 'Content-Type: application/json' \\\n  -d '{\"message\":\"Hello\",\"trace_id\":\"abc123\"}'",
              "python": "import requests\n\nresponse = requests.post(\n    'https://api.example.com/v1/chat/messages',\n    json={'message': 'Hello', 'trace_id': 'abc123'}\n)\nprint(response.json())",
              "javascript": "const response = await fetch('https://api.example.com/v1/chat/messages', {\n  method: 'POST',\n  headers: {'Content-Type': 'application/json'},\n  body: JSON.stringify({message: 'Hello', trace_id: 'abc123'})\n});\nconst data = await response.json();"
            },
            "error_codes": [
              {
                "code": 400,
                "message": "Invalid message format",
                "resolution": "Ensure message is non-empty string and trace_id is provided"
              },
              {
                "code": 503,
                "message": "All providers unavailable",
                "resolution": "Check provider health endpoints or retry with exponential backoff"
              }
            ]
          }
        ]
      }
    },
    "broken_links_report": {
      "path": "docs/v1/broken_links_report.json",
      "description": "Validación de enlaces internos/externos con auto-fix suggestions",
      "schema": {
        "type": "object",
        "properties": {
          "scan_date": { "type": "string", "format": "date-time" },
          "total_links_checked": { "type": "integer" },
          "broken_links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source_file": { "type": "string" },
                "link": { "type": "string" },
                "type": { "type": "string", "enum": ["internal", "external", "anchor"] },
                "status_code": { "type": "integer" },
                "error": { "type": "string" },
                "suggested_fix": { "type": "string" },
                "auto_fixable": { "type": "boolean" }
              },
              "required": ["source_file", "link", "type"],
              "additionalProperties": false
            }
          },
          "health_score": { "type": "number", "minimum": 0, "maximum": 100 }
        },
        "required": ["scan_date", "total_links_checked", "broken_links", "health_score"],
        "additionalProperties": false
      },
      "example": {
        "scan_date": "2025-10-04T11:00:00Z",
        "total_links_checked": 342,
        "broken_links": [
          {
            "source_file": "/docs/v1/modules/chat/README.md",
            "link": "/docs/modules/old_chat.md",
            "type": "internal",
            "status_code": 404,
            "error": "File not found",
            "suggested_fix": "/docs/v1/modules/chat_orchestrator/README.md",
            "auto_fixable": true
          },
          {
            "source_file": "/docs/v1/api/auth.md",
            "link": "https://old-api.example.com/docs",
            "type": "external",
            "status_code": 404,
            "error": "External link dead",
            "suggested_fix": "https://api.example.com/v1/docs",
            "auto_fixable": false
          }
        ],
        "health_score": 99.4
      }
    },
    "search_index": {
      "path": "docs/v1/search_index.json",
      "description": "Índice full-text para Algolia/MeiliSearch con weighted fields",
      "schema": {
        "type": "object",
        "properties": {
          "index_version": { "type": "string" },
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "objectID": { "type": "string" },
                "title": { "type": "string" },
                "content": { "type": "string" },
                "url": { "type": "string" },
                "category": { "type": "string" },
                "tags": { "type": "array", "items": { "type": "string" } },
                "weight": { "type": "integer", "minimum": 1, "maximum": 10 },
                "last_updated": { "type": "string", "format": "date-time" }
              },
              "required": ["objectID", "title", "content", "url", "category", "weight"],
              "additionalProperties": false
            }
          },
          "searchable_attributes": { "type": "array", "items": { "type": "string" } },
          "ranking_rules": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["index_version", "documents"],
        "additionalProperties": false
      },
      "example": {
        "index_version": "1.1.0",
        "documents": [
          {
            "objectID": "chat_orchestrator_readme",
            "title": "Chat Orchestrator Overview",
            "content": "Chat orchestrator maneja selección automática de AI providers con fallback y circuit breaker...",
            "url": "/docs/v1/modules/chat_orchestrator/README.md",
            "category": "modules",
            "tags": ["core", "ai", "chat"],
            "weight": 10,
            "last_updated": "2025-10-01T14:22:00Z"
          }
        ],
        "searchable_attributes": ["title", "content", "tags", "category"],
        "ranking_rules": ["weight:desc", "typo", "words", "proximity", "attribute", "exact"]
      }
    },
    "architecture_diagrams": {
      "path": "docs/v1/architecture/*.{mmd,svg}",
      "description": "Diagramas C4 Model y Mermaid auto-generados desde dependencies",
      "schema": {
        "type": "object",
        "properties": {
          "diagram_type": { "type": "string", "enum": ["c4_context", "c4_container", "c4_component", "sequence", "flowchart", "erd"] },
          "format": { "type": "string", "enum": ["mermaid", "plantuml", "svg", "png"] },
          "source_data": { "type": "string", "description": "Path to source JSON with dependencies" },
          "auto_generated": { "type": "boolean" },
          "diagrams": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "path": { "type": "string" },
                "description": { "type": "string" }
              },
              "required": ["name", "path"],
              "additionalProperties": false
            }
          }
        },
        "required": ["diagram_type", "format", "auto_generated", "diagrams"],
        "additionalProperties": false
      },
      "example": {
        "diagram_type": "c4_container",
        "format": "mermaid",
        "source_data": "/governance/module_roadmaps/dependencies.json",
