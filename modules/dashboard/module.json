{
  "name": "dashboard",
  "version": "2.0.0",
  "description": "Observability Dashboard - Web UI para monitorear todos los cores",
  "author": "Event Core Team",
  "language": "en",
  "provides": {
    "apis": [
      {
        "name": "cores",
        "method": "GET",
        "path": "/api/cores",
        "description": "Get list of active cores"
      },
      {
        "name": "coreDetail",
        "method": "GET",
        "path": "/api/cores/:id",
        "description": "Get detailed info about specific core"
      },
      {
        "name": "logs",
        "method": "GET",
        "path": "/api/logs/stream",
        "description": "Stream logs in real-time (SSE)"
      },
      {
        "name": "metrics",
        "method": "GET",
        "path": "/api/metrics",
        "description": "Get aggregated metrics from all cores"
      },
      {
        "name": "events",
        "method": "GET",
        "path": "/api/events/stream",
        "description": "Stream events in real-time (SSE)"
      }
    ],
    "hooks": []
  },
  "subscribes": [
    "core/+/logs/#",
    "core/+/events/#",
    "core/+/metrics/#"
  ],
  "requires": {
    "core": ">=0.5.0"
  },
  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "Dashboard",
    "icon": "⚡",
    "description": "Observability Dashboard - Monitor all cores in real-time",
    "views": {
      "main": {
        "type": "dashboard",
        "permissions": [
          "admin",
          "user"
        ],
        "layout": {
          "type": "two-column",
          "config": {
            "leftWidth": "65%",
            "rightWidth": "35%",
            "gap": "var(--space-lg)"
          }
        },
        "header": {
          "title": "⚡ Event Core Dashboard",
          "subtitle": "Real-time monitoring of all cores"
        },
        "sections": [
          {
            "id": "stats",
            "widget": "widget-group",
            "config": {
              "layout": "horizontal",
              "widgets": [
                {
                  "type": "stat-card",
                  "title": "Active Cores",
                  "value": "@data.cores.total",
                  "icon": "🖥️",
                  "color": "primary",
                  "endpoint": "/modules/dashboard/api/cores",
                  "mqtt_topics": [
                    "core/+/heartbeat"
                  ]
                },
                {
                  "type": "stat-card",
                  "title": "Status",
                  "value": "Connected",
                  "icon": "✓",
                  "color": "success"
                }
              ]
            }
          },
          {
            "id": "cores_section",
            "widget": "card",
            "config": {
              "title": "🖥️ Active Cores",
              "actions": [
                {
                  "type": "button",
                  "label": "Refresh",
                  "icon": "↻",
                  "action": "refresh"
                }
              ],
              "content": {
                "type": "grid",
                "endpoint": "/modules/dashboard/api/cores",
                "data_path": "cores",
                "mqtt_topics": [
                  "core/+/heartbeat"
                ],
                "refresh_on_event": true,
                "item_template": {
                  "type": "card",
                  "title": "@item.id",
                  "subtitle": "@item.host:@item.port",
                  "badge": {
                    "text": "@item.version",
                    "color": "info"
                  },
                  "status_indicator": {
                    "field": "is_alive",
                    "true_color": "success",
                    "false_color": "danger"
                  },
                  "fields": [
                    {
                      "label": "Uptime",
                      "value": "@compute.formatDuration(@item.uptime_ms)"
                    },
                    {
                      "label": "Modules",
                      "value": "@compute.count(@item.modules)"
                    },
                    {
                      "label": "Heartbeats",
                      "value": "@item.heartbeat_count"
                    }
                  ]
                }
              }
            }
          },
          {
            "id": "logs_section",
            "widget": "card",
            "config": {
              "title": "📝 Real-time Logs",
              "actions": [
                {
                  "type": "checkbox",
                  "label": "Auto-scroll",
                  "checked": true,
                  "action": "toggle_autoscroll"
                },
                {
                  "type": "button",
                  "label": "Clear",
                  "action": "clear_logs"
                }
              ],
              "content": {
                "type": "log-viewer",
                "sse_endpoint": "/modules/dashboard/api/logs/stream",
                "max_lines": 100,
                "auto_scroll": true,
                "format": "json"
              }
            }
          },
          {
            "id": "events_section",
            "widget": "card",
            "config": {
              "title": "📡 Event Stream",
              "collapsible": true,
              "actions": [
                {
                  "type": "button",
                  "label": "Clear",
                  "action": "clear_events"
                }
              ],
              "content": {
                "type": "event-stream",
                "sse_endpoint": "/modules/dashboard/api/events/stream",
                "max_items": 50,
                "format": "compact"
              }
            }
          },
          {
            "id": "metrics_section",
            "widget": "card",
            "config": {
              "title": "📊 Metrics",
              "content": {
                "type": "metrics-display",
                "endpoint": "/modules/dashboard/api/metrics",
                "refresh_interval": 5000
              }
            }
          }
        ]
      }
    }
  },
  "config": {
    "persistence": {
      "pattern":           "in-memory",
      "restart_resilient": false,
      "concurrency":       "single-writer",
      "lost_on_restart":   ["logBuffer", "eventBuffer", "sseClients", "discovery"]
    }
  }
}
