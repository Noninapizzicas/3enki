{
  "name": "conversation-manager",
  "version": "2.1.0",
  "description": "Facade/Coordinator que mantiene compatibilidad con frontend existente, delegando a chat-session, prompt-composer y chat-ai-bridge",
  "author": "Event Core Team",
  "main": "index.js",
  "deprecated": true,
  "deprecationNote": "Use chat-session, prompt-composer, chat-ai-bridge directly for new development",

  "events": {
    "publishes": [
      {
        "event": "chat.send.request",
        "description": "Delegate send message to chat-ai-bridge"
      },
      {
        "event": "session.create.request",
        "description": "Delegate create conversation to chat-session"
      },
      {
        "event": "session.list.request",
        "description": "Delegate list conversations to chat-session"
      },
      {
        "event": "session.get.request",
        "description": "Delegate get conversation to chat-session"
      },
      {
        "event": "session.update.request",
        "description": "Delegate update conversation to chat-session"
      },
      {
        "event": "session.delete.request",
        "description": "Delegate delete conversation to chat-session"
      },
      {
        "event": "session.messages.request",
        "description": "Delegate get messages to chat-session"
      },
      {
        "event": "session.context.load.request",
        "description": "Delegate load context to chat-session"
      },
      {
        "event": "session.context.toggle.request",
        "description": "Delegate toggle context to chat-session"
      },
      {
        "event": "session.context.stats.request",
        "description": "Delegate context stats to chat-session"
      },
      {
        "event": "project.active.request",
        "description": "Request active project from project-manager"
      }
    ],
    "subscribes": [
      {
        "event": "chat.send.response",
        "description": "Response from chat-ai-bridge",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.create.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.list.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.get.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.update.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.delete.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.messages.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.context.load.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.context.toggle.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "session.context.stats.response",
        "description": "Response from chat-session",
        "handler": "onDelegatedResponse"
      },
      {
        "event": "project.active.response",
        "description": "Response from project-manager",
        "handler": "onDelegatedResponse"
      }
    ]
  },

  "ui": {
    "zone": "chat",
    "icon": "💬",
    "handlers": {
      "domain": "conversation",
      "actions": ["send", "load", "create", "list", "get", "update", "delete", "toggleContext", "contextStats"]
    }
  },

  "dependencies": [
    "chat-session",
    "chat-ai-bridge",
    "project-manager"
  ],

  "config": {
    "requestTimeout": 30000,
    "chatTimeout": 180000
  }
}
