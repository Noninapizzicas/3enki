  "proposed_flow": {
    "description": "Flujo PROPUESTO (tools centralizados en ai-gateway)",
    "option_a": {
      "name": "Tools en ai-gateway (recomendado)",
      "description": "ai-gateway maneja todo el ciclo de tools internamente",
      "diagram": [
        "conversation-manager.handleUISend()",
        "    │",
        "    └─► eventBus.publish('chat.send.request', { conversationId, content })",
        "              │",
        "              ▼",
        "        chat-ai-bridge.onChatSendRequest()",
        "              │",
        "              ├─► session.save.request → chat-session (guarda user msg)",
        "              ├─► prompt.compose.request → prompt-composer",
        "              │",
        "              └─► eventBus.publish('ai.chat.request', {",
        "                    messages,",
        "                    tools: true,        ◄── Solo flag, ai-gateway carga tools",
        "                    execute_tools: true ◄── ai-gateway ejecuta el loop",
        "                  })",
        "                        │",
        "                        ▼",
        "                  ai-gateway.onAIChatRequest()",
        "                        │",
        "                        ├─► getAvailableTools() ◄── Centralizado aquí",
        "                        ├─► translateToolsForProvider()",
        "                        ├─► chatWithRetry() → LLM",
        "                        │",
        "                        ├─► Si tool_calls y execute_tools:",
        "                        │     executeToolCalls() ◄── Centralizado aquí",
        "                        │     formatToolResultsForProvider()",
        "                        │     LOOP interno hasta max_iterations",
        "                        │",
        "                        └─► eventBus.publish('ai.chat.response', {",
        "                              content: 'respuesta final',",
        "                              tool_calls_executed: [...],",
        "                              iterations: 3",
        "                            })",
        "                                  │",
        "                                  ▼",
        "                  chat-ai-bridge recibe respuesta final",
        "                        │",
        "                        └─► session.save.request (guarda assistant msg)"
      ],
      "benefits": [
        "Elimina ~400 líneas duplicadas de conversation-manager",
        "ai-gateway ya tiene la lógica de tools por provider",
        "Un solo lugar para mantener compatibilidad con providers",
        "chat-ai-bridge se simplifica enormemente"
      ]
    },
    "option_b": {
      "name": "Tools en chat-ai-bridge",
      "description": "Mantener tool loop en chat-ai-bridge, eliminar de ai-gateway",
      "when_to_use": "Si se necesita control granular del loop desde el chat"
    }
  },
