{
  "name": "cuentas",
  "version": "3.0.0",
  "description": "Gestion de cuentas con ciclo de vida completo (POS ticket lifecycle) — 100% Event-Driven. State machine de 7 estados orquestando items + cocina + cobro.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "provides": {
    "events": [
      "cuenta.creada",
      "cuenta.actualizada",
      "cuenta.eliminada",
      "cuenta.estado_cambiado"
    ]
  },
  "events": {
    "publishes": [
      {
        "event":       "cuenta.creada",
        "description": "Nueva cuenta creada (incluye turno + ref_display + project_id top-level + correlation_id + timestamp).",
        "schema":      { "$ref": "./schemas/events.json#/definitions/cuenta_creada" }
      },
      {
        "event":       "cuenta.actualizada",
        "description": "Cuenta actualizada (cambios diff: items/total/estado/alerta/pagado/nombre/ref_display).",
        "schema":      { "$ref": "./schemas/events.json#/definitions/cuenta_actualizada" }
      },
      {
        "event":       "cuenta.estado_cambiado",
        "description": "Transicion de estado de cuenta (estado_anterior → estado_nuevo).",
        "schema":      { "$ref": "./schemas/events.json#/definitions/cuenta_estado_cambiado" }
      },
      {
        "event":       "cuenta.eliminada",
        "description": "Cuenta eliminada (motivo: eliminacion_manual | cobro_completado | cuenta_cerrada_canal).",
        "schema":      { "$ref": "./schemas/events.json#/definitions/cuenta_eliminada" }
      },
      {
        "event":       "comandero.enviar_cocina",
        "description": "Cross-modulo: emitido por _inyectarPedidoInicial para integraciones delivery (Glovo, Llevadoo, webhooks externos). Pedidos lo recoge y crea el pedido formal."
      }
    ],
    "subscribes": [
      { "event": "comandero.item_agregado",    "handler": "onComanderoItemAgregado",    "description": "Item agregado al buffer del comandero — actualizar totales, transicionar a con_pedido si era el primero." },
      { "event": "comandero.item_eliminado",   "handler": "onComanderoItemEliminado",   "description": "Item eliminado — ajustar totales, regresar a pendiente si items=0." },
      { "event": "comandero.item_actualizado", "handler": "onComanderoItemActualizado", "description": "Cantidad de item modificada (+/-) — ajustar items/total con diff." },
      { "event": "comandero.enviar_cocina",    "handler": "onComanderoEnviarCocina",    "description": "Envio a cocina — transicionar a en_preparacion + registrar pedido en tracking." },
      { "event": "cocina.pedido_listo",        "handler": "onCocinaPedidoListo",        "description": "Pedido listo en cocina — transicionar a listo cuando todos los pedidos de la cuenta terminaron." },
      { "event": "cobro.iniciado",             "handler": "onCobroIniciado",            "description": "Cobro iniciado — transicionar a para_cobrar (excepto pago_externo)." },
      { "event": "cobro.procesado",            "handler": "onCobroProcesado",           "description": "Cobro procesado — marcar pagado e idempotente; transicionar a cobrado segun flags." },
      { "event": "cuenta.cerrada",             "handler": "onCuentaExternaCerrada",     "description": "Cuenta cerrada desde canal externo (cuentas-canales) — limpiar Map + cancelar timers." }
    ]
  },
  "ui_handlers": [
    { "domain": "cuenta", "action": "create",            "handler": "handleCreateCuenta",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cuenta", "action": "list",              "handler": "handleListCuentas",    "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cuenta", "action": "get",               "handler": "handleGetCuenta",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cuenta", "action": "delete",            "handler": "handleDeleteCuenta",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cuenta", "action": "marcar_entregado",  "handler": "handleMarcarEntregado","type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cuenta", "action": "rename",            "handler": "handleRenameCuenta",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cuenta", "action": "stats",             "handler": "handleGetStats",       "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cuenta", "action": "health",            "handler": "handleHealthCheck",    "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cuenta", "action": "metrics",           "handler": "handleGetMetrics",     "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [],
  "config": {
    "max_cuentas_activas": 100,
    "auto_numeracion":     true,
    "persistence": {
      "type":   "json-file",
      "atomic": true,
      "paths": [
        "data/current/contador_global.json",
        "data/current/cuentas_activas.json"
      ],
      "owner":       "modules/pizzepos/cuentas (contador) + persistencia-comandero (cuentas)",
      "concurrency": "single-writer-per-archivo",
      "notes":       "Modulo persiste contador global de turnos atomicamente; cuentas se restauran en onLoad desde cuentas_activas.json (escrito por persistencia-comandero)."
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level":          "info",
      "structured":     true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "cuenta.creada.total",
        "cuenta.eliminada.total",
        "cuenta.transicion.total",
        "cuenta.errors.total",
        "pizzepos-cuentas.errors"
      ],
      "gauges": [
        "cuenta.activas.count",
        "cuenta.por_tipo.local",
        "cuenta.por_tipo.delivery",
        "cuenta.por_tipo.llevar",
        "cuenta.por_estado.pendiente",
        "cuenta.por_estado.con_pedido",
        "cuenta.por_estado.en_preparacion",
        "cuenta.por_estado.listo",
        "cuenta.por_estado.entregado",
        "cuenta.por_estado.para_cobrar",
        "cuenta.por_estado.cobrado",
        "cuenta.alertas.count"
      ],
      "timings": [
        "cuenta.create.duration",
        "cuenta.list.duration"
      ]
    }
  },
  "ui": {
    "enabled":         true,
    "title":           "Cuentas Activas",
    "icon":            "📋",
    "description":     "Pantalla principal — Gestion de mesas, delivery y para llevar",
    "access_level":    "camarero",
    "is_main_screen":  true,
    "components":      ["cuenta-grid", "cuenta-card", "cuenta-type-button"],
    "mqtt": {
      "enabled":      true,
      "topics":       ["cuenta.creada", "cuenta.actualizada", "cuenta.eliminada", "cuenta.estado_cambiado"],
      "auto_refresh": true
    }
  }
}
