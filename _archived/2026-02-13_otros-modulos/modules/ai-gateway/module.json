{
  "name": "ai-gateway",
  "version": "2.1.0",
  "description": "Gateway unificado para múltiples proveedores LLM - 100% Event-Driven con credential-manager integration",
  "author": "Pizzepos Team",

  "dependencies": {
    "modules": ["credential-manager"],
    "optional": true,
    "fallback": "process.env for API keys"
  },

  "provides": {
    "events": ["ai.response", "ai.error"],
    "queries": ["ai.providers", "ai.usage"]
  },

  "events": {
    "publishes": [
      {
        "event": "ai.response",
        "description": "Respuesta de procesamiento IA exitosa",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/ai_response"
        }
      },
      {
        "event": "ai.error",
        "description": "Error en procesamiento IA",
        "schema": {
          "$ref": "./schemas/events.json#/definitions/ai_error"
        }
      },
      {
        "event": "credential.resolve.request",
        "description": "Request credential resolution from credential-manager",
        "schema": {
          "type": "object",
          "properties": {
            "key": { "type": "string" },
            "context": { "type": "object" }
          }
        }
      }
    ],
    "subscribes": [
      {
        "event": "ai.request",
        "description": "Solicitud de procesamiento IA",
        "handler": "onAIRequest"
      },
      {
        "event": "credential.saved",
        "description": "Credential saved - hot-reload API keys",
        "handler": "onCredentialSaved"
      },
      {
        "event": "credential.updated",
        "description": "Credential updated - hot-reload API keys",
        "handler": "onCredentialUpdated"
      },
      {
        "event": "credential.deleted",
        "description": "Credential deleted - hot-reload API keys",
        "handler": "onCredentialDeleted"
      },
      {
        "event": "credential.resolve.response",
        "description": "Credential resolution response from credential-manager",
        "handler": "handleCredentialResponse"
      }
    ]
  },

  "apis": [
    {
      "method": "POST",
      "path": "/chat",
      "handler": "handleChatCompletion",
      "description": "Chat completion directo (también publica ai.response)",
      "request_schema": {
        "$ref": "./schemas/ai.json#/definitions/chat_request"
      },
      "response_schema": {
        "$ref": "./schemas/ai.json#/definitions/chat_response"
      }
    },
    {
      "method": "GET",
      "path": "/providers",
      "handler": "handleListProviders",
      "description": "Listar proveedores disponibles"
    },
    {
      "method": "GET",
      "path": "/models",
      "handler": "handleListModels",
      "description": "Listar modelos por proveedor"
    },
    {
      "method": "GET",
      "path": "/usage",
      "handler": "handleGetUsage",
      "description": "Estadísticas de uso y costos"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Métricas del módulo"
    }
  ],

  "providers": {
    "deepseek": {
      "enabled": true,
      "priority": 1,
      "api_base": "https://api.deepseek.com/v1",
      "models": ["deepseek-chat", "deepseek-coder"],
      "default_model": "deepseek-chat",
      "cost_per_1k_tokens": {
        "input": 0.0001,
        "output": 0.0002
      }
    },
    "anthropic": {
      "enabled": true,
      "priority": 2,
      "api_base": "https://api.anthropic.com/v1",
      "models": ["claude-3-5-sonnet-20241022"],
      "default_model": "claude-3-5-sonnet-20241022",
      "cost_per_1k_tokens": {
        "input": 0.003,
        "output": 0.015
      }
    },
    "openai": {
      "enabled": true,
      "priority": 3,
      "api_base": "https://api.openai.com/v1",
      "models": ["gpt-4o-mini"],
      "default_model": "gpt-4o-mini",
      "cost_per_1k_tokens": {
        "input": 0.0015,
        "output": 0.006
      }
    },
    "ollama": {
      "enabled": false,
      "priority": 4,
      "api_base": "http://localhost:11434/api",
      "models": ["llama2"],
      "default_model": "llama2",
      "cost_per_1k_tokens": {
        "input": 0.0,
        "output": 0.0
      }
    }
  },

  "options": {
    "retry": {
      "max_attempts": 3,
      "initial_delay_ms": 1000,
      "backoff_multiplier": 2
    },
    "fallback": {
      "enabled": true,
      "strategy": "priority"
    },
    "timeout_ms": 60000
  },

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "ai.request.total",
        "ai.response.total",
        "ai.error.total",
        "ai.tokens.total"
      ],
      "gauges": [
        "ai.providers.active",
        "ai.cost.total"
      ],
      "timings": [
        "ai.request.duration"
      ]
    }
  }
}
