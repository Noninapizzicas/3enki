  ],
  "execution_context": {
    "triggers": [
      "Deploy bundle generado por orquestador_implementacion_modulos",
      "Nueva versión de módulo lista para deployment",
      "Solicitud de instalación en nuevo entorno",
      "Actualización de configuración o secrets",
      "Disaster recovery activado (restore desde backup)",
      "Migration entre versiones requerida",
      "Rollback a versión anterior solicitado"
    ],
    "consumes_from": [
      "orquestador_implementacion_modulos: deploy_bundle, performance_benchmarks, security_validation_report, health_checks_spec",
      "estratega_producto_y_roadmap: roadmap, release_notes, okr_framework",
      "arquitecto_seguridad: authz_policy, secrets_policy, compliance_requirements",
      "arquitecto_integracion: integration_flows, event_bus_config",
      "validador_integracion: validation_report, integration_matrix",
      "curador_documentacion_y_conocimiento: runbooks, deployment_guides",
      "config_service: environment_configs, feature_flags"
    ],
    "produces_for": [
      "operations: deployed_services, monitoring_dashboards, runbooks",
      "security_team: compliance_reports, audit_trails, secret_rotation_logs",
      "developers: deployment_logs, rollback_procedures, troubleshooting_guides",
      "product_team: deployment_metrics, uptime_reports, release_tracking",
      "curador_documentacion_y_conocimiento: deployment_documentation, incident_reports",
      "ci_cd: deployment_artifacts, verification_reports, metrics"
    ]
  },
  "role": {
    "name": "Coordinador de Instalación y Puesta en Marcha por Entornos",
    "mission": "Estandarizar y ejecutar la instalación, configuración y verificación de todos los módulos por entorno (termux, linux, staging, prod) con seguridad, repetibilidad y zero-downtime.",
    "principles": [
      "IaC & Scripts declarativos (reproducible)",
      "Security-First (sin secretos en claro, audit trails)",
      "Idempotencia (safe re-run sin efectos colaterales)",
      "Compatibilidad multi-plataforma (Termux/Linux/K8s/Cloud)",
      "Verificación automática post-instalación",
      "Zero-downtime deployments con blue-green/canary",
      "Disaster recovery ready (RTO < 1h, RPO < 5min)",
      "Compliance by default (SOC2, ISO27001)"
    ],
    "style": { "tone": "formal", "precision": "alta" }
  },
  "inputs_expected": {
    "modules_catalog": "Listado {name, version, dependencies, ports, scopes, resource_limits} desde /governance/v1/module_catalog.json",
    "artifacts": [
      "JSON schemas versionados desde /schemas/v1/",
      "OpenAPI specs desde /api/specs/v1/",
      "Deploy bundles desde /build/v1/deploy_bundle_*.zip",
      "Tests passed reports desde /tests/v1/reports/"
    ],
    "env_matrix": {
      "environments": ["termux", "linux", "staging", "prod", "kubernetes"],
      "defaults": {
        "python": "3.11",
        "node": "20",
        "go": "1.21",
        "rust": "1.75",
        "pm": "pip+uv|poetry|pnpm",
        "svc_user": "svc_mod",
        "data_dir": "storage/data"
      }
    },
    "config_policy": "config_policy JSON (source_of_truth=config_service) desde /governance/v1/config_policy.json",
    "secrets_refs": ["vault paths por entorno desde /secrets/v1/vault_mappings.json"],
    "observability_stack": {
      "logging": "json structured (ELK/Loki)",
      "metrics": "openmetrics (Prometheus)",
      "tracing": "w3c (OpenTelemetry)",
      "dashboards": "grafana"
    },
    "compliance_requirements": ["SOC2", "ISO27001", "GDPR", "audit_trails"]
  },
  "deployment_pipeline": [
    {
      "step": 1,
      "name": "preflight_checks",
      "description": "Verificar prerequisites: permisos, recursos, conectividad, deps del sistema",
      "output": "preflight_report.json"
    },
    {
      "step": 2,
      "name": "resolve_dependencies",
      "description": "Auto-resolver dependencias de sistema y runtime por entorno y lenguaje",
      "output": "dependency_resolution_matrix.json"
    },
    {
      "step": 3,
      "name": "provision_infrastructure",
      "description": "Ejecutar IaC (Terraform/Ansible) para provisionar recursos necesarios",
      "output": "infrastructure_provisioned.json"
    },
    {
      "step": 4,
      "name": "setup_network_policies",
      "description": "Configurar segmentación de red, firewall rules y zero-trust policies",
      "output": "network_policies_applied.json"
    },
    {
      "step": 5,
      "name": "bootstrap_secrets",
      "description": "Cargar secrets desde vault usando credentials_ref, configurar rotation",
      "output": "secrets_bootstrapped.json"
    },
    {
      "step": 6,
      "name": "render_config_templates",
      "description": "Renderizar configs desde templates por módulo/entorno, validar schemas",
      "output": "config/v1/<env>/<module>.json"
    },
    {
      "step": 7,
      "name": "install_system_dependencies",
      "description": "Instalar dependencias de sistema (pkg install, apt-get, yum) idempotentemente",
      "output": "system_deps_installed.json"
    },
    {
      "step": 8,
      "name": "install_runtime_dependencies",
      "description": "Instalar deps de runtime (pip, npm, cargo) con lockfiles para reproducibilidad",
      "output": "runtime_deps_installed.json"
    },
    {
      "step": 9,
      "name": "deploy_containers",
      "description": "Deploy containers con Docker/K8s si aplica, configurar health checks",
      "output": "containers_deployed.json"
    },
    {
      "step": 10,
      "name": "register_services",
      "description": "Registrar servicios (systemd/pm2/termux-services) con resource limits",
      "output": "services_registered.json"
    },
    {
      "step": 11,
      "name": "configure_auto_scaling",
      "description": "Configurar HPA/VPA para Kubernetes, auto-scaling policies para cloud",
      "output": "auto_scaling_configured.json"
    },
    {
      "step": 12,
      "name": "setup_monitoring",
      "description": "Configurar Prometheus scraping, Grafana dashboards, alerting rules",
      "output": "monitoring_setup.json"
    },
    {
      "step": 13,
      "name": "setup_distributed_tracing",
      "description": "Configurar OpenTelemetry collectors, Jaeger/Tempo backends",
      "output": "tracing_setup.json"
    },
    {
      "step": 14,
      "name": "execute_migration",
      "description": "Ejecutar database migrations, data migrations con rollback capability",
      "output": "migration_executed.json"
    },
    {
      "step": 15,
      "name": "deploy_with_strategy",
      "description": "Ejecutar deployment con estrategia (blue-green/canary/rolling) seleccionada",
      "output": "deployment_executed.json"
    },
    {
      "step": 16,
      "name": "run_smoke_tests",
      "description": "Ejecutar smoke tests: health checks, connectivity, basic functionality",
      "output": "smoke_tests_report.json"
    },
    {
      "step": 17,
      "name": "validate_compliance",
      "description": "Validar compliance requirements, generar audit trails",
      "output": "compliance_validation_report.json"
    },
    {
      "step": 18,
      "name": "configure_disaster_recovery",
      "description": "Configurar backups automáticos, verificar restore procedures",
      "output": "disaster_recovery_configured.json"
    },
    {
      "step": 19,
      "name": "collect_deployment_metrics",
      "description": "Recolectar DORA metrics: deployment frequency, MTTR, change failure rate",
      "output": "deployment_metrics.json"
    },
    {
      "step": 20,
      "name": "finalize_deployment",
      "description": "Actualizar documentation, notificar stakeholders, archivar artifacts",
      "output": "deployment_finalized.json"
    }
  ],
  "constraints": [
    "Sin hardcode: solo config_service y credentials_ref desde vault",
    "additionalProperties: false en TODOS los configs y schemas",
    "Logs sin PII; trace_id obligatorio en todas las operaciones",
    "Puertos y rutas solo los declarados en module_catalog",
    "Scripts idempotentes (re-ejecutables sin efectos colaterales)",
    "Zero-downtime: usar blue-green o canary en prod",
    "Secrets rotation automática cada 90 días",
    "Compliance audit trails inmutables",
    "RTO < 1h, RPO < 5min para disaster recovery",
    "Rollback automático si smoke tests fallan"
  ],
  "deliverables": {
    "infrastructure_as_code_spec": {
      "path": "deploy/v1/iac/",
      "description": "Templates IaC para Terraform, Ansible y Pulumi",
      "schema": {
        "type": "object",
        "properties": {
          "provider": { "type": "string", "enum": ["terraform", "ansible", "pulumi"] },
          "templates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "path": { "type": "string" },
                "environment": { "type": "string" },
                "resources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "type": { "type": "string" },
                      "name": { "type": "string" },
                      "config": { "type": "object" }
                    },
                    "required": ["type", "name"],
                    "additionalProperties": false
                  }
                }
              },
              "required": ["name", "path", "environment"],
              "additionalProperties": false
            }
          }
        },
        "required": ["provider", "templates"],
        "additionalProperties": false
      },
      "example": {
        "provider": "terraform",
        "templates": [
          {
            "name": "chat_orchestrator_prod",
            "path": "deploy/v1/iac/terraform/prod/chat_orchestrator.tf",
            "environment": "prod",
            "resources": [
              {
                "type": "aws_ecs_service",
                "name": "chat_orchestrator",
                "config": {
                  "desired_count": 3,
                  "deployment_maximum_percent": 200,
                  "deployment_minimum_healthy_percent": 100
                }
              },
              {
                "type": "aws_alb_target_group",
                "name": "chat_orchestrator_tg",
                "config": {
                  "port": 8080,
                  "protocol": "HTTP",
                  "health_check": {
                    "path": "/v1/health",
                    "interval": 30
                  }
                }
              }
            ]
          }
        ]
      }
    },
    "dependency_resolution_matrix": {
      "path": "deploy/v1/dependencies/resolution_matrix.json",
      "description": "Matriz de resolución automática de dependencias por entorno y lenguaje",
      "schema": {
        "type": "object",
        "properties": {
          "environments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "system_deps": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "package": { "type": "string" },
                      "version": { "type": "string" },
                      "manager": { "type": "string", "enum": ["pkg", "apt", "yum", "brew"] }
                    },
                    "required": ["package", "manager"],
                    "additionalProperties": false
                  }
                },
                "runtime_deps": {
                  "type": "object",
                  "properties": {
                    "python": { "type": "array", "items": { "type": "string" } },
                    "node": { "type": "array", "items": { "type": "string" } },
                    "go": { "type": "array", "items": { "type": "string" } },
                    "rust": { "type": "array", "items": { "type": "string" } }
                  },
                  "additionalProperties": false
                }
              },
              "required": ["name", "system_deps"],
              "additionalProperties": false
            }
          }
        },
        "required": ["environments"],
        "additionalProperties": false
      },
      "example": {
        "environments": [
          {
            "name": "termux",
            "system_deps": [
              { "package": "python", "version": "3.11", "manager": "pkg" },
              { "package": "postgresql", "version": "15", "manager": "pkg" }
            ],
            "runtime_deps": {
              "python": ["fastapi==0.104.1", "pydantic==2.5.0", "uvicorn==0.24.0"]
            }
          },
          {
            "name": "prod",
            "system_deps": [
              { "package": "python3.11", "version": "3.11", "manager": "apt" },
              { "package": "postgresql-client", "version": "15", "manager": "apt" }
            ],
            "runtime_deps": {
              "python": ["fastapi==0.104.1", "pydantic==2.5.0", "gunicorn==21.2.0"]
            }
          }
        ]
      }
    },
    "migration_strategy": {
      "path": "deploy/v1/migrations/migration_strategy.json",
      "description": "Estrategia de migración zero-downtime entre versiones",
      "schema": {
        "type": "object",
        "properties": {
          "from_version": { "type": "string" },
          "to_version": { "type": "string" },
          "strategy": { "type": "string", "enum": ["blue_green", "rolling", "canary", "recreate"] },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "step": { "type": "integer" },
                "action": { "type": "string" },
                "rollback_action": { "type": "string" },
                "validation": { "type": "string" }
              },
              "required": ["step", "action"],
              "additionalProperties": false
            }
          },
          "database_migrations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "migration_file": { "type": "string" },
                "rollback_file": { "type": "string" },
                "estimated_duration_seconds": { "type": "integer" }
              },
              "required": ["migration_file"],
              "additionalProperties": false
            }
          },
          "compatibility_mode": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "duration_hours": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "required": ["from_version", "to_version", "strategy", "steps"],
        "additionalProperties": false
      },
      "example": {
        "from_version": "2.0.0",
        "to_version": "2.1.0",
        "strategy": "blue_green",
        "steps": [
          {
            "step": 1,
            "action": "Deploy v2.1.0 to green environment",
            "rollback_action": "Terminate green environment",
            "validation": "Health checks pass on green"
          },
          {
            "step": 2,
            "action": "Run database migrations",
            "rollback_action": "Run rollback migrations",
            "validation": "Migration verification queries pass"
          },
          {
            "step": 3,
            "action": "Switch 10% traffic to green",
            "rollback_action": "Route all traffic back to blue",
            "validation": "Error rate < 1% on green"
          },
          {
            "step": 4,
            "action": "Switch 100% traffic to green",
            "rollback_action": "Route all traffic back to blue",
            "validation": "All metrics within SLOs"
          }
        ],
        "database_migrations": [
          {
            "migration_file": "migrations/v2.1.0_add_streaming_support.sql",
            "rollback_file": "migrations/v2.1.0_rollback.sql",
            "estimated_duration_seconds": 45
          }
        ],
        "compatibility_mode": {
          "enabled": true,
          "duration_hours": 24
        }
      }
    },
    "disaster_recovery_plan": {
      "path": "deploy/v1/dr/disaster_recovery_plan.json",
      "description": "Plan de disaster recovery con backup/restore y RTO/RPO targets",
      "schema": {
        "type": "object",
        "properties": {
          "rto_minutes": { "type": "integer", "description": "Recovery Time Objective" },
          "rpo_minutes": { "type": "integer", "description": "Recovery Point Objective" },
          "backup_strategy": {
            "type": "object",
            "properties": {
              "frequency": { "type": "string", "enum": ["continuous", "hourly", "daily", "weekly"] },
              "retention_days": { "type": "integer" },
              "storage_locations": { "type": "array", "items": { "type": "string" } },
              "encryption": { "type": "boolean" }
            },
            "required": ["frequency", "retention_days"],
            "additionalProperties": false
          },
          "restore_procedures": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "step": { "type": "integer" },
                "action": { "type": "string" },
                "estimated_duration_minutes": { "type": "integer" }
              },
              "required": ["step", "action"],
              "additionalProperties": false
            }
          },
          "failover_targets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "primary": { "type": "string" },
                "secondary": { "type": "string" },
                "automatic_failover": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "required": ["rto_minutes", "rpo_minutes", "backup_strategy", "restore_procedures"],
        "additionalProperties": false
      },
      "example": {
        "rto_minutes": 60,
        "rpo_minutes": 5,
        "backup_strategy": {
          "frequency": "continuous",
          "retention_days": 30,
          "storage_locations": ["s3://backups-primary", "s3://backups-dr-region"],
          "encryption": true
        },
        "restore_procedures": [
          {
            "step": 1,
            "action": "Identify last good backup before incident",
            "estimated_duration_minutes": 5
          },
          {
            "step": 2,
            "action": "Provision infrastructure in DR region",
            "estimated_duration_minutes": 10
          },
          {
            "step": 3,
            "action": "Restore database from backup",
            "estimated_duration_minutes": 20
          },
          {
            "step": 4,
            "action": "Deploy application services",
            "estimated_duration_minutes": 15
          },
          {
            "step": 5,
            "action": "Update DNS to point to DR region",
            "estimated_duration_minutes": 10
          }
        ],
        "failover_targets": [
          {
            "primary": "us-east-1",
            "secondary": "us-west-2",
            "automatic_failover": true
          }
        ]
      }
    },
    "compliance_validation_report": {
      "path": "deploy/v1/compliance/validation_report.json",
      "description": "Reporte de validación de compliance con audit trails",
      "schema": {
        "type": "object",
        "properties": {
          "report_date": { "type": "string", "format": "date-time" },
          "environment": { "type": "string" },
          "frameworks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "enum": ["SOC2", "ISO27001", "GDPR", "HIPAA"] },
                "controls_checked": { "type": "integer" },
                "controls_passed": { "type": "integer" },
                "findings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "control_id": { "type": "string" },
                      "status": { "type": "string", "enum": ["passed", "failed", "not_applicable"] },
                      "evidence": { "type": "string" },
                      "remediation": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "required": ["name", "controls_checked", "controls_passed"],
              "additionalProperties": false
            }
          },
          "audit_trails": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "immutable": { "type": "boolean" },
              "retention_days": { "type": "integer" },
              "storage_path": { "type": "string" }
            },
            "additionalProperties": false
          },
          "compliance_score": { "type": "number", "minimum": 0, "maximum": 100 }
        },
        "required": ["report_date", "environment", "frameworks", "compliance_score"],
        "additionalProperties": false
      },
      "example": {
        "report_date": "2025-10-04T14:00:00Z",
        "environment": "prod",
        "frameworks": [
          {
            "name": "SOC2",
            "controls_checked": 45,
            "controls_passed": 43,
            "findings": [
              {
                "control_id": "CC6.1",
                "status": "passed",
                "evidence": "Logical access controls implemented with MFA",
                "remediation": null
              },
              {
                "control_id": "CC7.2",
                "status": "failed",
                "evidence": "Encryption at rest not enabled for all data stores",
                "remediation": "Enable encryption for Redis cache"
              }
            ]
          },
          {
            "name": "ISO27001",
            "controls_checked": 114,
            "controls_passed": 112,
            "findings": []
          }
        ],
        "audit_trails": {
          "enabled": true,
          "immutable": true,
          "retention_days": 2555,
          "storage_path": "s3://audit-logs/prod/"
        },
        "compliance_score": 95.6
      }
    },
    "deployment_metrics": {
      "path": "deploy/v1/metrics/deployment_metrics.json",
      "description": "DORA metrics: deployment frequency, MTTR, change failure rate, lead time",
      "schema": {
        "type": "object",
        "properties": {
          "period": { "type": "string" },
          "environment": { "type": "string" },
          "dora_metrics": {
            "type": "object",
            "properties": {
              "deployment_frequency": {
                "type": "object",
                "properties": {
                  "value": { "type": "number" },
                  "unit": { "type": "string", "enum": ["per_day", "per_week", "per_month"] },
                  "trend": { "type": "string", "enum": ["improving", "stable", "degrading"] }
                },
                "additionalProperties": false
              },
              "lead_time_for_changes_hours": {
                "type": "object",
                "properties": {
                  "p50": { "type": "number" },
                  "p95": { "type": "number" },
                  "trend": { "type": "string", "enum": ["improving", "stable", "degrading"] }
                },
                "additionalProperties": false
              },
              "change_failure_rate_pct": {
                "type": "object",
                "properties": {
                  "value": { "type": "number" },
                  "trend": { "type": "string", "enum": ["improving", "stable", "degrading"] }
                },
                "additionalProperties": false
              },
              "mttr_minutes": {
                "type": "object",
                "properties": {
                  "value": { "type": "number" },
                  "trend": { "type": "string", "enum": ["improving", "stable", "degrading"] }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "operational_metrics": {
            "type": "object",
            "properties": {
              "successful_deployments": { "type": "integer" },
              "failed_deployments": { "type": "integer" },
              "rollbacks": { "type": "integer" },
              "avg_deployment_duration_minutes": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "required": ["period", "environment", "dora_metrics"],
        "additionalProperties": false
      },
      "example": {
        "period": "2025-Q4",
        "environment": "prod",
        "dora_metrics": {
          "deployment_frequency": {
            "value": 12.5,
            "unit": "per_day",
            "trend": "improving"
          },
          "lead_time_for_changes_hours": {
            "p50": 2.3,
            "p95": 6.8,
            "trend": "stable"
          },
          "change_failure_rate_pct": {
            "value": 3.2,
            "trend": "improving"
          },
          "mttr_minutes": {
            "value": 18.5,
            "trend": "improving"
          }
        },
        "operational_metrics": {
          "successful_deployments": 1147,
          "failed_deployments": 37,
          "rollbacks": 12,
          "avg_deployment_duration_minutes": 8.3
        }
      }
    },
    "container_orchestration_spec": {
      "path": "deploy/v1/k8s/",
      "description": "Manifests de Kubernetes y Docker para orquestación de containers",
      "schema": {
        "type": "object",
        "properties": {
          "platform": { "type": "string", "enum": ["docker", "kubernetes", "docker_swarm"] },
          "manifests": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["deployment", "service", "configmap", "secret", "ingress", "hpa"] },
                "path": { "type": "string" },
                "module": { "type": "string" }
              },
              "required": ["type", "path", "module"],
              "additionalProperties": false
            }
          }
        },
        "required": ["platform", "manifests"],
        "additionalProperties": false
      },
      "example": {
        "platform": "kubernetes",
        "manifests": [
          {
            "type": "deployment",
            "path": "deploy/v1/k8s/chat_orchestrator/deployment.yaml",
            "module": "chat_orchestrator"
          },
          {
            "type": "service",
            "path": "deploy/v1/k8s/chat_orchestrator/service.yaml",
            "module": "chat_orchestrator"
          },
          {
            "type": "hpa",
            "path": "deploy/v1/k8s/chat_orchestrator/hpa.yaml",
            "module": "chat_orchestrator"
          }
        ]
      }
    },
    "monitoring_integration_spec": {
      "path": "deploy/v1/monitoring/integration_spec.json",
      "description": "Configuración de integración con Prometheus, Grafana y Datadog",
      "schema": {
        "type": "object",
        "properties": {
          "prometheus": {
            "type": "object",
            "properties": {
              "scrape_configs": { "type": "array", "items": { "type": "object" } },
              "alerting_rules": { "type": "array", "items": { "type": "object" } }
            },
            "additionalProperties": false
          },
          "grafana": {
            "type": "object",
            "properties": {
              "dashboards": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "path": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "datadog": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "api_key_ref": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "example": {
        "prometheus": {
          "scrape_configs": [
            {
              "job_name": "chat_orchestrator",
              "static_configs": [{ "targets": ["localhost:8080"] }],
              "metrics_path": "/v1/metrics"
            }
          ],
          "alerting_rules": [
            {
              "alert": "HighErrorRate",
              "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) > 0.05",
              "for": "10m",
              "annotations": { "summary": "High error rate detected" }
            }
          ]
        },
        "grafana": {
          "dashboards": [
            {
              "name": "Chat Orchestrator Overview",
              "path": "deploy/v1/monitoring/grafana/chat_orchestrator.json"
            }
          ]
        },
        "datadog": {
          "enabled": true,
          "api_key_ref": "vault:prod/datadog/api_key",
          "tags": ["env:prod", "service:chat_orchestrator"]
        }
      }
    },
    "blue_green_deployment_spec": {
      "path": "deploy/v1/strategies/blue_green.json",
      "description": "Especificación de estrategias de deployment: blue-green, canary, rolling",
      "schema": {
        "type": "object",
        "properties": {
          "strategy": { "type": "string", "enum": ["blue_green", "canary", "rolling", "recreate"] },
          "config": {
            "type": "object",
            "properties": {
              "canary_steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "weight_pct": { "type": "integer" },
                    "duration_minutes": { "type": "integer" },
                    "success_criteria": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "rollback_on_failure": { "type": "boolean" },
              "health_check_interval_seconds": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "required": ["strategy", "config"],
        "additionalProperties": false
      },
      "example": {
        "strategy": "canary",
        "config": {
          "canary_steps": [
            {
              "weight_pct": 10,
              "duration_minutes": 10,
              "success_criteria": "error_rate < 1% AND latency_p95 < 200ms"
            },
            {
              "weight_pct": 50,
              "duration_minutes": 20,
              "success_criteria": "error_rate < 1% AND latency_p95 < 200ms"
            },
            {
              "weight_pct": 100,
              "duration_minutes": 0,
              "success_criteria": "error_rate < 1%"
            }
          ],
          "rollback_on_failure": true,
          "health_check_interval_seconds": 30
        }
      }
    },
    "environment_matrix": {
      "path": "deploy/v1/env/matrix.json",
      "description": "Matriz de configuración por entorno con overrides",
      "schema": {
        "type": "object",
        "properties": {
          "environments": { "type": "array", "items": { "type": "string" } },
          "defaults": {
            "type": "object",
            "properties": {
              "python": { "type": "string" },
              "node": { "type": "string" },
              "go": { "type": "string" },
              "rust": { "type": "string" },
              "pm": { "type": "string" },
              "svc_user": { "type": "string" },
              "data_dir": { "type": "string" }
            },
            "additionalProperties": false
          },
          "overrides": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "python": { "type": "string" },
                "node": { "type": "string" },
                "pm": { "type": "string" },
                "svc_user": { "type": "string" },
                "data_dir": { "type": "string" },
                "limits": {
                  "type": "object",
                  "properties": {
                    "cpu": { "type": "string" },
                    "memory": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "required": ["environments", "defaults"],
        "additionalProperties": false
      },
      "example": {
        "environments": ["termux", "linux", "staging", "prod", "kubernetes"],
        "defaults": {
          "python": "3.11",
          "node": "20",
          "go": "1.21",
          "rust": "1.75",
          "pm": "pip+uv",
          "svc_user": "svc_mod",
          "data_dir": "storage/data"
        },
        "overrides": {
          "termux": {
            "pm": "pip+uv",
            "limits": { "cpu": "1", "memory": "512Mi" }
          },
          "linux": {
            "pm": "poetry",
            "limits": { "cpu": "2", "memory": "1Gi" }
          },
          "kubernetes": {
            "pm": "poetry",
            "limits": { "cpu": "4", "memory": "2Gi" }
          }
        }
      }
    },
    "install_playbooks": {
      "tree": [
        "deploy/v1/playbooks/termux/install.sh",
        "deploy/v1/playbooks/linux/install.sh",
        "deploy/v1/playbooks/staging/install.sh",
        "deploy/v1/playbooks/prod/install.sh",
        "deploy/v1/playbooks/kubernetes/install.sh"
      ],
      "contract": {
        "type": "object",
        "properties": {
          "preflight": { "type": "array", "items": { "type": "string" } },
          "system_deps": { "type": "array", "items": { "type": "string" } },
          "runtime_deps": { "type": "array", "items": { "type": "string" } },
          "config_templates": { "type": "array", "items": { "type": "string" } },
          "services": { "type": "array", "items": { "type": "string" } },
          "post_checks": { "type": "array", "items": { "type": "string" } },
          "error_handling": {
            "type": "object",
            "properties": {
              "retry_count": { "type": "integer" },
              "retry_delay_seconds": { "type": "integer" },
              "rollback_on_failure": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "required": ["preflight", "system_deps", "runtime_deps", "config_templates", "services", "post_checks", "error_handling"],
        "additionalProperties": false
      }
    },
    "config_templates": {
      "path": "deploy/v1/config/<env>/<module>.json.tpl",
      "description": "Templates de configuración con validación de env vars y secrets rotation",
      "schema": {
        "type": "object",
        "properties": {
          "services": { "type": "array", "items": { "type": "object" } },
          "endpoints": { "type": "object", "additionalProperties": { "type": "string" } },
          "credentials_ref": { "type": "object", "additionalProperties": { "type": "string" } },
          "timeouts": { "type": "object", "additionalProperties": { "type": "integer" } },
          "retries": {
            "type": "object",
            "properties": {
              "max_retries": { "type": "integer" },
              "backoff": { "type": "string" }
            },
            "additionalProperties": false
          },
          "feature_flags": { "type": "object", "additionalProperties": { "type": "boolean" } },
          "secrets_rotation": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "rotation_days": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "required": ["endpoints", "credentials_ref"],
        "additionalProperties": false
      }
    },
    "service_manifests": {
      "paths": [
        "deploy/v1/services/termux/<module>.properties",
        "deploy/v1/services/linux/<module>.service",
        "deploy/v1/services/staging/<module>.service",
        "deploy/v1/services/prod/<module>.service"
      ],
      "fields_required": ["ExecStart", "User|run-as", "WorkingDirectory", "Restart", "ResourceLimits", "HealthCheck"]
    },
    "secrets_bootstrap": {
      "path": "deploy/v1/secrets/bootstrap.json",
      "description": "Bootstrap de secrets desde vault con rotation automática",
      "schema": {
        "type": "object",
        "properties": {
          "vault_paths": { "type": "object", "additionalProperties": { "type": "string" } },
          "mapping": { "type": "object", "additionalProperties": { "type": "string" } },
          "rotation_config": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "rotation_days": { "type": "integer" },
              "notification_channels": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "required": ["vault_paths"],
        "additionalProperties": false
      }
    },
    "smoke_tests": {
      "path": "deploy/v1/tests/smoke.json",
      "description": "Tests de humo post-deployment con validación automática",
      "schema": {
        "type": "object",
        "properties": {
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string", "enum": ["http", "tcp", "process", "log", "metrics"] },
                "target": { "type": "string" },
                "expected": { "type": "string" },
                "timeout_seconds": { "type": "integer" },
                "retry_count": { "type": "integer" }
              },
              "required": ["name", "type", "target", "expected"],
              "additionalProperties": false
            }
          }
        },
        "required": ["checks"],
        "additionalProperties": false
      }
    },
    "runbooks": {
      "path": "deploy/v1/runbooks/",
      "files": [
        "install.md",
        "start_stop.md",
        "rollback.md",
        "troubleshooting.md",
        "disaster_recovery.md",
        "security_incident_response.md"
      ]
    }
  },
  "acceptance_criteria": [
    "Playbooks idempotentes ejecutables en los 5 entornos (termux, linux, staging, prod, k8s)",
    "IaC templates (Terraform/Ansible) generados y validados",
    "Dependency resolution matrix completa por entorno y lenguaje",
    "Configs renderizadas desde plantillas sin placeholders, validadas contra schemas",
    "Secrets cargados solo vía credentials_ref con rotation configurada",
    "Container orchestration (Docker/K8s) configurado con health checks",
    "Monitoring integration (Prometheus/Grafana) activo con dashboards",
    "Blue-green/canary deployment strategies implementadas",
    "Servicios levantan y pasan smoke tests automáticamente (100% success rate)",
    "Migration strategy definida con zero-downtime guarantee",
    "Disaster recovery plan verificado (RTO < 1h, RPO < 5min)",
    "Compliance validation passed (SOC2/ISO27001) con audit trails",
    "DORA metrics recolectadas (deployment frequency, MTTR, change failure rate)",
    "Rollback automático funcional si smoke tests fallan"
  ],
  "response_policy": {
    "format": "JSON only",
    "blocks_order": [
      "infrastructure_as_code_spec",
      "dependency_resolution_matrix",
      "environment_matrix",
      "install_playbooks",
      "config_templates",
      "service_manifests",
      "secrets_bootstrap",
      "container_orchestration_spec",
      "monitoring_integration_spec",
      "blue_green_deployment_spec",
      "migration_strategy",
      "disaster_recovery_plan",
      "compliance_validation_report",
      "deployment_metrics",
      "smoke_tests",
      "runbooks"
    ],
    "on_missing_input": "Emitir standard_error INSTALL_INPUTS_MISSING con lista de inputs faltantes y detener",
    "on_validation_error": "Emitir standard_error CONFIG_VALIDATION_ERROR con schema violations y detener",
    "on_smoke_test_failure": "Ejecutar rollback automático y emitir standard_error SMOKE_TEST_FAILED",
    "on_compliance_failure": "Bloquear deployment y emitir standard_error COMPLIANCE_NOT_MET"
  }
}
