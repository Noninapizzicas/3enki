{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://event-core.com/schemas/{{name}}/events.json",
  "title": "Eventos de {{titleCase name}}",
  "description": "Schemas de eventos publicados por el módulo {{name}}",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": {
          "type": "string",
          "format": "uuid"
        },
        "event_type": {
          "type": "string"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "payload": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }{{#if publishEvents.length}},

    {{#each publishEvents}}
    "{{snakeCase this}}": {
      "allOf": [
        {
          "$ref": "#/definitions/event_envelope"
        },
        {
          "properties": {
            "event_type": {
              "const": "{{this}}"
            },
            "payload": {
              "type": "object",
              "properties": {
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "additionalProperties": true
            }
          }
        }
      ]
    }{{#unless @last}},{{/unless}}
    {{/each}}
    {{/if}}
  }
}
