{
  "name": "carta-digital",
  "version": "2.0.0",
  "description": "Backoffice de la carta pública. Configura branding, compone carta final (datos + marketing + ofertas), genera PWA. Los agentes hacen el trabajo.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "events": {
    "subscribes": [
      {
        "event": "project.activated",
        "handler": "onProjectActivated"
      },
      {
        "event": "project.deactivated",
        "handler": "onProjectDeactivated"
      },
      {
        "event": "carta.actualizada",
        "handler": "onCartaActualizada"
      },
      {
        "event": "tarifas.config.actualizada",
        "handler": "onTarifasActualizada"
      }
    ]
  },
  "ui_handlers": [
    {
      "domain": "carta-digital",
      "action": "config",
      "handler": "handleGetConfig"
    },
    {
      "domain": "carta-digital",
      "action": "update-config",
      "handler": "handleUpdateConfig"
    },
    {
      "domain": "carta-digital",
      "action": "carta-publica",
      "handler": "handleGetCartaPublica"
    },
    {
      "domain": "carta-digital",
      "action": "health",
      "handler": "handleHealth"
    }
  ],
  "tools": [
    {
      "name": "cartadigital.get_config",
      "description": "Configuración de branding de la carta pública: colores, WhatsApp, features",
      "handler": "toolGetConfig",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "name": "cartadigital.update_config",
      "description": "Actualiza branding: whatsapp_telefono, nombre_negocio, tema (colores), funcionalidades",
      "handler": "toolUpdateConfig",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          },
          "whatsapp_telefono": {
            "type": "string"
          },
          "nombre_negocio": {
            "type": "string"
          },
          "moneda": {
            "type": "string"
          },
          "tema": {
            "type": "object"
          },
          "funcionalidades": {
            "type": "object"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "name": "cartadigital.get_carta_publica",
      "description": "Carta pública compuesta lista para servir (datos + config + ofertas)",
      "handler": "toolGetCartaPublica",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "name": "cartadigital.set_carta_compuesta",
      "description": "Guarda carta compuesta en caché (usado por agente composer)",
      "handler": "toolSetCartaCompuesta",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          },
          "carta_compuesta": {
            "type": "object"
          }
        },
        "required": [
          "project_id",
          "carta_compuesta"
        ]
      }
    }
  ],
  "agents": {
    "cartadigital-composer": "Compone carta final: carta-manager + marketing + ofertas + config",
    "cartadigital-pwa-builder": "Genera export PWA (HTML + service worker + manifest)",
    "cartadigital-ofertas": "Gestiona ofertas y combos",
    "cartadigital-reviewer": "Revisa completitud: imágenes, descripciones, alérgenos, precios"
  },
  "observability": {
    "metrics": {
      "counters": [
        "carta-digital.recompose.triggered"
      ]
    }
  }
}
