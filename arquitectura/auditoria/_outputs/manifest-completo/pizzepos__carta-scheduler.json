      "parameters_property_names": ["project_id", "regla_id"],
      "parameters_size_chars": 129,
      "parameters_full_path_hint": "modules/pizzepos/carta-scheduler/module.json → tools[2].parameters"
    },
    {
      "name": "scheduler.detectar_conflictos",
      "description": "Detecta si una nueva regla entra en conflicto con otras activas (mismo canal)",
