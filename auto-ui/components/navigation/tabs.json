{
  "name": "tabs",
  "category": "navigation",
  "description": "Pestañas para organizar contenido en secciones",
  "version": "2.0.0",

  "variants": {
    "default": {
      "description": "Tabs estándar con línea inferior",
      "className": "tabs"
    },
    "pills": {
      "description": "Tabs estilo píldoras",
      "className": "tabs tabs-pills"
    },
    "boxed": {
      "description": "Tabs con fondo",
      "className": "tabs tabs-boxed"
    },
    "lifted": {
      "description": "Tabs elevadas (conectadas al contenido)",
      "className": "tabs tabs-lifted"
    },
    "minimal": {
      "description": "Tabs minimalistas",
      "className": "tabs tabs-minimal"
    }
  },

  "sizes": {
    "sm": {
      "description": "Tabs pequeñas",
      "className": "tabs-sm"
    },
    "md": {
      "description": "Tabs medianas (default)",
      "className": ""
    },
    "lg": {
      "description": "Tabs grandes",
      "className": "tabs-lg"
    }
  },

  "props": {
    "tabs": {
      "type": "array",
      "required": true,
      "description": "Definición de las tabs",
      "items": {
        "id": "string",
        "label": "string",
        "icon": "string",
        "badge": "object",
        "disabled": "boolean",
        "content": "string"
      }
    },
    "activeTab": {
      "type": "string",
      "description": "ID de la tab activa"
    },
    "defaultTab": {
      "type": "string",
      "description": "Tab activa por defecto"
    },
    "orientation": {
      "type": "string",
      "enum": ["horizontal", "vertical"],
      "default": "horizontal",
      "description": "Orientación de las tabs"
    },
    "centered": {
      "type": "boolean",
      "default": false,
      "description": "Centrar tabs (horizontal)"
    },
    "fullWidth": {
      "type": "boolean",
      "default": false,
      "description": "Tabs ocupan todo el ancho"
    },
    "scrollable": {
      "type": "boolean",
      "default": false,
      "description": "Permitir scroll horizontal si no caben"
    },
    "addable": {
      "type": "boolean",
      "default": false,
      "description": "Permitir añadir nuevas tabs"
    },
    "closable": {
      "type": "boolean",
      "default": false,
      "description": "Permitir cerrar tabs"
    },
    "draggable": {
      "type": "boolean",
      "default": false,
      "description": "Permitir reordenar tabs"
    }
  },

  "tabItem": {
    "id": {
      "type": "string",
      "required": true,
      "description": "ID único de la tab"
    },
    "label": {
      "type": "string",
      "required": true,
      "description": "Texto de la tab"
    },
    "icon": {
      "type": "string",
      "description": "Icono de la tab"
    },
    "badge": {
      "type": "object",
      "properties": {
        "text": "string|number",
        "variant": "string"
      },
      "description": "Badge de notificación"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Tab deshabilitada"
    },
    "closable": {
      "type": "boolean",
      "description": "Sobrescribe closable global"
    },
    "content": {
      "type": "string",
      "description": "Contenido de la tab"
    }
  },

  "features": {
    "lazyLoading": {
      "enabled": false,
      "loadOnActivate": true,
      "description": "Cargar contenido solo al activar"
    },
    "keepAlive": {
      "enabled": true,
      "description": "Mantener contenido en DOM al cambiar"
    },
    "animations": {
      "enabled": true,
      "type": "fade",
      "duration": 200
    },
    "urlSync": {
      "enabled": false,
      "param": "tab",
      "description": "Sincronizar tab activa con URL"
    },
    "keyboard": {
      "enabled": true,
      "arrows": true,
      "home": true,
      "end": true
    }
  },

  "interactions": {
    "tabClick": {
      "enabled": true,
      "action": "activate"
    },
    "tabClose": {
      "enabled": false,
      "action": "close",
      "confirmClose": false
    },
    "tabAdd": {
      "enabled": false,
      "action": "add",
      "template": "newTab"
    }
  },

  "accessibility": {
    "role": "tablist",
    "tabRole": "tab",
    "panelRole": "tabpanel",
    "ariaSelected": true,
    "ariaControls": true,
    "keyboardNavigation": true
  },

  "example": {
    "component": "tabs",
    "variant": "default",
    "size": "md",
    "props": {
      "tabs": [
        {
          "id": "overview",
          "label": "Resumen",
          "icon": "📊",
          "content": "Contenido del resumen..."
        },
        {
          "id": "details",
          "label": "Detalles",
          "icon": "📝",
          "badge": {"text": "3", "variant": "primary"},
          "content": "Contenido de detalles..."
        },
        {
          "id": "settings",
          "label": "Configuración",
          "icon": "⚙️",
          "content": "Contenido de configuración..."
        },
        {
          "id": "disabled",
          "label": "Deshabilitada",
          "disabled": true
        }
      ],
      "defaultTab": "overview",
      "scrollable": true
    }
  },

  "verticalExample": {
    "component": "tabs",
    "variant": "pills",
    "props": {
      "tabs": [
        {"id": "profile", "label": "Perfil", "icon": "👤"},
        {"id": "security", "label": "Seguridad", "icon": "🔒"},
        {"id": "notifications", "label": "Notificaciones", "icon": "🔔"}
      ],
      "orientation": "vertical",
      "defaultTab": "profile"
    }
  }
}
