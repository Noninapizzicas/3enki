{
  "_meta": {
    "modulo": "facturas",
    "ubicacion": "modules/facturas",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "facturas",
    "version": "2.0.0",
    "description_oficial": "Procesamiento comercial de facturas: pipeline step-based con agentes IA, validación y observabilidad",
    "author": "Event-Core Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": null,
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "factura.recibida",  "description": null },
      { "event": "factura.procesada", "description": null },
      { "event": "factura.error",     "description": null },
      { "event": "factura.exportada", "description": null }
    ],
    "subscribes": [
      { "event": "factura.entrada", "handler": "onFacturaEntrada", "extras": {} }
    ],
    "provides_eventos": []
  },

  "tools": [
    {
      "name": "facturas.procesar",
      "description": "Procesa un archivo de factura (PDF/imagen) y extrae datos estructurados via OCR + IA",
      "parameters_required": ["projectId", "filePath"],
      "parameters_property_names": ["projectId", "filePath", "source"],
      "parameters_size_chars": 282,
      "parameters_full_path_hint": "modules/facturas/module.json → tools[0].parameters"
    },
    {
      "name": "facturas.listar",
      "description": "Lista facturas de un proyecto con filtros opcionales",
      "parameters_required": ["projectId"],
      "parameters_property_names": ["projectId", "estado", "limit"],
      "parameters_size_chars": 246,
      "parameters_full_path_hint": "modules/facturas/module.json → tools[1].parameters"
    },
    {
      "name": "facturas.estadisticas",
      "description": "Obtiene estadísticas de facturas del proyecto",
      "parameters_required": ["projectId"],
      "parameters_property_names": ["projectId"],
      "parameters_size_chars": 101,
      "parameters_full_path_hint": "modules/facturas/module.json → tools[2].parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "handlers",
    "items": [
      { "domain": "facturas", "action": "procesar",        "handler": "handleProcesar" },
      { "domain": "facturas", "action": "subir",           "handler": "handleSubir" },
      { "domain": "facturas", "action": "reprocesar",      "handler": "handleReprocesar" },
      { "domain": "facturas", "action": "listar",          "handler": "handleListar" },
      { "domain": "facturas", "action": "obtener",         "handler": "handleObtener" },
      { "domain": "facturas", "action": "actualizar",      "handler": "handleActualizar" },
      { "domain": "facturas", "action": "estadisticas",    "handler": "handleEstadisticas" },
      { "domain": "facturas", "action": "exportar",        "handler": "handleExportar" },
      { "domain": "facturas", "action": "pipeline-metrics","handler": "handlePipelineMetrics" }
    ]
  },

  "apis_http": [],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      {
        "key": "ocr",
        "tipo": "object",
        "valor_default": {
          "provider": "local.google-vision",
          "hint": "DOCUMENT_TEXT_DETECTION",
          "languages": ["es", "en"]
        }
      },
      {
        "key": "ai",
        "tipo": "object",
        "valor_default": {
          "providers": ["deepseek", "anthropic", "openai", "gemini"],
          "temperature": 0.1,
          "maxTokens": 2000
        }
      },
      {
        "key": "processing",
        "tipo": "object",
        "valor_default": {
          "dpi": 300,
          "maxWidth": 2400,
          "maxHeight": 3200,
          "sharp": {
            "grayscale": true,
            "normalize": true,
            "sharpen": true
          }
        }
      },
      {
        "key": "timeouts",
        "tipo": "object",
        "valor_default": {
          "pdfConvert": 60000,
          "sharp": 30000,
          "ocr": 60000,
          "ai": 60000,
          "db": 30000
        }
      }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "facturas.procesadas.total",
        "facturas.errores.total",
        "facturas.subidas.total"
      ],
      "gauges": [],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": [],
    "prompts": [],
    "context": true,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": true,
    "ui_handlers_field_name": "handlers",
    "module_json_bytes": 3731,
    "module_json_lineas": 122,
    "tiene_main_no_estandar": false,
    "warnings": [
      "events usa forma top-level (events.publishes / events.subscribes) en lugar de publishes/subscribes directos",
      "ui_handlers declarados como 'handlers' con campo 'method' (no 'handler') — normalizado a handler en output",
      "observability.metrics declara 'histograms' (no canónico en schema) — capturado en outliers_capturados si se agregara, pero el campo metrics.histograms no tiene equivalente en schema output (solo counters/gauges/timings)",
      "tier_carga_inferido=null: 'facturas' no aparece en ningún tier de system.json.module_load_order.tiers"
    ]
  }
}
