{
  "id": "procesar-facturas",
  "name": "Procesar Facturas con OCR e IA",
  "description": "Procesa todas las facturas en inbox con Google Vision OCR y DeepSeek IA",
  "version": "1.0.0",
  "enabled": true,

  "schedule": {
    "cron": "0 2 * * 0",
    "timezone": "Europe/Madrid"
  },

  "steps": [
    {
      "id": "crear-directorios",
      "type": "parallel",
      "steps": [
        {
          "id": "mkdir-datos",
          "type": "service",
          "service": "fs",
          "action": "mkdir",
          "path": "@/projects/facturas-nonina/datos",
          "onError": "continue"
        },
        {
          "id": "mkdir-originales",
          "type": "service",
          "service": "fs",
          "action": "mkdir",
          "path": "@/projects/facturas-nonina/originales",
          "onError": "continue"
        }
      ]
    },
    {
      "id": "listar-inbox",
      "type": "service",
      "service": "fs",
      "action": "list",
      "path": "@/projects/facturas-nonina/inbox",
      "pattern": "*.{jpg,jpeg,png,pdf,webp}"
    },
    {
      "id": "verificar-archivos",
      "type": "condition",
      "if": "{{ count(steps.listar-inbox.files) }} > 0",
      "then": "log-inicio",
      "else": "log-vacio"
    },
    {
      "id": "log-vacio",
      "type": "log",
      "level": "info",
      "message": "No hay facturas pendientes en inbox"
    },
    {
      "id": "log-inicio",
      "type": "log",
      "level": "info",
      "message": "Procesando {{ count(steps.listar-inbox.files) }} facturas"
    },
    {
      "id": "set-contador",
      "type": "set",
      "variables": {
        "procesadas": 0,
        "errores": 0
      }
    },
    {
      "id": "emitir-procesar-cada-factura",
      "type": "emit",
      "event": "facturas-nonina.procesar.lote",
      "data": {
        "archivos": "{{ steps.listar-inbox.files }}",
        "total": "{{ count(steps.listar-inbox.files) }}"
      }
    }
  ]
}
