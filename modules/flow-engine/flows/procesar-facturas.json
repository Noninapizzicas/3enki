{
  "id": "procesar-facturas",
  "name": "Procesar Facturas OCR",
  "description": "Procesa imagenes de facturas recibidas via Telegram con OCR",
  "version": "1.2.0",
  "enabled": true,

  "trigger": {
    "event": "bot.file.stored",
    "filter": {
      "botName": "facturas_asesoria_bot",
      "file.mimeType": {
        "$in": ["image/jpeg", "image/png", "image/webp", "application/pdf"]
      }
    }
  },

  "steps": [
    {
      "id": "crear-directorio",
      "type": "service",
      "service": "fs",
      "action": "mkdir",
      "path": "@/projects/facturas-nonina/storage/procesadas",
      "onError": "continue"
    },

    {
      "id": "leer-archivo",
      "type": "service",
      "service": "fs",
      "action": "read",
      "path": "{{ globalPath(trigger.file.path) }}",
      "encoding": "base64"
    },

    {
      "id": "ocr",
      "type": "service",
      "service": "local.tesseract",
      "action": "extract",
      "image": "{{ steps.leer-archivo.output.content }}",
      "language": "spa",
      "timeout": 120000,
      "onError": "continue"
    },

    {
      "id": "preparar-resultado",
      "type": "transform",
      "operation": "map",
      "config": {
        "mapping": {
          "archivoOriginal": "{{ trigger.file.originalName }}",
          "rutaOriginal": "{{ trigger.file.path }}",
          "fechaRecepcion": "{{ trigger.timestamp }}",
          "caption": "{{ default(trigger.caption, 'sin caption') }}",
          "chatId": "{{ trigger.chatId }}",
          "userId": "{{ trigger.userId }}",
          "userName": "{{ trigger.userName }}",
          "textoExtraido": "{{ default(steps.ocr.output.text, 'OCR no disponible') }}",
          "confianza": "{{ default(steps.ocr.output.confidence, 0) }}",
          "palabras": "{{ default(steps.ocr.output.words, 0) }}",
          "lineas": "{{ default(steps.ocr.output.lines, 0) }}",
          "provider": "local.tesseract",
          "procesadoEn": "{{ now }}"
        }
      }
    },

    {
      "id": "guardar-json",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "@/projects/facturas-nonina/storage/procesadas/{{ date }}_{{ trigger.file.originalName }}.json",
      "content": "{{ steps.preparar-resultado.output }}"
    },

    {
      "id": "guardar-texto",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "@/projects/facturas-nonina/storage/procesadas/{{ date }}_{{ trigger.file.originalName }}.txt",
      "content": "FACTURA: {{ trigger.file.originalName }}\nFecha: {{ now }}\nConfianza: {{ default(steps.ocr.output.confidence, 'N/A') }}\n\n{{ default(steps.ocr.output.text, 'Sin texto extraido') }}"
    },

    {
      "id": "log-resultado",
      "type": "log",
      "level": "info",
      "message": "Factura procesada: {{ trigger.file.originalName }} - {{ default(steps.ocr.output.words, 0) }} palabras"
    }
  ]
}
