  "eventos": {
    "_descripcion": "Eventos publicados y suscritos por cada modulo",

    "ai-gateway": {
      "publica": [],
      "suscribe": ["ai.request.created"]
    },

    "menu-generator": {
      "publica": [
        "ai.request",
        "menu.generado",
        "menu.validado",
        "menu.error",
        "menu-generator.conversation.created",
        "menu-generator.message.sent",
        "menu-generator.message.received",
        "menu-generator.menu.created",
        "menu-generator.menu.exported"
      ],
      "suscribe": ["ai.response"]
    },

    "metricas": {
      "publica": ["metricas.snapshot", "metricas.alerta"],
      "suscribe": ["*.creado", "*.actualizado", "*.eliminado", "*.error", "*.completado"]
    },

    "plugin-manager": {
      "publica": ["plugin.loaded", "plugin.unloaded", "plugin.error", "plugin.reloaded"],
      "suscribe": ["plugin.get.request", "plugin.list.request"]
    },

    "dashboard": {
      "publica": [],
      "suscribe": ["core/+/logs/#", "core/+/events/#", "core/+/metrics/#"]
    },

    "admin-panel": {
      "publica": ["admin.action"],
      "suscribe": ["plugin.loaded", "ui.component.loaded"]
    },

    "calling-generator": {
      "publica": ["function.generated", "function.executed", "function.failed", "function.generation.error"],
      "suscribe": ["plugin.loaded", "function.get.request", "function.list.request", "function.execute.request"]
    },

    "tool-orchestrator": {
      "publica": ["tool.registered", "tool.unregistered", "tool.call.response", "tool.call.success", "tool.call.failed"],
      "suscribe": ["tool.call.request", "tool.list.request", "tool.get.request"]
    },

    "credential-manager": {
      "publica": ["credential.saved", "credential.updated", "credential.deleted", "credential.resolved", "credential.resolve.failed"],
      "suscribe": ["credential.resolve.request"]
    },

    "notas": {
      "publica": ["nota.creada", "nota.actualizada", "nota.eliminada"],
      "suscribe": []
    },

    "ai-agent-framework": {
      "publica": [],
      "suscribe": ["agent.*.created", "agent.*.completed", "agent.*.failed"]
    },

    "prompt-manager": {
      "publica": [],
      "suscribe": ["ai.completion.completed", "ai.request.started"]
    },

    "ui-designer": {
      "publica": [
        "ui-designer.template.created",
        "ui-designer.template.updated",
        "ui-designer.template.deleted",
        "ui-designer.export.yaml",
        "ui-designer.export.svelte",
        "ui-designer.export.json"
      ],
      "suscribe": []
    },

    "productos": {
      "publica": ["producto.creado", "producto.actualizado", "producto.eliminado", "catalogo.actualizado"],
      "suscribe": ["menu.generado", "menu.validado"]
    },

    "pedidos": {
      "publica": [
        "pedido.creado",
        "pedido.item_agregado",
        "pedido.item_actualizado",
        "pedido.item_eliminado",
        "pedido.enviado_cocina",
        "pedido.completado",
        "pedido.cancelado"
      ],
      "suscribe": ["variacion.validada", "variacion.rechazada", "cuenta.creada"]
    },

    "cuentas": {
      "publica": ["cuenta.creada", "cuenta.actualizada", "cuenta.eliminada", "cuenta.estado_cambiado"],
      "suscribe": ["pedido.item_agregado", "pedido.item_eliminado", "cobro.procesado"]
    },

    "cobros": {
      "publica": ["cobro.iniciado", "cobro.completado", "cobro.fallido", "cobro.reembolsado"],
      "suscribe": ["pedido.completado", "cuenta.creada"]
    },

    "categorias": {
      "publica": ["categoria.creada", "categoria.actualizada", "categoria.orden_actualizado"],
      "suscribe": ["menu.generado"]
    },

    "ingredientes": {
      "publica": ["ingrediente.creado", "ingrediente.actualizado"],
      "suscribe": ["menu.generado", "producto.creado"]
    },

    "variaciones": {
      "publica": ["variacion.validada", "variacion.rechazada"],
      "suscribe": ["producto.creado", "pedido.item_agregado"]
    },

    "comandero": {
      "publica": ["pedido.item_agregado", "pedido.item_eliminado", "pedido.enviado_cocina"],
      "suscribe": ["cuenta.actualizada"]
    },

    "cocina": {
      "publica": ["cocina.item_preparado", "cocina.pedido_listo"],
      "suscribe": ["pedido.enviado_cocina", "pedido.item_agregado", "pedido.cancelado"]
    },

    "cuentas-mesa": {
      "publica": ["mesa.abierta", "mesa.camarero_asignado", "mesa.cerrada", "cuenta.creada", "cuenta.cerrada"],
      "suscribe": ["pedido.creado", "cobro.completado"]
    },

    "cuentas-llevar": {
      "publica": ["llevar.ticket_creado", "llevar.ticket_listo", "llevar.ticket_entregado", "cuenta.creada", "cuenta.cerrada"],
      "suscribe": ["cocina.pedido_listo", "cobro.completado"]
    },

    "cuentas-telefono": {
      "publica": ["telefono.llamada_detectada", "telefono.contacto_identificado", "telefono.pedido_creado", "telefono.listo_para_recoger", "cuenta.creada", "cuenta.cerrada"],
      "suscribe": ["cocina.pedido_listo", "cobro.completado"]
    }
  },

  "acciones": {
    "_descripcion": "APIs/Acciones disponibles por modulo (metodo, path, descripcion)",

    "ai-gateway": [
      {"metodo": "POST", "path": "/chat", "descripcion": "Chat completion con proveedor"},
      {"metodo": "POST", "path": "/chat/stream", "descripcion": "Chat con streaming SSE"},
      {"metodo": "GET", "path": "/providers", "descripcion": "Listar proveedores disponibles"},
