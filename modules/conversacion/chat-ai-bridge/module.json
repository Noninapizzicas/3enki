{
  "name": "chat-ai-bridge",
  "version": "1.0.0",
  "description": "Adaptador MQTT/REST → eventos. Recibe mensajes del frontend con project_id y conversation_id, emite chat.send.request y retorna inmediatamente.",
  "author": "Event Core Team",

  "events": {
    "publishes": [
      "chat.send.request"
    ],
    "subscribes": []
  },

  "ui_handlers": [
    { "domain": "conversation", "action": "send", "handler": "handleConversationSend" }
  ],

  "apis": [
    {
      "method": "POST",
      "path": "/send",
      "handler": "handleSendMessage",
      "description": "Enviar mensaje (fire-and-forget)"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check"
    }
  ],

  "config": {
    "requestTimeout": 10000
  }
}
