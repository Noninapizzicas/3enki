{
  "_meta": {
    "modulo": "pizzepos/menu-generator",
    "ubicacion": "modules/pizzepos/menu-generator",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "menu-generator",
    "version": "6.1.0",
    "description_oficial": "Genera cartas estructuradas en JSON desde cualquier input: fotos, PDF, texto. Pipeline OCR determinista (Google Vision) + agente IA para estructuración. Siempre pregunta el nombre.",
    "author": "Pizzepos Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_6_ui",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "menu.generation.progress", "description": "Progreso del pipeline: extracting, structuring" },
      { "event": "menu.generation.failed", "description": "Error en el pipeline de generación" },
      { "event": "agent.execute.request", "description": "Invoca agente menu-structurer para estructurar carta" },
      { "event": "carta.generar.iniciada", "description": "Aceptada carta.generar.solicitada — pipeline en marcha" },
      { "event": "carta.generar.fallida", "description": "Fallo al iniciar generación" }
    ],
    "subscribes": [
      { "event": "carta.generar.solicitada", "handler": "onCartaGenerarSolicitada", "extras": {} }
    ],
    "provides_eventos": []
  },

  "tools": [
    {
      "name": "menu.generate",
      "description": "Genera una carta estructurada desde cualquier input. SIEMPRE requiere nombre — pregúntalo antes de llamar. Acepta texto (OCR, dictado, lista, JSON, recetas) o filePath (PDF/imagen). Si es archivo, extrae texto con Google Vision antes de estructurar.",
      "parameters_required": ["nombre", "project_id"],
      "parameters_property_names": ["nombre", "texto", "filePath", "project_id"],
      "parameters_size_chars": 463,
      "parameters_full_path_hint": "modules/pizzepos/menu-generator/module.json → tools[0].parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "menu", "action": "generate", "handler": "handleGenerate" },
      { "domain": "menu", "action": "health", "handler": "handleHealth" }
    ]
  },

  "apis_http": [],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": []
  },

  "observability_declarada": {
    "logging": { "level": null, "structured": null },
    "metrics": {
      "enabled": null,
      "counters": ["menu.generate.requested", "menu.generate.extract_failed"],
      "gauges": [],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": ["carta-output.json"],
    "prompts": [],
    "context": true,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": ["pipeline"],
    "snapshots": {
      "pipeline": {
        "extraction": {
          "description": "Pipeline OCR determinista (no usa LLM)",
          "steps": ["pdfjs.render (si PDF)", "sharp.prepare-ocr", "google-vision.extract"],
          "provider": "Google Vision",
          "timeouts": { "pdfInfo": 15000, "pdfRender": 30000, "sharp": 15000, "ocr": 60000 }
        },
        "structuring": {
          "description": "Agente IA que estructura el texto en carta JSON",
          "agent": "menu-structurer",
          "trigger": "menu.text.request"
        }
      }
    }
  },

  "version_archivada": {
    "existe": true,
    "ubicacion": "_archived/2026-02-13_otros-modulos/modules/menu-generator"
  },

  "quirks": {
    "eventos_top_level": false,
    "ui_handlers_field_name": "ui_handlers",
    "module_json_bytes": 2870,
    "module_json_lineas": 75,
    "tiene_main_no_estandar": false,
    "warnings": [
      "tools[0] declara campo 'handler' (no canónico en schema tools items) — ignorado en extracción",
      "observability.metrics declarado sin enabled ni logging — parcialmente poblado",
      "pipeline.structuring.trigger='menu.text.request' no aparece en events.subscribes ni publishes"
    ]
  }
