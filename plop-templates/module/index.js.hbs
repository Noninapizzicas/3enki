/**
 * {{titleCase name}} Module
 *
 * {{description}}
 *
 * @module {{name}}
 * @version 1.0.0
 */

{{#if persistence}}
const fs = require('fs').promises;
const path = require('path');
{{/if}}

class {{pascalCase name}}Module {
  constructor() {
    this.name = '{{name}}';
    this.version = '1.0.0';

    // Dependencies (injected in onLoad)
    this.logger = null;
    this.eventBus = null;
    this.uiHandler = null;
    this.config = null;

    // Internal state
    {{#if persistence}}
    this.data = new Map();
    this.dataDir = path.join(process.cwd(), 'data');
    this.dataFile = path.join(this.dataDir, '{{name}}.json');
    {{/if}}

    // Unsubscribe tracking for cleanup
    this.unsubscribes = [];

    // Startup time for health check
    this.startTime = Date.now();
  }

  // ==========================================
  // Lifecycle Hooks
  // ==========================================

  async onLoad(context) {
    this.logger = context.logger;
    this.eventBus = context.eventBus;
    this.uiHandler = context.uiHandler;
    this.config = context.config || {};

    this.logger.info('{{name}}.loading', {
      module: this.name,
      version: this.version
    });

    {{#if persistence}}
    // Load persisted data
    await this.loadFromJSON();
    {{/if}}

    // Register UI handlers (MQTT request/response)
    await this.registerUIHandlers();

    // Subscribe to events
    await this.subscribeToEvents();

    this.logger.info('{{name}}.loaded', {
      module: this.name
    });
  }

  async onUnload() {
    this.logger.info('{{name}}.unloading', { module: this.name });

    // Unregister UI handlers
    if (this.uiHandler) {
      {{#each uiActions}}
      this.uiHandler.unregister('{{../name}}', '{{this}}');
      {{/each}}
    }

    // Unsubscribe all event handlers
    for (const unsub of this.unsubscribes) {
      await unsub();
    }
    this.unsubscribes = [];

    {{#if persistence}}
    // Persist data before shutdown
    await this.persistToJSON();
    {{/if}}

    this.logger.info('{{name}}.unloaded', { module: this.name });
  }

  // ==========================================
  // UI Handler Registration
  // ==========================================

  async registerUIHandlers() {
    if (!this.uiHandler) return;

    // Register handlers for UI requests via MQTT
    {{#each uiActions}}
    this.uiHandler.register('{{../name}}', '{{this}}', this.handleUI{{pascalCase this}}.bind(this));
    {{/each}}

    this.logger.info('{{name}}.ui_handlers.registered', {
      domain: '{{name}}',
      actions: [{{#each uiActions}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}]
    });
  }

  // ==========================================
  // Event Subscriptions
  // ==========================================

  async subscribeToEvents() {
    {{#each subscriptions}}
    const unsub{{@index}} = await this.eventBus.subscribe(
      '{{this.event}}',
      this.on{{pascalCase this.handler}}.bind(this)
    );
    this.unsubscribes.push(unsub{{@index}});
    {{/each}}

    this.logger.info('{{name}}.events.subscribed', {
      events: [{{#each subscriptions}}'{{this.event}}'{{#unless @last}}, {{/unless}}{{/each}}]
    });
  }

  // ==========================================
  // Event Handlers
  // ==========================================

  {{#each subscriptions}}
  async on{{pascalCase this.handler}}(event) {
    const data = event.data || event.payload || event;

    try {
      this.logger.debug('{{../name}}.event.received', {
        event: '{{this.event}}',
        correlation_id: data.correlation_id
      });

      // TODO: Implement event handler logic

    } catch (error) {
      this.logger.error('{{../name}}.on{{pascalCase this.handler}}.error', {
        error: error.message,
        stack: error.stack
      });
    }
  }

  {{/each}}
  // ==========================================
  // UI Handlers (MQTT Request/Response)
  // ==========================================

  {{#each uiActions}}
  async handleUI{{pascalCase this}}(data, context) {
    try {
      this.logger.debug('{{../name}}.handleUI{{pascalCase this}}', {
        correlation_id: context.correlationId
      });

      // TODO: Implement UI handler logic
      const result = {
        message: '{{this}} action executed',
        timestamp: new Date().toISOString()
      };

      return { status: 200, data: result };
    } catch (error) {
      this.logger.error('{{../name}}.handleUI{{pascalCase this}}.error', {
        error: error.message
      });
      return { status: 500, error: error.message };
    }
  }

  {{/each}}
  // ==========================================
  // HTTP API Handlers
  // ==========================================

  {{#each apis}}
  async {{this.handler}}(req, context) {
    try {
      this.logger.debug('{{../name}}.{{this.handler}}', {
        correlation_id: context.correlationId
      });

      // TODO: Implement API handler logic
      const data = {
        message: '{{this.method}} {{this.path}} - Not implemented yet',
        timestamp: new Date().toISOString()
      };

      return { status: 200, data };
    } catch (error) {
      this.logger.error('{{../name}}.{{this.handler}}.error', {
        error: error.message,
        correlation_id: context.correlationId
      });
      return { status: 500, data: { error: error.message } };
    }
  }

  {{/each}}
  async handleHealthCheck(req, context) {
    const uptime = (Date.now() - this.startTime) / 1000;

    return {
      status: 200,
      data: {
        status: 'healthy',
        module: this.name,
        version: this.version,
        uptime,
        timestamp: new Date().toISOString()
      }
    };
  }

  // ==========================================
  // Tool Handlers (for AI)
  // ==========================================

  {{#each tools}}
  async tool{{pascalCase this.name}}(params, context) {
    try {
      this.logger.debug('{{../name}}.tool{{pascalCase this.name}}', {
        params,
        correlation_id: context.correlationId
      });

      // TODO: Implement tool logic
      return {
        success: true,
        message: 'Tool {{this.name}} executed',
        params
      };
    } catch (error) {
      this.logger.error('{{../name}}.tool{{pascalCase this.name}}.error', {
        error: error.message
      });
      return { success: false, error: error.message };
    }
  }

  {{/each}}
  {{#if persistence}}
  // ==========================================
  // Persistence (JSON)
  // ==========================================

  async loadFromJSON() {
    try {
      try {
        await fs.access(this.dataDir);
      } catch (error) {
        await fs.mkdir(this.dataDir, { recursive: true });
        this.logger.info('{{name}}.data_dir.created', { path: this.dataDir });
      }

      try {
        await fs.access(this.dataFile);
      } catch (error) {
        this.logger.info('{{name}}.load.first_run', {
          message: 'No persisted data, starting fresh'
        });
        return;
      }

      const fileContent = await fs.readFile(this.dataFile, 'utf8');
      const parsed = JSON.parse(fileContent);

      if (parsed.data) {
        this.data = new Map(Object.entries(parsed.data));
      }

      this.logger.info('{{name}}.loaded_from_json', {
        file: this.dataFile,
        saved_at: parsed.metadata?.saved_at
      });
    } catch (error) {
      this.logger.error('{{name}}.load.error', {
        error: error.message,
        file: this.dataFile
      });
    }
  }

  async persistToJSON() {
    try {
      const snapshot = {
        version: this.version,
        data: Object.fromEntries(this.data),
        metadata: {
          saved_at: new Date().toISOString(),
          module_version: this.version,
          uptime: (Date.now() - this.startTime) / 1000
        }
      };

      const tempFile = `${this.dataFile}.tmp`;
      await fs.writeFile(tempFile, JSON.stringify(snapshot, null, 2), 'utf8');
      await fs.rename(tempFile, this.dataFile);

      this.logger.debug('{{name}}.persisted_to_json', { file: this.dataFile });
    } catch (error) {
      this.logger.error('{{name}}.persist.error', {
        error: error.message,
        file: this.dataFile
      });
    }
  }
  {{/if}}
}

module.exports = {{pascalCase name}}Module;
