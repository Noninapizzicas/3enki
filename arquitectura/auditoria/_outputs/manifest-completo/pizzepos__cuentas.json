  "eventos": {
    "publica": [
      { "event": "cuenta.creada",        "description": "Nueva cuenta creada" },
      { "event": "cuenta.actualizada",   "description": "Cuenta actualizada" },
      { "event": "cuenta.eliminada",     "description": "Cuenta eliminada" },
      { "event": "cuenta.estado_cambiado", "description": "Estado de cuenta cambió" }
    ],
    "subscribes": [
      { "event": "comandero.item_agregado",    "handler": "onComanderoItemAgregado",    "extras": { "description": "Item agregado al buffer del comandero, actualizar totales" } },
      { "event": "comandero.item_eliminado",   "handler": "onComanderoItemEliminado",   "extras": { "description": "Item eliminado del buffer del comandero, actualizar totales" } },
      { "event": "comandero.item_actualizado", "handler": "onComanderoItemActualizado", "extras": { "description": "Item actualizado (cantidad +/-), ajustar items/total" } },
      { "event": "comandero.enviar_cocina",    "handler": "onComanderoEnviarCocina",    "extras": { "description": "Envío a cocina, transicionar a en_preparacion" } },
      { "event": "cocina.pedido_listo",        "handler": "onCocinaPedidoListo",        "extras": { "description": "Pedido listo en cocina, transicionar a listo" } },
      { "event": "cobro.iniciado",             "handler": "onCobroIniciado",            "extras": { "description": "Cobro iniciado, transicionar a para_cobrar" } },
      { "event": "cobro.procesado",            "handler": "onCobroProcesado",           "extras": { "description": "Cobro procesado, transicionar a cobrado y auto-eliminar" } },
      { "event": "cuenta.cerrada",             "handler": "onCuentaExternaCerrada",     "extras": { "description": "Cuenta cerrada desde canal externo, limpiar del Map y timers" } }
    ],
    "provides_eventos": [
      "cuenta.creada",
      "cuenta.actualizada",
      "cuenta.eliminada",
      "cuenta.estado_cambiado"
    ]
  },

