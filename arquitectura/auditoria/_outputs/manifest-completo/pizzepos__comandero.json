    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "comandero.item_agregado",  "description": "Item añadido al buffer del comandero" },
      { "event": "comandero.item_eliminado", "description": "Item eliminado del buffer del comandero" },
      { "event": "comandero.item_actualizado", "description": "Cantidad o notas de item actualizado en el buffer" },
      { "event": "comandero.enviar_cocina",  "description": "Comandero solicita enviar pedido a cocina — Pedidos recoge y crea pedido formal" }
    ],
    "subscribes": [
      { "event": "cuenta.creada",        "handler": "onCuentaCreada",        "extras": {} },
      { "event": "cuenta.actualizada",   "handler": "onCuentaActualizada",   "extras": {} },
      { "event": "caja.cerrada",         "handler": "onCajaCerrada",         "extras": {} },
      { "event": "dia.iniciado",         "handler": "onDiaIniciado",         "extras": {} },
      { "event": "catalogo.actualizado", "handler": "onCatalogoActualizado", "extras": {} },
      { "event": "producto.creado",      "handler": "onProductoActualizado", "extras": {} },
      { "event": "producto.actualizado", "handler": "onProductoActualizado", "extras": {} },
      { "event": "carta.actualizada",    "handler": "onCartaActualizada",    "extras": {} }
    ],
    "provides_eventos": [
      "comandero.item_agregado",
      "comandero.item_eliminado",
      "comandero.item_actualizado",
      "comandero.enviar_cocina"
    ]
  },

  "tools": [],

