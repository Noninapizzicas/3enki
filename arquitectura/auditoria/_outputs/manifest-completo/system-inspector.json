{
  "_meta": {
    "modulo": "system-inspector",
    "ubicacion": "modules/system-inspector",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "system-inspector",
    "version": "1.0.0",
    "description_oficial": "Captura estado del sistema (HTTP, MQTT, errores, logs) para consulta por IA",
    "author": null,
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_3_core",
    "tier_declarado": null,
    "dev_only_declarado": true,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [],
    "subscribes": [
      { "event": "core/+/events/#", "handler": null, "extras": {} },
      { "event": "core/+/errors/#", "handler": null, "extras": {} }
    ],
    "provides_eventos": []
  },

  "tools": [],

  "ui_handlers": {
    "campo_origen": null,
    "items": []
  },

  "apis_http": [
    {
      "method": "GET",
      "path": "/status",
      "handler": "handleGetStatus",
      "description": "Retorna estado completo del sistema (como consola DevTools)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/errors",
      "handler": "handleGetErrors",
      "description": "Retorna solo errores recientes",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/network",
      "handler": "handleGetNetwork",
      "description": "Retorna solo requests HTTP recientes",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "DELETE",
      "path": "/clear",
      "handler": "handleClear",
      "description": "Limpia el buffer de consola",
      "request_schema_ref": null,
      "response_schema_ref": null
    }
  ],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "buffer_size",      "tipo": "number",  "valor_default": 500 },
      { "key": "write_interval_ms","tipo": "number",  "valor_default": 2000 },
      { "key": "output_file",      "tipo": "string",  "valor_default": "./data/system-console.json" },
      { "key": "truncate_bodies",  "tipo": "number",  "valor_default": 1000 },
      { "key": "capture",          "tipo": "object",  "valor_default": { "http": true, "mqtt": true, "errors": true, "logs": true, "validation": true } }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "system-inspector.entries.captured",
        "system-inspector.errors.captured",
        "system-inspector.http.captured",
        "system-inspector.mqtt.captured"
      ],
      "gauges": [
        "system-inspector.buffer.size"
      ],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": ["schemas/status.schema.json"],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": true,
    "ui_handlers_field_name": null,
    "module_json_bytes": 1741,
    "module_json_lineas": 75,
    "tiene_main_no_estandar": false,
    "warnings": [
      "events.subscribes contiene MQTT wildcard topics (strings), no objetos {event,handler} — handler=null asignado",
      "events.publishes vacío — módulo no emite eventos de dominio",
      "Módulo marcado dev_only:true",
      "apis declaradas como 'apis' (no 'routes') — mapeadas a apis_http"
    ]
  }
}
