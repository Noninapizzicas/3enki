{
  "name": "floating-panel",
  "category": "feedback",
  "description": "Panel flotante ajustable desde abajo, optimizado para móvil, se abre desde TouchActionButton",
  "version": "2.0.0",
  "author": "Event Core Team",

  "variants": {
    "default": {
      "description": "Panel con glassmorphism",
      "className": "floating-panel--default"
    },
    "solid": {
      "description": "Panel con fondo sólido",
      "className": "floating-panel--solid"
    },
    "minimal": {
      "description": "Panel minimalista sin backdrop fuerte",
      "className": "floating-panel--minimal"
    },
    "fullscreen": {
      "description": "Panel en modo fullscreen",
      "className": "floating-panel--fullscreen"
    }
  },

  "sizes": {
    "small": {
      "description": "30% de altura - Para acciones rápidas, menús",
      "height": "30vh",
      "className": "floating-panel--small"
    },
    "medium": {
      "description": "60% de altura - Para formularios, detalles",
      "height": "60vh",
      "className": "floating-panel--medium"
    },
    "full": {
      "description": "90% de altura - Para contenido extenso",
      "height": "90vh",
      "className": "floating-panel--full"
    }
  },

  "props": {
    "variant": {
      "type": "enum",
      "values": ["default", "solid", "minimal", "fullscreen"],
      "default": "default",
      "required": false,
      "description": "Variante visual del panel"
    },
    "size": {
      "type": "enum",
      "values": ["small", "medium", "full"],
      "default": "medium",
      "required": false,
      "description": "Tamaño inicial del panel"
    },
    "title": {
      "type": "string",
      "required": false,
      "description": "Título del panel"
    },
    "content": {
      "type": "string|html",
      "required": false,
      "description": "Contenido del panel (HTML permitido)"
    },
    "showHandle": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar handle para arrastrar"
    },
    "showCloseButton": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar botón de cerrar (X)"
    },
    "draggable": {
      "type": "boolean",
      "default": true,
      "description": "Permitir arrastrar para ajustar altura"
    },
    "swipeToClose": {
      "type": "boolean",
      "default": true,
      "description": "Swipe down para cerrar"
    },
    "backdropClose": {
      "type": "boolean",
      "default": true,
      "description": "Cerrar al tocar el backdrop (fuera del panel)"
    },
    "backdrop": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar backdrop oscuro detrás"
    },
    "backdropBlur": {
      "type": "boolean",
      "default": true,
      "description": "Aplicar blur al backdrop"
    },
    "snapPoints": {
      "type": "array",
      "default": [30, 60, 90],
      "description": "Puntos de snap al arrastrar (en % de altura de viewport)"
    },
    "animation": {
      "type": "enum",
      "values": ["slide", "fade", "scale"],
      "default": "slide",
      "description": "Tipo de animación al abrir/cerrar"
    },
    "hapticFeedback": {
      "type": "boolean",
      "default": true,
      "description": "Vibración háptica al interactuar"
    },
    "persistent": {
      "type": "boolean",
      "default": false,
      "description": "No cerrar automáticamente (requiere acción manual)"
    },
    "actions": {
      "type": "array",
      "default": [],
      "description": "Botones de acción en el footer del panel"
    },
    "onOpen": {
      "type": "function",
      "description": "Callback al abrir"
    },
    "onClose": {
      "type": "function",
      "description": "Callback al cerrar"
    },
    "onResize": {
      "type": "function",
      "description": "Callback al cambiar de tamaño"
    }
  },

  "features": [
    "Aparece desde abajo (bottom sheet style)",
    "3 tamaños predefinidos: small (30%), medium (60%), full (90%)",
    "Draggable - Arrastrar handle para ajustar altura",
    "Snap points - Se ajusta automáticamente a tamaños predefinidos",
    "Swipe down para cerrar",
    "Tap fuera (backdrop) para cerrar",
    "Backdrop con blur (glassmorphism)",
    "Handle visual para indicar que es arrastrable",
    "Botón de cerrar (X) opcional",
    "Animaciones suaves (slide, fade, scale)",
    "Contenido totalmente flexible (HTML, formularios, listas, etc.)",
    "Footer con actions opcionales",
    "Vibración háptica al interactuar",
    "Responsive - En desktop se comporta como modal centrado",
    "ARIA compliant",
    "Keyboard support (ESC para cerrar)",
    "Focus trap - No se puede tabular fuera del panel",
    "Scroll interno si el contenido es largo",
    "Minimalista y limpio"
  ],

  "accessibility": {
    "role": "dialog",
    "ariaModal": true,
    "ariaLabel": true,
    "keyboard": true,
    "focusable": true,
    "focusTrap": true,
    "screenReader": true
  },

  "example": {
    "component": "floating-panel",
    "variant": "default",
    "size": "medium",
    "props": {
      "title": "Detalles del Documento",
      "content": "<p>Contenido del panel...</p>",
      "showHandle": true,
      "showCloseButton": true,
      "draggable": true,
      "swipeToClose": true,
      "backdropClose": true,
      "backdrop": true,
      "backdropBlur": true,
      "snapPoints": [30, 60, 90],
      "actions": [
        {
          "label": "Cancelar",
          "variant": "secondary",
          "action": "close"
        },
        {
          "label": "Guardar",
          "variant": "primary",
          "action": "submit"
        }
      ]
    }
  }
}
