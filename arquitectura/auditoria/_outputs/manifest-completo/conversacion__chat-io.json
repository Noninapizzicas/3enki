      { "event": "chat.message.saved",    "description": null },
      { "event": "chat.assistant.saved",  "description": null }
    ],
    "subscribes": [
      { "event": "ai.chat.response",  "handler": "onAiResponse",       "extras": {} },
      { "event": "db.query.response", "handler": "onDbQueryResponse",  "extras": {} },
      { "event": "project.activated", "handler": "onProjectActivated", "extras": {} }
    ],
    "provides_eventos": []
  },

  "tools": [],

