                "url": {"type": "string", "format": "uri"},
                "strengths": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "weaknesses": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "features_comparison": {
                  "type": "object",
                  "description": "Features: true=tienen, false=no tienen",
                  "additionalProperties": {"type": "boolean"}
                },
                "pricing": {
                  "type": "object",
                  "properties": {
                    "model": {"type": "string", "enum": ["free", "freemium", "paid", "enterprise"]},
                    "starting_price_usd": {"type": "number"}
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "differentiation": {
            "type": "object",
            "required": ["unique_value_props", "competitive_moats"],
            "properties": {
              "unique_value_props": {
                "type": "array",
                "items": {"type": "string"},
                "minItems": 2
              },
              "competitive_moats": {
                "type": "array",
                "items": {"type": "string"}
              },
              "features_only_we_have": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
