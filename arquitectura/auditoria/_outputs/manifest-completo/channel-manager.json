{
  "_meta": {
    "modulo": "channel-manager",
    "ubicacion": "modules/channel-manager",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "channel-manager",
    "version": "1.0.0",
    "description_oficial": "Registry de canales externos: mapea identificadores externos (chat_id, email, telefono) a proyectos y propositos internos",
    "author": "Event-Core Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": null,
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      {
        "event": "channel.registered",
        "description": "Nuevo canal vinculado a un proyecto"
      },
      {
        "event": "channel.updated",
        "description": "Canal actualizado"
      },
      {
        "event": "channel.removed",
        "description": "Canal desvinculado"
      },
      {
        "event": "channel.resolved",
        "description": "Canal resuelto exitosamente a proyecto+proposito"
      },
      {
        "event": "channel-manager.resolve.response",
        "description": "Respuesta a channel-manager.resolve.request (patron ServiceExecutor)"
      }
    ],
    "subscribes": [
      {
        "event": "channel-manager.resolve.request",
        "handler": "onResolveRequest",
        "extras": {
          "description": "Otro modulo pide resolver un identificador externo via services.call('channel-manager', 'resolve', ...)"
        }
      }
    ],
    "provides_eventos": [
      "channel.registered",
      "channel.updated",
      "channel.removed",
      "channel.resolved",
      "channel.resolve.request"
    ]
  },

  "tools": [
    {
      "name": "channel.resolve",
      "description": "Resuelve un identificador externo (chat_id, email, telefono) al proyecto y proposito al que pertenece.",
      "parameters_required": ["channel_type", "external_id"],
      "parameters_property_names": ["channel_type", "external_id"],
      "parameters_size_chars": 345,
      "parameters_full_path_hint": "modules/channel-manager/module.json#/tools/0/parameters"
    },
    {
      "name": "channel.list",
      "description": "Lista todos los canales registrados, opcionalmente filtrados por proyecto o tipo.",
      "parameters_required": [],
      "parameters_property_names": ["project_id", "channel_type"],
      "parameters_size_chars": 225,
      "parameters_full_path_hint": "modules/channel-manager/module.json#/tools/1/parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "handlers",
    "items": [
      { "domain": "channel", "action": "register", "handler": "handleRegister" },
      { "domain": "channel", "action": "update", "handler": "handleUpdate" },
      { "domain": "channel", "action": "remove", "handler": "handleRemove" },
      { "domain": "channel", "action": "resolve", "handler": "handleResolve" },
      { "domain": "channel", "action": "list", "handler": "handleList" },
      { "domain": "channel", "action": "list-by-project", "handler": "handleListByProject" }
    ]
  },

  "apis_http": [],

  "config_y_deps": {
    "dependencies_declaradas": ["database-manager"],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      {
        "key": "db_project_id",
        "tipo": "string",
        "valor_default": "system"
      },
      {
        "key": "table_name",
        "tipo": "string",
        "valor_default": "channels"
      }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "channel.registered.total",
        "channel.resolved.total",
        "channel.resolve.failed.total",
        "channel.removed.total"
      ],
      "gauges": [
        "channel.count.total",
        "channel.count.by_type"
      ],
      "timings": [
        "channel.resolve.duration"
      ]
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": [
      "modules/channel-manager/schemas/channel.json",
      "modules/channel-manager/schemas/events.json"
    ],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": false,
    "ui_handlers_field_name": "handlers",
    "module_json_bytes": 4213,
    "module_json_lineas": 138,
    "tiene_main_no_estandar": false,
    "warnings": [
      "tier_carga_inferido=null: channel-manager no aparece en ningún tier de system.json.module_load_order.tiers, aunque está en config.modules.enabled",
      "observability.logging.correlation_id=true es un campo extra no capturado por el schema de observability_declarada (solo se captura level y structured)",
      "provides.queries=['channel.resolve.request'] es información adicional no capturada en eventos.provides_eventos (solo se listan provides.events)"
    ]
  }
}
