{
  "name": "{{name}}",
  "version": "2.0.0",
  "_category": "{{category}}",
  "description": "Componente {{name}} para Auto-UI v2",
  "author": "Auto-generated by Plop",
  "generated_at": "{{currentDate}}",

  "props": {
    "variant": {
      "type": "enum",
      "values": {{#if hasVariants}}["primary", "secondary", "success", "warning", "danger", "ghost", "outline"]{{else}}["default"]{{/if}},
      "default": "primary",
      "description": "Visual variant of the component"
    },
    "size": {
      "type": "enum",
      "values": ["sm", "md", "lg"],
      "default": "md",
      "description": "Size of the component"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether the component is disabled"
    },
    "loading": {
      "type": "boolean",
      "default": false,
      "description": "Whether the component is in loading state"
    }
  },

  {{#if hasVariants}}
  "variants": {
    "primary": {
      "bg": "var(--primary)",
      "color": "var(--text)",
      "border": "var(--primary)",
      "hover": {
        "bg": "var(--primary-hover)"
      }
    },
    "secondary": {
      "bg": "var(--bg-card)",
      "color": "var(--text)",
      "border": "var(--border)",
      "hover": {
        "bg": "var(--bg-hover)"
      }
    },
    "success": {
      "bg": "var(--success)",
      "color": "var(--text)",
      "border": "var(--success)",
      "hover": {
        "bg": "var(--success-hover)"
      }
    },
    "warning": {
      "bg": "var(--warning)",
      "color": "var(--text-dark)",
      "border": "var(--warning)",
      "hover": {
        "bg": "var(--warning-hover)"
      }
    },
    "danger": {
      "bg": "var(--danger)",
      "color": "var(--text)",
      "border": "var(--danger)",
      "hover": {
        "bg": "var(--danger-hover)"
      }
    },
    "ghost": {
      "bg": "transparent",
      "color": "var(--primary)",
      "border": "transparent",
      "hover": {
        "bg": "var(--bg-hover)"
      }
    },
    "outline": {
      "bg": "transparent",
      "color": "var(--text)",
      "border": "var(--border)",
      "hover": {
        "bg": "var(--bg-hover)"
      }
    }
  },
  {{/if}}

  "sizes": {
    "sm": {
      "padding": "var(--space-xs) var(--space-sm)",
      "fontSize": "var(--size-sm)",
      "height": "32px",
      "borderRadius": "var(--radius-sm)"
    },
    "md": {
      "padding": "var(--space-sm) var(--space-md)",
      "fontSize": "var(--size-base)",
      "height": "40px",
      "borderRadius": "var(--radius-md)"
    },
    "lg": {
      "padding": "var(--space-md) var(--space-lg)",
      "fontSize": "var(--size-lg)",
      "height": "48px",
      "borderRadius": "var(--radius-lg)"
    }
  },

  "interactions": {
    {{#each interactions}}
    "{{this}}": {
      "enabled": true,
      {{#if (eq this "hold")}}
      "duration": 2000,
      "feedback": "progress-ring",
      "confirm": false
      {{else if (eq this "double-click")}}
      "delay": 300
      {{else if (eq this "swipe")}}
      "threshold": 50,
      "direction": "horizontal"
      {{else if (eq this "drag")}}
      "draggable": true,
      "dropzone": false
      {{else}}
      "debounce": 0
      {{/if}}
    }{{#unless @last}},{{/unless}}
    {{/each}}
  },

  "states": {
    "default": {
      "opacity": 1,
      "cursor": "pointer"
    },
    "hover": {
      "transform": "translateY(-1px)",
      "boxShadow": "var(--shadow-md)",
      "transition": "var(--transition-normal)"
    },
    "active": {
      "transform": "translateY(0)",
      "boxShadow": "var(--shadow-sm)"
    },
    "focus": {
      "outline": "2px solid var(--primary)",
      "outlineOffset": "2px"
    },
    "disabled": {
      "opacity": 0.5,
      "cursor": "not-allowed",
      "pointerEvents": "none"
    },
    "loading": {
      "cursor": "wait",
      "pointerEvents": "none"
    }
  },

  "accessibility": {
    "role": "{{#if (eq category 'core')}}button{{else if (eq category 'form')}}{{name}}{{else}}region{{/if}}",
    "tabindex": 0,
    "aria-label": "{{name}}",
    "keyboard": {
      "Enter": "activate",
      "Space": "activate",
      "Escape": "cancel"
    }
  },

  "animations": {
    "fadeIn": {
      "keyframes": "fadeIn",
      "duration": "var(--transition-normal)"
    },
    "slideIn": {
      "keyframes": "slideIn",
      "duration": "var(--transition-normal)"
    }
  }
}
