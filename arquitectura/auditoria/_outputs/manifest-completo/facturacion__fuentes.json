      {
        "key": "telegram",
        "tipo": "object",
        "valor_default": {
          "tipos_permitidos": ["image/jpeg", "image/png", "image/webp", "image/tiff", "application/pdf"]
        }
      },
      {
        "key": "gmail",
        "tipo": "object",
        "valor_default": {
          "tipos_permitidos": ["application/pdf", "image/jpeg", "image/png"],
          "query_default": "has:attachment is:unread",
          "max_results": 20
        }
      }
    ]
