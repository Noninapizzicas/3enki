{
  "name": "file-drop-zone",
  "category": "input",
  "description": "Zona de carga de archivos genérica con drag & drop, camera capture, clipboard paste y preview",
  "version": "1.0.0",
  "author": "Event Core Team",

  "variants": {
    "image-only": {
      "description": "Solo imágenes con crop opcional",
      "className": "file-drop-zone--image-only",
      "acceptedTypes": ["image/jpeg", "image/png", "image/webp", "image/gif"],
      "icon": "🖼️",
      "dropMessage": "Arrastra imágenes aquí o haz click para seleccionar"
    },
    "document": {
      "description": "Documentos (PDF, Word, Excel)",
      "className": "file-drop-zone--document",
      "acceptedTypes": ["application/pdf", "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/vnd.ms-excel", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"],
      "icon": "📄",
      "dropMessage": "Arrastra documentos aquí (PDF, Word, Excel)"
    },
    "media": {
      "description": "Imágenes y videos",
      "className": "file-drop-zone--media",
      "acceptedTypes": ["image/*", "video/mp4", "video/webm", "video/ogg"],
      "icon": "🎬",
      "dropMessage": "Arrastra imágenes o videos aquí"
    },
    "any": {
      "description": "Cualquier tipo de archivo",
      "className": "file-drop-zone--any",
      "acceptedTypes": ["*/*"],
      "icon": "📁",
      "dropMessage": "Arrastra cualquier archivo aquí"
    }
  },

  "sizes": {
    "sm": {
      "description": "Pequeño - 200px altura",
      "height": "200px",
      "className": "file-drop-zone--sm"
    },
    "md": {
      "description": "Mediano - 300px altura (por defecto)",
      "height": "300px",
      "className": "file-drop-zone--md"
    },
    "lg": {
      "description": "Grande - 400px altura",
      "height": "400px",
      "className": "file-drop-zone--lg"
    },
    "fullscreen": {
      "description": "Pantalla completa",
      "height": "100vh",
      "className": "file-drop-zone--fullscreen"
    }
  },

  "props": {
    "variant": {
      "type": "enum",
      "values": ["image-only", "document", "media", "any"],
      "default": "any",
      "required": false,
      "description": "Tipo de archivos aceptados"
    },
    "size": {
      "type": "enum",
      "values": ["sm", "md", "lg", "fullscreen"],
      "default": "md",
      "required": false,
      "description": "Altura de la zona de drop"
    },
    "acceptedTypes": {
      "type": "array",
      "default": ["*/*"],
      "description": "MIME types aceptados (sobrescribe variant si se especifica)"
    },
    "maxFileSize": {
      "type": "number",
      "default": 10485760,
      "description": "Tamaño máximo por archivo en bytes (por defecto 10MB)"
    },
    "maxFiles": {
      "type": "number",
      "default": 1,
      "description": "Número máximo de archivos permitidos"
    },
    "uploadMode": {
      "type": "enum",
      "values": ["single", "multiple"],
      "default": "single",
      "description": "Modo de carga: un archivo o múltiples"
    },
    "captureMode": {
      "type": "enum",
      "values": ["environment", "user", "none"],
      "default": "none",
      "description": "Modo de captura de cámara: trasera (environment), frontal (user), o sin cámara (none)"
    },
    "showPreview": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar preview de archivos antes de subir"
    },
    "enablePaste": {
      "type": "boolean",
      "default": true,
      "description": "Permitir pegar archivos desde clipboard (Ctrl+V)"
    },
    "enableCrop": {
      "type": "boolean",
      "default": false,
      "description": "Habilitar crop de imágenes antes de subir (solo para variant image-only)"
    },
    "dropMessage": {
      "type": "string",
      "default": "Arrastra archivos aquí o haz click para seleccionar",
      "description": "Mensaje mostrado en la zona de drop"
    },
    "icon": {
      "type": "string",
      "default": "📁",
      "description": "Emoji o icono mostrado en la zona de drop"
    },
    "endpoint": {
      "type": "string",
      "required": true,
      "description": "Endpoint para subir archivos (ej: /modules/storage/upload)"
    },
    "uploadOnSelect": {
      "type": "boolean",
      "default": false,
      "description": "Subir automáticamente al seleccionar (true) o esperar confirmación (false)"
    },
    "showProgress": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar barra de progreso durante upload"
    },
    "thumbnailSize": {
      "type": "string",
      "default": "120px",
      "description": "Tamaño de thumbnails en preview"
    },
    "compressionQuality": {
      "type": "number",
      "default": 0.8,
      "description": "Calidad de compresión para imágenes (0-1)"
    },
    "compressionEnabled": {
      "type": "boolean",
      "default": false,
      "description": "Comprimir imágenes antes de subir"
    },
    "onUploadSuccess": {
      "type": "function",
      "description": "Callback ejecutado cuando upload es exitoso"
    },
    "onUploadError": {
      "type": "function",
      "description": "Callback ejecutado cuando upload falla"
    },
    "metadata": {
      "type": "object",
      "default": {},
      "description": "Metadata adicional enviada con el upload"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Deshabilitar la zona de drop"
    },
    "ariaLabel": {
      "type": "string",
      "default": "Zona de carga de archivos",
      "description": "Label para accesibilidad"
    }
  },

  "features": [
    "Drag & drop de archivos con feedback visual",
    "Click para abrir selector de archivos nativo",
    "Captura desde cámara (mobile) con elección frontal/trasera",
    "Paste desde clipboard (Ctrl+V o Cmd+V)",
    "Preview de archivos con thumbnails",
    "Validación de tipo MIME y tamaño",
    "Progress bar durante upload",
    "Soporte múltiples archivos con conteo",
    "Compresión opcional de imágenes",
    "Crop opcional de imágenes (variant image-only)",
    "Estados visuales: idle, dragging, uploading, success, error",
    "Accesible con keyboard navigation",
    "Responsive y mobile-first",
    "Integración con cualquier endpoint backend"
  ],

  "accessibility": {
    "role": "region",
    "ariaLabel": true,
    "keyboard": true,
    "focusable": true,
    "screenReader": true,
    "dropInstructions": "Arrastra archivos o presiona Enter para seleccionar"
  },

  "events": {
    "fileSelected": "Disparado cuando se seleccionan archivos",
    "uploadStart": "Disparado al iniciar upload",
    "uploadProgress": "Disparado durante upload con porcentaje",
    "uploadSuccess": "Disparado cuando upload es exitoso",
    "uploadError": "Disparado cuando upload falla",
    "fileRemoved": "Disparado cuando se elimina un archivo del preview",
    "validationError": "Disparado cuando validación falla (tipo/tamaño)"
  },

  "example": {
    "component": "file-drop-zone",
    "variant": "image-only",
    "size": "md",
    "props": {
      "maxFiles": 5,
      "maxFileSize": 5242880,
      "captureMode": "environment",
      "showPreview": true,
      "enableCrop": true,
      "compressionEnabled": true,
      "compressionQuality": 0.8,
      "endpoint": "/modules/menu-generator/upload",
      "uploadOnSelect": false,
      "dropMessage": "Sube fotos de la carta de menú",
      "icon": "📸",
      "metadata": {
        "module": "menu-generator",
        "type": "menu-card"
      }
    }
  },

  "useCases": [
    "Menu-generator: Subir fotos de cartas de menú",
    "Productos: Subir imágenes de productos",
    "Chat: Adjuntar archivos en conversaciones",
    "Admin: Subir documentos, logos, facturas",
    "Cocina: Subir fotos de platos preparados",
    "Cobros: Adjuntar comprobantes de pago"
  ]
}
