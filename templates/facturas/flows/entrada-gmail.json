{
  "id": "entrada-gmail",
  "name": "Entrada Facturas - Gmail",
  "description": "Recoge facturas desde Gmail, las guarda en inbox y registra en BD",
  "version": "1.0.0",
  "enabled": false,
  "schedule": {
    "cron": "{{ config.schedule.gmail }}",
    "timezone": "{{ config.schedule.timezone }}"
  },
  "trigger": {
    "event": "flow.trigger",
    "filter": {
      "flowId": {
        "$endsWith": ":entrada-gmail"
      }
    }
  },
  "steps": [
    {
      "id": "verificar-gmail-habilitado",
      "type": "condition",
      "if": "{{ config.gmail.enabled }}",
      "then": "log-inicio",
      "else": "log-deshabilitado"
    },
    {
      "id": "log-deshabilitado",
      "type": "log",
      "level": "debug",
      "message": "Gmail deshabilitado para proyecto {{ project.id }}"
    },
    {
      "id": "log-inicio",
      "type": "log",
      "level": "info",
      "message": "Buscando facturas en Gmail: {{ config.gmail.account }}"
    },
    {
      "id": "crear-directorio",
      "type": "service",
      "service": "fs",
      "action": "mkdir",
      "path": "@/projects/{{ project.id }}/{{ config.storage.inbox }}",
      "onError": "continue"
    },
    {
      "id": "buscar-emails",
      "type": "service",
      "service": "local.gmail",
      "action": "search",
      "account": "{{ config.gmail.account }}",
      "query": "{{ config.gmail.searchQuery }}",
      "timeout": 60000
    },
    {
      "id": "verificar-emails",
      "type": "condition",
      "if": "{{ steps.buscar-emails.data.total > 0 }}",
      "then": "procesar-emails",
      "else": "log-sin-emails"
    },
    {
      "id": "log-sin-emails",
      "type": "log",
      "level": "info",
      "message": "No se encontraron emails nuevos con facturas"
    },
    {
      "id": "procesar-emails",
      "type": "parallel",
      "forEach": "{{ steps.buscar-emails.data.emails }}",
      "as": "email",
      "steps": [
        {
          "id": "procesar-adjuntos",
          "type": "parallel",
          "forEach": "{{ email.attachments }}",
          "as": "adjunto",
          "steps": [
            {
              "id": "descargar-adjunto",
              "type": "service",
              "service": "local.gmail",
              "action": "downloadAttachment",
              "account": "{{ config.gmail.account }}",
              "messageId": "{{ email.id }}",
              "attachmentId": "{{ adjunto.id }}",
              "timeout": 30000
            },
            {
              "id": "generar-nombre",
              "type": "set",
              "variables": {
                "extension": "{{ adjunto.filename.split('.').pop() }}",
                "nombreArchivo": "gmail_{{ date }}_{{ email.id.substring(0, 8) }}_{{ adjunto.filename }}"
              }
            },
            {
              "id": "copiar-archivo",
              "type": "service",
              "service": "fs",
              "action": "copy",
              "source": "{{ steps.descargar-adjunto.path }}",
              "destination": "@/projects/{{ project.id }}/{{ config.storage.inbox }}/{{ variables.nombreArchivo }}",
              "timeout": 30000
            },
            {
              "id": "registrar-bd",
              "type": "service",
              "service": "local.facturas-db",
              "action": "registrar",
              "proyecto": "{{ project.id }}",
              "nombre_archivo": "{{ variables.nombreArchivo }}",
              "source": "gmail",
              "path_original": "@/projects/{{ project.id }}/{{ config.storage.inbox }}/{{ variables.nombreArchivo }}",
              "origen": {
                "account": "{{ config.gmail.account }}",
                "messageId": "{{ email.id }}",
                "subject": "{{ email.subject }}",
                "from": "{{ email.from }}",
                "date": "{{ email.date }}",
                "originalFilename": "{{ adjunto.filename }}"
              },
              "timeout": 10000
            },
            {
              "id": "emitir-factura-recibida",
              "type": "emit",
              "event": "factura.recibida",
              "data": {
                "projectId": "{{ project.id }}",
                "id": "{{ steps.registrar-bd.data.id }}",
                "source": "gmail",
                "archivo": {
                  "nombre": "{{ variables.nombreArchivo }}",
                  "path": "@/projects/{{ project.id }}/{{ config.storage.inbox }}/{{ variables.nombreArchivo }}",
                  "mimeType": "{{ adjunto.mimeType }}"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "marcar-leidos",
      "type": "service",
      "service": "local.gmail",
      "action": "markAsRead",
      "account": "{{ config.gmail.account }}",
      "messageIds": "{{ steps.buscar-emails.data.emails.map(e => e.id) }}",
      "timeout": 30000
    },
    {
      "id": "log-completado",
      "type": "log",
      "level": "info",
      "message": "Gmail procesado: {{ steps.buscar-emails.data.total }} emails, facturas registradas"
    }
  ]
}