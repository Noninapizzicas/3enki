{
  "name": "facturas",
  "version": "3.0.0",
  "description": "Procesamiento comercial de facturas: pipeline step-based con agentes IA, validacion y observabilidad. Pipeline v2 (Intake → Convert → Prepare → OCR → Structure (IA) → Validate → Store).",
  "author": "Event-Core Team",
  "language": "es",
  "main": "index.js",
  "provides": {
    "events": [
      "factura.recibida",
      "factura.procesada",
      "factura.error",
      "factura.exportada"
    ]
  },
  "events": {
    "publishes": [
      {
        "event": "factura.recibida",
        "description": "Factura aceptada como entrada del pipeline (lleva project_id top-level + correlation_id + timestamp)."
      },
      {
        "event": "factura.procesada",
        "description": "Pipeline completo OK. Lleva factura_id si aplica + duplicate flag."
      },
      {
        "event": "factura.error",
        "description": "Pipeline fallido o archivo de entrada invalido. Lleva code canonico + message."
      },
      {
        "event": "factura.exportada",
        "description": "CSV fiscal generado y persistido. Lleva project_id + total + ruta del archivo."
      },
      {
        "event": "telegram.send_message.request",
        "description": "Notificacion fire-and-forget al chat de Telegram que envio la factura. Consumido por telegram-service."
      }
    ],
    "subscribes": [
      {
        "event": "factura.entrada",
        "handler": "onFacturaEntrada",
        "description": "Entrada al pipeline desde fuentes externas (telegram, gmail, manual, etc.)."
      }
    ]
  },
  "ui_handlers": [
    {
      "domain": "facturas",
      "action": "procesar",
      "handler": "handleProcesar",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "facturas",
      "action": "subir",
      "handler": "handleSubir",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "facturas",
      "action": "reprocesar",
      "handler": "handleReprocesar",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "facturas",
      "action": "listar",
      "handler": "handleListar",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "facturas",
      "action": "obtener",
      "handler": "handleObtener",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "facturas",
      "action": "actualizar",
      "handler": "handleActualizar",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "facturas",
      "action": "estadisticas",
      "handler": "handleEstadisticas",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "facturas",
      "action": "exportar",
      "handler": "handleExportar",
      "type": "workspace_module",
      "zone": "barra_modulos"
    },
    {
      "domain": "facturas",
      "action": "pipeline-metrics",
      "handler": "handlePipelineMetrics",
      "type": "workspace_module",
      "zone": "barra_modulos"
    }
  ],
  "tools": [
    {
      "name": "facturas.procesar",
      "description": "Procesa un archivo de factura (PDF/imagen) y extrae datos estructurados via OCR + IA. Devuelve los campos fiscales detectados.",
      "handler": "handleToolProcesar",
      "parameters": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "ID del proyecto"
          },
          "filePath": {
            "type": "string",
            "description": "Ruta absoluta al archivo (PDF, JPG, PNG, WebP, TIFF)"
          },
          "source": {
            "type": "string",
            "enum": [
              "telegram",
              "gmail",
              "manual"
            ],
            "default": "manual",
            "description": "Origen del archivo"
          }
        },
        "required": [
          "projectId",
          "filePath"
        ]
      },
      "errores_conocidos": [
        "INVALID_INPUT",
        "RESOURCE_NOT_FOUND",
        "UPSTREAM_TIMEOUT",
        "UPSTREAM_INVALID_RESPONSE"
      ]
    },
    {
      "name": "facturas.listar",
      "description": "Lista facturas del proyecto con filtros opcionales por estado, fechas y limite.",
      "handler": "handleToolListar",
      "parameters": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "ID del proyecto"
          },
          "estado": {
            "type": "string",
            "enum": [
              "pendiente",
              "procesando",
              "procesada",
              "error",
              "exportada"
            ],
            "description": "Filtrar por estado"
          },
          "limit": {
            "type": "number",
            "default": 50,
            "description": "Maximo de resultados"
          }
        },
        "required": [
          "projectId"
        ]
      },
      "errores_conocidos": [
        "INVALID_INPUT",
        "UPSTREAM_UNREACHABLE"
      ]
    },
    {
      "name": "facturas.estadisticas",
      "description": "Devuelve estadisticas agregadas de facturas del proyecto: totales, pendientes, procesadas, errores, exportadas, por origen.",
      "handler": "handleToolEstadisticas",
      "parameters": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "ID del proyecto"
          }
        },
        "required": [
          "projectId"
        ]
      },
      "errores_conocidos": [
        "INVALID_INPUT",
        "UPSTREAM_UNREACHABLE"
      ]
    }
  ],
  "config": {
    "ocr": {
      "provider": "local.google-vision",
      "hint": "DOCUMENT_TEXT_DETECTION",
      "languages": [
        "es",
        "en"
      ]
    },
    "ai": {
      "providers": [
        "deepseek",
        "anthropic",
        "openai",
        "gemini"
      ],
      "temperature": 0.1,
      "maxTokens": 2000
    },
    "processing": {
      "dpi": 300,
      "maxWidth": 2400,
      "maxHeight": 3200,
      "sharp": {
        "grayscale": true,
        "normalize": true,
        "sharpen": true
      }
    },
    "timeouts": {
      "pdfConvert": 60000,
      "sharp": 30000,
      "ocr": 60000,
      "ai": 60000,
      "db": 30000
    },
    "persistence": {
      "type": "mixed",
      "owner": "DB de facturas via provider local.facturas-db (ServiceExecutor.call); archivos de entrada y CSV export en filesystem del proyecto.",
      "paths": [
        "data/projects/<projectId>/storage/pendientes/<ts>_<safe_name>",
        "data/projects/<projectId>/storage/export/facturas_<yyyymmdd>.csv"
      ],
      "concurrency": "single-writer-per-archivo"
    }
  },
  "tracing": {
    "propaga_correlation_id": true
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "facturas.procesadas.total",
        "facturas.errores.total",
        "facturas.subidas.total",
        "facturas.errors"
      ],
      "histograms": [
        "facturas.procesamiento.duration"
      ]
    }
  }
}
