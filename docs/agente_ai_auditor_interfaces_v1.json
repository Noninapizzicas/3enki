{
  "artifact_name": "agente_ai_auditor_interfaces_v1",
  "version": "1.0.0",
  "input_schema": {
    "pantallas": [
      {
        "id": "string",
        "descripcion": "string",
        "componentes": [
          {
            "tipo": "BotonOperativo|IndicadorEstado|Otro",
            "props": "dict",
            "color_hex": "string",
            "contraste_ratio": "float",
            "icono": "string|emoji|nombre",
            "tamanio_px": {
              "ancho": "int",
              "alto": "int"
            },
            "separacion_px": "int",
            "ritmo_hz": "float|optional"
          }
        ]
      }
    ]
  },
  "reglas": [
    {
      "id": "R1",
      "descripcion": "Color debe mapear a una única intención",
      "peso": 0.25
    },
    {
      "id": "R2",
      "descripcion": "Contraste ≥ 4.5:1 (AA)",
      "peso": 0.2
    },
    {
      "id": "R3",
      "descripcion": "Tap target ≥ 56 px y separación ≥ 8 px",
      "peso": 0.2
    },
    {
      "id": "R4",
      "descripcion": "Ritmo (parpadeo) solo en crítico y ≤1.5 s",
      "peso": 0.15
    },
    {
      "id": "R5",
      "descripcion": "Un símbolo = un significado (sin ambigüedad)",
      "peso": 0.2
    }
  ],
  "escoring": {
    "umbral_aprobacion": 0.85,
    "categoria": [
      {
        "rango": [
          0.85,
          1.0
        ],
        "label": "Cumple"
      },
      {
        "rango": [
          0.7,
          0.85
        ],
        "label": "Mejorable"
      },
      {
        "rango": [
          0.0,
          0.7
        ],
        "label": "No cumple"
      }
    ]
  },
  "salida": {
    "pantalla_id": "string",
    "score_total": "0-1",
    "incumplimientos": [
      {
        "regla_id": "R#",
        "descripcion": "string",
        "evidencia": "string",
        "sugerencia": "string"
      }
    ],
    "sugerencias_priorizadas": [
      {
        "impacto": "alto|medio|bajo",
        "accion": "string",
        "justificacion": "string"
      }
    ]
  },
  "pseudocodigo": [
    "parse(input)",
    "for pantalla in pantallas:",
    "  score=0; pesos=∑reglas.peso",
    "  for regla in reglas:",
    "     evaluar cumplimiento → añadir (peso) si cumple",
    "  normalizar score=score/pesos",
    "  generar listado incumplimientos+sugerencias",
    "  clasificar por umbral"
  ]
}