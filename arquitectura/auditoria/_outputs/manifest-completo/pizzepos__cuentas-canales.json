  "eventos": {
    "publica": [
      { "event": "cuenta.creada",          "description": "Cuenta creada en cualquier canal (mesa/telefono/llevar/glovo/whatsapp)" },
      { "event": "cuenta.cerrada",         "description": "Cuenta cerrada en cualquier canal" },
      { "event": "mesa.abierta",           "description": "Mesa abierta para servicio" },
      { "event": "mesa.cerrada",           "description": "Mesa cerrada y liberada" },
      { "event": "telefono.pedido_creado", "description": "Pedido telefónico creado" },
      { "event": "llevar.ticket_creado",   "description": "Ticket para llevar creado" },
      { "event": "glovo.pedido_recibido",  "description": "Pedido Glovo recibido desde la plataforma" },
      { "event": "glovo.pedido_aceptado",  "description": "Pedido Glovo aceptado por el restaurante" },
      { "event": "glovo.pedido_listo",     "description": "Pedido Glovo listo para rider" },
      { "event": "whatsapp.pedido_creado", "description": "Pedido creado desde conversación WhatsApp" },
      { "event": "whatsapp.pedido_listo",  "description": "Pedido WhatsApp listo, cliente notificado" }
    ],
    "subscribes": [
      {
        "event": "cobro.procesado",
        "handler": "onCobroProcesado",
        "extras": { "description": "Cobro completado — cierra cuenta en el canal correspondiente por prefijo" }
      },
      {
        "event": "pedido.creado",
        "handler": "MesaStrategy.onPedidoCreado",
        "extras": { "description": "Pedido creado para mesa — actualiza total" }
      },
      {
        "event": "cocina.pedido_listo",
        "handler": "TelefonoStrategy/LlevarStrategy/GlovoStrategy/WhatsAppStrategy.onCocinaPedidoListo",
        "extras": { "description": "Pedido listo en cocina — notifica canal telefono/llevar/glovo/whatsapp" }
      }
    ],
    "provides_eventos": [
      "mesa.abierta",
      "mesa.camarero_asignado",
      "mesa.cerrada",
      "mesa.renombrada",
      "telefono.llamada_detectada",
