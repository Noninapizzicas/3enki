      "parameters_property_names": ["project_id", "regla"],
      "parameters_size_chars": 215,
      "parameters_full_path_hint": "modules/pizzepos/carta-scheduler/module.json → tools[0].parameters"
    },
    {
      "name": "scheduler.listar_reglas",
