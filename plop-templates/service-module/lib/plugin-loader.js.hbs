/**
 * Plugin Loader for {{titleCase name}} Service
 *
 * Descubre y carga plugins de tipo {{name}}-engine desde:
 * - plugins/{{name}}/{plugin-name}/engine.json
 *
 * Cada plugin puede ser:
 * - local: true → requiere handler.js en el mismo directorio
 * - local: false → usa configuración HTTP para API externa
 */

const fs = require('fs');
const path = require('path');

class PluginLoader {
  constructor(logger, config = {}) {
    this.logger = logger;
    this.config = config;
    this.pluginsPath = path.resolve(
      config.pluginsPath || path.join(process.cwd(), 'plugins', '{{name}}')
    );
  }

  /**
   * Descubre todos los plugins disponibles
   * @returns {Array} Lista de configuraciones de plugins
   */
  async discover() {
    const plugins = [];

    if (!fs.existsSync(this.pluginsPath)) {
      this.logger.info('plugin-loader.path_not_found', {
        path: this.pluginsPath
      });
      return plugins;
    }

    const dirs = fs.readdirSync(this.pluginsPath, { withFileTypes: true })
      .filter(d => d.isDirectory())
      .map(d => d.name);

    for (const dir of dirs) {
      try {
        const plugin = await this.loadPlugin(dir);
        if (plugin) {
          plugins.push(plugin);
        }
      } catch (error) {
        this.logger.error('plugin-loader.load_error', {
          plugin: dir,
          error: error.message
        });
      }
    }

    return plugins;
  }

  /**
   * Carga un plugin específico
   * @param {string} pluginName - Nombre del directorio del plugin
   * @returns {Object|null} Configuración del plugin o null
   */
  async loadPlugin(pluginName) {
    const pluginPath = path.join(this.pluginsPath, pluginName);
    const engineJsonPath = path.join(pluginPath, 'engine.json');

    // Verificar que existe engine.json
    if (!fs.existsSync(engineJsonPath)) {
      this.logger.warn('plugin-loader.no_engine_json', {
        plugin: pluginName
      });
      return null;
    }

    // Leer configuración
    const config = JSON.parse(fs.readFileSync(engineJsonPath, 'utf-8'));

    // Validar tipo
    if (config.type !== '{{name}}-engine') {
      this.logger.warn('plugin-loader.invalid_type', {
        plugin: pluginName,
        expected: '{{name}}-engine',
        got: config.type
      });
      return null;
    }

    // Si es local, cargar handler
    if (config.local) {
      const handlerPath = path.join(pluginPath, 'handler.js');

      if (!fs.existsSync(handlerPath)) {
        this.logger.error('plugin-loader.handler_not_found', {
          plugin: pluginName,
          path: handlerPath
        });
        return null;
      }

      config.handler = require(handlerPath);
      config.handlerPath = handlerPath;
    }

    config.pluginPath = pluginPath;

    this.logger.info('plugin-loader.loaded', {
      plugin: config.name,
      local: config.local,
      capabilities: config.capabilities
    });

    return config;
  }

  /**
   * Recarga un plugin específico
   * @param {string} pluginName - Nombre del plugin
   * @returns {Object|null} Configuración actualizada
   */
  async reload(pluginName) {
    // Limpiar cache de require si es local
    const pluginPath = path.join(this.pluginsPath, pluginName);
    const handlerPath = path.join(pluginPath, 'handler.js');

    if (require.cache[handlerPath]) {
      delete require.cache[handlerPath];
    }

    return this.loadPlugin(pluginName);
  }

  /**
   * Valida la estructura de un engine.json
   * @param {Object} config - Configuración a validar
   * @returns {Object} { valid: boolean, errors: string[] }
   */
  validate(config) {
    const errors = [];

    if (!config.name) errors.push('Missing required field: name');
    if (!config.type) errors.push('Missing required field: type');

    if (config.local === undefined) {
      errors.push('Missing required field: local (boolean)');
    }

    if (!config.local) {
      if (!config.request?.url) {
        errors.push('Remote engine requires request.url');
      }
      if (!config.credentialKey) {
        errors.push('Remote engine requires credentialKey');
      }
    }

    return {
      valid: errors.length === 0,
      errors
    };
  }
}

module.exports = PluginLoader;
