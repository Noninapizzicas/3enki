{
  "name": "{{name}}",
  "version": "2.0.0",
  "type": "dashboard",
  "description": "Dashboard with tabs layout for {{name}}",
  "author": "{{author}}",
  "generated_at": "{{currentDate}}",

  "permissions": ["admin", "user"],

  "layout": {
    "type": "tabs",
    "config": {
      "variant": "pills",
      "defaultTab": "overview",
      "persistent": true,
      "urlSync": true
    }
  },

  "header": {
    "title": "{{titleCase name}}",
    "icon": "{{icon}}",
    "actions": [
      {
        "label": "Crear Nuevo",
        "icon": "➕",
        "action": "navigate",
        "target": "/auto-ui/{{name}}/form",
        "variant": "primary",
        "permissions": ["admin"]
      }
    ]
  },

  "tabs": [
    {
      "id": "overview",
      "label": "Resumen",
      "icon": "📊",
      "sections": [
        {
          "id": "stats_overview",
          "widget": "stat-card",
          "config": {
            "label": "Total",
            "value": "@compute.count(@data.items)",
            "icon": "📈",
            "color": "primary",
            "trend": "+15%",
            "trendDirection": "up"
          }
        },
        {
          "id": "stats_active",
          "widget": "stat-card",
          "config": {
            "label": "Activos",
            "value": "@compute.count(@data.items, 'status', 'active')",
            "icon": "✓",
            "color": "success"
          }
        },
        {
          "id": "stats_pending",
          "widget": "stat-card",
          "config": {
            "label": "Pendientes",
            "value": "@compute.count(@data.items, 'status', 'pending')",
            "icon": "⏳",
            "color": "warning"
          }
        },
        {
          "id": "chart_status",
          "widget": "chart",
          "config": {
            "title": "Distribución por Estado",
            "type": "doughnut",
            "data": {
              "labels": ["Activos", "Pendientes", "Inactivos"],
              "datasets": [{
                "data": [
                  "@compute.count(@data.items, 'status', 'active')",
                  "@compute.count(@data.items, 'status', 'pending')",
                  "@compute.count(@data.items, 'status', 'inactive')"
                ],
                "backgroundColor": ["var(--success)", "var(--warning)", "var(--muted)"]
              }]
            }
          }
        }
      ]
    },
    {
      "id": "data",
      "label": "Datos",
      "icon": "📋",
      "badge": {
        "text": "@compute.count(@data.items)",
        "variant": "primary"
      },
      "sections": [
        {
          "id": "main_table",
          "widget": "table-advanced",
          "config": {
            "title": "Todos los {{titleCase name}}",
            "dataSource": "@data.items",
            "columns": [
              {
                "key": "id",
                "label": "ID",
                "sortable": true,
                "width": "80px"
              },
              {
                "key": "name",
                "label": "Nombre",
                "sortable": true,
                "searchable": true
              },
              {
                "key": "status",
                "label": "Estado",
                "sortable": true,
                "filterable": true,
                "format": "badge"
              },
              {
                "key": "priority",
                "label": "Prioridad",
                "sortable": true,
                "filterable": true
              },
              {
                "key": "createdAt",
                "label": "Creado",
                "sortable": true,
                "format": "date"
              }
            ],
            "sortable": true,
            "filterable": true,
            "searchable": true,
            "paginated": true,
            "pageSize": 15,
            "exportable": true,
            "actions": [
              {
                "label": "Ver",
                "icon": "👁",
                "action": "navigate",
                "target": "/auto-ui/{{name}}/detail/:id",
                "permissions": ["admin", "user"]
              },
              {
                "label": "Editar",
                "icon": "✏️",
                "action": "navigate",
                "target": "/auto-ui/{{name}}/form/:id",
                "permissions": ["admin"]
              },
              {
                "label": "Eliminar",
                "icon": "🗑️",
                "action": "delete",
                "endpoint": "/modules/{{name}}/items/:id",
                "permissions": ["admin"],
                "confirm": true
              }
            ]
          }
        }
      ]
    },
    {
      "id": "analytics",
      "label": "Analíticas",
      "icon": "📈",
      "permissions": ["admin"],
      "sections": [
        {
          "id": "chart_timeline",
          "widget": "chart",
          "config": {
            "title": "Tendencia en el Tiempo",
            "type": "line",
            "data": {
              "labels": "@data.timeline.labels",
              "datasets": [{
                "label": "Creados",
                "data": "@data.timeline.created",
                "borderColor": "var(--primary)",
                "fill": false
              }, {
                "label": "Completados",
                "data": "@data.timeline.completed",
                "borderColor": "var(--success)",
                "fill": false
              }]
            },
            "options": {
              "responsive": true,
              "scales": {
                "y": {
                  "beginAtZero": true
                }
              }
            }
          }
        },
        {
          "id": "stats_metrics",
          "widget": "stat-card",
          "config": {
            "label": "Promedio Diario",
            "value": "@compute.avg(@data.dailyMetrics, 'count')",
            "icon": "📊",
            "color": "info"
          }
        },
        {
          "id": "stats_growth",
          "widget": "stat-card",
          "config": {
            "label": "Crecimiento",
            "value": "@compute.percentage(@data.thisWeek, @data.lastWeek)",
            "icon": "📈",
            "color": "success",
            "trend": "+25%",
            "trendDirection": "up"
          }
        }
      ]
    },
    {
      "id": "activity",
      "label": "Actividad",
      "icon": "🔔",
      "sections": [
        {
          "id": "recent_activity",
          "widget": "activity-feed",
          "config": {
            "title": "Actividad Reciente",
            "maxItems": 20,
            "showTimestamp": true,
            "showAvatar": true,
            "showActions": true,
            "activities": "@data.recentActivity",
            "emptyMessage": "No hay actividad reciente",
            "dateFormat": "relative",
            "groupBy": "date"
          }
        }
      ]
    },
    {
      "id": "settings",
      "label": "Configuración",
      "icon": "⚙️",
      "permissions": ["admin"],
      "sections": [
        {
          "id": "settings_card",
          "widget": "card",
          "config": {
            "title": "Configuración del Módulo",
            "variant": "outlined",
            "content": {
              "type": "form",
              "fields": [
                {
                  "name": "auto_refresh",
                  "component": "checkbox",
                  "variant": "switch",
                  "props": {
                    "label": "Auto-actualización",
                    "value": true
                  }
                },
                {
                  "name": "notifications",
                  "component": "checkbox",
                  "variant": "switch",
                  "props": {
                    "label": "Notificaciones",
                    "value": true
                  }
                },
                {
                  "name": "refresh_interval",
                  "component": "select",
                  "props": {
                    "label": "Intervalo de actualización",
                    "options": [
                      {"value": "5000", "label": "5 segundos"},
                      {"value": "10000", "label": "10 segundos"},
                      {"value": "30000", "label": "30 segundos"},
                      {"value": "60000", "label": "1 minuto"}
                    ],
                    "default": "10000"
                  }
                }
              ]
            }
          }
        },
        {
          "id": "info_card",
          "widget": "card",
          "config": {
            "title": "Información del Sistema",
            "variant": "default",
            "content": {
              "type": "info",
              "items": [
                {
                  "label": "Versión",
                  "value": "2.0.0",
                  "icon": "🏷️"
                },
                {
                  "label": "Estado",
                  "value": "Operacional",
                  "color": "var(--success)"
                },
                {
                  "label": "Última sincronización",
                  "value": "@env.LAST_SYNC",
                  "format": "date"
                }
              ]
            }
          }
        }
      ]
    }
  ],

  "mqtt": {
    "enabled": true,
    "topics": [
      "{{name}}.created",
      "{{name}}.updated",
      "{{name}}.deleted"
    ],
    "auto_refresh": true
  }
}
