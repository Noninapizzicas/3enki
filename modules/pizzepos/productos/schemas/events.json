{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pizzepos.com/schemas/producto-events.json",
  "title": "Producto Events Schema",
  "description": "Esquemas de eventos del módulo productos",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID único del evento"
        },
        "event_type": {
          "type": "string",
          "pattern": "^[a-z]+\\.[a-z_]+$",
          "description": "Tipo de evento"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID de correlación"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp del evento"
        },
        "producer": {
          "type": "string",
          "minLength": 1,
          "description": "Módulo productor"
        },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Versión del schema"
        },
        "payload": {
          "type": "object",
          "description": "Datos del evento"
        }
      },
      "additionalProperties": false
    },

    "producto_creado": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "producto.creado"},
            "payload": {
              "type": "object",
              "required": ["producto_id", "nombre", "categoria", "precio"],
              "properties": {
                "producto_id": {"type": "string"},
                "nombre": {"type": "string"},
                "emoji": {"type": "string"},
                "categoria": {"type": "string"},
                "precio": {"type": "number"},
                "ingredientes_base": {"type": "array"},
                "alergenos": {"type": "array"},
                "menu_source_id": {"type": "string"},
                "created_at": {"type": "string", "format": "date-time"}
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "producto_actualizado": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "producto.actualizado"},
            "payload": {
              "type": "object",
              "required": ["producto_id", "cambios"],
              "properties": {
                "producto_id": {"type": "string"},
                "cambios": {
                  "type": "object",
                  "minProperties": 1
                },
                "updated_at": {"type": "string", "format": "date-time"}
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "producto_eliminado": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "producto.eliminado"},
            "payload": {
              "type": "object",
              "required": ["producto_id"],
              "properties": {
                "producto_id": {"type": "string"},
                "motivo": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "catalogo_actualizado": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "catalogo.actualizado"},
            "payload": {
              "type": "object",
              "required": ["menu_id", "estadisticas"],
              "properties": {
                "menu_id": {"type": "string"},
                "estadisticas": {
                  "type": "object",
                  "properties": {
                    "productos_nuevos": {"type": "integer"},
                    "productos_actualizados": {"type": "integer"},
                    "productos_desactivados": {"type": "integer"},
                    "categorias_nuevas": {"type": "integer"}
                  }
                },
                "sync_duration": {"type": "integer"}
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
