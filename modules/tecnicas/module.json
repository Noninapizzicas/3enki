{
  "name": "tecnicas",
  "version": "1.0.0",
  "description": "Libreria de tecnicas culinarias codificadas del proyecto (esferificacion, confitar, marinada, etc.) con parametros. Cada tecnica es referenciable desde recetas y prototipos por tecnica_id. Modulo del subsistema-recetario (ver arquitectura/decisiones/_contratos/subsistema-recetario.contract.json).",
  "author": "Enki",
  "language": "es",
  "tier": "tier_4_dominio",

  "events": {
    "publishes": [
      {
        "event":               "tecnica.creada",
        "description":         "Una tecnica nueva fue codificada en la libreria del proyecto.",
        "response_schema_ref": "arquitectura/decisiones/_schemas/subsistema-recetario/tecnica.creada.schema.json"
      },
      {
        "event":               "tecnica.actualizada",
        "description":         "Parametros o metadata de una tecnica existente cambiaron.",
        "response_schema_ref": "arquitectura/decisiones/_schemas/subsistema-recetario/tecnica.actualizada.schema.json"
      }
    ],
    "subscribes": [
      { "event": "project.activated",     "handler": "onProjectActivated",  "description": "Cachea base_path del proyecto activado." },
      { "event": "project.get.response",  "handler": "onProjectGetResponse","description": "Resuelve project.get pendiente por request_id." },
      { "event": "fs.read.response",      "handler": "onFsReadResponse",    "description": "Resuelve lectura pendiente por request_id." },
      { "event": "fs.write.response",     "handler": "onFsWriteResponse",   "description": "Resuelve escritura pendiente por request_id." },

      { "event": "tecnicas.codificar",    "handler": "onCodificar",       "description": "Tool LLM: codificar tecnica nueva." },
      { "event": "tecnicas.listar",       "handler": "onListar",          "description": "Tool LLM: listar tecnicas." },
      { "event": "tecnicas.obtener",      "handler": "onObtener",         "description": "Tool LLM: obtener tecnica por id." },
      { "event": "tecnicas.actualizar",   "handler": "onActualizar",      "description": "Tool LLM: actualizar tecnica." },
      { "event": "tecnicas.parametros",   "handler": "onParametros",      "description": "Tool LLM: obtener solo los parametros de una tecnica." }
    ]
  },

  "apis": [],

  "tools": [
    {
      "name":        "tecnicas.codificar",
      "description": "Codificar una tecnica culinaria nueva en la libreria del proyecto. La tecnica queda referenciable por tecnica_id desde recetas y prototipos.",
      "handler":     "onCodificar",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id":    { "type": "string", "description": "ID del proyecto activo." },
          "nombre":        { "type": "string", "description": "Nombre de la tecnica (1-100 chars)." },
          "categoria":     { "type": "string", "description": "Familia: cocciones, fermentaciones, esferificaciones, marinadas, etc. (1-50 chars)." },
          "parametros":    { "type": "object", "description": "Parametros propios de la tecnica (tiempos, temperaturas, ratios, etc.). Opcional." },
          "instrucciones": { "type": "string", "description": "Pasos para ejecutarla. Opcional, max 5000 chars." },
          "materiales":    { "type": "array",  "items": { "type": "string" }, "description": "Materiales/herramientas. Opcional." },
          "user_id":       { "type": "string", "description": "ID del usuario que codifica. Opcional (default 'default')." }
        },
        "required": ["project_id", "nombre", "categoria"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UPSTREAM_TIMEOUT", "UPSTREAM_UNREACHABLE", "UNKNOWN_ERROR"]
    },
    {
      "name":        "tecnicas.listar",
      "description": "Listar las tecnicas codificadas del proyecto. Acepta filtro opcional por categoria.",
      "handler":     "onListar",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string", "description": "ID del proyecto activo." },
          "categoria":  { "type": "string", "description": "Filtro opcional por categoria." }
        },
        "required": ["project_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UPSTREAM_TIMEOUT", "UNKNOWN_ERROR"]
    },
    {
      "name":        "tecnicas.obtener",
      "description": "Obtener una tecnica por id.",
      "handler":     "onObtener",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string", "description": "ID del proyecto activo." },
          "tecnica_id": { "type": "string", "description": "ID de la tecnica." }
        },
        "required": ["project_id", "tecnica_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    },
    {
      "name":        "tecnicas.actualizar",
      "description": "Actualizar campos de una tecnica existente. Solo cambia los campos presentes en 'cambios'.",
      "handler":     "onActualizar",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string", "description": "ID del proyecto activo." },
          "tecnica_id": { "type": "string", "description": "ID de la tecnica a actualizar." },
          "cambios":    { "type": "object", "description": "Objeto con los campos a actualizar (nombre, categoria, parametros, instrucciones, materiales)." },
          "user_id":    { "type": "string", "description": "Opcional." }
        },
        "required": ["project_id", "tecnica_id", "cambios"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    },
    {
      "name":        "tecnicas.parametros",
      "description": "Obtener solo los parametros de una tecnica (sin instrucciones ni materiales). Util para que el LLM consulte rapido sin payload extra.",
      "handler":     "onParametros",
      "parameters": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string", "description": "ID del proyecto activo." },
          "tecnica_id": { "type": "string", "description": "ID de la tecnica." }
        },
        "required": ["project_id", "tecnica_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND"]
    }
  ],

  "config": {
    "data_file_pattern":          "data/projects/{slug}/tecnicas.json",
    "persistence":                "json-per-project",
    "max_nombre_length":          100,
    "max_categoria_length":       50,
    "max_instrucciones_length":   5000,
    "max_material_length":        100,
    "project_get_timeout_ms":     5000,
    "fs_request_timeout_ms":      5000
  },

  "observability": {
    "metrics": {
      "counters": [
        "tecnicas.codificar.total",
        "tecnicas.actualizar.total",
        "tecnicas.codificar.errors",
        "tecnicas.listar.errors",
        "tecnicas.obtener.errors",
        "tecnicas.actualizar.errors",
        "tecnicas.parametros.errors",
        "tecnicas.publish_error",
        "tecnicas.persist.errors"
      ],
      "gauges": [
        "tecnicas.activas.count"
      ],
      "timings": [
        "tecnicas.codificar.duration",
        "tecnicas.actualizar.duration"
      ]
    }
  }
}
