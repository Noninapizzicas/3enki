{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enki.local/arquitectura/decisiones/lifecycle.schema.json",
  "title": "Lifecycle Convention — Output Schema",
  "description": "Schema strict de la instancia lifecycle.json. Valida arquitectura/decisiones/_outputs/lifecycle.json. additionalProperties=false en todos los niveles.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_meta",
    "regla",
    "signatures",
    "core_api",
    "state_machine",
    "auto_wiring_sequence",
    "hot_reload_sequence",
    "error_handling",
    "config_namespacing",
    "detection_patterns"
  ],

  "properties": {
    "_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["convencion", "version", "creado_en", "contrato_referencia"],
      "properties": {
        "convencion":          { "const": "lifecycle" },
        "version":             { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "creado_en":           { "type": "string", "format": "date" },
        "contrato_referencia": { "type": "string", "pattern": "^arquitectura/decisiones/_contratos/" },
        "supersedes_nota":     { "type": ["string", "null"] }
      }
    },

    "regla": {
      "type": "string",
      "minLength": 80
    },

    "signatures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["onLoad", "onUnload"],
      "properties": {
        "onLoad":   { "$ref": "#/$defs/signature_onLoad" },
        "onUnload": { "$ref": "#/$defs/signature_onUnload" }
      }
    },

    "core_api": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/core_api_field" }
        },
        "optional": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/core_api_field" }
        }
      }
    },

    "state_machine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["estados", "transiciones"],
      "properties": {
        "estados": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "descripcion", "es_terminal", "es_fallo"],
            "properties": {
              "id":           { "enum": ["unloaded", "loading", "loaded", "unloading", "failed", "unloaded_with_errors"] },
              "descripcion":  { "type": "string", "minLength": 10 },
              "es_terminal":  { "type": "boolean" },
              "es_fallo":     { "type": "boolean" }
            }
          }
        },
        "transiciones": {
          "type": "array",
          "minItems": 6,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["desde", "hasta", "disparada_por", "condicion"],
            "properties": {
              "desde":         { "type": "string" },
              "hasta":         { "type": "string" },
              "disparada_por": { "enum": ["loader", "modulo", "fs.watch", "timeout"] },
              "condicion":     { "type": "string", "minLength": 10 }
            }
          }
        }
      }
    },

    "auto_wiring_sequence": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/sequence_step" }
    },

    "hot_reload_sequence": {
      "type": "array",
      "minItems": 12,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/sequence_step" }
    },

    "error_handling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arranque", "apagado"],
      "properties": {
        "arranque": { "$ref": "#/$defs/error_handling_block" },
        "apagado":  { "$ref": "#/$defs/error_handling_block" }
      }
    },

    "config_namespacing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["access_pattern", "scope", "prohibited_patterns", "merge_pattern"],
      "properties": {
        "access_pattern":      { "type": "string", "minLength": 5 },
        "scope":               { "type": "string", "minLength": 10 },
        "prohibited_patterns": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 5 }
        },
        "merge_pattern":       { "type": "string", "minLength": 10 }
      }
    },

    "detection_patterns": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prohibited_signatures",
        "forbidden_core_internals",
        "module_scope_state_regex",
        "silent_catch_in_load_regex",
        "state_machine_event_pattern",
        "reservation_keywords",
        "release_keywords"
      ],
      "properties": {
        "prohibited_signatures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$" }
        },
        "forbidden_core_internals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "module_scope_state_regex":    { "type": "string", "minLength": 5 },
        "silent_catch_in_load_regex":  { "type": "string", "minLength": 5 },
        "state_machine_event_pattern": { "type": "string", "minLength": 5 },
        "reservation_keywords": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 3 }
        },
        "release_keywords": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 3 }
        }
      }
    }
  },

  "$defs": {
    "signature_onLoad": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signature", "is_async", "params", "returns", "semantics"],
      "properties": {
        "signature": { "const": "async onLoad(core)" },
        "is_async":  { "const": true },
        "params": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "required"],
            "properties": {
              "name":     { "const": "core" },
              "type":     { "type": "string" },
              "required": { "const": true }
            }
          }
        },
        "returns":   { "type": "string" },
        "semantics": { "type": "string", "minLength": 20 }
      }
    },
    "signature_onUnload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signature", "is_async", "params", "returns", "semantics", "timeout_ms"],
      "properties": {
        "signature":  { "const": "async onUnload()" },
        "is_async":   { "const": true },
        "params":     { "type": "array", "maxItems": 0 },
        "returns":    { "type": "string" },
        "semantics":  { "type": "string", "minLength": 20 },
        "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 60000 }
      }
    },
    "core_api_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "descripcion", "ejemplo_uso"],
      "properties": {
        "name":         { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
        "type":         { "type": "string", "minLength": 3 },
        "descripcion":  { "type": "string", "minLength": 10 },
        "ejemplo_uso":  { "type": "string", "minLength": 5 }
      }
    },
    "sequence_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["orden", "accion", "responsable"],
      "properties": {
        "orden":       { "type": "integer", "minimum": 1, "maximum": 20 },
        "accion":      { "type": "string", "minLength": 10 },
        "responsable": { "enum": ["loader", "modulo"] },
        "nota":        { "type": ["string", "null"] }
      }
    },
    "error_handling_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["on_error_actions", "observable_event", "recovery"],
      "properties": {
        "on_error_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 5 }
        },
        "observable_event": { "type": "string", "minLength": 5 },
        "recovery":         { "type": "string", "minLength": 5 },
        "timeout_ms":       { "type": ["integer", "null"], "minimum": 1000, "maximum": 60000 }
      }
    }
  }
}
