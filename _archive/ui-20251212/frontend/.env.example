# Event-Core Frontend Configuration
# Copy this to .env and customize for your setup

# Event-Core API URL
PUBLIC_API_URL=http://localhost:3000

# MQTT WebSocket URL (browser needs WebSocket, not TCP)
PUBLIC_MQTT_URL=ws://localhost:9001

# Core ID (must match Event-Core config)
PUBLIC_CORE_ID=core-a

# Environment (development, staging, production)
PUBLIC_ENV=development
