{
  "name": "esp32-flasher",
  "version": "2.0.0",
  "description": "Flash de firmware a ESP32 via serial (esptool/platformio) y monitor serial en tiempo real. Tambien hace bridge MQTT enki/<project>/debug/<device> → flash.serial_output para debug remoto. Multi-tenant con project_id opcional propagado a todos los publishes.",
  "author": "Enki",
  "language": "en",
  "main": "index.js",
  "tracing": {
    "propaga_correlation_id": true
  },
  "events": {
    "publishes": [
      { "event": "flash.started",       "description": "Flash iniciado en un puerto serial. project_id top-level (si fue parte del request) + correlation_id + timestamp." },
      { "event": "flash.progress",      "description": "Progreso de flash (porcentaje, etapa, mensaje). project_id top-level + correlation_id + timestamp." },
      { "event": "flash.completed",     "description": "Flash completado exitosamente. project_id top-level + correlation_id + timestamp." },
      { "event": "flash.failed",        "description": "Flash fallo (cancelacion, exit_code != 0, spawn_error). project_id top-level + correlation_id + timestamp." },
      { "event": "flash.serial_output", "description": "Linea de salida del monitor serial o de debug remoto MQTT (port=remote:<deviceId>). project_id top-level + correlation_id + timestamp." }
    ],
    "subscribes": [
      { "event": "firmware.build_completed", "handler": "onBuildCompleted", "description": "Notifica que hay un binario listo para flashear (auto-suggest en list-ports)." }
    ]
  },
  "ui_handlers": [
    { "domain": "flash", "action": "list-ports",     "handler": "handleListPorts",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "start",          "handler": "handleStart",       "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "status",         "handler": "handleStatus",      "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "cancel",         "handler": "handleCancel",      "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "monitor-start",  "handler": "handleMonitorStart","type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "monitor-stop",   "handler": "handleMonitorStop", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "monitor-send",   "handler": "handleMonitorSend", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "history",        "handler": "handleHistory",     "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "health",         "handler": "handleHealth",      "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "debug-control",  "handler": "handleDebugControl","type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "debug-stream",   "handler": "handleDebugStream", "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "flash", "action": "serial-relay",   "handler": "handleSerialRelay", "type": "system_panel", "zone": "lateral_derecha" }
  ],
  "tools": [
    {
      "name": "flash.list_ports",
      "description": "Detecta puertos serial conectados (USB) donde puede haber un ESP32",
      "handler": "handleListPorts",
      "parameters": { "type": "object", "properties": {} },
      "errores_conocidos": []
    },
    {
      "name": "flash.start",
      "description": "Flashea un firmware.bin a un ESP32 conectado por USB. Asincrono con eventos de progreso.",
      "handler": "handleStart",
      "parameters": {
        "type": "object",
        "properties": {
          "port": { "type": "string", "description": "Puerto serial (ej: /dev/ttyUSB0)" },
          "binary_path": { "type": "string", "description": "Ruta al archivo .bin" },
          "method": { "type": "string", "enum": ["esptool", "platformio"], "description": "Metodo de flash (default esptool)" },
          "baud": { "type": "number", "description": "Baud rate (default 460800)" },
          "flash_mode": { "type": "string", "enum": ["qio", "qout", "dio", "dout"] },
          "flash_freq": { "type": "string", "enum": ["20m", "26m", "40m", "80m"] },
          "erase_before": { "type": "boolean" },
          "project_dir": { "type": "string", "description": "Directorio del proyecto PlatformIO (auto-detect si esta vacio)" },
          "project_id": { "type": "string", "description": "Multi-tenant project_id (opcional)" }
        },
        "required": ["port", "binary_path"]
      },
      "errores_conocidos": [
        { "code": "INVALID_INPUT",          "cuando": "port o binary_path ausentes, o port con formato invalido" },
        { "code": "RESOURCE_NOT_FOUND",     "cuando": "binary_path no existe o port no accesible o no se encuentra platformio.ini" },
        { "code": "CONFLICT_STATE",         "cuando": "puerto ya en uso por otro flash activo" },
        { "code": "UPSTREAM_UNREACHABLE", "cuando": "esptool/platformio no estan en PATH" }
      ]
    },
    {
      "name": "flash.status",
      "description": "Estado de las operaciones de flash activas y puertos detectados",
      "handler": "handleStatus",
      "parameters": {
        "type": "object",
        "properties": { "flash_id": { "type": "string", "description": "ID de flash especifico (opcional)" } }
      },
      "errores_conocidos": [
        { "code": "RESOURCE_NOT_FOUND", "cuando": "flash_id no existe ni en activos ni en historial" }
      ]
    },
    {
      "name": "flash.history",
      "description": "Historial de operaciones de flash realizadas",
      "handler": "handleHistory",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": { "type": "number", "description": "Numero maximo de entradas (default 50)" },
          "port": { "type": "string", "description": "Filtrar por puerto" }
        }
      },
      "errores_conocidos": []
    },
    {
      "name": "flash.cancel",
      "description": "Cancela un flash en curso",
      "handler": "handleCancel",
      "parameters": {
        "type": "object",
        "properties": { "flash_id": { "type": "string" } },
        "required": ["flash_id"]
      },
      "errores_conocidos": [
        { "code": "INVALID_INPUT",      "cuando": "flash_id ausente" },
        { "code": "RESOURCE_NOT_FOUND", "cuando": "flash_id no encontrado o ya termino" }
      ]
    },
    {
      "name": "flash.monitor_start",
      "description": "Inicia monitor serial en tiempo real en un puerto. Las lineas se publican como eventos flash.serial_output.",
      "handler": "handleMonitorStart",
      "parameters": {
        "type": "object",
        "properties": {
          "port": { "type": "string" },
          "baud": { "type": "number", "description": "Baud rate (default 115200)" },
          "project_id": { "type": "string" }
        },
        "required": ["port"]
      },
      "errores_conocidos": [
        { "code": "INVALID_INPUT",  "cuando": "port ausente" },
        { "code": "CONFLICT_STATE", "cuando": "monitor ya activo o flash en ese puerto" }
      ]
    },
    {
      "name": "flash.monitor_stop",
      "description": "Detiene el monitor serial de un puerto",
      "handler": "handleMonitorStop",
      "parameters": {
        "type": "object",
        "properties": { "port": { "type": "string" } },
        "required": ["port"]
      },
      "errores_conocidos": [
        { "code": "INVALID_INPUT",      "cuando": "port ausente" },
        { "code": "RESOURCE_NOT_FOUND", "cuando": "no hay monitor activo en ese puerto" }
      ]
    },
    {
      "name": "flash.monitor_send",
      "description": "Envia datos al puerto serial activo del monitor",
      "handler": "handleMonitorSend",
      "parameters": {
        "type": "object",
        "properties": {
          "port": { "type": "string" },
          "data": { "type": "string", "description": "Texto a enviar (se anade newline al final)" }
        },
        "required": ["port", "data"]
      },
      "errores_conocidos": [
        { "code": "INVALID_INPUT",      "cuando": "port o data ausentes" },
        { "code": "RESOURCE_NOT_FOUND", "cuando": "no hay monitor activo en ese puerto" },
        { "code": "UNKNOWN_ERROR",   "cuando": "fallo de escritura al puerto" }
      ]
    }
  ],
  "dependencies": [],
  "config": {
    "esptool_path": "esptool",
    "platformio_path": "platformio",
    "default_baud": 115200,
    "flash_baud": 460800,
    "monitor_baud": 115200,
    "flash_timeout_ms": 120000,
    "serial_patterns": ["/dev/ttyUSB*", "/dev/ttyACM*"],
    "max_monitor_buffer": 5000,
    "max_history": 200,
    "persistence": {
      "type": "in-memory",
      "owner": "ESP32FlasherModule (Map activeFlashes + Map activeMonitors + Array flashHistory + Map debugBuffers)",
      "external": "MQTT bridge para enki/<project>/debug/<device> + spawn esptool/platformio + cat/stty para serial",
      "restart_resilient": false,
      "concurrency": "single-instance",
      "lost_on_restart": ["activeFlashes", "activeMonitors", "flashHistory", "lastBuild", "debugBuffers"]
    }
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "esp32-flasher.started.total",
        "esp32-flasher.completed.total",
        "esp32-flasher.failed.total",
        "esp32-flasher.cancelled.total",
        "esp32-flasher.monitor_started.total",
        "esp32-flasher.errors"
      ],
      "gauges": [
        "esp32-flasher.active.count",
        "esp32-flasher.monitors.count",
        "esp32-flasher.ports_detected.count"
      ],
      "timings": [
        "esp32-flasher.duration"
      ]
    }
  }
}
