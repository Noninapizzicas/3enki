{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scheduler/events",
  "title": "Scheduler Events",
  "description": "Event schemas for scheduler module",
  "definitions": {
    "job_created": {
      "type": "object",
      "required": ["job", "timestamp"],
      "properties": {
        "job": { "$ref": "job.json" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "job_updated": {
      "type": "object",
      "required": ["job", "timestamp"],
      "properties": {
        "job": { "$ref": "job.json" },
        "changes": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "job_deleted": {
      "type": "object",
      "required": ["jobId", "jobName", "timestamp"],
      "properties": {
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "job_enabled": {
      "type": "object",
      "required": ["jobId", "jobName", "timestamp"],
      "properties": {
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "job_disabled": {
      "type": "object",
      "required": ["jobId", "jobName", "timestamp"],
      "properties": {
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "job_triggered": {
      "type": "object",
      "required": ["jobId", "jobName", "executionId", "timestamp"],
      "properties": {
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "executionId": { "type": "string" },
        "trigger": {
          "type": "object",
          "properties": {
            "type": { "type": "string" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "job_completed": {
      "type": "object",
      "required": ["jobId", "jobName", "executionId", "duration", "timestamp"],
      "properties": {
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "executionId": { "type": "string" },
        "duration": { "type": "number", "description": "Execution duration in ms" },
        "result": { "description": "Action result" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "job_failed": {
      "type": "object",
      "required": ["jobId", "jobName", "executionId", "error", "timestamp"],
      "properties": {
        "jobId": { "type": "string" },
        "jobName": { "type": "string" },
        "executionId": { "type": "string" },
        "error": { "type": "string" },
        "duration": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  }
}
