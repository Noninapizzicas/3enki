{
  "name": "code-executor",
  "version": "2.1.0",
  "description": "Shell command and script execution for AI with security controls",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",
  "provides": {
    "events": [
      "shell.executed",
      "shell.error",
      "shell.process.started",
      "shell.process.stopped"
    ]
  },
  "events": {
    "publishes": [
      {
        "event": "shell.executed",
        "description": "Command executed successfully"
      },
      {
        "event": "shell.error",
        "description": "Command execution failed"
      },
      {
        "event": "shell.process.started",
        "description": "Background process started"
      },
      {
        "event": "shell.process.stopped",
        "description": "Background process stopped"
      }
    ],
    "subscribes": [
      {
        "event": "shell.exec.request",
        "handler": "onExecRequest"
      }
    ]
  },
  "tools": [
    {
      "name": "shell.exec",
      "description": "Ejecuta un comando shell. Retorna stdout, stderr y exitCode. Timeout por defecto: 30s.",
      "handler": "handleToolExec",
      "confirmation": true,
      "errores_conocidos": [
        "INVALID_INPUT",
        "PERMISSION_DENIED",
        "UPSTREAM_TIMEOUT"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "Comando a ejecutar"
          },
          "cwd": {
            "type": "string",
            "description": "Directorio de trabajo (opcional)"
          },
          "timeout": {
            "type": "number",
            "description": "Timeout en ms (default: 30000)"
          },
          "env": {
            "type": "object",
            "description": "Variables de entorno adicionales"
          }
        },
        "required": [
          "command"
        ]
      }
    },
    {
      "name": "shell.script",
      "description": "Ejecuta un archivo de script (bash, python, node). Detecta intérprete automáticamente.",
      "handler": "handleToolScript",
      "confirmation": true,
      "errores_conocidos": [
        "INVALID_INPUT",
        "PERMISSION_DENIED",
        "RESOURCE_NOT_FOUND",
        "UPSTREAM_TIMEOUT"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "ID del proyecto"
          },
          "scriptPath": {
            "type": "string",
            "description": "Ruta al script dentro del proyecto"
          },
          "args": {
            "type": "array",
            "description": "Argumentos para el script",
            "items": {
              "type": "string"
            }
          },
          "timeout": {
            "type": "number",
            "description": "Timeout en ms (default: 60000)"
          }
        },
        "required": [
          "projectId",
          "scriptPath"
        ]
      }
    },
    {
      "name": "shell.background",
      "description": "Inicia un proceso en segundo plano (ej: servidor dev). Retorna PID para control.",
      "handler": "handleToolBackground",
      "confirmation": true,
      "errores_conocidos": [
        "INVALID_INPUT",
        "PERMISSION_DENIED",
        "RATE_LIMITED"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "Comando a ejecutar"
          },
          "cwd": {
            "type": "string",
            "description": "Directorio de trabajo"
          },
          "name": {
            "type": "string",
            "description": "Nombre para identificar el proceso"
          }
        },
        "required": [
          "command"
        ]
      }
    },
    {
      "name": "shell.kill",
      "description": "Detiene un proceso en segundo plano por PID o nombre.",
      "handler": "handleToolKill",
      "errores_conocidos": [
        "INVALID_INPUT",
        "RESOURCE_NOT_FOUND"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "pid": {
            "type": "number",
            "description": "PID del proceso"
          },
          "name": {
            "type": "string",
            "description": "Nombre del proceso (si se usó en shell.background)"
          }
        }
      }
    },
    {
      "name": "shell.list",
      "description": "Lista procesos en segundo plano activos.",
      "handler": "handleToolList",
      "errores_conocidos": [],
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "code.orquestar",
      "description": "Ejecuta un script JS cuya UNICA capacidad es el bus de eventos (bus.publish, bus.publishAndWait). Cura la regla \"una operacion por turno\": en vez de N tool-calls fragiles, escribe UN script que itera/ramifica sobre el bus y se ejecuta determinista. Sandbox capability-based: sin require/process/fs/red. Devuelve { resultado, logs }. Doble timeout corta runaway.",
      "handler": "handleToolOrquestar",
      "confirmation": true,
      "errores_conocidos": [
        "INVALID_INPUT",
        "UPSTREAM_TIMEOUT",
        "EXEC_FAILED"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string",
            "description": "Cuerpo JS async. Puede usar await bus.publishAndWait(topic,data,{timeout_ms}) y bus.publish(topic,data). Usa return para devolver el resultado."
          },
          "project_id": {
            "type": "string",
            "description": "Proyecto (se inyecta en cada evento del bus)."
          },
          "correlation_id": {
            "type": "string",
            "description": "Correlacion (se inyecta y propaga). Opcional."
          },
          "timeout_ms": {
            "type": "number",
            "description": "Timeout total en ms (default 30000, max 60000)."
          }
        },
        "required": [
          "codigo"
        ]
      }
    }
  ],
  "config": {
    "defaultTimeout": 30000,
    "maxTimeout": 300000,
    "maxProcesses": 10,
    "allowedCommands": [],
    "blockedCommands": [
      "rm -rf /",
      "rm -rf /*",
      "mkfs",
      "dd if=/dev/zero",
      ":(){:|:&};:",
      "chmod -R 777 /",
      "chown -R",
      "sudo rm",
      "sudo dd",
      "sudo mkfs",
      "> /dev/sda",
      "mv /* /dev/null"
    ],
    "blockedPatterns": [
      "rm\\s+-rf\\s+/[^a-zA-Z]",
      ">(\\s+)?/dev/[hs]d",
      "\\|\\s*sh\\s*$",
      "\\|\\s*bash\\s*$",
      "curl.*\\|.*sh",
      "wget.*\\|.*sh"
    ],
    "shell": "/bin/sh",
    "projectsPath": "./data/projects",
    "orquestarTimeout": 30000,
    "orquestarMaxTimeout": 60000
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "code-executor.exec.total",
        "code-executor.exec.success",
        "code-executor.exec.error",
        "code-executor.exec.timeout",
        "code-executor.exec.blocked",
        "code-executor.errors"
      ]
    },
    "tracing": {
      "propaga_correlation_id": true
    }
  }
}
