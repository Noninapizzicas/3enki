            },
            "status": "mitigating",
            "affected_releases": ["2025-Q3-R1"],
            "last_reviewed": "2025-01-20"
          },
          {
            "risk_id": "RISK-002",
            "description": "Competidor lanza feature similar antes que nosotros",
            "category": "market",
            "probability": "medium",
            "impact": "medium",
            "risk_score": 9,
            "mitigation": {
