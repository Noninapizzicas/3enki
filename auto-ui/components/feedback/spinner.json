{
  "name": "spinner",
  "category": "feedback",
  "description": "Indicadores de carga animados (spinners)",
  "version": "2.0.0",

  "variants": {
    "circle": {
      "description": "Spinner circular (default)",
      "className": "spinner spinner-circle",
      "animation": "spin"
    },
    "dots": {
      "description": "Tres puntos animados",
      "className": "spinner spinner-dots",
      "animation": "pulse"
    },
    "bars": {
      "description": "Barras verticales",
      "className": "spinner spinner-bars",
      "animation": "wave"
    },
    "ring": {
      "description": "Anillo con un segmento",
      "className": "spinner spinner-ring",
      "animation": "rotate"
    },
    "dualRing": {
      "description": "Anillo doble",
      "className": "spinner spinner-dual-ring",
      "animation": "rotate"
    },
    "bounce": {
      "description": "Círculos con bounce",
      "className": "spinner spinner-bounce",
      "animation": "bounce"
    },
    "pulse": {
      "description": "Círculo pulsante",
      "className": "spinner spinner-pulse",
      "animation": "pulse"
    },
    "ellipsis": {
      "description": "Puntos suspensivos animados",
      "className": "spinner spinner-ellipsis",
      "animation": "wave"
    }
  },

  "sizes": {
    "xs": {
      "description": "Extra pequeño (16px)",
      "className": "spinner-xs",
      "size": "16px"
    },
    "sm": {
      "description": "Pequeño (24px)",
      "className": "spinner-sm",
      "size": "24px"
    },
    "md": {
      "description": "Mediano (32px, default)",
      "className": "",
      "size": "32px"
    },
    "lg": {
      "description": "Grande (48px)",
      "className": "spinner-lg",
      "size": "48px"
    },
    "xl": {
      "description": "Extra grande (64px)",
      "className": "spinner-xl",
      "size": "64px"
    }
  },

  "colors": {
    "primary": {
      "description": "Color primario",
      "className": "spinner-primary"
    },
    "success": {
      "description": "Color de éxito",
      "className": "spinner-success"
    },
    "warning": {
      "description": "Color de advertencia",
      "className": "spinner-warning"
    },
    "danger": {
      "description": "Color de error",
      "className": "spinner-danger"
    },
    "info": {
      "description": "Color informativo",
      "className": "spinner-info"
    },
    "white": {
      "description": "Blanco (para fondos oscuros)",
      "className": "spinner-white"
    },
    "muted": {
      "description": "Gris apagado",
      "className": "spinner-muted"
    }
  },

  "props": {
    "label": {
      "type": "string",
      "description": "Texto descriptivo"
    },
    "labelPosition": {
      "type": "string",
      "enum": ["top", "right", "bottom", "left"],
      "default": "bottom",
      "description": "Posición del label"
    },
    "speed": {
      "type": "string",
      "enum": ["slow", "normal", "fast"],
      "default": "normal",
      "description": "Velocidad de animación"
    },
    "overlay": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar como overlay (cubre contenido)"
    },
    "fullscreen": {
      "type": "boolean",
      "default": false,
      "description": "Modo fullscreen"
    },
    "inline": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar inline (no centrado)"
    },
    "backdrop": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar backdrop (requiere overlay)"
    }
  },

  "speeds": {
    "slow": {
      "duration": "2s"
    },
    "normal": {
      "duration": "1s"
    },
    "fast": {
      "duration": "0.6s"
    }
  },

  "features": {
    "delay": {
      "enabled": false,
      "duration": 300,
      "description": "Retrasar aparición para evitar flash en cargas rápidas"
    },
    "timeout": {
      "enabled": false,
      "duration": 30000,
      "fallbackMessage": "Esto está tardando más de lo esperado..."
    }
  },

  "accessibility": {
    "role": "status",
    "ariaLabel": "Cargando",
    "ariaLive": "polite",
    "ariaBusy": true
  },

  "example": {
    "component": "spinner",
    "variant": "circle",
    "size": "md",
    "color": "primary",
    "props": {
      "label": "Cargando...",
      "labelPosition": "bottom"
    }
  },

  "overlayExample": {
    "component": "spinner",
    "variant": "ring",
    "size": "lg",
    "color": "white",
    "props": {
      "overlay": true,
      "backdrop": true,
      "label": "Procesando...",
      "labelPosition": "bottom"
    }
  },

  "inlineExample": {
    "component": "spinner",
    "variant": "dots",
    "size": "sm",
    "color": "primary",
    "props": {
      "inline": true,
      "label": "Guardando"
    }
  },

  "buttonExample": {
    "description": "Spinner dentro de un botón",
    "usage": "<button disabled><spinner variant='circle' size='xs' color='white' inline /> Cargando...</button>"
  }
}
