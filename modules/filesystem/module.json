{
  "name": "filesystem",
  "version": "2.0.0",
  "description": "Operaciones de filesystem para todo el sistema. Acceso scopeado por proyecto activo (storage/ subdir) + system mode (Sistema project = root). 14 ui_handlers + 14 tools del LLM + 14 bus handlers fs.*.request/response + 3 spanish handlers. v2.0.0: 5 helpers POC2, todos los handlers shape canonico { status, data | error: { code, message, details? } }, _publicarEvento canonical correlation_id + timestamp.",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",

  "ui_handlers": [
    { "domain": "fs", "action": "list",       "handler": "handleList" },
    { "domain": "fs", "action": "read",       "handler": "handleRead" },
    { "domain": "fs", "action": "write",      "handler": "handleWrite" },
    { "domain": "fs", "action": "edit",       "handler": "handleEdit" },
    { "domain": "fs", "action": "delete",     "handler": "handleDelete" },
    { "domain": "fs", "action": "mkdir",      "handler": "handleMkdir" },
    { "domain": "fs", "action": "move",       "handler": "handleMove" },
    { "domain": "fs", "action": "copy",       "handler": "handleCopy" },
    { "domain": "fs", "action": "search",     "handler": "handleSearch" },
    { "domain": "fs", "action": "info",       "handler": "handleInfo" },
    { "domain": "fs", "action": "append",     "handler": "handleAppend" },
    { "domain": "fs", "action": "cleanup",    "handler": "handleCleanup" },
    { "domain": "fs", "action": "stats",      "handler": "handleStats" },
    { "domain": "fs", "action": "set_work_dir", "handler": "handleSetWorkDir" },
    { "domain": "fs", "action": "get_work_dir", "handler": "handleGetWorkDir" }
  ],

  "tools": [
    {
      "name": "fs.list",
      "description": "Lista archivos y carpetas de un directorio.",
      "handler": "handleList",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string", "description": "Ruta del directorio", "default": "/" } }
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.read",
      "description": "Lee el contenido de un archivo. La response incluye hash (SHA-256 hex) que el caller puede pasar como expected_hash a fs.write para versionado optimista (CAS).",
      "handler": "handleRead",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string", "description": "Ruta del archivo" } },
        "required": ["path"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.write",
      "description": "Escribe contenido a un archivo (crea si no existe). Soporta versionado optimista opt-in: si llega expected_hash, verifica que el contenido actual en disco lo cumple antes de escribir; si no coincide devuelve CONFLICT_STATE con current_hash y expected_hash. Sin expected_hash, comportamiento legacy (sobrescribe sin verificar).",
      "handler": "handleWrite",
      "parameters": {
        "type": "object",
        "properties": {
          "path":          { "type": "string", "description": "Ruta del archivo" },
          "content":       { "type": "string", "description": "Contenido a escribir" },
          "expected_hash": { "type": "string", "description": "SHA-256 hex del contenido actual del archivo (obtenido del fs.read previo). Si se pasa, fs.write valida que el disco no cambio desde el read y devuelve CONFLICT_STATE si difiere. Opcional; omitir para escritura sin verificacion (crear nuevo, single-writer puro, scripts de migracion)." }
        },
        "required": ["path", "content"]
      },
      "errores_conocidos": ["INVALID_INPUT", "CONFLICT_STATE", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.edit",
      "description": "Edita un archivo JSON aplicando JSON Patch (RFC 6902). El caller declara INTENCIONES (op:add con path /recetas/- para append a array, etc.) en lugar de componer el archivo entero — cierra el bug 'salmorejo perdido'. v1: solo op:add. CAS opcional via expected_hash. Si el archivo no existe: RESOURCE_NOT_FOUND. Si JSON malformado o patch invalido: INVALID_INPUT.",
      "handler": "handleEdit",
      "parameters": {
        "type": "object",
        "properties": {
          "path":          { "type": "string", "description": "Ruta del archivo JSON a editar" },
          "patches":       {
            "type": "array",
            "description": "Array de operaciones JSON Patch (RFC 6902). v1 solo soporta op:add. Cada patch tiene { op, path, value }. path usa JSON Pointer (RFC 6901): / al principio, / como separador, '-' como ultimo segmento para append a array, indices numericos para insertar en posicion. Ejemplo: { op:'add', path:'/recetas/-', value:{...} } anyade al final del array 'recetas'.",
            "items": {
              "type": "object",
              "properties": {
                "op":    { "type": "string", "enum": ["add"], "description": "Operacion. v1 solo soporta 'add'." },
                "path":  { "type": "string", "description": "JSON Pointer (RFC 6901) a la posicion donde aplicar la operacion." },
                "value": { "description": "Valor a insertar/anyadir. Puede ser cualquier JSON." }
              },
              "required": ["op", "path", "value"]
            }
          },
          "expected_hash": { "type": "string", "description": "SHA-256 hex del contenido actual del archivo (obtenido del fs.read previo). Si se pasa, fs.edit valida CAS antes de aplicar patches. Opcional." }
        },
        "required": ["path", "patches"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "CONFLICT_STATE", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.delete",
      "description": "Elimina un archivo o carpeta.",
      "handler": "handleDelete",
      "confirmation": true,
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string", "description": "Ruta a eliminar" } },
        "required": ["path"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.mkdir",
      "description": "Crea un directorio.",
      "handler": "handleMkdir",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string", "description": "Ruta del directorio a crear" } },
        "required": ["path"]
      },
      "errores_conocidos": ["INVALID_INPUT", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.move",
      "description": "Mueve un archivo o carpeta.",
      "handler": "handleMove",
      "confirmation": true,
      "parameters": {
        "type": "object",
        "properties": {
          "from": { "type": "string", "description": "Ruta origen" },
          "to":   { "type": "string", "description": "Ruta destino" }
        },
        "required": ["from", "to"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.copy",
      "description": "Copia un archivo.",
      "handler": "handleCopy",
      "parameters": {
        "type": "object",
        "properties": {
          "from": { "type": "string", "description": "Ruta origen" },
          "to":   { "type": "string", "description": "Ruta destino" }
        },
        "required": ["from", "to"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.search",
      "description": "Busca archivos por nombre o contenido.",
      "handler": "handleSearch",
      "parameters": {
        "type": "object",
        "properties": {
          "query":   { "type": "string", "description": "Texto a buscar" },
          "path":    { "type": "string", "description": "Directorio base", "default": "/" },
          "content": { "type": "boolean", "description": "Buscar en contenido", "default": false }
        },
        "required": ["query"]
      },
      "errores_conocidos": ["INVALID_INPUT", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.info",
      "description": "Obtiene informacion de un archivo o carpeta.",
      "handler": "handleInfo",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string", "description": "Ruta del archivo o carpeta" } },
        "required": ["path"]
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.cleanup",
      "description": "Limpia archivos temporales que tengan mas de N horas.",
      "handler": "handleCleanup",
      "parameters": {
        "type": "object",
        "properties": {
          "path":          { "type": "string",  "description": "Ruta del directorio a limpiar", "default": "/temp" },
          "max_age_hours": { "type": "number",  "description": "Edad maxima en horas",          "default": 24 },
          "dry_run":       { "type": "boolean", "description": "Solo muestra que se eliminaria sin eliminar", "default": false }
        }
      },
      "errores_conocidos": ["INVALID_INPUT", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.stats",
      "description": "Estadisticas de uso del storage (tamano total, conteo por extension, top largest files).",
      "handler": "handleStats",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string", "description": "Ruta base", "default": "/" } }
      },
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.set_work_dir",
      "description": "Cambia el directorio de trabajo actual. Las rutas relativas se resuelven desde aqui.",
      "handler": "handleSetWorkDir",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string", "description": "Nueva ruta de trabajo" } },
        "required": ["path"]
      },
      "errores_conocidos": ["INVALID_INPUT", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    },
    {
      "name": "fs.get_work_dir",
      "description": "Devuelve el directorio de trabajo actual y contexto del proyecto activo.",
      "handler": "handleGetWorkDir",
      "parameters": { "type": "object", "properties": {} },
      "errores_conocidos": ["UNKNOWN_ERROR"]
    },
    {
      "name": "fs.append",
      "description": "Anyade contenido al final de un archivo (lo crea si no existe).",
      "handler": "handleAppend",
      "parameters": {
        "type": "object",
        "properties": {
          "path":     { "type": "string", "description": "Ruta del archivo" },
          "content":  { "type": "string", "description": "Contenido a anyadir" },
          "encoding": { "type": "string", "description": "Encoding (utf-8 default)", "default": "utf-8" }
        },
        "required": ["path", "content"]
      },
      "errores_conocidos": ["INVALID_INPUT", "PERMISSION_DENIED", "UNKNOWN_ERROR"]
    }
  ],

  "events": {
    "publishes": [
      "fs.file.created",
      "fs.file.updated",
      "fs.file.deleted",
      "fs.directory.created",
      "fs.workdir.changed",
      "fs.read.response",
      "fs.write.response",
      "fs.copy.response",
      "fs.delete.response",
      "fs.list.response",
      "fs.mkdir.response",
      "fs.move.response",
      "fs.rename.response",
      "fs.exists.response",
      "fs.info.response",
      "fs.append.response",
      "fs.search.response",
      "fs.stats.response",
      "archivo.listado",
      "archivo.leido",
      "archivo.borrado",
      "archivo.listar.fallido",
      "archivo.leer.fallido",
      "archivo.borrar.fallido"
    ],
    "subscribes": [
      { "event": "project.activated",          "handler": "onProjectActivated" },
      { "event": "project.deactivated",        "handler": "onProjectDeactivated" },
      { "event": "archivo.listar.solicitado",  "handler": "onArchivoListarSolicitado" },
      { "event": "archivo.leer.solicitado",    "handler": "onArchivoLeerSolicitado" },
      { "event": "archivo.borrar.solicitado",  "handler": "onArchivoBorrarSolicitado" },
      { "event": "fs.read.request",            "handler": "onReadRequest" },
      { "event": "fs.write.request",           "handler": "onWriteRequest" },
      { "event": "fs.copy.request",            "handler": "onCopyRequest" },
      { "event": "fs.delete.request",          "handler": "onDeleteRequest" },
      { "event": "fs.list.request",            "handler": "onListRequest" },
      { "event": "fs.mkdir.request",           "handler": "onMkdirRequest" },
      { "event": "fs.move.request",            "handler": "onMoveRequest" },
      { "event": "fs.rename.request",          "handler": "onMoveRequest" },
      { "event": "fs.exists.request",          "handler": "onExistsRequest" },
      { "event": "fs.info.request",            "handler": "onInfoRequest" },
      { "event": "fs.append.request",          "handler": "onAppendRequest" },
      { "event": "fs.search.request",          "handler": "onSearchRequest" },
      { "event": "fs.stats.request",           "handler": "onStatsRequest" }
    ]
  },

  "ui": { "zone": "work-bar", "icon": "📁" },

  "config": {
    "persistence": {
      "pattern": "filesystem-real-per-project",
      "restart_resilient": true,
      "concurrency": "single-writer-per-path",
      "lost_on_restart": ["activeProjectId", "activeProjectPath", "workingDirectory", "systemMode"]
    }
  },

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "tracing": {
      "propaga_correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "filesystem.list.success",
        "filesystem.read.success",
        "filesystem.write.success",
        "filesystem.delete.success",
        "filesystem.mkdir.success",
        "filesystem.move.success",
        "filesystem.copy.success",
        "filesystem.search.success",
        "filesystem.append.success",
        "filesystem.cleanup.success",
        "filesystem.errors"
      ]
    }
  }
}
