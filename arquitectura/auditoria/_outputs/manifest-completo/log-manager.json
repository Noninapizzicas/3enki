  },

  "identidad": {
    "name": "log-manager",
    "version": "2.0.0",
    "description_oficial": "Sistema centralizado de logs por sesión. Cada arranque crea una nueva sesión con logs organizados por módulo. Configurable para trackear módulos específicos.",
    "author": null,
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_1_infra_disabled",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [],
    "subscribes": [
      { "event": "core/+/logs/#", "handler": null, "extras": {} },
      { "event": "activity.logged", "handler": null, "extras": {} },
      { "event": "activity.batch", "handler": null, "extras": {} }
    ],
    "provides_eventos": ["logging", "observability", "sessions", "log-storage"]
  },

  "tools": [],

  "ui_handlers": {
    "campo_origen": null,
    "items": []
  },

  "apis_http": [
    {
      "method": "GET",
      "path": "/session",
      "handler": "getSession",
      "description": "Info de la sesión actual",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/session/modules",
      "handler": "getSessionModules",
      "description": "Módulos con logs en la sesión actual",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/session/modules/*/logs",
      "handler": "getSessionModuleLogs",
      "description": "Logs de un módulo en la sesión actual",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "PUT",
      "path": "/session/track",
      "handler": "setTrackedModules",
      "description": "Configurar qué módulos trackear",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/session/track/add",
      "handler": "addTrackedModules",
      "description": "Añadir módulos al tracking",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/sessions",
      "handler": "getSessions",
      "description": "Listar todas las sesiones",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/sessions/*",
      "handler": "getSessionById",
      "description": "Info de una sesión específica",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/sessions/*/logs",
      "handler": "getSessionLogs",
      "description": "Logs de una sesión (con filtro opcional de módulo)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/logs",
      "handler": "getLogs",
      "description": "Obtener logs consolidados con filtros",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/logs",
      "handler": "addLog",
      "description": "Agregar log (desde frontend u otros sistemas)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/stats",
      "handler": "getStats",
      "description": "Estadísticas de logs y sesión actual",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/session/resumen",
      "handler": "getSessionResumen",
      "description": "Diagnóstico rápido post-servicio: errores, MQTT, impresora, timeline problemas",
      "request_schema_ref": null,
      "response_schema_ref": null
    }
  ],

