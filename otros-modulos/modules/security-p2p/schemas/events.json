{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/security-p2p/events.json",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": { "type": "string", "format": "uuid" },
        "event_type": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "producer": { "type": "string", "const": "security-p2p" },
        "schema_version": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },

    "keypair_generated": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.keypair.generated" },
            "payload": {
              "type": "object",
              "required": ["key_id", "algorithm", "generated_at"],
              "properties": {
                "key_id": { "type": "string" },
                "algorithm": { "type": "string" },
                "key_length": { "type": "integer" },
                "generated_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "session_established": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.session.established" },
            "payload": {
              "type": "object",
              "required": ["session_id", "peer_id", "established_at"],
              "properties": {
                "session_id": { "type": "string" },
                "peer_id": { "type": "string" },
                "established_at": { "type": "string", "format": "date-time" },
                "expires_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "session_terminated": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.session.terminated" },
            "payload": {
              "type": "object",
              "required": ["session_id", "peer_id", "terminated_at"],
              "properties": {
                "session_id": { "type": "string" },
                "peer_id": { "type": "string" },
                "reason": { "type": "string" },
                "terminated_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "message_encrypted": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.message.encrypted" },
            "payload": {
              "type": "object",
              "required": ["session_id", "peer_id", "data_size"],
              "properties": {
                "session_id": { "type": "string" },
                "peer_id": { "type": "string" },
                "data_size": { "type": "integer" },
                "encrypted_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "message_decrypted": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.message.decrypted" },
            "payload": {
              "type": "object",
              "required": ["session_id", "peer_id", "data_size"],
              "properties": {
                "session_id": { "type": "string" },
                "peer_id": { "type": "string" },
                "data_size": { "type": "integer" },
                "decrypted_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "peer_authenticated": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.peer.authenticated" },
            "payload": {
              "type": "object",
              "required": ["peer_id", "authenticated_at"],
              "properties": {
                "peer_id": { "type": "string" },
                "public_key_hash": { "type": "string" },
                "authenticated_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "peer_revoked": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.peer.revoked" },
            "payload": {
              "type": "object",
              "required": ["peer_id", "revoked_at"],
              "properties": {
                "peer_id": { "type": "string" },
                "reason": { "type": "string" },
                "revoked_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "keypair_get_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.keypair.get.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "public_key": { "type": "string" },
                "key_id": { "type": "string" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "encrypt_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.encrypt.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "encrypted_data": { "type": "string" },
                "iv": { "type": "string" },
                "session_id": { "type": "string" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "decrypt_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.decrypt.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "decrypted_data": { "type": "string" },
                "session_id": { "type": "string" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "session_create_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.session.create.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "session_id": { "type": "string" },
                "peer_id": { "type": "string" },
                "established_at": { "type": "string", "format": "date-time" },
                "expires_at": { "type": "string", "format": "date-time" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "peer_verify_response": {
      "allOf": [
        { "$ref": "#/definitions/event_envelope" },
        {
          "properties": {
            "event_type": { "const": "security.peer.verify.response" },
            "payload": {
              "type": "object",
              "required": ["request_id", "success", "verified"],
              "properties": {
                "request_id": { "type": "string" },
                "success": { "type": "boolean" },
                "verified": { "type": "boolean" },
                "peer_id": { "type": "string" },
                "error": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
