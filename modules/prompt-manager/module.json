{
  "name": "prompt-manager",
  "version": "1.0.0",
  "description": "Sistema de gestión de prompts con versionado, templates y analytics",
  "author": "Event Core Team",
  "provides": ["prompt-management", "template-rendering", "analytics"],
  "subscribes": [
    "ai.completion.completed",
    "ai.request.started"
  ],
  "apis": {
    "create_prompt": {
      "method": "POST",
      "path": "/prompts",
      "description": "Crear un nuevo prompt",
      "schema": "./schemas/create-prompt.json"
    },
    "list_prompts": {
      "method": "GET",
      "path": "/prompts",
      "description": "Listar todos los prompts",
      "schema": "./schemas/list-prompts.json"
    },
    "get_prompt": {
      "method": "GET",
      "path": "/prompts/:id",
      "description": "Obtener un prompt específico",
      "schema": "./schemas/get-prompt.json"
    },
    "update_prompt": {
      "method": "PUT",
      "path": "/prompts/:id",
      "description": "Actualizar un prompt existente",
      "schema": "./schemas/update-prompt.json"
    },
    "delete_prompt": {
      "method": "DELETE",
      "path": "/prompts/:id",
      "description": "Eliminar un prompt",
      "schema": "./schemas/delete-prompt.json"
    },
    "list_versions": {
      "method": "GET",
      "path": "/prompts/:id/versions",
      "description": "Listar versiones de un prompt",
      "schema": "./schemas/list-versions.json"
    },
    "render_template": {
      "method": "POST",
      "path": "/prompts/:id/render",
      "description": "Renderizar template de prompt con variables",
      "schema": "./schemas/render-template.json"
    },
    "get_analytics": {
      "method": "GET",
      "path": "/analytics",
      "description": "Obtener analytics de prompts",
      "schema": "./schemas/get-analytics.json"
    },
    "compare_prompts": {
      "method": "POST",
      "path": "/prompts/compare",
      "description": "Comparar performance de dos prompts (A/B testing)",
      "schema": "./schemas/compare-prompts.json"
    }
  },
  "hooks": {
    "afterEventReceive": {
      "event_pattern": "ai.*.completed",
      "description": "Registrar analytics cuando se completa una IA request"
    }
  },
  "config": {
    "storage_path": "./data/prompts",
    "max_versions_per_prompt": 10,
    "enable_analytics": true,
    "analytics_retention_days": 90
  },
  "dependencies": [],
  "tags": ["ai", "prompts", "templates", "analytics"]
}
