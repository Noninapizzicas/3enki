{
  "_VERSION": "2.0.0",
  "_CREATED": "2026-01-20",
  "_UPDATED": "2026-02-03",
  "_DESCRIPTION": "Pipeline de facturas basado en handlers - procesamiento OCR + IA + CSV fiscal",

  "_AI_INSTRUCTIONS": {
    "cuando_leer": "ANTES de trabajar con facturas, OCR, PDF, CSV fiscal o asesorias",
    "principio_clave": "Pipeline basado en handlers JS directos, NO en flow-engine JSON",
    "CRITICO_SERVICIOS": "ai-gateway se llama con services.call('ai', 'chat') — NO 'ai-gateway'",
    "CRITICO_DEEPSEEK": "DeepSeek NO soporta imagenes via API. Usar Google Vision para OCR",
    "CRITICO_RESULTADO": "Siempre: const d = result.data || result;",
    "CRITICO_REPROCESO": "Archivos procesados sin error se mueven a procesados/ — no se reprocesan",
    "referencia_handlers": "contexto/handlers.json",
    "referencia_providers": "contexto/providers.json",
    "referencia_credenciales": "contexto/credentials.json"
  },

  "proyecto_referencia": {
    "id": "facturas-nonina",
    "nombre": "Facturas Nonina Pizzicas",
    "config": "data/projects/facturas-nonina/config/config.json",
    "handlers": "data/projects/facturas-nonina/handlers/",
    "storage": "data/projects/facturas-nonina/storage/",
    "nota": "Proyecto generico — bot name y cuenta Gmail vienen de config, reutilizable para distintas empresas"
  },

  "fuentes_entrada": {
    "telegram_bot": {
      "directorio": "data/bots/{botName}/received/",
      "tipos": ["jpg", "jpeg", "png", "webp", "tiff", "pdf"],
      "como_llegan": "Usuario envia foto/PDF al bot de Telegram",
      "config_key": "telegram.botName"
    },
    "gmail": {
      "directorio": "data/gmail/{account}/",
      "tipos": ["pdf"],
      "como_llegan": "Descargados con /gogmail o paso 1 del batch",
      "config_keys": ["gmail.account", "gmail.query", "gmail.maxResults"]
    }
  },

  "pipeline_completo": {
    "comando": "/gofull",
    "handler": "procesar-facturas.js",
    "descripcion": "Pipeline batch: Gmail → PDF→PNG → Sharp → OCR → Estructura → CSV → Mover procesados",
    "pasos": {
      "1_gmail": {
        "servicio": "local.gmail",
        "acciones": ["search", "read", "attachments.download"],
        "timeout": 30000,
        "resultado": "PDFs descargados a data/gmail/{account}/",
        "nota": "Solo si gmail.account esta configurado"
      },
      "2_recoger_inbox": {
        "servicio": "filesystem",
        "fuentes": ["data/bots/{botName}/received/", "data/gmail/{account}/"],
        "tipos": {
          "pdf": "Se convierte a PNG en paso 3",
          "imagen": "Se copia directamente a preprocesadas/"
        }
      },
      "3_pdf_a_png": {
        "servicio": "local.pdf-to-png",
        "accion": "convert",
        "params": { "pdf": "ruta", "dpi": 300, "outputFolder": "storage/preprocesadas/" },
        "timeout": 60000,
        "nota": "Un PDF puede generar multiples paginas (imagenes)"
      },
      "4_sharp_prepare": {
        "servicio": "local.sharp",
        "accion": "prepare-ocr",
        "params": {
          "image": "ruta imagen",
          "options": { "grayscale": true, "normalize": true, "sharpen": true, "maxWidth": 2400, "maxHeight": 3200 },
          "output": "storage/preprocesadas/prepared_{nombre}.png"
        },
        "timeout": 30000
      },
      "5_ocr": {
        "servicio": "local.google-vision",
        "accion": "extract",
        "params": { "image": "ruta preparada", "hint": "DOCUMENT_TEXT_DETECTION", "languageHints": ["es"] },
        "timeout": 60000,
        "resultado": "Texto OCR guardado en storage/ocr/{nombre}.txt",
        "confianza_tipica": "92%"
      },
      "6_estructura": {
        "servicio": "ai (ai-gateway)",
        "accion": "chat",
        "IMPORTANTE": "services.call('ai', 'chat') — NO 'ai-gateway'",
        "params": {
          "messages": ["system: prompt extraccion", "user: texto OCR"],
          "provider": "deepseek",
          "temperature": 0.1,
          "max_tokens": 2000
        },
        "timeout": 60000,
        "resultado": "JSON estructurado guardado en storage/estructuradas/{nombre}.json",
        "coste_tipico": "$0.0002 por factura"
      },
      "7_csv_fiscal": {
        "servicio": "local (generacion propia)",
        "formato": "Libro Registro Facturas Recibidas (SII/modelo 303)",
        "separador": ";",
        "encoding": "UTF-8 con BOM",
        "columnas": [
          "Fecha", "Num_Factura", "NIF_Emisor", "Nombre_Emisor",
          "NIF_Receptor", "Nombre_Receptor", "Descripcion",
          "Base_Imponible", "Tipo_IVA", "Cuota_IVA",
          "Tipo_RE", "Cuota_RE", "Total_Factura",
          "Forma_Pago", "Clave_Operacion"
        ],
        "claves_operacion": {
          "F1": "Factura corriente (tiene NIF emisor y total >= 400 o tiene NIF receptor)",
          "F2": "Factura simplificada (sin NIF emisor o total < 400 sin NIF receptor)"
        },
        "resultado": "storage/export/facturas_{fecha}.csv",
        "envio": "Se envia como documento por Telegram"
      },
      "8_descarte": {
        "accion": "fs.renameSync(original, procesados/)",
        "condicion": "SOLO si todos los pasos del archivo fueron OK",
        "efecto": "Original sale del inbox — no se reprocesa",
        "fallos": "Se quedan en inbox para reintento en siguiente ejecucion"
      }
    }
  },

  "handlers_test": {
    "descripcion": "Comandos /go* para probar cada paso individualmente",
    "tabla": {
      "/gogmail": { "handler": "test-gmail.js", "paso": "1. Descarga Gmail" },
      "/gopdf": { "handler": "test-pdf.js", "paso": "2. PDF a PNG" },
      "/gosharp": { "handler": "test-preparar.js", "paso": "3. Sharp prepare-ocr" },
      "/gocr": { "handler": "test-ocr.js", "paso": "4. OCR Google Vision" },
      "/gostructure": { "handler": "test-structure.js", "paso": "5. Estructura DeepSeek" },
      "/goexport": { "handler": "test-export.js", "paso": "6. CSV fiscal" },
      "/gofull": { "handler": "procesar-facturas.js", "paso": "Pipeline completo" }
    }
  },

  "estructura_storage": {
    "base": "data/projects/{projectId}/storage/",
    "directorios": {
      "preprocesadas/": "Imagenes convertidas de PDF y preparadas con Sharp",
      "ocr/": "Textos OCR extraidos (.txt)",
      "estructuradas/": "JSONs con datos estructurados (.json)",
      "export/": "CSVs fiscales generados",
      "procesados/": "Originales procesados sin error (sacados del inbox)"
    }
  },

  "json_factura_estructura": {
    "descripcion": "Formato JSON que devuelve DeepSeek al estructurar el OCR",
    "schema": {
      "emisor": { "nombre": "", "cif": "", "direccion": "", "telefono": "", "web": "" },
      "receptor": { "nombre": "", "cif": "", "direccion": "", "codigo_cliente": "" },
      "factura": { "numero": "", "fecha": "", "forma_pago": "" },
      "lineas": [{ "descripcion": "", "unidades": 0, "precio": 0, "descuento": "", "importe": 0 }],
      "totales": { "base_imponible": 0, "iva_porcentaje": 0, "iva_importe": 0, "total_factura": 0, "resto_cobrar": 0 }
    }
  },

  "config_proyecto": {
    "archivo": "data/projects/{projectId}/config/config.json",
    "campos_usados": {
      "telegram.botName": "Nombre del bot Telegram (determina directorio received)",
      "gmail.account": "Cuenta Gmail para descargar adjuntos",
      "gmail.query": "Query de busqueda Gmail (default: 'has:attachment is:unread')",
      "gmail.maxResults": "Max resultados Gmail (default: 20)",
      "storage.inbox.telegram": "Ruta inbox bot (default: data/bots/{botName}/received)",
      "storage.inbox.gmail": "Ruta inbox gmail (default: data/gmail/{account})",
      "storage.procesados": "Ruta para originales procesados",
      "schedule.gmail.cron": "Cron para ejecucion batch (default: '0 3 * * 0')"
    },
    "ejemplo": {
      "telegram": { "botName": "facturas_noninapizzicas_bot" },
      "gmail": { "account": "noninapizzicas", "query": "has:attachment is:unread", "maxResults": 20 },
      "storage": {
        "inbox": {
          "telegram": "./data/bots/facturas_noninapizzicas_bot/received",
          "gmail": "./data/gmail/noninapizzicas"
        },
        "procesados": "./data/projects/facturas-nonina/storage/procesados"
      },
      "schedule": { "gmail": { "cron": "0 3 * * 0" } }
    }
  },

  "scheduler": {
    "job": "facturas-nonina-gmail-domingo",
    "archivo": "data/scheduler/jobs.json",
    "cron": "0 3 * * 0",
    "timezone": "Europe/Madrid",
    "descripcion": "Domingos a las 3:00 AM — ejecuta pipeline completo"
  },

  "gotchas": {
    "ai_gateway_nombre": {
      "problema": "services.call('ai-gateway', 'chat') no funciona",
      "causa": "ai-gateway escucha ai.chat.request, no ai-gateway.chat.request",
      "solucion": "services.call('ai', 'chat', ...)"
    },
    "deepseek_no_vision": {
      "problema": "DeepSeek V3 timeout en imagenes",
      "causa": "DeepSeek NO soporta imagenes via API",
      "solucion": "Usar Google Vision para OCR, DeepSeek solo para texto (estructurar)"
    },
    "http_timeout": {
      "problema": "Requests HTTP colgados infinitamente",
      "causa": "base-provider.js no tenia timeout",
      "solucion": "Se anadio req.setTimeout(90000) en base-provider.js"
    },
    "credential_manager_borra": {
      "problema": "credential-manager borraba claves .env al guardar",
      "causa": "Solo cargaba patron _API_KEY_ con nivel, ignoraba legacy y otras lineas",
      "solucion": "Anadido soporte _API_KEY legacy + _unmanagedLines para preservar todo"
    },
    "gmail_refresh_token": {
      "problema": "Gmail: No refresh token found",
      "causa": "Token guardado como GMAIL_API_KEY_GLOBAL (nombre incorrecto)",
      "solucion": "Usar GMAIL_REFRESH_TOKEN_{account} en .env"
    },
    "error_sin_diagnostico": {
      "problema": "Handlers reportan 'Errores: 25' sin decir que fallo",
      "causa": "Catch solo logueaba, no mostraba en Telegram",
      "solucion": "Anadir primerError al mensaje: capturar primer error.message"
    }
  },

  "resultado_tests": {
    "descripcion": "Resultados de tests reales con facturas de Nonina Pizzicas",
    "sharp": "OK — grayscale, normalize, sharpen aplicados",
    "ocr": "OK — 92% confianza, texto completo extraido (factura Zambu)",
    "estructura": "OK — JSON completo con emisor, receptor, lineas, totales. Coste: $0.0002",
    "csv": "OK — formato SII correcto, separador ;, BOM UTF-8",
    "gmail": "OK — 25 correos, 25 adjuntos PDF descargados",
    "pdf_a_png": "OK — 25 PDFs convertidos, 33 paginas generadas",
    "pipeline_completo": "Pendiente test batch /gofull"
  },

  "proximos_pasos": {
    "inmediato": [
      "Probar /gofull end-to-end",
      "Conectar scheduler con /gofull"
    ],
    "futuro_fiscal": [
      "Gestion interna de negocio (no solo asesoria)",
      "Dashboard de gastos por categoria",
      "Integracion con contabilidad externa"
    ]
  }
}
