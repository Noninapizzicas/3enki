{
  "title": "Plan de Refactorización: Chat Modules",
  "version": "1.1.0",
  "status": "proposed",
  "created": "2026-01-07",
  "updated": "2026-01-07",
  "problem": {
    "summary": "Duplicación de lógica entre conversation-manager y ai-gateway",
    "modules_affected": [
      {
        "module": "conversation-manager",
        "location": "modules/conversation-manager/index.js",
        "lines": 2469,
        "issues": [
          "Viola Single Responsibility Principle (SRP)",
          "17+ responsabilidades en un solo archivo",
          "Difícil de testear y mantener",
          "Tool execution hardcodeada en lugar de eventos",
          "Lógica de UI mezclada con lógica de negocio",
          "Duplica lógica de tools que ya existe en ai-gateway"
        ]
      },
      {
        "module": "ai-gateway",
        "location": "modules/ai-gateway/index.js",
        "lines": 1523,
        "issues": [
          "Tiene lógica de tools que no se usa (conversation-manager la reimplementa)",
          "Podría centralizar toda la lógica de tools"
        ]
      }
    ],
    "duplicated_logic": {
      "description": "Ambos módulos implementan la misma funcionalidad de tools",
      "conversation_manager": {
        "loadAvailableTools": "línea 586 - Carga tools desde moduleLoader",
        "formatToolsForLLM": "línea 620 - Convierte a formato OpenAI",
        "convertToolNameFromLLM": "línea 644 - fs_write → fs.write",
        "executeToolCall": "línea 770 - Ejecuta tool individual",
        "executeToolCalls": "línea 831 - Ejecuta múltiples tools",
        "formatToolResultsAsMessages": "línea 844 - Formatea resultados"
      },
      "ai_gateway": {
        "getAvailableTools": "línea 1228 - Carga tools desde moduleLoader",
        "translateToolsForProvider": "línea 1317 - Convierte por provider",
        "parseToolCallsFromProvider": "línea 1390 - Parsea respuesta del LLM",
        "executeToolCalls": "línea 1242 - Ejecuta múltiples tools",
        "formatToolResultsForProvider": "línea 1468 - Formatea por provider"
      },
      "total_duplicated_lines": "~400 líneas"
    }
  },
  "ai_gateway_analysis": {
    "current_structure": {
      "main_file": "modules/ai-gateway/index.js (1523 líneas)",
      "providers": {
