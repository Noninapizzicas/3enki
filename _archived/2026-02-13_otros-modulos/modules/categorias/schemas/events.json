{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pizzepos.com/schemas/categoria-events.json",
  "title": "Categoria Events Schema",
  "description": "Esquemas de eventos del módulo categorias",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": {"type": "string", "format": "uuid"},
        "event_type": {"type": "string", "pattern": "^[a-z]+\\.[a-z_]+$"},
        "correlation_id": {"type": "string", "format": "uuid"},
        "occurred_at": {"type": "string", "format": "date-time"},
        "producer": {"type": "string", "minLength": 1},
        "schema_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "payload": {"type": "object"}
      },
      "additionalProperties": false
    },

    "categoria_creada": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "categoria.creada"},
            "payload": {
              "type": "object",
              "required": ["categoria_id", "nombre", "orden"],
              "properties": {
                "categoria_id": {"type": "string"},
                "nombre": {"type": "string"},
                "emoji": {"type": "string"},
                "orden": {"type": "integer"},
                "created_at": {"type": "string", "format": "date-time"}
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "categoria_actualizada": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "categoria.actualizada"},
            "payload": {
              "type": "object",
              "required": ["categoria_id", "cambios"],
              "properties": {
                "categoria_id": {"type": "string"},
                "cambios": {"type": "object"},
                "updated_at": {"type": "string", "format": "date-time"}
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "categoria_orden_actualizado": {
      "allOf": [
        {"$ref": "#/definitions/event_envelope"},
        {
          "properties": {
            "event_type": {"const": "categoria.orden_actualizado"},
            "payload": {
              "type": "object",
              "required": ["nuevo_orden"],
              "properties": {
                "nuevo_orden": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "categoria_id": {"type": "string"},
                      "orden": {"type": "integer"}
                    }
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
