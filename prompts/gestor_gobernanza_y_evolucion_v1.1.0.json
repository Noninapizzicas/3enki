    "sunset_policy": {
      "path": "governance/v1/sunset_policy.json",
      "schema": {
        "type": "object",
        "required": ["criteria", "notification_timeline", "hard_deletion"],
        "properties": {
          "criteria": {
            "type": "object",
            "required": ["usage_threshold_pct", "age_months", "replacement_available"],
            "properties": {
              "usage_threshold_pct": {
                "type": "number",
                "default": 5,
                "description": "< 5% usage → eligible for sunset"
              },
              "age_months": {
                "type": "integer",
                "default": 12,
                "description": "Deprecated for at least 12 months"
              },
              "replacement_available": {
                "type": "boolean",
                "description": "Must have stable replacement"
              },
              "no_critical_clients": {
                "type": "boolean",
                "description": "No critical/enterprise clients still using"
              }
            }
          },
          "notification_timeline": {
            "type": "object",
            "required": ["deprecation_announcement", "final_warning", "sunset_date"],
            "properties": {
              "deprecation_announcement": {
                "type": "string",
                "description": "6 months before sunset"
              },
              "migration_guide_published": {
                "type": "string",
                "description": "With deprecation announcement"
              },
              "final_warning": {
                "type": "string",
                "description": "3 months before sunset"
              },
              "sunset_date": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "hard_deletion": {
            "type": "boolean",
            "default": false,
            "description": "Si false, mantener endpoint con 410 Gone y mensaje de migración"
          },
          "tombstone_config": {
            "type": "object",
            "properties": {
              "http_status": {"type": "integer", "const": 410},
              "response_body": {
                "type": "object",
                "properties": {
                  "error": {"type": "string"},
                  "sunset_date": {"type": "string"},
                  "migration_guide_url": {"type": "string"},
                  "replacement_endpoint": {"type": "string"}
                }
              }
            }
          }
        },
        "additionalProperties": false
      },
      "example": {
        "criteria": {
          "usage_threshold_pct": 5,
          "age_months": 12,
          "replacement_available": true,
          "no_critical_clients": true
        },
        "notification_timeline": {
          "deprecation_announcement": "2024-09-01",
          "migration_guide_published": "2024-09-01",
          "final_warning": "2024-12-01",
          "sunset_date": "2025-03-01"
        },
        "hard_deletion": false,
        "tombstone_config": {
          "http_status": 410,
          "response_body": {
            "error": "This endpoint has been sunset. Please migrate to /help/search",
            "sunset_date": "2025-03-01",
            "migration_guide_url": "https://docs.company.com/migration/search_v2",
            "replacement_endpoint": "/help/search"
          }
        }
      }
    },
    "migration_tooling": {
      "path": "governance/v1/migration_tooling.json",
      "schema": {
        "type": "object",
        "required": ["automated_migration", "manual_steps", "testing"],
        "properties": {
          "automated_migration": {
            "type": "object",
            "required": ["script_path", "language", "rollback_script"],
            "properties": {
              "script_path": {"type": "string"},
              "language": {"type": "string", "enum": ["python", "bash", "sql", "javascript"]},
              "rollback_script": {"type": "string"},
              "dry_run_available": {"type": "boolean", "default": true},
              "estimated_duration_minutes": {"type": "integer"}
            }
          },
          "manual_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["step", "estimated_duration_hours"],
              "properties": {
                "step": {"type": "string"},
                "estimated_duration_hours": {"type": "number"},
                "responsible": {"type": "string"},
                "verification_command": {"type": "string"}
              }
            }
          },
          "testing": {
            "type": "object",
            "required": ["test_coverage", "compatibility_tests"],
            "properties": {
              "test_coverage": {"type": "number", "minimum": 80},
              "compatibility_tests": {"type": "array", "items": {"type": "string"}},
              "smoke_tests": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "additionalProperties": false
      },
      "example": {
        "automated_migration": {
          "script_path": "./scripts/migrate_help_schema_v1_to_v2.py",
          "language": "python",
          "rollback_script": "./scripts/rollback_help_schema_v2.sh",
          "dry_run_available": true,
          "estimated_duration_minutes": 45
        },
        "manual_steps": [
          {
            "step": "Validar que todos los clientes están usando SDK >= 1.8.0",
            "estimated_duration_hours": 2,
            "responsible": "platform_team",
            "verification_command": "curl https://api.company.com/clients/versions | jq '.[] | select(.sdk_version < \"1.8.0\")'"
          },
          {
            "step": "Comunicar ventana de mantenimiento a clientes enterprise",
            "estimated_duration_hours": 1,
            "responsible": "customer_success",
            "verification_command": "check_email_sent('enterprise_migration_notice')"
          }
        ],
        "testing": {
          "test_coverage": 92,
          "compatibility_tests": [
            "test_v1_v2_dual_write",
            "test_v1_read_compatibility",
            "test_v2_schema_validation"
          ],
          "smoke_tests": [
            "curl /help/search?tags=python → 200 OK",
            "curl /help/register -d @payload_v2.json → 201 Created"
          ]
        }
      }
    },
    "compatibility_testing": {
      "path": "governance/v1/compatibility_testing.json",
      "schema": {
        "type": "object",
        "required": ["ci_integration", "tools", "test_matrix"],
        "properties": {
          "ci_integration": {
            "type": "object",
            "properties": {
              "enabled": {"type": "boolean", "const": true},
              "fail_on_breaking_change": {"type": "boolean", "default": true},
              "auto_create_rfc": {"type": "boolean", "default": true}
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string", "enum": ["openapi-diff", "json-schema-diff", "breaking-change-detector"]},
                "command": {"type": "string"},
                "threshold": {"type": "string", "enum": ["strict", "moderate", "lenient"]}
              }
            }
          },
          "test_matrix": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "version_from": {"type": "string"},
                "version_to": {"type": "string"},
                "compatible": {"type": "boolean"},
                "breaking_changes": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      },
      "example": {
        "ci_integration": {
          "enabled": true,
          "fail_on_breaking_change": true,
          "auto_create_rfc": true
        },
        "tools": [
          {
            "name": "openapi-diff",
            "command": "openapi-diff openapi_v1.yaml openapi_v2.yaml --fail-on-incompatible",
            "threshold": "strict"
          },
          {
            "name": "json-schema-diff",
            "command": "json-schema-diff schemas/v1/ schemas/v2/ --check-breaking",
            "threshold": "strict"
          }
        ],
        "test_matrix": [
          {
            "version_from": "1.5.2",
            "version_to": "2.0.0",
            "compatible": false,
            "breaking_changes": ["field 'tags' changed from string[] to object[]"]
          },
          {
            "version_from": "2.0.0",
            "version_to": "2.1.0",
            "compatible": true,
            "breaking_changes": []
          }
        ]
      }
    }
  },

  "acceptance_criteria": [
    "100% de módulos inventariados con versión semver ✅",
    "Dependency graph actualizado (blast radius calculado) ✅",
    "Breaking change detection automático en CI/CD ✅",
