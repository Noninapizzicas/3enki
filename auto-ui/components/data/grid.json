{
  "name": "grid",
  "category": "data",
  "description": "Grid de items con diseño de tarjetas responsive",
  "version": "2.0.0",

  "variants": {
    "cards": {
      "description": "Grid de tarjetas",
      "className": "grid grid-cards"
    },
    "masonry": {
      "description": "Grid estilo masonry (alturas variables)",
      "className": "grid grid-masonry"
    },
    "compact": {
      "description": "Grid compacto con menos espaciado",
      "className": "grid grid-compact"
    }
  },

  "props": {
    "items": {
      "type": "array",
      "required": true,
      "description": "Items a mostrar en el grid"
    },
    "columns": {
      "type": "object",
      "description": "Número de columnas por breakpoint",
      "default": {
        "xs": 1,
        "sm": 2,
        "md": 3,
        "lg": 4,
        "xl": 5
      }
    },
    "gap": {
      "type": "string",
      "default": "md",
      "enum": ["xs", "sm", "md", "lg", "xl"],
      "description": "Espaciado entre items"
    },
    "minItemWidth": {
      "type": "string",
      "default": "250px",
      "description": "Ancho mínimo de cada item"
    },
    "renderItem": {
      "type": "function",
      "description": "Función para renderizar cada item"
    },
    "loading": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar skeleton loaders"
    },
    "emptyMessage": {
      "type": "string",
      "default": "No hay elementos para mostrar",
      "description": "Mensaje cuando no hay items"
    }
  },

  "features": {
    "lazyLoading": {
      "enabled": true,
      "threshold": "200px"
    },
    "infiniteScroll": {
      "enabled": false,
      "endpoint": "/api/{module}/more"
    },
    "filtering": {
      "enabled": true,
      "fields": []
    },
    "sorting": {
      "enabled": true,
      "options": []
    }
  },

  "accessibility": {
    "role": "grid",
    "ariaLabel": "Item grid"
  },

  "example": {
    "widget": "grid",
    "variant": "cards",
    "props": {
      "items": "@data.products",
      "columns": {
        "xs": 1,
        "sm": 2,
        "md": 3,
        "lg": 4
      },
      "gap": "md",
      "minItemWidth": "280px",
      "renderItem": "productCard"
    }
  }
}
