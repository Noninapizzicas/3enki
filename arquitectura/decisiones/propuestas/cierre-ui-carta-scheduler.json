  "fases": [
    {
      "id": "F1",
      "nombre": "Crear ruta SvelteKit + store",
      "esfuerzo_horas": 1.5,
      "ok_explicito_antes_de_continuar": true,
      "operaciones": [
        {
          "id": "F1.op1_crear_ruta",
          "descripcion": "Crear frontend/src/routes/[project_id]/carta-scheduler/+page.svelte",
          "pseudocodigo": [
            "mkdir -p frontend/src/routes/[project_id]/carta-scheduler",
            "crear +page.svelte con shell minimal:",
            "  <script lang='ts'>",
            "    import { LazyShell } from '$lib/components/layout'",
            "  </script>",
            "  <LazyShell />"
          ]
        },
        {
          "id": "F1.op2_crear_store",
          "descripcion": "Crear frontend/src/lib/stores/carta-scheduler.ts",
          "pseudocodigo": [
            "crear archivo",
            "imports:",
            "  import { writable, derived } from 'svelte/store'",
            "  import { mqttRequest } from '$lib/ui-core/mqtt-request'",
            "  import { subscribe as busSubscribe } from '$lib/ui-core/bus'",
            "constantes:",
            "  const REGLAS_PATH = '/storage/pizzepos/carta-scheduler/reglas.json'",
            "  const PENDIENTES_PATH = '/storage/pizzepos/carta-scheduler/pendientes.json'",
            "tipos:",
            "  interface Regla { id: string, canal: string, carta_id_destino: string, cron_expression: string, etiquetas?: string[], prioridad?: number, descripcion?: string, activa?: boolean, created_at?: string, updated_at?: string }",
            "  interface Pendiente { id: string, regla_id: string, canal: string, carta_id_destino: string, carta_id_anterior?: string, fecha_objetivo?: string, estado?: string, motivo?: string, created_at?: string }",
            "stores:",
            "  export const reglasStore = writable<Regla[]>([])",
            "  export const pendientesStore = writable<Pendiente[]>([])",
            "  export const reglasActivas = derived(reglasStore, $r => $r.filter(x => x.activa !== false))",
            "  export const reglasLoading = writable<boolean>(false)",
            "  export const pendientesLoading = writable<boolean>(false)",
            "  export const cartaSchedulerError = writable<string | null>(null)",
            "  // Conflictos: detecta colisiones canal+cron approximado (mismo canal, expressions similares)",
            "  export const conflictosDetectados = derived(reglasActivas, ($activas) => {",
            "    const conflictos = []",
            "    for (let i = 0; i < $activas.length; i++) {",
            "      for (let j = i + 1; j < $activas.length; j++) {",
            "        const a = $activas[i], b = $activas[j]",
            "        if (a.canal === b.canal && a.cron_expression === b.cron_expression && a.carta_id_destino !== b.carta_id_destino) {",
            "          conflictos.push({ regla_a: a, regla_b: b, motivo: 'mismo canal + cron, diferente carta destino' })",
            "        }",
            "      }",
            "    }",
            "    return conflictos",
            "  })",
            "funciones:",
            "  export async function loadReglas() {",
            "    reglasLoading.set(true)",
            "    cartaSchedulerError.set(null)",
            "    try {",
            "      const res = await mqttRequest('fs', 'read', { path: REGLAS_PATH })",
            "      if (res?.status === 404) { reglasStore.set([]); return }",
            "      if (res?.status >= 400) throw new Error('fs.read fallo ' + res.status)",
            "      const store = JSON.parse(res.data.content)",
            "      reglasStore.set(Array.isArray(store.reglas) ? store.reglas : [])",
            "    } catch (err) {",
            "      cartaSchedulerError.set(err?.message || 'Error al cargar reglas')",
            "    } finally {",
            "      reglasLoading.set(false)",
            "    }",
            "  }",
            "  export async function loadPendientes() {",
            "    pendientesLoading.set(true)",
            "    try {",
            "      const res = await mqttRequest('fs', 'read', { path: PENDIENTES_PATH })",
            "      if (res?.status === 404) { pendientesStore.set([]); return }",
            "      if (res?.status >= 400) throw new Error('fs.read fallo ' + res.status)",
            "      const store = JSON.parse(res.data.content)",
            "      pendientesStore.set(Array.isArray(store.pendientes) ? store.pendientes : [])",
            "    } catch (err) {",
            "      cartaSchedulerError.set(err?.message || 'Error al cargar pendientes')",
            "    } finally {",
            "      pendientesLoading.set(false)",
            "    }",
            "  }",
            "  export function initCartaSchedulerSubscriptions(): () => void {",
            "    const unsubs: Array<() => void> = []",
            "    unsubs.push(busSubscribe('carta-scheduler.regla.creada', () => loadReglas()))",
            "    unsubs.push(busSubscribe('carta-scheduler.regla.actualizada', () => loadReglas()))",
            "    unsubs.push(busSubscribe('carta-scheduler.regla.eliminada', () => loadReglas()))",
            "    unsubs.push(busSubscribe('carta-scheduler.cambio.aplicado', () => loadPendientes()))",
            "    unsubs.push(busSubscribe('carta-scheduler.cambio.rechazado', () => loadPendientes()))",
            "    return () => unsubs.forEach(u => u())",
            "  }"
          ]
        }
      ],
      "salida_esperada": {
        "archivos_creados": [
          "frontend/src/routes/[project_id]/carta-scheduler/+page.svelte",
          "frontend/src/lib/stores/carta-scheduler.ts (~180 lineas)"
        ]
      }
    },
    {
      "id": "F2",
      "nombre": "Crear modulo frontend con Panel router + tabs",
      "esfuerzo_horas": 4,
      "ok_explicito_antes_de_continuar": true,
      "depende_de": "DEP1",
      "operaciones": [
        {
          "id": "F2.op0_dep1",
          "pseudocodigo": ["comprobar chatInputDraft", "si NO existe parar"]
        },
        {
          "id": "F2.op1_CartaSchedulerPanel",
          "descripcion": "Panel router con tabs reglas|pendientes + ConflictosBanner arriba",
          "pseudocodigo": [
            "crear CartaSchedulerPanel.svelte:",
            "  <script>",
            "    import { onMount, onDestroy } from 'svelte'",
            "    import ReglasView from './ReglasView.svelte'",
            "    import PendientesView from './PendientesView.svelte'",
            "    import ConflictosBanner from './ConflictosBanner.svelte'",
            "    import { loadReglas, loadPendientes, initCartaSchedulerSubscriptions, conflictosDetectados, cartaSchedulerError } from '$lib/stores/carta-scheduler'",
            "    let activeView: 'reglas' | 'pendientes' = 'reglas'",
            "    let cleanupSubs: (() => void) | null = null",
            "    onMount(() => {",
            "      loadReglas()",
            "      loadPendientes()",
            "      cleanupSubs = initCartaSchedulerSubscriptions()",
            "    })",
            "    onDestroy(() => { if (cleanupSubs) cleanupSubs() })",
            "  </script>",
            "  <div class='carta-scheduler-panel'>",
            "    {#if $cartaSchedulerError}<div class='error-banner'>{$cartaSchedulerError}</div>{/if}",
            "    {#if $conflictosDetectados.length > 0}",
            "      <ConflictosBanner conflictos={$conflictosDetectados} />",
            "    {/if}",
            "    <nav class='tabs'>",
            "      <button class:active={activeView === 'reglas'} on:click={() => activeView = 'reglas'}>Reglas</button>",
            "      <button class:active={activeView === 'pendientes'} on:click={() => activeView = 'pendientes'}>Pendientes</button>",
            "    </nav>",
            "    {#if activeView === 'reglas'}",
            "      <ReglasView />",
            "    {:else if activeView === 'pendientes'}",
            "      <PendientesView />",
            "    {/if}",
            "  </div>"
          ]
        },
        {
          "id": "F2.op2_ConflictosBanner",
          "descripcion": "Banner arriba si hay conflictos",
          "pseudocodigo": [
            "crear ConflictosBanner.svelte:",
            "  <script>",
            "    import { prefillChatInput } from '$lib/stores/chatInputDraft'",
            "    export let conflictos: Array<any>",
            "    function resolver() {",
            "      prefillChatInput('Detecta conflictos entre las reglas activas de programacion.')",
            "    }",
            "  </script>",
            "  <div class='conflictos-banner'>",
            "    <h3>⚠ {conflictos.length} conflicto{conflictos.length > 1 ? 's' : ''} detectado{conflictos.length > 1 ? 's' : ''} en las reglas</h3>",
            "    <ul>",
            "      {#each conflictos as c}",
            "        <li>Canal <strong>{c.regla_a.canal}</strong>: regla \"{c.regla_a.cron_expression}\" colisiona con otra (cartas distintas).</li>",
            "      {/each}",
            "    </ul>",
            "    <button on:click={resolver}>Resolver conflictos en chat</button>",
            "  </div>"
          ]
        },
        {
          "id": "F2.op3_ReglasView",
          "descripcion": "Vista de reglas activas con boton crear + accion eliminar",
          "pseudocodigo": [
            "crear ReglasView.svelte:",
            "  <script>",
            "    import { reglasActivas, reglasLoading } from '$lib/stores/carta-scheduler'",
            "    import { prefillChatInput } from '$lib/stores/chatInputDraft'",
            "    import ReglaCard from './ReglaCard.svelte'",
            "    function crearRegla() {",
            "      prefillChatInput('Crea una regla de programacion: [describe canal, carta, cron_expression, prioridad opcional].')",
            "    }",
            "    function recalcular() {",
            "      prefillChatInput('Recalcula los proximos cambios programados de carta+canal.')",
            "    }",
            "  </script>",
            "  <section class='reglas-view'>",
            "    <header class='view-header'>",
            "      <h2>Reglas activas</h2>",
            "      <div class='acciones-header'>",
            "        <button on:click={crearRegla}>+ Nueva regla</button>",
            "        <button on:click={recalcular}>↻ Recalcular pendientes</button>",
            "      </div>",
            "    </header>",
            "    {#if $reglasLoading}",
            "      <div class='loading'>Cargando...</div>",
            "    {:else if $reglasActivas.length === 0}",
            "      <div class='empty-state'>",
            "        <p>Sin reglas activas. Crea la primera regla de programacion para que las cartas roten automaticamente por canal y franja horaria.</p>",
            "        <button on:click={crearRegla}>Crear primera regla</button>",
            "      </div>",
            "    {:else}",
            "      <ul class='reglas-list'>",
            "        {#each $reglasActivas as regla}",
            "          <ReglaCard {regla} />",
            "        {/each}",
            "      </ul>",
            "    {/if}",
            "  </section>"
          ]
        },
        {
          "id": "F2.op4_ReglaCard",
          "descripcion": "Card de cada regla",
          "pseudocodigo": [
            "crear ReglaCard.svelte:",
            "  <script>",
            "    import { prefillChatInput } from '$lib/stores/chatInputDraft'",
            "    export let regla",
            "    function eliminar() {",
            "      prefillChatInput('Elimina la regla de programacion ' + regla.id + ' (canal=' + regla.canal + ', carta=' + regla.carta_id_destino + ').')",
            "    }",
            "  </script>",
            "  <li class='regla-card'>",
            "    <div class='regla-header'>",
            "      <span class='canal-badge'>📡 {regla.canal}</span>",
            "      <span class='cron'>⏰ {regla.cron_expression}</span>",
            "      {#if regla.prioridad !== undefined}<span class='prioridad'>prio: {regla.prioridad}</span>{/if}",
            "    </div>",
            "    <div class='carta-destino'><strong>Carta:</strong> {regla.carta_id_destino}</div>",
            "    {#if regla.descripcion}<div class='descripcion'>{regla.descripcion}</div>{/if}",
            "    {#if regla.etiquetas?.length > 0}",
            "      <div class='etiquetas'>{#each regla.etiquetas as et}<span class='etiqueta'>{et}</span>{/each}</div>",
            "    {/if}",
            "    <div class='regla-meta'>",
