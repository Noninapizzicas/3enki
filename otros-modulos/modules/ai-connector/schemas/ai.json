{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aichat.com/schemas/ai-connector.json",

  "definitions": {
    "provider": {
      "type": "string",
      "enum": ["deepseek", "openai", "anthropic"],
      "description": "AI provider"
    },

    "generate_request": {
      "type": "object",
      "required": ["prompt"],
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50000,
          "description": "Text prompt to send to AI"
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "content"],
            "properties": {
              "role": { "type": "string", "enum": ["system", "user", "assistant"] },
              "content": { "type": "string" }
            }
          },
          "description": "Optional conversation history"
        },
        "provider": { "$ref": "#/definitions/provider" },
        "model": {
          "type": "string",
          "description": "Override default model"
        },
        "project_id": {
          "type": "string",
          "description": "Project ID for credential resolution"
        },
        "client_id": {
          "type": "string",
          "description": "Client ID for credential resolution"
        },
        "custom_id": {
          "type": "string",
          "description": "Custom ID for credential resolution"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "default": 0.7
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "default": 2000
        }
      },
      "additionalProperties": false
    },

    "generate_response": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "response": {
          "type": "string",
          "description": "AI generated text"
        },
        "provider": { "$ref": "#/definitions/provider" },
        "model": { "type": "string" },
        "usage": {
          "type": "object",
          "properties": {
            "prompt_tokens": { "type": "integer" },
            "completion_tokens": { "type": "integer" },
            "total_tokens": { "type": "integer" }
          }
        },
        "duration": { "type": "integer", "minimum": 0 },
        "error": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
