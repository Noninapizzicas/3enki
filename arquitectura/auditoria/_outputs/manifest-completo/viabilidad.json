  "tools": [
    {
      "name": "viabilidad.estudio",
      "description": "Genera un estudio de viabilidad completo del negocio basándose en las recetas, sus costes y los parámetros del negocio. Incluye punto de equilibrio, proyección de ingresos, gastos fijos/variables y rentabilidad estimada.",
      "parameters_required": ["gastos_fijos_mensuales"],
      "parameters_property_names": ["nombre_negocio", "tipo_negocio", "gastos_fijos_mensuales", "dias_operacion_mes", "comensales_dia_estimados", "ticket_medio", "precios_venta"],
      "parameters_size_chars": 813,
      "parameters_full_path_hint": "modules/viabilidad/module.json → tools[0].parameters"
    },
    {
      "name": "viabilidad.punto_equilibrio",
      "description": "Calcula el punto de equilibrio (break-even): cuántos servicios/comensales necesitas al día/mes para cubrir gastos fijos. Cuánto tienes que vender para no perder dinero.",
      "parameters_required": ["gastos_fijos_mensuales"],
      "parameters_property_names": ["gastos_fijos_mensuales", "ticket_medio", "food_cost_porcentaje", "dias_operacion_mes"],
      "parameters_size_chars": 449,
      "parameters_full_path_hint": "modules/viabilidad/module.json → tools[1].parameters"
    },
    {
      "name": "viabilidad.escenario",
      "description": "Compara escenarios de negocio: cambia variables (comensales, precios, gastos) y ve cómo afectan al resultado. Útil para decidir entre diferentes opciones de carta o modelo de negocio.",
      "parameters_required": ["nombre", "gastos_fijos_mensuales", "comensales_dia", "ticket_medio"],
      "parameters_property_names": ["nombre", "gastos_fijos_mensuales", "comensales_dia", "ticket_medio", "food_cost_porcentaje", "dias_operacion_mes"],
      "parameters_size_chars": 629,
      "parameters_full_path_hint": "modules/viabilidad/module.json → tools[2].parameters"
    },
    {
      "name": "viabilidad.comparar_escenarios",
      "description": "Compara varios escenarios lado a lado: muestra ingresos, gastos, beneficio y punto de equilibrio de cada uno.",
      "parameters_required": ["escenarios"],
      "parameters_property_names": ["escenarios"],
      "parameters_size_chars": 473,
      "parameters_full_path_hint": "modules/viabilidad/module.json → tools[3].parameters"
    },
    {
      "name": "viabilidad.proyeccion",
      "description": "Proyección financiera a 3, 6 o 12 meses. Muestra evolución de ingresos, gastos y beneficio mes a mes, con crecimiento progresivo de comensales.",
      "parameters_required": ["gastos_fijos_mensuales", "comensales_dia_inicial", "ticket_medio"],
      "parameters_property_names": ["meses", "gastos_fijos_mensuales", "comensales_dia_inicial", "comensales_dia_objetivo", "ticket_medio", "food_cost_porcentaje", "dias_operacion_mes", "inversion_inicial"],
      "parameters_size_chars": 811,
      "parameters_full_path_hint": "modules/viabilidad/module.json → tools[4].parameters"
    },
    {
      "name": "viabilidad.guardar_config",
      "description": "Guarda la configuración del negocio (gastos fijos, tipo, nombre, etc.) para no tener que repetirla en cada cálculo.",
      "parameters_required": [],
      "parameters_property_names": ["nombre_negocio", "tipo_negocio", "gastos_fijos_mensuales", "dias_operacion_mes", "comensales_dia_estimados", "ticket_medio", "food_cost_objetivo", "inversion_inicial", "notas"],
      "parameters_size_chars": 363,
      "parameters_full_path_hint": "modules/viabilidad/module.json → tools[5].parameters"
    }
  ],

