{
  "name": "ui-renderer",
  "version": "1.0.0",
  "description": "JSON-driven UI component renderer with design system tokens",
  "apis": {
    "get_component": {
      "method": "GET",
      "path": "/component/:name"
    },
    "list_components": {
      "method": "GET",
      "path": "/components"
    },
    "render_component": {
      "method": "POST",
      "path": "/component/:name/render"
    },
    "get_tokens": {
      "method": "GET",
      "path": "/tokens"
    }
  },
  "events": {
    "publishes": ["ui.component.loaded", "ui.component.rendered"],
    "subscribes": []
  }
}
