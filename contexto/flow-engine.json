{
  "module": "flow-engine",
  "version": "1.0.0",
  "description": "Motor de automatizacion de flujos de trabajo basado en eventos",

  "mision": {
    "principal": "Orquestar secuencias de pasos que se ejecutan cuando ocurren eventos",
    "objetivos": [
      "Escuchar eventos del sistema (triggers)",
      "Ejecutar secuencias de pasos cuando eventos coinciden con filtros",
      "Orquestar servicios (providers), agentes AI, APIs HTTP",
      "Transformar datos entre pasos",
      "Persistir resultados"
    ]
  },

  "arquitectura": {
    "componentes": {
      "index.js": {
        "responsabilidad": "Orquestador principal del modulo",
        "funciones": [
          "Inicializacion y ciclo de vida",
          "Suscripcion a eventos trigger",
          "Routing de respuestas de providers",
          "API HTTP para gestion"
        ]
      },
      "flow-registry.js": {
        "responsabilidad": "Gestion de definiciones de flujos",
        "funciones": [
          "Almacena flujos en memoria (Map)",
          "Indexa por evento trigger para busqueda rapida",
          "Evalua filtros estilo MongoDB",
          "Carga flujos desde archivos JSON"
        ]
      },
      "flow-executor.js": {
        "responsabilidad": "Motor de ejecucion de flujos",
        "funciones": [
          "Ejecuta pasos secuencialmente",
          "Mantiene contexto de ejecucion",
          "Maneja errores segun configuracion",
          "Emite eventos de progreso"
        ]
      },
      "step-handlers.js": {
        "responsabilidad": "Implementacion de cada tipo de paso",
        "tipos_soportados": ["service", "transform", "condition", "parallel", "agent", "http", "delay", "log", "set", "emit"]
      },
      "variable-resolver.js": {
        "responsabilidad": "Interpolacion de variables y evaluacion de condiciones",
        "funciones": [
          "Resuelve sintaxis {{ variable }}",
          "Proporciona variables especiales (now, uuid, date, etc.)",
          "Evalua condiciones con operadores"
        ]
      }
    },
    "diagrama": "index.js -> registry (busca flujos) -> executor (ejecuta) -> step-handlers (procesa cada paso) -> variable-resolver (interpola)"
  },

  "flujo_definicion": {
    "estructura": {
      "id": "Identificador unico del flujo",
      "name": "Nombre descriptivo",
      "description": "Descripcion del proposito",
      "version": "Version semantica",
      "enabled": "Boolean para activar/desactivar",
      "trigger": {
        "event": "Nombre del evento que dispara el flujo",
        "filter": "Filtros MongoDB-style para coincidir"
      },
      "schedule": {
        "cron": "Expresion cron (minuto hora dia-mes mes dia-semana)",
        "timezone": "Zona horaria (default: Europe/Madrid)"
      },
      "steps": "Array de pasos a ejecutar"
    },
    "schedule_examples": {
      "domingo_3am": "0 3 * * 0",
      "domingo_6am": "0 6 * * 0",
      "diario_3am": "0 3 * * *",
      "lunes_viernes_8am": "0 8 * * 1-5",
      "cada_hora": "0 * * * *"
    },
    "ejemplo": {
      "id": "procesar-facturas",
      "trigger": {
        "event": "bot.file.stored",
        "filter": {
          "botName": "facturas_asesoria_bot",
          "file.mimeType": { "$in": ["image/jpeg", "image/png"] }
        }
      },
      "steps": ["..."]
    }
  },

  "tipos_de_pasos": {
    "service": {
      "descripcion": "Llama a providers via eventos",
      "patron_eventos": "{service}.{action}.request -> {service}.{action}.response",
      "propiedades": {
        "service": "Nombre del provider (ej: fs, local.tesseract, google.vision)",
        "action": "Accion a ejecutar (ej: read, extract, create)",
        "input": "Datos de entrada",
        "config": "Configuracion adicional",
        "timeout": "Timeout en ms (default: 60000)"
      }
    },
    "transform": {
      "descripcion": "Transforma datos",
      "operaciones": {
        "map": "Mapea campos a nuevo objeto",
        "filter": "Filtra array por condicion",
        "merge": "Combina objetos",
        "extract": "Extrae campos especificos",
        "template": "Aplica template string",
        "json.parse": "Parsea JSON string",
        "json.stringify": "Convierte a JSON string",
        "split": "Divide string en array",
        "join": "Une array en string",
        "regex": "Extrae con expresion regular"
      }
    },
    "condition": {
      "descripcion": "Bifurcacion condicional",
      "propiedades": {
        "if": "Condicion a evaluar",
        "then": "ID del paso si verdadero",
        "else": "ID del paso si falso"
      }
    },
    "parallel": {
      "descripcion": "Ejecuta pasos en paralelo",
      "propiedades": {
        "steps": "Array de pasos a ejecutar simultaneamente"
      },
      "output": {
        "results": "Objeto con resultado por paso",
        "allSuccess": "Boolean si todos exitosos",
        "successCount": "Numero de exitos",
        "failCount": "Numero de fallos"
      }
    },
    "agent": {
      "descripcion": "Invoca agente AI",
      "patron_eventos": "agent.execute.request -> agent.*.completed",
      "propiedades": {
        "agent": "Nombre del agente",
        "task": "Tarea a ejecutar",
        "timeout": "Timeout en ms (default: 120000)"
      }
    },
    "http": {
      "descripcion": "Llamada HTTP externa",
      "propiedades": {
        "url": "URL destino",
        "method": "GET, POST, PUT, DELETE, etc.",
        "headers": "Headers HTTP",
        "body": "Cuerpo de la peticion",
        "timeout": "Timeout en ms (default: 30000)"
      }
    },
    "delay": {
      "descripcion": "Espera un tiempo",
      "propiedades": {
        "ms": "Milisegundos a esperar"
      }
    },
    "log": {
      "descripcion": "Escribe en el log",
      "propiedades": {
        "level": "info, warn, error, debug",
        "message": "Mensaje (soporta variables)",
        "data": "Datos adicionales"
      }
    },
    "set": {
      "descripcion": "Define variables para pasos posteriores",
      "propiedades": {
        "variables": "Objeto con variables a definir"
      }
    },
    "emit": {
      "descripcion": "Publica evento para encadenar flujos",
      "propiedades": {
        "event": "Nombre del evento a publicar (ej: factura.nueva)",
        "data": "Datos a incluir en el evento (soporta variables {{ }})"
      },
      "output": {
        "emitted": "boolean - true si se emitió correctamente",
        "event": "string - nombre del evento emitido",
        "data": "object - datos enviados"
      },
      "ejemplo": {
        "id": "emitir-factura",
        "type": "emit",
        "event": "factura.nueva",
        "data": {
          "source": "telegram",
          "archivo": "{{ steps.normalizar.archivo }}"
        }
      },
      "uso": "Encadenar flujos modulares - un flujo emite, otro escucha como trigger"
    }
  },

  "variables": {
    "sintaxis": "{{ path.to.value }}",
    "contextos": {
      "trigger": "Datos del evento que disparo el flujo",
      "steps.ID": "Resultado de un paso anterior (output guardado directamente)",
      "steps.ID.data": "Para servicios que devuelven data anidada (ej: OCR)",
      "variables": "Variables definidas con step 'set'",
      "env.VAR": "Variables de entorno"
    },
    "especiales": {
      "now": "ISO timestamp actual",
      "timestamp": "Unix timestamp en ms",
      "uuid": "UUID v4 aleatorio",
      "date": "Fecha YYYY-MM-DD",
      "time": "Hora HH:mm:ss"
    },
    "funciones": {
      "default(value, fallback)": "Valor por defecto si null/undefined",
      "lowercase(value)": "Convierte a minusculas",
      "uppercase(value)": "Convierte a mayusculas",
      "length(value)": "Longitud de string/array",
      "globalPath(path)": "Convierte rutas data/... a @/... para acceso global",
      "json(value)": "Serializa objeto a JSON string (para fs.write)"
    }
  },

  "rutas_filesystem": {
    "principio": "Los flujos deben ser AUTOCONTENIDOS - no depender del proyecto activo",
    "prefijos": {
      "@/": {
        "descripcion": "Ruta global absoluta desde data/",
        "uso": "RECOMENDADO para todos los flujos",
        "ejemplo": "@/bots/mi_bot/received/archivo.jpg -> data/bots/mi_bot/received/archivo.jpg"
      },
      "/": {
        "descripcion": "Ruta relativa al proyecto activo (storage/)",
        "uso": "EVITAR - depende del contexto del sistema",
        "ejemplo": "/procesadas/archivo.json -> data/projects/{proyecto_activo}/storage/procesadas/archivo.json"
      }
    },
    "rutas_comunes": {
      "bots_entrada": "@/bots/{nombre_bot}/received/",
      "proyectos_storage": "@/projects/{nombre_proyecto}/storage/",
      "proyectos_procesadas": "@/projects/{nombre_proyecto}/storage/procesadas/"
    },
    "conversion_dinamica": {
      "funcion": "globalPath()",
      "descripcion": "Convierte rutas que vienen de triggers (data/...) al formato @/",
      "ejemplo": "{{ globalPath(trigger.file.path) }} -> @/bots/mi_bot/received/archivo.jpg",
      "cuando_usar": "Cuando el trigger proporciona una ruta en formato data/..."
    },
    "patron_recomendado": {
      "entrada": "{{ globalPath(trigger.file.path) }}",
      "salida": "@/projects/{nombre_proyecto}/storage/procesadas/{{ date }}_{{ trigger.file.originalName }}.json"
    }
  },

  "filtros_trigger": {
    "descripcion": "Filtros estilo MongoDB para coincidir eventos",
    "operadores": {
      "$eq": "Igual",
      "$ne": "No igual",
      "$in": "Valor en lista",
      "$nin": "Valor no en lista",
      "$gt": "Mayor que",
      "$gte": "Mayor o igual que",
      "$lt": "Menor que",
      "$lte": "Menor o igual que",
      "$contains": "String contiene",
      "$startsWith": "String comienza con",
      "$endsWith": "String termina con",
      "$regex": "Coincide expresion regular",
      "$exists": "Campo existe o no"
    },
    "ejemplo": {
      "botName": "mi-bot",
      "file.mimeType": { "$in": ["image/jpeg", "image/png"] },
      "file.size": { "$lt": 10000000 }
    }
  },

  "manejo_errores": {
    "comportamiento_default": "Error en un paso falla todo el flujo",
    "opciones": {
      "continue": "Ignora error y sigue con siguiente paso",
      "step-id": "Salta a paso especifico para manejar error"
    },
    "ejemplo": {
      "id": "paso-opcional",
      "type": "service",
      "onError": "continue"
    }
  },

  "providers_soportados": {
    "filesystem": {
      "fs": {
        "acciones": ["read", "write", "append", "delete", "exists", "list", "mkdir", "move", "rename", "info", "search", "stats"],
        "descripcion": "Operaciones de filesystem via modules/filesystem/",
        "patron": "fs.{action}.request -> fs.{action}.response"
      }
    },
    "locales": {
      "local.tesseract": {
        "acciones": ["extract"],
        "descripcion": "OCR local con Tesseract.js"
      },
      "local.scribe-ocr": {
        "acciones": ["extract"],
        "descripcion": "OCR avanzado con scribe.js-ocr (WASM)",
        "input": "input (imagen/PDF base64 o path), lang, oem, psm",
        "output": "data.text, data.confidence, data.pages",
        "nota": "Soporta PDFs directamente. No requiere Tesseract instalado"
      },
      "local.google-vision": {
        "acciones": ["extract"],
        "descripcion": "OCR con Google Cloud Vision API",
        "input": "image (base64 o path), hint (TEXT_DETECTION|DOCUMENT_TEXT_DETECTION|HANDWRITING), languageHints, account",
        "output": "data.text, data.confidence, data.blocks, data.pages, data.locale",
        "credenciales": ["GOOGLE_API_KEY"],
        "nota": "Alta precisión, soporta multi-cuenta, compatible con @/ para rutas globales"
      },
      "local.google-documentai": {
        "acciones": ["parse"],
        "descripcion": "Extracción estructurada con Google Document AI",
        "input": "document (base64 o path), processor (invoice|form|ocr), account",
        "output": "data.text, data.entities, data.tables, data.pages",
        "credenciales": ["OAuth con scope cloud-platform (mismas que Gmail)"],
        "config_requerida": ["GOOGLE_PROJECT_ID", "GOOGLE_DOCUMENTAI_PROCESSOR_{TYPE}"],
        "nota": "Ideal para facturas. Extrae vendor, total, date, line_items estructurados"
      },
      "local.pdf-to-png": {
        "acciones": ["convert"],
        "descripcion": "Convertir PDF a imágenes PNG",
        "input": "pdf (base64 o path), pages (array), scale, outputFolder, password",
        "output": "data.images[], data.totalPages",
        "nota": "Sin dependencias binarias. Ideal para preview y OCR de escaneados"
      },
      "local.pdf-parse": {
        "acciones": ["extract"],
        "descripcion": "Extraer texto de PDF (simple)",
        "input": "pdf (base64 o path), maxPages (opcional)",
        "output": "data.text, data.pages, data.info",
        "nota": "Acceder via steps.ID.data.text"
      },
      "local.pdfjs": {
        "acciones": ["extract", "render", "info"],
        "descripcion": "PDF avanzado con pdfjs-dist",
        "input": "pdf (base64 o path), pages (rango), includePositions, scale",
        "output": "data.text, data.pages, data.pageTexts, data.metadata, data.image",
        "nota": "extract: texto con posiciones, render: página a PNG, info: metadata"
      },
      "local.pdf": {
        "acciones": ["create"],
        "descripcion": "Generacion de PDFs"
      },
      "local.csv": {
        "acciones": ["create", "parse"],
        "descripcion": "Manipulacion de archivos CSV"
      },
      "local.xlsx": {
        "acciones": ["create", "parse"],
        "descripcion": "Manipulacion de archivos Excel"
      },
      "gmail": {
        "acciones": ["send", "list", "read", "search", "attachments.download"],
        "descripcion": "Gmail API - Envio y lectura de correos",
        "credenciales": ["GMAIL_CLIENT_ID", "GMAIL_CLIENT_SECRET", "GMAIL_REFRESH_TOKEN"]
      }
    },
    "externos": {
      "google.vision": {
        "acciones": ["extract"],
        "descripcion": "OCR con Google Cloud Vision"
      },
      "google.tts": {
        "acciones": ["synthesize"],
        "descripcion": "Text-to-Speech con Google"
      },
      "google.translate": {
        "acciones": ["text"],
        "descripcion": "Traduccion con Google"
      },
      "anthropic.vision": {
        "acciones": ["extract"],
        "descripcion": "OCR con analisis via Claude"
      },
      "elevenlabs.tts": {
        "acciones": ["synthesize"],
        "descripcion": "Text-to-Speech con ElevenLabs"
      },
      "telegram": {
        "acciones": ["send_message"],
        "descripcion": "Envio de mensajes Telegram"
      }
    }
  },

  "eventos": {
    "publicados": {
      "flow.started": "Flujo iniciado",
      "flow.step.started": "Paso iniciado",
      "flow.step.completed": "Paso completado",
      "flow.step.failed": "Paso fallido",
      "flow.completed": "Flujo completado exitosamente",
      "flow.failed": "Flujo fallido"
    },
    "suscritos": {
      "triggers": ["bot.file.stored", "bot.message.received", "bot.command.received", "flow.trigger", "factura.nueva", "factura.procesada", "factura.guardada", "factura.completada", "factura.error"],
      "providers": "Todos los eventos {provider}.{action}.response y {provider}.{action}.failed"
    }
  },

  "api_http": {
    "base_path": "/modules/flow-engine",
    "endpoints": [
      { "method": "GET", "path": "/health", "descripcion": "Health check" },
      { "method": "GET", "path": "/flows", "descripcion": "Lista flujos" },
      { "method": "GET", "path": "/flows/:flowId", "descripcion": "Obtiene flujo" },
      { "method": "POST", "path": "/flows", "descripcion": "Crea flujo" },
      { "method": "PUT", "path": "/flows/:flowId", "descripcion": "Actualiza flujo" },
      { "method": "DELETE", "path": "/flows/:flowId", "descripcion": "Elimina flujo" },
      { "method": "POST", "path": "/flows/:flowId/trigger", "descripcion": "Dispara flujo manualmente" },
      { "method": "GET", "path": "/executions", "descripcion": "Lista ejecuciones" },
      { "method": "GET", "path": "/executions/:executionId", "descripcion": "Estado de ejecucion" },
      { "method": "POST", "path": "/executions/:executionId/cancel", "descripcion": "Cancela ejecucion" }
    ]
  },

  "contexto_ejecucion": {
    "descripcion": "Objeto disponible durante la ejecucion del flujo",
    "estructura": {
      "trigger": "Datos del evento que disparo el flujo",
      "steps": "Resultados de cada paso ejecutado (indexado por step.id)",
      "variables": "Variables definidas con step 'set'",
      "flow": { "id": "ID del flujo", "name": "Nombre del flujo" },
      "project": {
        "id": "ID del proyecto (null si flujo global)",
        "config": "Configuracion del proyecto (de config/facturas.json)"
      },
      "config": "Shortcut a project.config",
      "execution": { "id": "ID de ejecucion", "startedAt": "Timestamp inicio" }
    },
    "acceso": "{{ steps.paso-id.campo }} o {{ steps.paso-id.data.campo }} para servicios",
    "acceso_config": "{{ config.telegram.botName }} o {{ project.id }}"
  },

  "flujos_por_proyecto": {
    "descripcion": "Los flujos se organizan por proyecto, no globalmente",
    "ubicacion": "data/projects/{projectId}/flows/",
    "configuracion": "data/projects/{projectId}/config/facturas.json",
    "id_compuesto": "Los flujos de proyecto tienen ID {projectId}:{flowId}",
    "carga_automatica": "flow-registry carga flujos de todos los proyectos al iniciar",
    "plantilla": {
      "ubicacion": "templates/facturas/",
      "uso": "cp -r templates/facturas/* data/projects/{nuevo_proyecto}/",
      "flujos_incluidos": [
        "entrada-telegram - Recibe facturas desde Telegram",
        "entrada-gmail - Recoge facturas desde Gmail",
        "procesar-lote - Procesa lote semanal con OCR",
        "procesar-factura - OCR individual de cada factura",
        "consolidar-excel - Exporta a Excel para asesoria"
      ]
    },
    "configuracion_proyecto": {
      "telegram.botName": "Nombre del bot de Telegram",
      "gmail.enabled": "Si habilitar recogida de Gmail",
      "gmail.account": "Cuenta Gmail a usar",
      "schedule.gmail": "Cron para Gmail (default: 0 3 * * *)",
      "schedule.procesamiento": "Cron para OCR (default: 0 3 * * 0)",
      "schedule.exportacion": "Cron para Excel (default: 0 6 * * 0)",
      "storage.inbox": "Ruta relativa para entrada",
      "storage.procesadas": "Ruta relativa para procesadas",
      "storage.exports": "Ruta relativa para exports"
    }
  },

  "scheduling": {
    "descripcion": "Ejecucion programada de flujos via cron",
    "componente": "services/scheduler.js",
    "uso": {
      "cron": "Expresion cron (min hora dia mes dia-semana)",
      "timezone": "Zona horaria (default: Europe/Madrid)"
    },
    "trigger_event": "flow.trigger con flowId para activar flujo programado",
    "ejemplos": {
      "domingo_3am": "0 3 * * 0",
      "diario_3am": "0 3 * * *",
      "lunes_viernes_8am": "0 8 * * 1-5"
    }
  },

  "buenas_practicas": [
    "Usar IDs descriptivos para pasos (ej: 'leer-archivo', 'procesar-ocr')",
    "Definir timeouts apropiados para servicios externos",
    "Usar onError para pasos no criticos",
    "Guardar resultados intermedios con filesystem para debugging",
    "Usar step 'log' para trazabilidad",
    "Validar datos con step 'condition' antes de procesar",
    "RUTAS: Usar @/ para rutas globales - flujos deben ser autocontenidos",
    "RUTAS: Usar globalPath() para convertir rutas de triggers",
    "RUTAS: Definir rutas de salida explicitas con @/projects/{proyecto}/storage/"
  ],

  "ubicacion_archivos": {
    "modulo": "modules/flow-engine/",
    "flujos_globales": "modules/flow-engine/flows/",
    "servicios": "modules/flow-engine/services/",
    "flujos_proyecto": "data/projects/{projectId}/flows/",
    "config_proyecto": "data/projects/{projectId}/config/",
    "plantillas": "templates/facturas/"
  }
}
