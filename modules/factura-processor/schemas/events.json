{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "factura.queued": {
      "type": "object",
      "description": "Factura encolada para procesamiento OCR",
      "properties": {
        "filePath": { "type": "string", "description": "Ruta del archivo" },
        "originalName": { "type": "string", "description": "Nombre original" },
        "queuePosition": { "type": "integer", "description": "Posición en cola" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["filePath", "originalName", "timestamp"]
    },
    "factura.processing": {
      "type": "object",
      "description": "Factura siendo procesada por OCR",
      "properties": {
        "request_id": { "type": "string", "format": "uuid" },
        "filePath": { "type": "string" },
        "originalName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["request_id", "filePath", "timestamp"]
    },
    "factura.processed": {
      "type": "object",
      "description": "Factura procesada exitosamente",
      "properties": {
        "originalFile": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "outputFile": {
          "type": "object",
          "properties": {
            "textPath": { "type": "string" },
            "jsonPath": { "type": "string" }
          }
        },
        "ocr": {
          "type": "object",
          "properties": {
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "words": { "type": "integer" },
            "engine": { "type": "string" },
            "textLength": { "type": "integer" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["originalFile", "outputFile", "ocr", "timestamp"]
    },
    "factura.failed": {
      "type": "object",
      "description": "Error procesando factura",
      "properties": {
        "filePath": { "type": "string" },
        "originalName": { "type": "string" },
        "error": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["filePath", "error", "timestamp"]
    }
  }
}
