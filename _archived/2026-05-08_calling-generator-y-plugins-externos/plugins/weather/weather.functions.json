{
  "metadata": {
    "name": "weather",
    "version": "1.0.0",
    "description": "OpenWeatherMap API integration for weather data and forecasts",
    "base_url": "https://api.openweathermap.org/data/2.5",
    "auth_type": "api_key_query",
    "auth_query_param_name": "appid",
    "documentation": "https://openweathermap.org/api"
  },
  "functions": {
    "get_current_weather": {
      "method": "GET",
      "endpoint": "/weather",
      "description": "Get current weather for a city",
      "parameters": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "description": "City name (e.g., 'Madrid', 'London,UK')"
          },
          "lat": {
            "type": "number",
            "description": "Latitude coordinate"
          },
          "lon": {
            "type": "number",
            "description": "Longitude coordinate"
          },
          "units": {
            "type": "string",
            "enum": ["standard", "metric", "imperial"],
            "description": "Units of measurement (metric for Celsius, imperial for Fahrenheit)",
            "default": "metric"
          },
          "lang": {
            "type": "string",
            "description": "Language for weather description (e.g., 'es', 'en')",
            "default": "en"
          }
        },
        "required": []
      }
    },
    "get_forecast": {
      "method": "GET",
      "endpoint": "/forecast",
      "description": "Get 5-day weather forecast with 3-hour intervals",
      "parameters": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "description": "City name"
          },
          "lat": {
            "type": "number",
            "description": "Latitude"
          },
          "lon": {
            "type": "number",
            "description": "Longitude"
          },
          "units": {
            "type": "string",
            "enum": ["standard", "metric", "imperial"],
            "default": "metric"
          },
          "cnt": {
            "type": "integer",
            "description": "Number of timestamps to return (max 40)",
            "default": 40
          }
        },
        "required": []
      }
    },
    "get_air_pollution": {
      "method": "GET",
      "endpoint": "/air_pollution",
      "description": "Get current air pollution data",
      "parameters": {
        "type": "object",
        "properties": {
          "lat": {
            "type": "number",
            "description": "Latitude"
          },
          "lon": {
            "type": "number",
            "description": "Longitude"
          }
        },
        "required": ["lat", "lon"]
      }
    }
  }
}
