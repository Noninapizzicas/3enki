{
  "name": "cocina",
  "version": "3.2.0",
  "description": "Display de cocina en tiempo real - Sistema de preparacion de pedidos. Sistema de pases multi-estacion (general, horno) + multi-device con colores. Snapshot persistente atomico. Publica periferico.display para pantallas externas.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "events": {
    "publishes": [
      {
        "event": "cocina.item_preparando",
        "description": "Cocinero empieza a preparar un item (primer tap pendiente -> preparando). Lleva project_id top-level + correlation_id + timestamp."
      },
      {
        "event": "cocina.item_avanzado",
        "description": "Item avanza de estacion (pase++). Payload incluye desde_estacion + estado (pendiente|preparando segun auto_preparar). project_id top-level + correlation_id + timestamp."
      },
      {
        "event": "cocina.item_preparado",
        "description": "Item terminado en estacion final. project_id top-level + correlation_id + timestamp."
      },
      {
        "event": "cocina.item_ticket",
        "description": "Ticket de pieza individual cuando estacion tiene imprime_al_completar. Incluye ingredientes, variaciones, notas, impresora. project_id top-level + correlation_id + timestamp."
      },
      {
        "event": "cocina.pedido_listo",
        "description": "Pedido completamente preparado y listo para servir. project_id top-level + correlation_id + timestamp."
      },
      {
        "event": "periferico.display",
        "description": "Notificacion a display externo de cocina (TV, LED, tablet) con accion + contenido + prioridad. project_id top-level + correlation_id + timestamp."
      },
      {
        "event": "cocina.device_registered",
        "description": "Device fisico de cocina registrado con color asignado. project_id top-level + correlation_id + timestamp."
      },
      {
        "event": "cocina.device_unregistered",
        "description": "Device fisico de cocina removido. project_id top-level + correlation_id + timestamp."
      },
      {
        "event": "cocina.device_updated",
        "description": "Device fisico re-conectado o metadata actualizada. project_id top-level + correlation_id + timestamp."
      }
    ],
    "subscribes": [
      { "event": "pedido.enviado_cocina", "handler": "onPedidoEnviadoCocina", "description": "Pedido formal enviado a cocina (desde modulo Pedidos)." },
      { "event": "pedido.cancelado",      "handler": "onPedidoCancelado",     "description": "Pedido cancelado - remover de cocina." },
      { "event": "cuenta.creada",         "handler": "onCuentaCreada",        "description": "Cachear ref_display de cuenta para mostrar en cocina." },
      { "event": "cuenta.actualizada",    "handler": "onCuentaActualizada",   "description": "Actualizar ref_display cuando cuenta se renombra y propagar a pedidos activos." },
      { "event": "cuenta.eliminada",      "handler": "onCuentaEliminada",     "description": "Limpiar cache + housekeeping de pedidos huerfanos al eliminar cuenta." },
      { "event": "caja.cerrada",          "handler": "onCajaCerrada",         "description": "Cierre de caja - reset de pedidos activos y snapshot." },
      { "event": "dia.iniciado",          "handler": "onDiaIniciado",         "description": "Nuevo dia - reset de estado de cocina." }
    ]
  },
  "ui_handlers": [
    { "domain": "cocina", "action": "list-active",        "handler": "handleGetActivos",       "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "get",                "handler": "handleGetPedido",        "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "history",            "handler": "handleGetHistorial",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "prepare-item",       "handler": "handlePrepararItem",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "mark-ready",         "handler": "handleMarcarListo",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "register-device",    "handler": "handleRegisterDevice",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "unregister-device",  "handler": "handleUnregisterDevice", "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "list-devices",       "handler": "handleListDevices",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "list-station-types", "handler": "handleListTiposEstacion","type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "list-displays",      "handler": "handleListarDisplays",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "health",             "handler": "handleHealthCheck",      "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "cocina", "action": "metrics",            "handler": "handleGetMetrics",       "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [],
  "dependencies": [],
  "tracing": {
    "propaga_correlation_id": true
  },
  "config": {
    "display_destino": "display-cocina",
    "persistence": {
      "type": "filesystem-snapshot",
      "owner": "CocinaModule (snapshot atomico tmp + rename con debounce 1s)",
      "paths": [
        "data/current/cocina_snapshot.json",
        "data/current/cuentas_activas.json (lectura legacy fallback)"
      ],
      "restart_resilient": true,
      "concurrency": "single-instance (in-memory pedidosActivos + devices)"
    }
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "cocina.pedido_recibido.total",
        "cocina.pedido_cancelado.total",
        "cocina.item_preparado.total",
        "cocina.item_avanzado.total",
        "cocina.pedido_listo.total",
        "cocina.errors"
      ],
      "gauges": [
        "cocina.pedidos_activos.count",
        "cocina.items_pendientes.count"
      ],
      "timings": [
        "cocina.preparacion_item.duration",
        "cocina.preparacion_pedido.duration"
      ]
    }
  }
}
