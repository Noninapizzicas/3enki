{
  "id": "consolidar-enviar",
  "name": "Consolidar y Enviar a Asesoría",
  "description": "Empaqueta todas las facturas procesadas en ZIP y envía por email a la asesoría",
  "version": "1.1.0",
  "enabled": true,

  "schedule": {
    "cron": "0 5 * * 0",
    "timezone": "Europe/Madrid"
  },

  "steps": [
    {
      "id": "crear-exports",
      "type": "service",
      "service": "fs",
      "action": "mkdir",
      "path": "{{ projectPath('exports') }}",
      "onError": "continue"
    },
    {
      "id": "crear-archivados",
      "type": "service",
      "service": "fs",
      "action": "mkdir",
      "path": "{{ projectPath('archivados') }}",
      "onError": "continue"
    },
    {
      "id": "listar-datos",
      "type": "service",
      "service": "fs",
      "action": "list",
      "path": "{{ projectPath('datos') }}"
    },
    {
      "id": "verificar-datos",
      "type": "condition",
      "if": "{{ count(default(steps.listar-datos.files, [])) }} > 0",
      "then": "log-inicio",
      "else": "log-vacio"
    },
    {
      "id": "log-vacio",
      "type": "log",
      "level": "info",
      "message": "No hay facturas procesadas para consolidar esta semana"
    },
    {
      "id": "log-inicio",
      "type": "log",
      "level": "info",
      "message": "Consolidando {{ count(steps.listar-datos.files) }} facturas"
    },
    {
      "id": "set-fecha",
      "type": "set",
      "variables": {
        "fechaExport": "{{ date }}",
        "semana": "semana_{{ date }}"
      }
    },
    {
      "id": "crear-zip",
      "type": "service",
      "service": "local.zip",
      "action": "createFromFiles",
      "files": [
        {
          "source": "{{ projectPath('originales') }}",
          "name": "originales"
        },
        {
          "source": "{{ projectPath('datos') }}",
          "name": "datos_json"
        }
      ],
      "output": "{{ projectPath('exports/facturas_nonina_', variables.semana, '.zip') }}"
    },
    {
      "id": "log-zip-creado",
      "type": "log",
      "level": "info",
      "message": "ZIP creado: {{ steps.crear-zip.path }} ({{ steps.crear-zip.files }} archivos)"
    },
    {
      "id": "enviar-email",
      "type": "service",
      "service": "gmail",
      "action": "send",
      "to": "{{ config.asesoria.email }}",
      "subject": "Facturas {{ project.id }} - {{ variables.semana }}",
      "body": "Adjunto el paquete de facturas de la semana.\n\nContenido del ZIP:\n- Carpeta 'originales': Imágenes y PDFs de las facturas\n- Carpeta 'datos_json': Datos extraídos en formato JSON\n\nTotal facturas procesadas: {{ count(steps.listar-datos.files) }}\n\nPara importar a Excel, puedes usar los archivos JSON de la carpeta datos_json.\n\nSaludos,\nSistema Automático de Facturas",
      "attachments": [
        "{{ projectPath('exports/facturas_nonina_', variables.semana, '.zip') }}"
      ]
    },
    {
      "id": "crear-dir-semana",
      "type": "service",
      "service": "fs",
      "action": "mkdir",
      "path": "{{ projectPath('archivados/', variables.semana) }}"
    },
    {
      "id": "archivar-datos",
      "type": "service",
      "service": "fs",
      "action": "move",
      "from": "{{ projectPath('datos') }}",
      "to": "{{ projectPath('archivados/', variables.semana, '/datos') }}"
    },
    {
      "id": "archivar-originales",
      "type": "service",
      "service": "fs",
      "action": "move",
      "from": "{{ projectPath('originales') }}",
      "to": "{{ projectPath('archivados/', variables.semana, '/originales') }}"
    },
    {
      "id": "recrear-directorios",
      "type": "parallel",
      "steps": [
        {
          "id": "recrear-datos",
          "type": "service",
          "service": "fs",
          "action": "mkdir",
          "path": "{{ projectPath('datos') }}"
        },
        {
          "id": "recrear-originales",
          "type": "service",
          "service": "fs",
          "action": "mkdir",
          "path": "{{ projectPath('originales') }}"
        }
      ]
    },
    {
      "id": "log-completado",
      "type": "log",
      "level": "info",
      "message": "Consolidación completada: {{ count(steps.listar-datos.files) }} facturas enviadas a {{ config.asesoria.email }}"
    }
  ]
}
