{
  "name": "pdf-viewer",
  "version": "2.0.0",
  "description": "PDF viewer and text extraction module",
  "author": "Aichat Team",
  "language": "en",
  "main": "index.js",
  "ui": {
    "enabled": true,
    "title": "Visor PDF",
    "icon": "📄",
    "description": "Visualizador y extractor de texto de PDFs",
    "views": {
      "viewer": {
        "title": "Visor PDF",
        "description": "Visualizador de documentos PDF",
        "layout": "fullscreen"
      }
    }
  },
  "apis": [
    {
      "method": "GET",
      "path": "/pdf/view",
      "handler": "viewPdf",
      "description": "Get PDF file for viewing",
      "query_params": {
        "project_id": {
          "type": "string",
          "required": true
        },
        "file_path": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "method": "GET",
      "path": "/pdf/extract-text",
      "handler": "extractText",
      "description": "Extract text from PDF",
      "query_params": {
        "project_id": {
          "type": "string",
          "required": true
        },
        "file_path": {
          "type": "string",
          "required": true
        },
        "page": {
          "type": "number",
          "required": false,
          "description": "Specific page number (1-indexed). If not provided, extracts all pages."
        }
      }
    },
    {
      "method": "GET",
      "path": "/pdf/metadata",
      "handler": "getMetadata",
      "description": "Get PDF metadata",
      "query_params": {
        "project_id": {
          "type": "string",
          "required": true
        },
        "file_path": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "method": "GET",
      "path": "/pdf/list",
      "handler": "listPdfs",
      "description": "List all PDF files in project",
      "query_params": {
        "project_id": {
          "type": "string",
          "required": true
        }
      }
    }
  ],
  "events": {
    "subscribes": [
      {
        "event": "pdf.view.request",
        "handler": "handleViewRequest"
      },
      {
        "event": "pdf.extract.request",
        "handler": "handleExtractRequest"
      },
      {
        "event": "pdf.metadata.request",
        "handler": "handleMetadataRequest"
      },
      {
        "event": "pdf.list.request",
        "handler": "handleListRequest"
      }
    ],
    "publishes": [
      "pdf.view.response",
      "pdf.extract.response",
      "pdf.metadata.response",
      "pdf.list.response",
      "db.query.request",
      "local.pdf.create.request"
    ]
  },
  "ui_handlers": [
    {
      "domain": "pdf",
      "action": "view",
      "handler": "handleUIView"
    },
    {
      "domain": "pdf",
      "action": "metadata",
      "handler": "handleUIMetadata"
    },
    {
      "domain": "pdf",
      "action": "list",
      "handler": "handleUIListPdfs"
    }
  ],
  "dependencies": {
    "modules": [
      "filesystem",
      "project-manager"
    ]
  },
  "tools": [
    {
      "name": "pdf.create",
      "description": "Crea un archivo PDF desde texto plano. IMPORTANTE: usa texto plano corto (máx 3000 caracteres). NO envíes HTML largo ni contenido extenso — el JSON se truncará y fallará. Si el contenido es largo, resúmelo antes de llamar a esta tool. Usa el campo 'title' para el encabezado.",
      "handler": "handleToolCreate",
      "errores_conocidos": [
        { "code": "INVALID_INPUT", "cuando": "filename o content no provistos" },
        { "code": "UPSTREAM_UNREACHABLE", "cuando": "pdfkit no instalado y provider no disponible" },
        { "code": "UNKNOWN_ERROR", "cuando": "error al escribir en disco" }
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string",
            "description": "Nombre del archivo PDF (ej: 'informe.pdf'). Requerido."
          },
          "content": {
            "type": "string",
            "description": "Texto plano del documento. Máximo 3000 caracteres. NO usar HTML largo."
          },
          "title": {
            "type": "string",
            "description": "Título centrado al inicio del PDF (opcional)"
          },
          "type": {
            "type": "string",
            "enum": [
              "from_text"
            ],
            "description": "Siempre 'from_text'. No usar from_html."
          },
          "orientation": {
            "type": "string",
            "enum": [
              "portrait",
              "landscape"
            ],
            "description": "Orientación: portrait (por defecto) o landscape"
          },
          "format": {
            "type": "string",
            "enum": [
              "A4",
              "letter",
              "legal"
            ],
            "description": "Formato de página: A4 (por defecto), letter o legal"
          },
          "project_id": {
            "type": "string",
            "description": "ID del proyecto (opcional)"
          }
        },
        "required": [
          "filename",
          "content"
        ]
      }
    },
    {
      "name": "pdf.list",
      "description": "Lista todos los archivos PDF en un proyecto.",
      "handler": "handleToolList",
      "errores_conocidos": [
        { "code": "INVALID_INPUT", "cuando": "projectId no provisto" },
        { "code": "UNKNOWN_ERROR", "cuando": "error de lectura del directorio" }
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "ID del proyecto"
          }
        },
        "required": [
          "projectId"
        ]
      }
    },
    {
      "name": "pdf.metadata",
      "description": "Obtiene metadata de un archivo PDF (tamaño, fecha, etc.).",
      "handler": "handleToolMetadata",
      "errores_conocidos": [
        { "code": "INVALID_INPUT", "cuando": "projectId o filePath no provistos" },
        { "code": "INVALID_INPUT", "cuando": "el archivo no es un PDF" },
        { "code": "RESOURCE_NOT_FOUND", "cuando": "el archivo no existe" },
        { "code": "PERMISSION_DENIED", "cuando": "path fuera del directorio del proyecto" }
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "ID del proyecto"
          },
          "filePath": {
            "type": "string",
            "description": "Ruta al archivo PDF"
          }
        },
        "required": [
          "projectId",
          "filePath"
        ]
      }
    },
    {
      "name": "pdf.extract",
      "description": "Extrae texto de un archivo PDF. Puede extraer una página específica o todo el documento.",
      "handler": "handleToolExtract",
      "errores_conocidos": [
        { "code": "INVALID_INPUT", "cuando": "projectId o filePath no provistos" },
        { "code": "INVALID_INPUT", "cuando": "el archivo no es un PDF" },
        { "code": "RESOURCE_NOT_FOUND", "cuando": "el archivo no existe" },
        { "code": "PERMISSION_DENIED", "cuando": "path fuera del directorio del proyecto" }
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "ID del proyecto"
          },
          "filePath": {
            "type": "string",
            "description": "Ruta al archivo PDF"
          },
          "page": {
            "type": "number",
            "description": "Número de página (1-indexed). Si no se especifica, extrae todo."
          }
        },
        "required": [
          "projectId",
          "filePath"
        ]
      }
    }
  ],
  "config": {
    "max_pdf_size": 52428800,
    "cache_enabled": true,
    "cache_ttl": 3600000
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "prefix": "pdf-viewer",
      "custom": [
        "pdf-viewer.view.success",
        "pdf-viewer.view.failed",
        "pdf-viewer.extract.success",
        "pdf-viewer.extract.failed",
        "pdf-viewer.metadata.success",
        "pdf-viewer.metadata.failed",
        "pdf-viewer.list.success",
        "pdf-viewer.list.failed",
        "pdf-viewer.tool.create.success",
        "pdf-viewer.tool.extract.success",
        "pdf-viewer.tool.extract.no_parser"
      ]
    },
    "tracing": {
      "propaga_correlation_id": true
    }
  }
}
