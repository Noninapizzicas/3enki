{
  "name": "credential-manager",
  "version": "2.0.0",
  "description": "Core canónico: CRUD de credenciales API + resolución cascada (CUSTOM → CLIENT → PROJECT → GLOBAL) + cache .env atómico. Tras descomposición 2026-05-04: NO incluye test de credenciales (módulo credential-tester pendiente), NO incluye OAuth flow (credential-oauth pendiente), NO incluye configs vendor multi-campo Glovo/Telegram (credential-vendor-* pendientes). Ver arquitectura/migracion/notas/credential-manager-descomposicion.md.",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",

  "events": {
    "publishes": [
      {
        "event": "credential.saved",
        "description": "Credencial creada exitosamente. correlation_id propagado del request original."
      },
      {
        "event": "credential.updated",
        "description": "Credencial actualizada (api_key cambiado o re-creada con misma key)."
      },
      {
        "event": "credential.deleted",
        "description": "Credencial eliminada del store + .env."
      },
      {
        "event": "credential.resolve.response",
        "description": "Respuesta a credential.resolve.request con api_key resuelta o error. Correlacion por request_id."
      },
      {
        "event": "credential.state",
        "description": "Snapshot del estado del module (lista de credenciales sin valores). Publicado tras cada CRUD + onStateRequest."
      }
    ],
    "subscribes": [
      {
        "event": "credential.state.request",
        "handler": "onStateRequest",
        "description": "Frontend pide snapshot del estado actual."
      },
      {
        "event": "credential.create.request",
        "handler": "onCreateCredential",
        "description": "Crear nueva credencial. Payload: { provider, level, identifier?, api_key }. Publica credential.saved."
      },
      {
        "event": "credential.update.request",
        "handler": "onUpdateCredential",
        "description": "Actualizar api_key de credencial existente. Payload: { key, api_key }. Publica credential.updated."
      },
      {
        "event": "credential.delete.request",
        "handler": "onDeleteCredential",
        "description": "Eliminar credencial. Payload: { key }. Publica credential.deleted."
      },
      {
        "event": "credential.resolve.request",
        "handler": "onResolveRequest",
        "description": "Resolver credencial via cascada CUSTOM → CLIENT → PROJECT → GLOBAL. Payload: { request_id, provider, customId?, client_id?, project_id? }. Publica credential.resolve.response con api_key + resolved_from o error."
      }
    ]
  },

  "apis": [
    { "method": "POST",   "path": "/credentials",          "handler": "handleSaveCredential",    "description": "Crear o actualizar credencial." },
    { "method": "POST",   "path": "/credentials/resolve",  "handler": "handleResolveCredential", "description": "Resolver credencial via cascada." },
    { "method": "GET",    "path": "/credentials",          "handler": "handleListCredentials",   "description": "Listar credenciales (sin valores)." },
    { "method": "PUT",    "path": "/credentials/:key",     "handler": "handleUpdateCredential",  "description": "Actualizar credencial." },
    { "method": "DELETE", "path": "/credentials/:key",     "handler": "handleDeleteCredential",  "description": "Eliminar credencial." },
    { "method": "GET",    "path": "/health",               "handler": "handleHealthCheck",       "description": "Health check." },
    { "method": "GET",    "path": "/metrics",              "handler": "handleGetMetrics",        "description": "Metricas (count por level)." },
    { "method": "GET",    "path": "/levels",               "handler": "handleGetLevels",         "description": "Lista de levels validos." }
  ],

  "ui_handlers": [
    { "domain": "credential", "action": "list",   "handler": "handleUIList" },
    { "domain": "credential", "action": "get",    "handler": "handleUIGet" },
    { "domain": "credential", "action": "create", "handler": "handleUICreate" },
    { "domain": "credential", "action": "update", "handler": "handleUIUpdate" },
    { "domain": "credential", "action": "delete", "handler": "handleUIDelete" }
  ],

  "tools": [
    {
      "name": "credential.list",
      "description": "Lista nombres de credenciales disponibles por proveedor y nivel. NUNCA retorna valores de API keys, solo metadata (provider, level, identifier) y preview enmascarado.",
      "handler": "handleToolCredentialList",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      },
      "errores_conocidos": ["UNKNOWN_ERROR"]
    }
  ],

  "dependencies": [],

  "config": {
    "envFile": null,
    "maskLength": 4,
    "persistence": {
      "pattern": "env-file-atomic",
      "restart_resilient": true,
      "concurrency": "single-writer",
      "lost_on_restart": []
    }
  },

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "credential-manager.created",
        "credential-manager.updated",
        "credential-manager.deleted",
        "credential-manager.resolved",
        "credential-manager.not_found",
        "credential-manager.errors",
        "credential-manager.fetch.errors"
      ],
      "gauges": [
        "credential-manager.count.total",
        "credential-manager.count.global",
        "credential-manager.count.project",
        "credential-manager.count.client",
        "credential-manager.count.custom",
        "credential-manager.count.bot"
      ],
      "timings": [
        "credential-manager.save.duration",
        "credential-manager.fetch.duration"
      ]
    }
  }
}
