{
  "id": "facturas-nonina",
  "name": "Facturas Nonina Pizzicas",
  "description": "Procesamiento automático de facturas",

  "telegram": {
    "botName": "facturas_noninapizzicas_bot",
    "chatId": null,
    "commands": {
      "/gmailnoninapizzicas": "Descarga adjuntos PDF de Gmail",
      "/procesarnoninapizzicas": "Procesa facturas con Document AI",
      "/ayuda": "Muestra ayuda de comandos"
    }
  },

  "gmail": {
    "account": "noninapizzicas",
    "query": "has:attachment is:unread",
    "maxResults": 20
  },

  "processing": {
    "backend": "google-documentai",
    "language": "es",
    "moveOriginal": true,
    "confidenceThreshold": 0.85
  },

  "storage": {
    "inbox": {
      "telegram": "./data/bots/facturas_noninapizzicas_bot/received",
      "gmail": "./data/gmail/noninapizzicas"
    },
    "procesados": "./data/projects/facturas-nonina/storage/procesados",
    "pendientes": "./data/projects/facturas-nonina/storage/pendientes"
  },

  "schedule": {
    "gmail": {
      "cron": "0 3 * * 0",
      "description": "Domingos a las 3:00 AM"
    }
  },

  "asesoria": {
    "email": "EMAIL_ASESORIA en .env",
    "formatos": ["ZIP con PDFs originales", "resumen.csv"]
  }
}
