        "funciones": ["audit", "audit-providers", "audit-modules", "fix-manifests", "report"],
        "credenciales": "No requiere",
        "nota": "contexto/ es la fuente de verdad. Si el código no se ajusta, el código es el problema."
      },
      "local.handler-generator": {
        "descripcion": "Generador de handlers JavaScript con patrones reales de producción",
        "funciones": ["generate", "list", "archive", "restore"],
        "credenciales": "No requiere",
        "nota": "Genera handlers con envelope pattern, filtros, services.call, emit, config/store. Soporta global y por proyecto."
      },
      "local.url-data": {
        "descripcion": "Estación de datos de URL — extrae contenido, metadata y datos estructurados",
        "funciones": ["extract", "metadata", "search"],
        "credenciales": "No requiere",
        "dependencias": ["cheerio"],
        "nota": "Extrae texto limpio/HTML, metadata OG, busca con selectores CSS. Generado por local.skills."
      },
      "local.backup-manager": {
        "descripcion": "Gestión de backups — respalda providers, handlers, contexto y datos",
        "funciones": ["create", "list", "restore", "cleanup", "status"],
        "credenciales": "No requiere",
        "nota": "Scopes: full, providers, handlers, contexto, config, project. Restore con dryRun por defecto."
      }
    }
  },

