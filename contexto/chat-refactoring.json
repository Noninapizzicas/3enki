    "chat_ai_bridge_flow": {
      "description": "Flujo implementado en 7 pasos",
      "steps": [
        "1. Save user message → chat-session (session.save.request)",
        "2. Load context messages → chat-session (session.getMessages.request)",
        "3. Compose prompt → prompt-composer (prompt.compose.request)",
        "4. Build AI messages array (system + context + user)",
        "5. Call AI → ai-gateway (ai.chat.request) con agentic loop",
        "6. Save assistant message → chat-session",
        "6b. Safety-net: publish complete message via MQTT QoS 1",
        "7. Return response → frontend (via UIRequestHandler)"
      ],
      "streaming": {
        "type": "post-hoc",
        "description": "Cuando hay tools, el AI response se entrega progresivamente después del agentic loop (~12 chars per 10ms)",
        "mqtt_topics": [
          "conversation/{id}/message - chunks de streaming",
          "conversation/{id}/tool-status - estado de ejecución de tools",
          "conversation/stream/end - señal de fin de streaming"
        ]
      }
    }
  },
  "bugs_found_and_fixed": {
    "date": "2026-02-04",
    "bugs": [
      {
        "id": "BUG-001",
        "title": "Chat no operativo - NO_PROJECT",
        "root_cause": "LazyShell.svelte (página principal /) no llamaba a initProjectsSubscriptions() ni initConversations(). El backend no tenía proyecto activo, causando error NO_PROJECT en cada envío",
        "fix": "Añadir initProjectsSubscriptions() e initConversations() en LazyShell.onMount + cleanup en onDestroy",
        "files": ["frontend/src/lib/components/layout/LazyShell.svelte"],
        "severity": "critical",
        "lesson": "LazyShell es bootstrap mínimo - verificar que TODAS las inicializaciones necesarias estén presentes"
      },
      {
        "id": "BUG-002",
        "title": "Errores silenciosos en sendMessage",
        "root_cause": "sendMessage en chat.ts solo hacía console.error sin feedback al usuario",
        "fix": "Añadir notifyError() para mostrar toast con el mensaje de error",
        "files": ["frontend/src/lib/stores/chat.ts"],
        "severity": "medium",
        "lesson": "Siempre mostrar errores al usuario, nunca silenciarlos solo con console.error"
      },
      {
        "id": "BUG-003",
        "title": "Race condition en ordenamiento de mensajes",
        "root_cause": "La suscripción MQTT a conversation/stream/end llamaba endStreaming() que ponía isStreaming=false. Esto desbloqueaba el botón de envío ANTES de que mqttRequest retornara. Si el usuario enviaba rápido, el segundo mensaje se intercalaba con la respuesta del primero",
        "fix": "stream/end ahora solo finaliza el contenido del mensaje (quita flag streaming) sin tocar isStreaming. Solo sendMessage completion y stopGeneration controlan isStreaming",
        "files": ["frontend/src/lib/stores/chat.ts"],
        "severity": "high",
        "lesson": "isStreaming debe ser controlado SOLO por sendMessage (request/response), no por señales MQTT asíncronas"
      },
      {
        "id": "BUG-004",
        "title": "AI response no aparece después de tool execution",
        "root_cause": "Tres causas: (1) Frontend timeout 60s vs backend 180s, (2) chunks de streaming perdidos sin safety-net, (3) addMessage no manejaba mensajes assistant no-streaming",
        "fix": "(1) Timeout frontend → 180s, (2) Safety-net MQTT QoS 1 en chat-ai-bridge después de guardar, (3) addMessage mejorado para manejar ambos casos",
        "files": ["frontend/src/lib/stores/chat.ts", "modules/chat-ai-bridge/index.js"],
        "severity": "high",
        "lesson": "Para mensajes críticos usar QoS 1. El timeout del frontend debe ser >= al del backend"
      }
    ]
  },
