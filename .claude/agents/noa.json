        { "type": "pseudo_step", "action": "validate", "target": "ctx.step.action", "condition": "in enum_14_acciones_de_Fiel", "value": null },
        { "type": "pseudo_step", "action": "call", "target": "this.traducirAccionATool", "condition": null, "value": "ctx" },
