    "okr_framework": {
      "path": "strategy/v1/okrs_YYYY-QX.json",
      "schema": {
        "type": "object",
        "required": ["quarter", "objectives", "alignment"],
        "properties": {
          "quarter": {"type": "string", "pattern": "^\\d{4}-Q[1-4]$"},
          "created_at": {"type": "string", "format": "date-time"},
          "objectives": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["objective", "key_results", "owner", "status"],
              "properties": {
                "objective": {
                  "type": "string",
                  "minLength": 20,
                  "description": "Inspirational, qualitative goal"
                },
                "rationale": {
                  "type": "string",
                  "description": "Por qué este objetivo importa ahora"
                },
                "key_results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["kr", "baseline", "target", "metric", "current"],
                    "properties": {
                      "kr": {"type": "string", "minLength": 10},
                      "baseline": {"type": "number"},
                      "target": {"type": "number"},
                      "metric": {"type": "string"},
                      "unit": {"type": "string"},
                      "current": {"type": "number"},
                      "progress_pct": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "description": "Confianza en alcanzar target"
                      },
                      "at_risk": {"type": "boolean", "default": false}
                    },
                    "additionalProperties": false
                  },
                  "minItems": 2,
                  "maxItems": 5
                },
                "owner": {"type": "string"},
                "status": {
                  "type": "string",
                  "enum": ["on_track", "at_risk", "off_track", "completed", "cancelled"]
                },
                "aligned_releases": {
                  "type": "array",
                  "items": {"type": "string"},
                  "description": "IDs de releases que contribuyen a este objetivo"
                },
                "aligned_business_goals": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              },
              "additionalProperties": false
            },
            "minItems": 2,
            "maxItems": 5
          },
          "alignment": {
            "type": "object",
            "properties": {
              "business_goals_coverage_pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "% de business goals cubiertos por OKRs"
              },
              "roadmap_alignment_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "% de roadmap items alineados con OKRs"
              }
            }
          }
        },
        "additionalProperties": false
      },
      "example": {
        "quarter": "2025-Q2",
        "created_at": "2025-01-15T10:00:00Z",
        "objectives": [
          {
            "objective": "Acelerar onboarding de desarrolladores para crecer comunidad activa",
            "rationale": "Feedback muestra que TTD > 10min es blocker #1 para adopción. Reducir TTD incrementará MAU 2x.",
            "key_results": [
              {
                "kr": "Reducir Time To Deploy (TTD) de 10.2min a <5min",
                "baseline": 10.2,
                "target": 5.0,
                "metric": "ttd_minutes",
                "unit": "minutes",
                "current": 7.5,
                "progress_pct": 53,
                "confidence": 0.85,
                "at_risk": false
              },
              {
                "kr": "Incrementar MAU de 500 a 1000 usuarios activos",
                "baseline": 500,
                "target": 1000,
                "metric": "monthly_active_users",
                "unit": "users",
                "current": 680,
                "progress_pct": 36,
                "confidence": 0.7,
                "at_risk": true
              },
              {
                "kr": "Alcanzar NPS 60+ puntos (desde 52 actual)",
                "baseline": 52,
                "target": 60,
                "metric": "nps",
                "unit": "points",
                "current": 56,
