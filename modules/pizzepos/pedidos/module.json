{
  "name": "pedidos",
  "version": "3.0.0",
  "description": "Gestion completa de pedidos formales pizzepos. Recibe del comandero (bridge comandero.enviar_cocina) o se crea via UI handler. Persiste en memoria con restauracion desde cuentas_activas.json al arrancar (delegacion a persistencia-comandero). Cache de productos invalidada por catalogo.actualizado y producto.{creado,actualizado}.",
  "author": "Pizzepos Team",
  "language": "es",
  "main": "index.js",
  "events": {
    "publishes": [
      { "event": "pedido.creado",            "description": "Nuevo pedido formal creado. Lleva project_id top-level + correlation_id + timestamp." },
      { "event": "pedido.item_agregado",     "description": "Item agregado al pedido. project_id top-level + correlation_id + timestamp." },
      { "event": "pedido.item_actualizado",  "description": "Item del pedido actualizado (cantidad, variaciones, notas). project_id top-level + correlation_id + timestamp." },
      { "event": "pedido.item_eliminado",    "description": "Item eliminado del pedido. project_id top-level + correlation_id + timestamp." },
      { "event": "pedido.enviado_cocina",    "description": "Pedido enviado a cocina para preparacion (consumido por pizzepos__cocina). project_id top-level + correlation_id + timestamp." },
      { "event": "pedido.completado",        "description": "Pedido completado (todos los items servidos). project_id top-level + correlation_id + timestamp." },
      { "event": "pedido.cancelado",         "description": "Pedido cancelado. project_id top-level + correlation_id + timestamp." }
    ],
    "subscribes": [
      { "event": "comandero.enviar_cocina",  "handler": "onComanderoEnviarCocina", "description": "Bridge: comandero solicita enviar a cocina → crear pedido formal y publicar pedido.enviado_cocina." },
      { "event": "variacion.validada",       "handler": "onVariacionValidada",     "description": "Variacion validada — confirmar precio del item." },
      { "event": "variacion.rechazada",      "handler": "onVariacionRechazada",    "description": "Variacion rechazada — rechazar item." },
      { "event": "cuenta.creada",            "handler": "onCuentaCreada",          "description": "Cuenta creada — vincular pedido si necesario." },
      { "event": "catalogo.actualizado",     "handler": "onCatalogoActualizado",   "description": "Catalogo actualizado — sync cache de productos." },
      { "event": "producto.creado",          "handler": "onProductoActualizado",   "description": "Producto creado — actualizar cache." },
      { "event": "producto.actualizado",     "handler": "onProductoActualizado",   "description": "Producto actualizado — actualizar cache." },
      { "event": "caja.cerrada",             "handler": "onCajaCerrada",           "description": "Cierre de caja — limpiar pedidos del dia." },
      { "event": "dia.iniciado",             "handler": "onDiaIniciado",           "description": "Nuevo dia — limpiar pedidos stale." }
    ]
  },
  "ui_handlers": [
    { "domain": "pedido", "action": "list",         "handler": "handleListPedidos",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "get",          "handler": "handleGetPedido",       "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "create",       "handler": "handleCreatePedido",    "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "add-item",     "handler": "handleAgregarItem",     "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "update-item",  "handler": "handleActualizarItem",  "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "delete-item",  "handler": "handleEliminarItem",    "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "send-kitchen", "handler": "handleEnviarCocina",    "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "complete",     "handler": "handleCompletarPedido", "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "cancel",       "handler": "handleCancelarPedido",  "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "total",        "handler": "handleCalcularTotal",   "type": "workspace_module", "zone": "barra_modulos" },
    { "domain": "pedido", "action": "health",       "handler": "handleHealthCheck",     "type": "workspace_module", "zone": "barra_modulos" }
  ],
  "tools": [
    {
      "name": "pedido.list",
      "description": "Lista pedidos con filtros opcionales por cuenta_id y estado. Orden descendente por fecha de creacion.",
      "parameters": {
        "type": "object",
        "properties": {
          "cuenta_id": { "type": "string", "description": "Filtro por cuenta." },
          "estado":    { "type": "string", "description": "Filtro por estado del pedido." }
        },
        "additionalProperties": false
      },
      "handler": "handleListPedidos",
      "errores_conocidos": ["UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.get",
      "description": "Obtiene un pedido por id.",
      "parameters": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Identificador del pedido." }
        },
        "required": ["id"],
        "additionalProperties": false
      },
      "handler": "handleGetPedido",
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.create",
      "description": "Crea un pedido formal nuevo en estado borrador vinculado a una cuenta. Detecta canal por prefijo del cuenta_id.",
      "parameters": {
        "type": "object",
        "properties": {
          "cuenta_id":        { "type": "string", "description": "Identificador de la cuenta." },
          "project_id":       { "type": "string", "description": "Identificador del proyecto (opcional)." },
          "notas_generales":  { "type": "string", "description": "Notas generales del pedido." }
        },
        "required": ["cuenta_id"],
        "additionalProperties": false
      },
      "handler": "handleCreatePedido",
      "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.add-item",
      "description": "Agrega un item al pedido (solo en estado borrador/confirmado). Consulta precios al cache de productos.",
      "parameters": {
        "type": "object",
        "properties": {
          "pedido_id":   { "type": "string", "description": "Identificador del pedido." },
          "producto_id": { "type": "string", "description": "Identificador del producto." },
          "cantidad":    { "type": "integer", "description": "Cantidad (default 1)." },
          "variaciones": { "type": "object",  "description": "Variaciones aplicadas (quitar/anadir)." },
          "notas":       { "type": "string",  "description": "Notas del item." }
        },
        "required": ["pedido_id", "producto_id"],
        "additionalProperties": false
      },
      "handler": "handleAgregarItem",
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "CONFLICT_STATE", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.update-item",
      "description": "Actualiza un item del pedido (cantidad, variaciones, notas).",
      "parameters": {
        "type": "object",
        "properties": {
          "pedido_id": { "type": "string", "description": "Identificador del pedido." },
          "item_id":   { "type": "string", "description": "Identificador del item." }
        },
        "required": ["pedido_id", "item_id"],
        "additionalProperties": true
      },
      "handler": "handleActualizarItem",
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "CONFLICT_STATE", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.delete-item",
      "description": "Elimina un item del pedido (solo en estado borrador/confirmado).",
      "parameters": {
        "type": "object",
        "properties": {
          "pedido_id": { "type": "string", "description": "Identificador del pedido." },
          "item_id":   { "type": "string", "description": "Identificador del item." }
        },
        "required": ["pedido_id", "item_id"],
        "additionalProperties": false
      },
      "handler": "handleEliminarItem",
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "CONFLICT_STATE", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.send-kitchen",
      "description": "Marca el pedido como enviado a cocina. Emite pedido.enviado_cocina.",
      "parameters": {
        "type": "object",
        "properties": {
          "pedido_id": { "type": "string", "description": "Identificador del pedido." }
        },
        "required": ["pedido_id"],
        "additionalProperties": false
      },
      "handler": "handleEnviarCocina",
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "CONFLICT_STATE", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.complete",
      "description": "Marca el pedido como completado (todos los items servidos). Emite pedido.completado.",
      "parameters": {
        "type": "object",
        "properties": {
          "pedido_id": { "type": "string", "description": "Identificador del pedido." }
        },
        "required": ["pedido_id"],
        "additionalProperties": false
      },
      "handler": "handleCompletarPedido",
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "CONFLICT_STATE", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.cancel",
      "description": "Cancela el pedido. Emite pedido.cancelado.",
      "parameters": {
        "type": "object",
        "properties": {
          "pedido_id": { "type": "string", "description": "Identificador del pedido." },
          "motivo":    { "type": "string", "description": "Motivo de la cancelacion." }
        },
        "required": ["pedido_id"],
        "additionalProperties": false
      },
      "handler": "handleCancelarPedido",
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "CONFLICT_STATE", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.total",
      "description": "Recalcula el subtotal/total de un pedido sumando precios de los items.",
      "parameters": {
        "type": "object",
        "properties": {
          "pedido_id": { "type": "string", "description": "Identificador del pedido." }
        },
        "required": ["pedido_id"],
        "additionalProperties": false
      },
      "handler": "handleCalcularTotal",
      "errores_conocidos": ["INVALID_INPUT", "RESOURCE_NOT_FOUND", "UNKNOWN_ERROR"]
    },
    {
      "name": "pedido.health",
      "description": "Health check del modulo pedidos.",
      "parameters": { "type": "object", "properties": {}, "additionalProperties": false },
      "handler": "handleHealthCheck",
      "errores_conocidos": []
    }
  ],
  "dependencies": [],
  "tracing": {
    "propaga_correlation_id": true
  },
  "config": {
    "persistence": {
      "type": "in-memory",
      "owner": "PedidosModule (Map pedidos + Map pedidosPorCuenta + Map productosCache)",
      "filesystem_read": [
        "data/current/cuentas_activas.json (lectura legacy fallback al arrancar)"
      ],
      "restart_resilient": false,
      "concurrency": "single-instance",
      "lost_on_restart": ["pedidos", "pedidosPorCuenta", "productosCache"]
    }
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "pedidos.creado.total",
        "pedidos.item_agregado.total",
        "pedidos.enviado_cocina.total",
        "pedidos.completado.total",
        "pedidos.cancelado.total",
        "pedidos.errors"
      ],
      "gauges": [
        "pedidos.activos.count",
        "pedidos.en_cocina.count",
        "pedidos.items_total.count"
      ],
      "timings": [
        "pedidos.create.duration",
        "pedidos.envio_cocina.duration"
      ]
    }
  }
}
