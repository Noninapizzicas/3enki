  "apis_http": [
    {
      "method": "POST",
      "path": "/cuentas",
      "handler": "handleCreateCuenta",
      "description": "Crear nueva cuenta (publica evento cuenta.creada)",
      "request_schema_ref": "./schemas/cuenta.json#/definitions/create_request",
      "response_schema_ref": "./schemas/cuenta.json#/definitions/create_response"
    },
    {
      "method": "GET",
      "path": "/cuentas",
