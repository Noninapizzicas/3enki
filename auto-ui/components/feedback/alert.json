{
  "name": "alert",
  "category": "feedback",
  "description": "Alertas para mostrar mensajes importantes al usuario",
  "version": "2.0.0",

  "variants": {
    "info": {
      "description": "Alerta informativa",
      "className": "alert alert-info",
      "icon": "ℹ️",
      "color": "info"
    },
    "success": {
      "description": "Alerta de éxito",
      "className": "alert alert-success",
      "icon": "✓",
      "color": "success"
    },
    "warning": {
      "description": "Alerta de advertencia",
      "className": "alert alert-warning",
      "icon": "⚠️",
      "color": "warning"
    },
    "danger": {
      "description": "Alerta de error/peligro",
      "className": "alert alert-danger",
      "icon": "✗",
      "color": "danger"
    }
  },

  "styles": {
    "solid": {
      "description": "Fondo sólido",
      "className": "alert-solid"
    },
    "outlined": {
      "description": "Solo borde",
      "className": "alert-outlined"
    },
    "subtle": {
      "description": "Fondo sutil",
      "className": "alert-subtle"
    }
  },

  "sizes": {
    "sm": {
      "description": "Alerta pequeña",
      "className": "alert-sm"
    },
    "md": {
      "description": "Alerta mediana (default)",
      "className": ""
    },
    "lg": {
      "description": "Alerta grande",
      "className": "alert-lg"
    }
  },

  "props": {
    "title": {
      "type": "string",
      "description": "Título de la alerta"
    },
    "message": {
      "type": "string",
      "required": true,
      "description": "Mensaje de la alerta"
    },
    "icon": {
      "type": "string",
      "description": "Icono personalizado"
    },
    "showIcon": {
      "type": "boolean",
      "default": true,
      "description": "Mostrar icono"
    },
    "closable": {
      "type": "boolean",
      "default": false,
      "description": "Permitir cerrar la alerta"
    },
    "actions": {
      "type": "array",
      "description": "Acciones/botones de la alerta",
      "items": {
        "label": "string",
        "action": "string",
        "variant": "string"
      }
    },
    "banner": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar como banner (ancho completo)"
    },
    "autoClose": {
      "type": "number",
      "description": "Auto cerrar después de N milisegundos"
    }
  },

  "features": {
    "animation": {
      "enabled": true,
      "enter": "fadeIn",
      "exit": "fadeOut",
      "duration": 200
    },
    "sound": {
      "enabled": false,
      "playOnShow": true
    },
    "persistence": {
      "enabled": false,
      "storageKey": "dismissed-alerts",
      "expirationDays": 7
    }
  },

  "accessibility": {
    "role": "alert",
    "ariaLive": "polite",
    "ariaAtomic": true,
    "focusOnShow": false
  },

  "example": {
    "component": "alert",
    "variant": "warning",
    "style": "solid",
    "size": "md",
    "props": {
      "title": "Atención",
      "message": "Tu suscripción expira en 7 días",
      "showIcon": true,
      "closable": true,
      "actions": [
        {"label": "Renovar ahora", "action": "renew", "variant": "warning"},
        {"label": "Recordar después", "action": "dismiss", "variant": "ghost"}
      ]
    }
  },

  "bannerExample": {
    "component": "alert",
    "variant": "info",
    "style": "subtle",
    "props": {
      "message": "Estamos actualizando el sistema. Algunos servicios pueden estar temporalmente no disponibles.",
      "banner": true,
      "closable": true
    }
  }
}
