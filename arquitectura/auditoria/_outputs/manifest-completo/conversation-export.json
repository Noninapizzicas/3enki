  "identidad": {
    "name": "conversation-export",
    "version": "1.0.0",
    "description_oficial": "Endpoints HTTP públicos para exportar conversaciones completas (mensajes + tool calls + eventos de agentes + errores) en JSON optimizado para análisis por LLMs externos. Autenticación por token.",
