      "chat.ts": {
        "purpose": "Estado de conversación activa - mensajes visibles en ChatArea",
        "stores": ["messages", "conversationId", "isStreaming", "streamingMessageId", "toolStatus"],
        "derived": ["messageCount", "hasConversation", "lastMessage", "userMessages", "assistantMessages"],
        "key_functions": ["sendMessage", "addMessage", "endStreaming", "loadConversation", "toggleMessageContext"],
        "mqtt_subscriptions": [
          "conversation/+/message - chunks de streaming y mensajes finales",
          "conversation/+/tool-status - estado de ejecución de tools",
          "conversation/stream/end - finalización de streaming (solo marca mensaje, NO desbloquea envío)"
        ]
      },
      "conversations.ts": {
        "purpose": "Gestión de lista de conversaciones (separado de chat.ts)",
        "key_functions": ["selectConversation", "initConversations"],
        "note": "selectConversation llama tanto a conversations.ts loadConversation como a chat.ts loadConversation"
      },
      "projects.ts": {
        "purpose": "Gestión de proyectos",
        "key_functions": ["initProjects (alias initProjectsSubscriptions)", "activateProject"],
        "note": "activateProject envía mqttRequest('project', 'activate', {id}) al backend + guarda en localStorage"
      }
    },
    "critical_initialization": {
      "LazyShell.svelte": {
        "must_call": [
          "initWorkspaceSubscriptions() - suscripciones de workspace",
          "initChatSubscriptions() - suscripciones MQTT del chat",
          "initProjectsSubscriptions() - carga proyectos + activa proyecto guardado",
          "initConversations() - carga conversaciones + restaura conversación activa"
        ],
        "order_matters": "initProjectsSubscriptions ANTES de initConversations (necesita proyecto activo)"
      }
    },
    "request_response_pattern": {
      "flow": "mqttRequest(domain, action, data) → ui/request/{domain}/{action} → UIRequestHandler → handler → ui/response/{requestId}",
      "timeout_defaults": {
        "general": "10s",
        "chat_with_tools": "180s"
      }
    }
  }
}
