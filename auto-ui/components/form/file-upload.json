{
  "name": "file-upload",
  "category": "form",
  "description": "Componente para subida de archivos con drag & drop",
  "version": "2.0.0",

  "variants": {
    "default": {
      "description": "Upload estándar",
      "className": "form-file-upload"
    },
    "dropzone": {
      "description": "Zona de arrastre destacada",
      "className": "form-file-upload form-file-dropzone"
    },
    "avatar": {
      "description": "Upload circular para avatares",
      "className": "form-file-upload form-file-avatar"
    },
    "button": {
      "description": "Solo botón de subida",
      "className": "form-file-upload form-file-button"
    }
  },

  "props": {
    "label": {
      "type": "string",
      "description": "Etiqueta del campo"
    },
    "name": {
      "type": "string",
      "required": true,
      "description": "Nombre del campo"
    },
    "accept": {
      "type": "string",
      "description": "Tipos de archivo aceptados",
      "example": "image/*,.pdf,.doc"
    },
    "multiple": {
      "type": "boolean",
      "default": false,
      "description": "Permitir múltiples archivos"
    },
    "maxFiles": {
      "type": "number",
      "description": "Máximo número de archivos"
    },
    "maxSize": {
      "type": "number",
      "description": "Tamaño máximo en bytes",
      "example": 5242880
    },
    "minSize": {
      "type": "number",
      "description": "Tamaño mínimo en bytes"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Campo deshabilitado"
    },
    "required": {
      "type": "boolean",
      "default": false,
      "description": "Campo requerido"
    },
    "helpText": {
      "type": "string",
      "description": "Texto de ayuda"
    },
    "errorText": {
      "type": "string",
      "description": "Mensaje de error"
    },
    "uploadText": {
      "type": "string",
      "default": "Arrastra archivos o haz click para seleccionar",
      "description": "Texto de la zona de subida"
    },
    "uploadIcon": {
      "type": "string",
      "default": "📁",
      "description": "Icono de la zona de subida"
    }
  },

  "features": {
    "dragAndDrop": {
      "enabled": true,
      "highlightOnDrag": true
    },
    "preview": {
      "enabled": true,
      "showThumbnails": true,
      "imagePreview": true
    },
    "validation": {
      "validateType": true,
      "validateSize": true,
      "validateDimensions": false,
      "minWidth": null,
      "minHeight": null,
      "maxWidth": null,
      "maxHeight": null
    },
    "upload": {
      "mode": "manual",
      "autoUpload": false,
      "endpoint": "/api/upload",
      "method": "POST",
      "fieldName": "file",
      "headers": {},
      "withCredentials": false
    },
    "progress": {
      "showProgress": true,
      "showSpeed": true,
      "showTimeRemaining": true
    }
  },

  "fileItem": {
    "id": "string",
    "name": "string",
    "size": "number",
    "type": "string",
    "status": "pending|uploading|success|error",
    "progress": "number",
    "url": "string",
    "thumbnail": "string",
    "error": "string"
  },

  "states": {
    "idle": {
      "description": "Estado inicial",
      "className": ""
    },
    "dragover": {
      "description": "Arrastrando sobre la zona",
      "className": "dragover"
    },
    "uploading": {
      "description": "Subiendo archivo",
      "className": "uploading"
    },
    "success": {
      "description": "Subida exitosa",
      "className": "success"
    },
    "error": {
      "description": "Error en subida",
      "className": "error"
    },
    "disabled": {
      "description": "Deshabilitado",
      "className": "disabled"
    }
  },

  "accessibility": {
    "role": "button",
    "ariaLabel": true,
    "ariaDescribedBy": true,
    "ariaDisabled": true
  },

  "example": {
    "component": "file-upload",
    "variant": "dropzone",
    "props": {
      "label": "Subir documentos",
      "name": "documents",
      "accept": ".pdf,.doc,.docx",
      "multiple": true,
      "maxFiles": 5,
      "maxSize": 10485760,
      "helpText": "Máximo 5 archivos de 10MB cada uno",
      "uploadText": "Arrastra tus documentos aquí",
      "uploadIcon": "📄"
    }
  },

  "imageExample": {
    "component": "file-upload",
    "variant": "avatar",
    "props": {
      "label": "Foto de perfil",
      "name": "avatar",
      "accept": "image/*",
      "maxSize": 2097152,
      "helpText": "JPG, PNG o GIF. Máximo 2MB",
      "features": {
        "validation": {
          "validateDimensions": true,
          "minWidth": 200,
          "minHeight": 200,
          "maxWidth": 2000,
          "maxHeight": 2000
        }
      }
    }
  }
}
