{
  "name": "admin-panel",
  "version": "2.0.0",
  "description": "Web-based admin panel para gestionar Event Core (modulos, plugins, agentes, prompts). Bus-driven via ui_handlers canonicos. Cache in-memory de 4 secciones (plugins/agents/prompts/modules) con refresh on-demand. Integra con plugin-manager + prompt-manager via HTTP loopback hasta que esos modulos canonicen su ui_handler API.",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",
  "tracing": {
    "propaga_correlation_id": true
  },
  "dependencies": ["plugin-manager", "prompt-manager"],
  "events": {
    "publishes": [
      { "event": "admin.plugin.toggled",     "description": "Plugin toggled (enable/disable) desde el admin panel. project_id top-level + correlation_id + timestamp." },
      { "event": "admin.agent.creado",       "description": "Agente creado desde el admin panel. project_id top-level + correlation_id + timestamp." },
      { "event": "admin.agent.eliminado",    "description": "Agente eliminado desde el admin panel. project_id top-level + correlation_id + timestamp." },
      { "event": "admin.prompt.creado",      "description": "Prompt creado desde el admin panel. project_id top-level + correlation_id + timestamp." },
      { "event": "admin.prompt.actualizado", "description": "Prompt actualizado desde el admin panel. project_id top-level + correlation_id + timestamp." }
    ],
    "subscribes": [
      { "event": "plugin.loaded", "handler": "onPluginLoaded", "description": "Plugin cargado por plugin-manager — refresca cache local." }
    ]
  },
  "ui_handlers": [
    { "domain": "admin-panel", "action": "dashboard",       "handler": "handleDashboard",     "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "modules",         "handler": "handleListModules",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "plugins",         "handler": "handleListPlugins",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "plugin-toggle",   "handler": "handleTogglePlugin",  "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "agents",          "handler": "handleListAgents",    "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "agent-create",    "handler": "handleCreateAgent",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "agent-delete",    "handler": "handleDeleteAgent",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "prompts",         "handler": "handleListPrompts",   "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "prompt-get",      "handler": "handleGetPrompt",     "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "prompt-create",   "handler": "handleCreatePrompt",  "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "prompt-update",   "handler": "handleUpdatePrompt",  "type": "system_panel", "zone": "lateral_derecha" },
    { "domain": "admin-panel", "action": "health",          "handler": "handleHealth",        "type": "system_panel", "zone": "lateral_derecha" }
  ],
  "tools": [],
  "ui": {
    "enabled": true,
    "title": "Admin Panel",
    "icon": "⚙️",
    "description": "System administration and monitoring"
  },
  "config": {
    "persistence": {
      "type": "in-memory",
      "owner": "AdminPanelModule (4 caches: plugins, agents, prompts, modules)",
      "filesystem_read": [
        "modules/<*>/module.json (lectura para cache de modulos)"
      ],
      "restart_resilient": false,
      "concurrency": "single-instance",
      "lost_on_restart": ["cache.plugins", "cache.agents", "cache.prompts", "cache.modules"]
    }
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "admin-panel.errors"
      ]
    }
  }
}
