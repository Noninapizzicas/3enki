{
  "name": "tool-orchestrator",
  "version": "2.0.0",
  "description": "Orchestrates tool calls between AI agents and tool providers with validation and execution",
  "author": "Aichat Team",
  "main": "index.js",

  "provides": {
    "events": [
      "tool.registered",
      "tool.unregistered",
      "tool.call.response",
      "tool.call.success",
      "tool.call.failed"
    ],
    "queries": [
      "tool.call.request",
      "tool.list.request",
      "tool.get.request"
    ]
  },

  "events": {
    "publishes": [
      {
        "event": "tool.registered",
        "description": "Tool registered successfully",
        "schema": { "$ref": "./schemas/events.json#/definitions/tool_registered" }
      },
      {
        "event": "tool.unregistered",
        "description": "Tool unregistered",
        "schema": { "$ref": "./schemas/events.json#/definitions/tool_unregistered" }
      },
      {
        "event": "tool.call.response",
        "description": "Response to tool execution request",
        "schema": { "$ref": "./schemas/events.json#/definitions/tool_call_response" }
      },
      {
        "event": "tool.call.success",
        "description": "Tool executed successfully",
        "schema": { "$ref": "./schemas/events.json#/definitions/tool_call_success" }
      },
      {
        "event": "tool.call.failed",
        "description": "Tool execution failed",
        "schema": { "$ref": "./schemas/events.json#/definitions/tool_call_failed" }
      },
      {
        "event": "tool.list.response",
        "description": "Response to tool list request",
        "schema": { "$ref": "./schemas/events.json#/definitions/tool_list_response" }
      },
      {
        "event": "tool.get.response",
        "description": "Response to tool get request",
        "schema": { "$ref": "./schemas/events.json#/definitions/tool_get_response" }
      }
    ],
    "subscribes": [
      {
        "event": "tool.call.request",
        "description": "Execute tool with provided arguments",
        "handler": "onToolCallRequest"
      },
      {
        "event": "tool.list.request",
        "description": "List all registered tools",
        "handler": "onListToolsRequest"
      },
      {
        "event": "tool.get.request",
        "description": "Get specific tool definition",
        "handler": "onGetToolRequest"
      }
    ]
  },

  "apis": [
    {
      "method": "GET",
      "path": "/tools",
      "handler": "handleListTools",
      "description": "List all registered tools",
      "response_schema": { "$ref": "./schemas/tool.json#/definitions/list_response" }
    },
    {
      "method": "GET",
      "path": "/tools/:name",
      "handler": "handleGetTool",
      "description": "Get tool definition",
      "response_schema": { "$ref": "./schemas/tool.json#/definitions/get_response" }
    },
    {
      "method": "POST",
      "path": "/tools/:name/call",
      "handler": "handleCallTool",
      "description": "Execute tool (publishes tool.call.success/failed)",
      "request_schema": { "$ref": "./schemas/tool.json#/definitions/call_request" },
      "response_schema": { "$ref": "./schemas/tool.json#/definitions/call_response" }
    },
    {
      "method": "POST",
      "path": "/tools/register",
      "handler": "handleRegisterTool",
      "description": "Register new tool (publishes tool.registered)",
      "request_schema": { "$ref": "./schemas/tool.json#/definitions/register_request" },
      "response_schema": { "$ref": "./schemas/tool.json#/definitions/register_response" }
    },
    {
      "method": "DELETE",
      "path": "/tools/:name",
      "handler": "handleUnregisterTool",
      "description": "Unregister tool (publishes tool.unregistered)",
      "response_schema": { "$ref": "./schemas/tool.json#/definitions/unregister_response" }
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check endpoint"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Module metrics"
    }
  ],

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "tool.registered.total",
        "tool.unregistered.total",
        "tool.call.total",
        "tool.call.success",
        "tool.call.failed",
        "tool.call.timeout",
        "tool.call.invalid_args"
      ],
      "gauges": [
        "tool.registered.count"
      ],
      "timings": [
        "tool.call.duration",
        "tool.validation.duration"
      ]
    }
  },

  "config": {
    "validationEnabled": true,
    "timeoutMs": 30000,
    "maxRetries": 0,
    "enableCache": false,
    "cacheExpiryMs": 60000
  }
}
