            "rationale": "Top 3 feedback de power users es latencia. 35% priorizan performance sobre features nuevas.",
            "key_results": [
              {
                "kr": "Reducir latency p95 de 185ms a <100ms en endpoints críticos",
                "baseline": 185,
                "target": 100,
                "metric": "latency_p95_ms",
                "unit": "milliseconds",
                "current": 92,
