{
  "_meta": {
    "modulo": "firmware-builder",
    "ubicacion": "modules/firmware-builder",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "firmware-builder",
    "version": "1.1.0",
    "description_oficial": "Compilación de firmware ESP32 con arquitectura BASE + LÓGICA. Detecta drivers en firmware/drivers/, compila via PlatformIO",
    "author": "Enki",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": null,
    "tier_declarado": "tier_3_core",
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "firmware.build_started",   "description": "Compilación de driver iniciada" },
      { "event": "firmware.build_completed",  "description": "Compilación completada, binario disponible" },
      { "event": "firmware.build_failed",     "description": "Compilación falló" }
    ],
    "subscribes": [],
    "provides_eventos": [
      "firmware.build_started",
      "firmware.build_completed",
      "firmware.build_failed"
    ]
  },

  "tools": [
    {
      "name": "builder.list_drivers",
      "description": "Lista los drivers ESP32 disponibles para compilar, con metadatos (utility, board, capabilities, archivos fuente)",
      "parameters_required": [],
      "parameters_property_names": [],
      "parameters_size_chars": 38,
      "parameters_full_path_hint": "modules/firmware-builder/module.json → tools[0].parameters"
    },
    {
      "name": "builder.build",
      "description": "Compila un driver ESP32 via PlatformIO. Asíncrono: retorna inmediatamente, usa builder.build_status para seguir el progreso.",
      "parameters_required": ["driver"],
      "parameters_property_names": ["driver", "board", "clean"],
      "parameters_size_chars": 380,
      "parameters_full_path_hint": "modules/firmware-builder/module.json → tools[1].parameters"
    },
    {
      "name": "builder.build_status",
      "description": "Estado del build actual o último build de un driver. Incluye log de compilación.",
      "parameters_required": [],
      "parameters_property_names": ["driver"],
      "parameters_size_chars": 104,
      "parameters_full_path_hint": "modules/firmware-builder/module.json → tools[2].parameters"
    },
    {
      "name": "builder.list_boards",
      "description": "Lista los boards ESP32 soportados (esp32dev, esp32-s3, esp32-c3, etc.)",
      "parameters_required": [],
      "parameters_property_names": [],
      "parameters_size_chars": 38,
      "parameters_full_path_hint": "modules/firmware-builder/module.json → tools[3].parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "builder", "action": "list-drivers",  "handler": "handleListDrivers" },
      { "domain": "builder", "action": "build",         "handler": "handleBuild" },
      { "domain": "builder", "action": "build-status",  "handler": "handleBuildStatus" },
      { "domain": "builder", "action": "list-boards",   "handler": "handleListBoards" }
    ]
  },

  "apis_http": [],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "firmware_path",         "tipo": "string",  "valor_default": "./firmware/drivers" },
      { "key": "platformio_path",       "tipo": "string",  "valor_default": "platformio" },
      { "key": "build_timeout_ms",      "tipo": "number",  "valor_default": 300000 },
      { "key": "max_concurrent_builds", "tipo": "number",  "valor_default": 2 }
    ]
  },

  "observability_declarada": {
    "logging": { "level": "info", "structured": true },
    "metrics": {
      "enabled": true,
      "counters": [
        "firmware.build_started.total",
        "firmware.build_completed.total",
        "firmware.build_failed.total"
      ],
      "gauges": [
        "firmware.active_builds.count",
        "firmware.drivers.count"
      ],
      "timings": [
        "firmware.build.duration"
      ]
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": false,
    "enabled": null,
    "title": null,
    "icon": null,
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 0,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": [],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": true,
    "ui_handlers_field_name": "ui_handlers",
    "module_json_bytes": 3664,
    "module_json_lineas": 117,
    "tiene_main_no_estandar": false,
    "warnings": [
      "eventos_top_level=true: usa events.publishes/events.subscribes wrapeado bajo 'events', pero también tiene 'provides.events' duplicando los mismos 3 eventos publicados",
      "tier declarado como 'tier_3_core' pero firmware-builder no aparece en system.json.module_load_order.tiers.tier_3_core — tier_carga_inferido=null",
      "ui_handlers contiene inline schema object en action 'build' (campo 'schema' en el handler item) — campo no estándar en items"
    ]
  }
}
