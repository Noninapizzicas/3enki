        { "type": "pseudo_step", "action": "comment", "target": null, "condition": null, "value": "ignorar" },
        { "type": "pseudo_step", "action": "branch", "target": "if_action_emit_o_listen_describe_modulo_final", "condition": "step.action in [emit, listen] && contexto_node_path describe modulo a generar", "value": null },
        { "type": "pseudo_step", "action": "call", "target": "Write_o_Edit", "condition": null, "value": "escribir el codigo del modulo que emite/escucha, no invocar el bus" },
        { "type": "pseudo_step", "action": "branch", "target": "if_action_return_o_throw", "condition": "step.action in [return, throw]", "value": null },
        { "type": "pseudo_step", "action": "comment", "target": null, "condition": null, "value": "salida del metodo del plan; si describe modulo final se escribe como codigo del modulo" }
