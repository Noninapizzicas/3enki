    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      {
        "event": "staff.session.tap_in",
        "description": "Empleado inicia jornada (tap in)"
      },
      {
        "event": "staff.session.tap_out",
        "description": "Empleado finaliza jornada (tap out)"
      },
      {
        "event": "staff.session.auto_timeout",
        "description": "Jornada cerrada por superar maxShiftHours sin tap_out (válido para turnos nocturnos y rotativos)"
      },
      {
        "event": "staff.session.manager_close",
        "description": "Jornada cerrada manualmente por el manager"
      }
    ],
    "subscribes": [],
    "provides_eventos": []
  },

  "tools": [],

  "ui_handlers": {
    "campo_origen": null,
    "items": []
  },

  "apis_http": [
    {
      "method": "GET",
      "path": "/status",
      "handler": null,
      "description": "Estado del módulo: empleados activos y sesiones abiertas",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/employee",
      "handler": null,
      "description": "Crear empleado. Body: { name, role, pin? }",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/employee",
      "handler": null,
      "description": "Listar empleados. Query: active_only=true|false",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/employee/:id",
      "handler": null,
      "description": "Obtener empleado por ID",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "PUT",
      "path": "/employee/:id",
      "handler": null,
      "description": "Actualizar empleado (patch parcial). Body: { name?, role?, pin?, active? }",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "DELETE",
      "path": "/employee/:id",
      "handler": null,
      "description": "Baja lógica de empleado (active = false)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/session/tap-in",
      "handler": null,
      "description": "Empleado inicia jornada. Body: { employee_id, device_id? }",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/session/tap-out",
      "handler": null,
      "description": "Empleado finaliza jornada. Body: { employee_id }",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/session/active",
      "handler": null,
      "description": "Sesiones de jornada actualmente abiertas (con datos del empleado)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/session/history",
      "handler": null,
      "description": "Histórico de jornadas. Query: employee_id | date (YYYY-MM-DD, default hoy)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/session/stale",
      "handler": null,
      "description": "Sesiones abiertas más de maxShiftHours horas (candidatas a revisión)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/session/manager-close",
      "handler": null,
      "description": "Manager cierra jornada de un empleado. Body: { employee_id }",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/nfc/employee-card",
      "handler": null,
      "description": "Genera payload JSON para escribir en NTAG215 del empleado. Body: { employee_id }",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/nfc/core-tag",
      "handler": null,
      "description": "Genera payload JSON del core (Opción A: onboarding de tablets). Requiere security-p2p.",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/nfc/parse",
      "handler": null,
      "description": "Parsea y valida un payload leído de una NTAG215. Body: { raw }",
      "request_schema_ref": null,
      "response_schema_ref": null
    }
  ],

