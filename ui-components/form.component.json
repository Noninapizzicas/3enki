{
  "component": "form",
  "name": "Input Form",
  "description": "Form component with validation support",
  "field_types": {
    "text": {
      "input_type": "text",
      "validation": "string"
    },
    "email": {
      "input_type": "email",
      "validation": "email"
    },
    "number": {
      "input_type": "number",
      "validation": "numeric"
    },
    "password": {
      "input_type": "password",
      "validation": "string",
      "min_length": 8
    },
    "textarea": {
      "input_type": "textarea",
      "rows": 4
    }
  },
  "styling": {
    "input_background": "#0F1216",
    "input_border": "#374151",
    "input_focus_border": "#1D4ED8",
    "label_color": "white"
  },
  "validation": {
    "required_indicator": "*",
    "error_color": "#E63946",
    "show_inline_errors": true
  }
}
