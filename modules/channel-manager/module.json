{
  "name": "channel-manager",
  "version": "2.0.0",
  "description": "Registry centralizado de canales externos. Mapea identificadores externos (chat_id, email, telefono) a proyectos y propositos internos. Storage SQLite via database-manager (proyecto 'system'). v2.0.0: 5 helpers POC2, handlers shape canonico, _publicarEvento con correlation_id propagado, pendingDbRequests Map con timeout/cleanup.",
  "author": "Event Core Team",
  "language": "en",
  "main": "index.js",
  "dependencies": [
    "database-manager"
  ],
  "events": {
    "publishes": [
      { "event": "channel.registered", "description": "Nuevo canal vinculado a un proyecto. Payload: { channel_type, external_id, project_id, purpose, label, timestamp, correlation_id }.", "schema": { "$ref": "./schemas/events.json#/definitions/channel_registered" } },
      { "event": "channel.updated",    "description": "Canal actualizado. Payload: { channel_type, external_id, updates, timestamp, correlation_id }.",                                              "schema": { "$ref": "./schemas/events.json#/definitions/channel_updated" } },
      { "event": "channel.removed",    "description": "Canal desvinculado. Payload: { channel_type, external_id, project_id, timestamp, correlation_id }.",                                          "schema": { "$ref": "./schemas/events.json#/definitions/channel_removed" } },
      { "event": "channel.resolved",   "description": "Canal resuelto exitosamente a proyecto+proposito. Payload: { channel_type, external_id, project_id, purpose, label, metadata, duration, timestamp, correlation_id }.", "schema": { "$ref": "./schemas/events.json#/definitions/channel_resolved" } },
      { "event": "channel-manager.resolve.response", "description": "Respuesta a channel-manager.resolve.request correlacionada por request_id. found=true|false.",                                  "schema": { "$ref": "./schemas/events.json#/definitions/channel_resolve_response" } },
      "db.query.request",
      "db.schema.init.request"
    ],
    "subscribes": [
      { "event": "channel-manager.resolve.request", "handler": "onResolveRequest", "description": "Otro modulo pide resolver un identificador externo. Publica channel-manager.resolve.response con request_id correlacionado." },
      { "event": "db.query.response",       "handler": "onDbResponse", "description": "Response de database-manager para queries (resuelve pendingDbRequests por correlation_id)." },
      { "event": "db.schema.init.response", "handler": "onDbResponse", "description": "Response de database-manager para schema init (resuelve pendingDbRequests por correlation_id)." }
    ]
  },
  "ui_handlers": [
    { "domain": "channel", "action": "register",        "handler": "handleRegister" },
    { "domain": "channel", "action": "update",          "handler": "handleUpdate" },
    { "domain": "channel", "action": "remove",          "handler": "handleRemove" },
    { "domain": "channel", "action": "resolve",         "handler": "handleResolve" },
    { "domain": "channel", "action": "list",            "handler": "handleList" },
    { "domain": "channel", "action": "list-by-project", "handler": "handleListByProject" }
  ],
  "tools": [
    {
      "name": "channel.resolve",
      "description": "Resuelve un identificador externo (chat_id, email, telefono) al proyecto y proposito al que pertenece.",
      "handler": "handleToolResolve",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "channel_type": { "type": "string", "enum": ["telegram", "gmail", "whatsapp", "glovo", "web"], "description": "Tipo de canal externo." },
          "external_id":  { "type": "string", "minLength": 1, "description": "Identificador externo (ej: 'mibot:12345', 'cuenta@gmail.com', '+34600123456')." }
        },
        "required": ["channel_type", "external_id"]
      },
      "errores_conocidos": ["INVALID_INPUT", "UNKNOWN_ERROR"]
    },
    {
      "name": "channel.list",
      "description": "Lista todos los canales registrados, opcionalmente filtrados por proyecto o tipo.",
      "handler": "handleToolList",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "project_id":   { "type": "string", "description": "Filtrar por proyecto (opcional)." },
          "channel_type": { "type": "string", "description": "Filtrar por tipo de canal (opcional)." }
        },
        "required": []
      },
      "errores_conocidos": ["UNKNOWN_ERROR"]
    }
  ],
  "config": {
    "db_project_id": "system",
    "table_name": "channels",
    "dbTimeout": 10000,
    "persistence": {
      "pattern": "owned-table-via-database-manager",
      "restart_resilient": true,
      "concurrency": "single-writer",
      "lost_on_restart": ["cache", "pendingDbRequests"]
    }
  },
  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "tracing": {
      "propaga_correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "channel-manager.registered",
        "channel-manager.updated",
        "channel-manager.removed",
        "channel-manager.resolve.success",
        "channel-manager.resolve.miss",
        "channel-manager.errors"
      ],
      "gauges": [
        "channel-manager.cache_size",
        "channel-manager.pending_db_requests"
      ]
    }
  }
}
