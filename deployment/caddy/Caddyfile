# Event Core - Caddyfile para VPS
#
# Caddy obtiene certificados HTTPS automáticamente via Let's Encrypt.
# Event-core corre en HTTP internamente, Caddy hace TLS termination.
#
# Uso:
#   1. Reemplazar {$DOMAIN} con tu dominio o setear variable de entorno
#   2. caddy run --config Caddyfile
#
# Puertos internos (event-core):
#   - 3000: HTTP Gateway (API REST)
#   - 9001: MQTT WebSocket (broker Aedes)

{$DOMAIN:localhost} {
	# Frontend - archivos estáticos del build de SvelteKit
	root * /srv/event-core/frontend/build
	file_server

	# API REST → event-core HTTP gateway
	handle /modules/* {
		reverse_proxy localhost:3000
	}

	handle /health {
		reverse_proxy localhost:3000
	}

	# MQTT WebSocket → broker Aedes
	# El frontend conecta a wss://domain/mqtt automáticamente
	handle /mqtt {
		reverse_proxy localhost:9001
	}

	# SPA fallback: rutas que no matchean archivos → index.html
	try_files {path} /index.html

	# Logs
	log {
		output file /var/log/caddy/event-core.log
		format json
	}
}
