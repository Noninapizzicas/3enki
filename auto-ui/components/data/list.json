{
  "name": "list",
  "category": "data",
  "description": "Lista de items con soporte para avatares, badges y acciones",
  "version": "2.0.0",

  "variants": {
    "default": {
      "description": "Lista simple",
      "className": "list"
    },
    "divided": {
      "description": "Lista con divisores entre items",
      "className": "list list-divided"
    },
    "bordered": {
      "description": "Lista con borde",
      "className": "list list-bordered"
    },
    "interactive": {
      "description": "Lista con hover y click",
      "className": "list list-interactive"
    }
  },

  "props": {
    "items": {
      "type": "array",
      "required": true,
      "description": "Items de la lista"
    },
    "showAvatar": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar avatar en cada item"
    },
    "showIcon": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar icono en cada item"
    },
    "showBadge": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar badge en cada item"
    },
    "showActions": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar acciones en cada item"
    },
    "dense": {
      "type": "boolean",
      "default": false,
      "description": "Modo compacto"
    },
    "selectable": {
      "type": "boolean",
      "default": false,
      "description": "Permitir selección de items"
    }
  },

  "itemStructure": {
    "avatar": {
      "type": "string",
      "description": "URL de imagen o emoji"
    },
    "icon": {
      "type": "string",
      "description": "Icono del item"
    },
    "title": {
      "type": "string",
      "required": true,
      "description": "Título principal"
    },
    "subtitle": {
      "type": "string",
      "description": "Texto secundario"
    },
    "description": {
      "type": "string",
      "description": "Descripción adicional"
    },
    "badge": {
      "text": "string",
      "variant": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "label": "string",
        "icon": "string",
        "action": "string"
      }
    }
  },

  "interactions": {
    "itemClick": {
      "enabled": true,
      "action": "navigate"
    },
    "itemHold": {
      "enabled": false,
      "action": "showContextMenu"
    }
  },

  "accessibility": {
    "role": "list",
    "itemRole": "listitem",
    "keyboardNavigation": true
  },

  "example": {
    "widget": "list",
    "variant": "interactive",
    "props": {
      "items": [
        {
          "avatar": "👤",
          "title": "Juan Pérez",
          "subtitle": "Desarrollador",
          "badge": {"text": "Activo", "variant": "success"},
          "actions": [
            {"label": "Ver perfil", "icon": "👁️", "action": "view"},
            {"label": "Mensaje", "icon": "💬", "action": "message"}
          ]
        }
      ],
      "showAvatar": true,
      "showBadge": true,
      "showActions": true
    }
  }
}
