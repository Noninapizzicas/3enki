    "deprecation_policy": {
      "path": "strategy/v1/deprecation_policy.json",
      "schema": {
        "type": "object",
        "required": ["timeline", "communication_plan", "migration_support", "criteria"],
        "properties": {
          "criteria": {
            "type": "object",
            "required": ["usage_threshold_pct", "age_months", "replacement_available"],
            "properties": {
              "usage_threshold_pct": {
                "type": "number",
                "default": 5,
                "description": "< 5% usage → eligible for deprecation"
              },
              "age_months": {
                "type": "integer",
                "default": 12,
                "description": "Deprecated for at least 12 months before sunset"
              },
              "replacement_available": {
                "type": "boolean",
                "description": "Must have stable replacement"
              },
              "no_critical_clients": {
                "type": "boolean",
                "description": "No enterprise clients still using"
              }
            }
          },
          "timeline": {
            "type": "object",
            "required": ["announcement_weeks_before", "final_warning_weeks_before", "sunset_execution"],
            "properties": {
              "announcement_weeks_before": {
                "type": "integer",
                "minimum": 12,
                "default": 26,
                "description": "6 months notice"
              },
              "final_warning_weeks_before": {
                "type": "integer",
                "minimum": 4,
                "default": 12,
                "description": "3 months final warning"
              },
              "sunset_execution": {
                "type": "string",
                "enum": ["hard_delete", "tombstone_410"],
                "default": "tombstone_410"
              }
            }
          },
          "communication_plan": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["channel", "timing", "message_template"],
              "properties": {
                "channel": {
                  "type": "string",
                  "enum": ["email", "in_app_banner", "docs", "blog", "github_issue"]
                },
                "timing": {"type": "string"},
                "message_template": {"type": "string"},
                "audience": {"type": "array", "items": {"type": "string"}}
              }
            }
          },
          "migration_support": {
            "type": "object",
            "required": ["migration_guide_url", "automation_tools"],
            "properties": {
              "migration_guide_url": {"type": "string", "format": "uri"},
              "automation_tools": {
                "type": "array",
                "items": {"type": "string"}
              },
              "support_hours_allocated": {"type": "number"},
              "migration_deadline": {"type": "string", "format": "date"}
            }
          },
          "tombstone_config": {
            "type": "object",
            "properties": {
              "http_status": {"type": "integer", "const": 410},
              "error_message": {"type": "string"},
              "redirect_to": {"type": "string", "format": "uri"},
              "keep_tombstone_months": {"type": "integer", "default": 6}
            }
          }
        },
        "additionalProperties": false
      },
      "example": {
        "criteria": {
          "usage_threshold_pct": 5,
          "age_months": 12,
          "replacement_available": true,
          "no_critical_clients": true
        },
        "timeline": {
          "announcement_weeks_before": 26,
          "final_warning_weeks_before": 12,
          "sunset_execution": "tombstone_410"
        },
        "communication_plan": [
          {
            "channel": "email",
            "timing": "26 weeks before sunset",
            "message_template": "Subject: Deprecation Notice - {{feature}} will be sunset on {{date}}...",
            "audience": ["all_users"]
          },
          {
            "channel": "in_app_banner",
            "timing": "12 weeks before sunset",
            "message_template": "⚠️ Final Warning: {{feature}} will be removed on {{date}}. Migrate to {{replacement}}.",
            "audience": ["active_users_of_feature"]
          }
        ],
        "migration_support": {
          "migration_guide_url": "https://docs.project.com/migration/v2-to-v3",
          "automation_tools": ["./scripts/migrate_v2_to_v3.sh"],
          "support_hours_allocated": 40,
          "migration_deadline": "2025-06-30"
        },
        "tombstone_config": {
          "http_status": 410,
          "error_message": "This endpoint has been sunset. Please migrate to {{replacement}}.",
          "redirect_to": "https://docs.project.com/migration/v2-to-v3",
          "keep_tombstone_months": 6
        }
      }
    },

    "risk_register": {
      "path": "strategy/v1/risk_register.json",
      "schema": {
        "type": "object",
        "required": ["risks"],
        "properties": {
          "risks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["risk_id", "description", "probability", "impact", "mitigation", "status"],
              "properties": {
                "risk_id": {"type": "string"},
                "description": {"type": "string", "minLength": 20},
                "category": {
                  "type": "string",
                  "enum": ["technical", "resource", "market", "regulatory", "security"]
                },
                "probability": {
                  "type": "string",
                  "enum": ["low", "medium", "high"]
                },
                "impact": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "critical"]
                },
                "risk_score": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 25,
                  "description": "Probability (1-5) * Impact (1-5)"
                },
                "mitigation": {
                  "type": "object",
                  "required": ["plan", "owner"],
                  "properties": {
                    "plan": {"type": "string"},
                    "owner": {"type": "string"},
                    "cost_eur": {"type": "number"},
                    "timeline": {"type": "string"}
                  }
                },
                "status": {
                  "type": "string",
                  "enum": ["identified", "analyzing", "mitigating", "monitoring", "resolved", "accepted"]
                },
                "affected_releases": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "last_reviewed": {"type": "string", "format": "date"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "example": {
        "risks": [
          {
            "risk_id": "RISK-001",
