    "dx_metrics": {
      "path": "reports/v1/dx_metrics.json",
      "schema": {
        "type": "object",
        "required": ["onboarding", "development", "quality", "adoption"],
        "properties": {
          "onboarding": {
            "type": "object",
            "required": ["ttd_minutes", "ttfx_minutes"],
            "properties": {
              "ttd_minutes": {
                "type": "number",
                "description": "Time To Deploy: tiempo desde clone hasta primer deploy exitoso",
                "minimum": 0
              },
              "ttfx_minutes": {
                "type": "number",
                "description": "Time To First Success: tiempo desde clone hasta primer test passing",
                "minimum": 0
              },
              "setup_errors": {
                "type": "integer",
                "description": "Errores encontrados durante setup",
                "minimum": 0
              }
            }
          },
          "development": {
            "type": "object",
            "required": ["build_time_sec", "test_time_sec"],
            "properties": {
              "build_time_sec": {"type": "number", "minimum": 0},
              "test_time_sec": {"type": "number", "minimum": 0},
              "hot_reload_time_ms": {"type": "number", "minimum": 0},
              "sdk_gen_time_sec": {"type": "number", "minimum": 0}
            }
          },
          "quality": {
            "type": "object",
            "required": ["test_pass_rate_pct", "lint_pass_rate_pct", "coverage_pct"],
            "properties": {
              "test_pass_rate_pct": {"type": "number", "minimum": 0, "maximum": 100},
              "lint_pass_rate_pct": {"type": "number", "minimum": 0, "maximum": 100},
              "coverage_pct": {"type": "number", "minimum": 0, "maximum": 100},
              "type_safety_score": {"type": "number", "minimum": 0, "maximum": 100}
            }
          },
          "adoption": {
            "type": "object",
            "required": ["cli_usage_rate", "sdk_usage_rate", "scaffold_usage_rate"],
            "properties": {
              "cli_usage_rate": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "% de developers usando CLI vs comandos manuales"
              },
              "sdk_usage_rate": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "% de módulos usando SDK generados"
              },
              "scaffold_usage_rate": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "% de módulos creados desde scaffold vs manual"
              },
              "git_hooks_active_rate": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "% de developers con git hooks activos"
              }
            }
          },
          "errors": {
            "type": "object",
            "properties": {
              "dev_error_rate": {
                "type": "number",
                "description": "Errores por hora durante desarrollo",
                "minimum": 0
              },
              "common_errors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "error_code": {"type": "string"},
                    "count": {"type": "integer"},
                    "avg_resolution_minutes": {"type": "number"}
                  }
                }
              }
            }
          },
          "documentation": {
            "type": "object",
            "properties": {
              "doc_quality_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Score basado en completeness, ejemplos, actualización"
              },
              "outdated_docs_pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            }
          },
          "collection": {
            "type": "object",
            "properties": {
              "timestamp": {"type": "string", "format": "date-time"},
              "collection_method": {"type": "string", "enum": ["automated", "survey", "manual"]},
              "sample_size": {"type": "integer", "minimum": 1}
            }
          }
        },
        "additionalProperties": false
      },
