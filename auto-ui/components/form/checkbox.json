{
  "name": "checkbox",
  "category": "form",
  "description": "Checkbox para selección múltiple",
  "version": "2.0.0",

  "variants": {
    "default": {
      "description": "Checkbox estándar",
      "className": "form-checkbox"
    },
    "switch": {
      "description": "Estilo switch/toggle",
      "className": "form-checkbox form-switch"
    },
    "button": {
      "description": "Estilo botón",
      "className": "form-checkbox form-checkbox-button"
    }
  },

  "sizes": {
    "sm": {
      "description": "Checkbox pequeño",
      "className": "form-checkbox-sm"
    },
    "md": {
      "description": "Checkbox mediano (default)",
      "className": ""
    },
    "lg": {
      "description": "Checkbox grande",
      "className": "form-checkbox-lg"
    }
  },

  "props": {
    "label": {
      "type": "string",
      "description": "Etiqueta del checkbox"
    },
    "name": {
      "type": "string",
      "required": true,
      "description": "Nombre del campo"
    },
    "value": {
      "type": "string|number|boolean",
      "description": "Valor del checkbox"
    },
    "checked": {
      "type": "boolean",
      "default": false,
      "description": "Estado checked"
    },
    "indeterminate": {
      "type": "boolean",
      "default": false,
      "description": "Estado indeterminado"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Checkbox deshabilitado"
    },
    "required": {
      "type": "boolean",
      "default": false,
      "description": "Campo requerido"
    },
    "helpText": {
      "type": "string",
      "description": "Texto de ayuda"
    },
    "errorText": {
      "type": "string",
      "description": "Mensaje de error"
    }
  },

  "states": {
    "unchecked": {
      "description": "No seleccionado",
      "icon": "☐"
    },
    "checked": {
      "description": "Seleccionado",
      "icon": "☑",
      "className": "checked"
    },
    "indeterminate": {
      "description": "Estado indeterminado (parcial)",
      "icon": "▣",
      "className": "indeterminate"
    },
    "disabled": {
      "description": "Deshabilitado",
      "className": "disabled"
    }
  },

  "group": {
    "description": "Grupo de checkboxes",
    "props": {
      "label": "string",
      "name": "string",
      "options": "array",
      "value": "array",
      "inline": "boolean",
      "selectAll": "boolean"
    }
  },

  "accessibility": {
    "role": "checkbox",
    "ariaChecked": true,
    "ariaLabel": true,
    "ariaDescribedBy": true
  },

  "example": {
    "component": "checkbox",
    "variant": "default",
    "size": "md",
    "props": {
      "label": "Acepto los términos y condiciones",
      "name": "terms",
      "required": true,
      "helpText": "Debes aceptar para continuar"
    }
  },

  "groupExample": {
    "component": "checkbox-group",
    "props": {
      "label": "Intereses",
      "name": "interests",
      "options": [
        {"value": "tech", "label": "Tecnología"},
        {"value": "sports", "label": "Deportes"},
        {"value": "music", "label": "Música"}
      ],
      "value": ["tech"],
      "inline": false,
      "selectAll": true
    }
  }
}
