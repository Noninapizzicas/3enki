{
  "_meta": {
    "modulo": "ui-designer",
    "ubicacion": "modules/ui-designer",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "ui-designer",
    "version": "1.0.0",
    "description_oficial": "Diseñador visual de interfaces para módulos Event-Core",
    "author": "Event Core Team",
    "main": null
  },

  "estado_en_sistema": {
    "habilitado_en_config": false,
    "en_disabled_de_config": true,
    "estado_modulo": "dormido_por_diseno",
    "tier_carga_inferido": null,
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "ui-designer.template.created", "description": "Nuevo template de UI creado" },
      { "event": "ui-designer.template.updated", "description": "Template actualizado" },
      { "event": "ui-designer.template.deleted", "description": "Template eliminado" },
      { "event": "ui-designer.export.yaml",       "description": "Template exportado como YAML" },
      { "event": "ui-designer.export.svelte",     "description": "Template exportado como código Svelte" },
      { "event": "ui-designer.export.json",       "description": "Template exportado como JSON" }
    ],
    "subscribes": [],
    "provides_eventos": [
      "ui-designer.template.created",
      "ui-designer.template.updated",
      "ui-designer.template.deleted",
      "ui-designer.export.yaml",
      "ui-designer.export.svelte",
      "ui-designer.export.json"
    ]
  },

  "tools": [],

  "ui_handlers": {
    "campo_origen": null,
    "items": []
  },

  "apis_http": [
    {
      "method": "GET",
      "path": "/templates",
      "handler": "handleListTemplates",
      "description": "Listar todos los templates",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/templates",
      "handler": "handleCreateTemplate",
      "description": "Crear nuevo template",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/templates/:id",
      "handler": "handleGetTemplate",
      "description": "Obtener template por ID",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "PUT",
      "path": "/templates/:id",
      "handler": "handleUpdateTemplate",
      "description": "Actualizar template",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "DELETE",
      "path": "/templates/:id",
      "handler": "handleDeleteTemplate",
      "description": "Eliminar template",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/templates/:id/duplicate",
      "handler": "handleDuplicateTemplate",
      "description": "Duplicar template",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/templates/:id/publish",
      "handler": "handlePublishTemplate",
      "description": "Publicar template (draft → published)",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/templates/:id/archive",
      "handler": "handleArchiveTemplate",
      "description": "Archivar template",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/layouts",
      "handler": "handleListLayouts",
      "description": "Listar layouts disponibles",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/layouts/:type",
      "handler": "handleGetLayout",
      "description": "Obtener configuración de layout",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/predefined",
      "handler": "handleGetPredefinedTemplates",
      "description": "Obtener templates predefinidos",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/predefined/create",
      "handler": "handleCreateFromPredefined",
      "description": "Crear template desde predefinido",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/components",
      "handler": "handleListComponents",
      "description": "Listar componentes disponibles",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/components/:name",
      "handler": "handleGetComponentSchema",
      "description": "Obtener schema de componente",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/export/yaml",
      "handler": "handleExportYaml",
      "description": "Exportar template como YAML blueprint",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/export/svelte",
      "handler": "handleExportSvelte",
      "description": "Exportar template como código Svelte",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/export/json",
      "handler": "handleExportJson",
      "description": "Exportar como JSON para module.json",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check del módulo",
      "request_schema_ref": null,
      "response_schema_ref": null
    }
  ],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "enabled",              "tipo": "boolean", "valor_default": true },
      { "key": "autosave",             "tipo": "boolean", "valor_default": true },
      { "key": "autosave_interval_ms", "tipo": "number",  "valor_default": 30000 }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [],
      "gauges": [],
      "timings": []
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": true,
    "enabled": true,
    "title": "UI Designer",
    "icon": "🎨",
    "views_keys": [],
    "section_widget_types": [],
    "permissions_declaradas": [],
    "tamano_bytes": 232,
    "endpoints_referenciados": [],
    "mqtt_topics_declarados": []
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": [],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": false,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {
      "provides": {
        "events": [
          "ui-designer.template.created",
          "ui-designer.template.updated",
          "ui-designer.template.deleted",
          "ui-designer.export.yaml",
          "ui-designer.export.svelte",
          "ui-designer.export.json"
        ],
        "queries": []
      },
      "schema": {
        "template": {
          "type": "object",
          "required": ["name", "type"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$", "minLength": 3, "maxLength": 50 },
            "display_name": { "type": "string", "maxLength": 100 },
            "description": { "type": "string", "maxLength": 500 },
            "icon": { "type": "string", "maxLength": 4 },
            "type": { "type": "string", "enum": ["view", "modal", "form", "dashboard", "component", "page"] },
            "category": { "type": "string", "enum": ["general", "admin", "data", "analytics", "settings", "ai", "custom"] },
            "status": { "type": "string", "enum": ["draft", "published", "archived"] },
            "layout": { "type": "object" },
            "components": { "type": "array" },
            "theme": { "type": "object" },
            "permissions": { "type": "array", "items": { "type": "string" } },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": false,
    "ui_handlers_field_name": null,
    "module_json_bytes": 6398,
    "module_json_lineas": 247,
    "tiene_main_no_estandar": false,
    "warnings": [
      "provides.events duplica events.publishes — mismos 6 eventos declarados en dos lugares",
      "ui.version='2.0' declarada pero módulo DISABLED — nunca carga",
      "module.json carece de campo 'main' — entry point implícito index.js",
      "schema inline en module.json (schema.template) — no externalizado en schemas/"
    ]
  }
}
