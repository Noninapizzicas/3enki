{
  "id": "recibir-documento",
  "name": "Recibir Documento",
  "description": "Recibe archivos del bot Telegram, los renombra con timestamp y guarda metadata",
  "version": "2.0.0",
  "enabled": true,

  "trigger": {
    "event": "bot.file.stored",
    "filter": {
      "botName": "facturas_asesoria_bot",
      "file.mimeType": {
        "$in": ["image/jpeg", "image/png", "image/webp", "application/pdf"]
      }
    }
  },

  "steps": [
    {
      "id": "set-variables",
      "type": "set",
      "variables": {
        "timestamp": "{{ replace(substring(now, 0, 19), ':', '') }}",
        "fechaHora": "{{ replace(replace(substring(now, 0, 19), 'T', '-'), ':', '') }}",
        "nombreOriginal": "{{ trigger.file.originalName }}",
        "nuevoNombre": "{{ replace(replace(substring(now, 0, 19), 'T', '-'), ':', '') }}_{{ trigger.file.originalName }}",
        "dirDestino": "{{ trigger.botName }}/recibidas"
      }
    },
    {
      "id": "crear-directorio",
      "type": "service",
      "service": "fs",
      "action": "mkdir",
      "path": "{{ projectPath(variables.dirDestino) }}",
      "onError": "continue"
    },
    {
      "id": "copiar-archivo",
      "type": "service",
      "service": "fs",
      "action": "copy",
      "from": "{{ globalPath(trigger.file.path) }}",
      "to": "{{ projectPath(variables.dirDestino, '/', variables.nuevoNombre) }}",
      "onError": "notificar-error"
    },
    {
      "id": "guardar-metadata",
      "type": "service",
      "service": "fs",
      "action": "write",
      "path": "{{ projectPath(variables.dirDestino, '/', variables.nuevoNombre, '.meta.json') }}",
      "content": "{{ json({ id: uuid, recibido: now, fuente: 'telegram', bot: trigger.botName, chatId: trigger.chatId, userId: trigger.userId, username: trigger.username, archivoOriginal: variables.nombreOriginal, archivoGuardado: variables.nuevoNombre, mimeType: trigger.file.mimeType, size: trigger.file.size }) }}",
      "onError": "continue"
    },
    {
      "id": "confirmar-recepcion",
      "type": "service",
      "service": "telegram",
      "action": "send_message",
      "chatId": "{{ trigger.chatId }}",
      "text": "✅ Recibido: {{ variables.nombreOriginal }}\nSe procesará próximamente.",
      "onError": "continue"
    },
    {
      "id": "log-exito",
      "type": "log",
      "level": "info",
      "message": "Documento recibido: {{ variables.nuevoNombre }} de @{{ trigger.username }}"
    },
    {
      "id": "notificar-error",
      "type": "service",
      "service": "telegram",
      "action": "send_message",
      "chatId": "{{ trigger.chatId }}",
      "text": "❌ Error al guardar el archivo. Por favor, inténtalo de nuevo.",
      "onError": "continue"
    },
    {
      "id": "log-error",
      "type": "log",
      "level": "error",
      "message": "Error guardando documento de @{{ trigger.username }}: {{ error.message }}"
    }
  ]
}
