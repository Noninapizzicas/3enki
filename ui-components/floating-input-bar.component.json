{
  "component": "floating-input-bar",
  "version": "1.0.0",
  "description": "Barra de entrada de texto flotante de ancho completo (20mm alto) con botón de acción 10x10mm",
  "features": {
    "dimensions": {
      "height_mm": 20,
      "height_px": 76,
      "width": "100vw",
      "max_width": "calc(100vw - 32px)",
      "button_size_mm": 10,
      "button_size_px": 38,
      "description": "Barra de 20mm de alto con botón de 10mm x 10mm"
    },
    "positioning": {
      "fixed": true,
      "default_position": "bottom",
      "alignment": "center",
      "offset_bottom": "16px",
      "draggable": true,
      "description": "Flotante en bottom center, draggable para reposicionar"
    },
    "visual": {
      "semi_transparent": true,
      "backdrop_blur": "8px",
      "background_opacity": 0.9,
      "border_radius": "16px",
      "shadow": true,
      "description": "Semi-transparente con blur para ver contenido debajo"
    },
    "input": {
      "type": "text",
      "placeholder": "Escribe algo...",
      "max_length": 500,
      "auto_focus": false,
      "clear_on_submit": true,
      "description": "Input de texto de una línea"
    },
    "button": {
      "size": "38x38px",
      "position": "right",
      "type": "emoji",
      "customizable": true,
      "actions": ["submit", "voice", "send", "search", "custom"],
      "description": "Botón de acción configurable (enviar, buscar, voz, etc.)"
    },
    "voice_integration": {
      "enabled": true,
      "auto_integration": true,
      "voice_button_mode": true,
      "description": "Integración opcional con VoiceInput component"
    },
    "interactions": {
      "submit_on_enter": true,
      "submit_on_button": true,
      "escape_to_clear": true,
      "auto_hide": false,
      "description": "Enter para enviar, ESC para limpiar"
    },
    "animations": {
      "slide_in": true,
      "slide_out": true,
      "focus_expand": false,
      "pulse_on_error": true,
      "description": "Animaciones de entrada y estados"
    }
  },
  "use_cases": [
    "Barra de búsqueda flotante",
    "Chat input (mensajería)",
    "Comentarios rápidos",
    "Comandos por voz/texto",
    "Quick note input",
    "Global search bar",
    "AI chat interface"
  ],
  "integration": {
    "voice_input": true,
    "emoji_action_button": true,
    "floating_topbar": true,
    "overlay_panel": true,
    "description": "Compatible con todos los componentes UI"
  },
  "responsive": {
    "mobile": {
      "width": "calc(100vw - 16px)",
      "position": "bottom",
      "keyboard_aware": true,
      "description": "En móvil se ajusta al teclado virtual"
    },
    "tablet": {
      "width": "calc(100vw - 32px)",
      "max_width": "800px",
      "description": "En tablet tiene max-width para mejor UX"
    },
    "desktop": {
      "width": "auto",
      "max_width": "600px",
      "description": "En desktop tiene max-width configurable"
    }
  },
  "accessibility": {
    "aria_labels": true,
    "keyboard_navigation": true,
    "screen_reader": true,
    "focus_visible": true,
    "description": "Accesible para lectores de pantalla y teclado"
  }
}
