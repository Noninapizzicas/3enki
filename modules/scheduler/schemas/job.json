{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scheduler/job",
  "title": "Scheduler Job",
  "description": "Schema for scheduler job definition",
  "type": "object",
  "required": ["name", "trigger", "action"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique job identifier (auto-generated if not provided)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable job name"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Job description"
    },
    "trigger": {
      "$ref": "#/definitions/trigger"
    },
    "action": {
      "$ref": "#/definitions/action"
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether the job is enabled"
    },
    "options": {
      "$ref": "#/definitions/options"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "definitions": {
    "trigger": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        { "$ref": "#/definitions/cronTrigger" },
        { "$ref": "#/definitions/intervalTrigger" },
        { "$ref": "#/definitions/datetimeTrigger" },
        { "$ref": "#/definitions/eventTrigger" },
        { "$ref": "#/definitions/conditionTrigger" },
        { "$ref": "#/definitions/compositeTrigger" }
      ]
    },
    "cronTrigger": {
      "type": "object",
      "required": ["type", "expression"],
      "properties": {
        "type": { "const": "cron" },
        "expression": {
          "type": "string",
          "description": "Cron expression (minute hour day-month month day-week)"
        },
        "timezone": {
          "type": "string",
          "default": "Europe/Madrid",
          "description": "Timezone for cron evaluation"
        }
      }
    },
    "intervalTrigger": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "interval" },
        "value": {
          "type": "number",
          "minimum": 1,
          "description": "Interval value"
        },
        "unit": {
          "type": "string",
          "enum": ["ms", "s", "m", "h", "d"],
          "default": "ms",
          "description": "Time unit"
        }
      }
    },
    "datetimeTrigger": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "datetime" },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date in YYYY-MM-DD format"
        },
        "time": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}(:\\d{2})?$",
          "description": "Time in HH:mm or HH:mm:ss format"
        },
        "repeat": {
          "type": "string",
          "enum": ["once", "daily", "weekly", "monthly", "yearly"],
          "default": "once",
          "description": "Repeat pattern"
        },
        "timezone": {
          "type": "string",
          "default": "Europe/Madrid"
        }
      }
    },
    "eventTrigger": {
      "type": "object",
      "required": ["type", "topic"],
      "properties": {
        "type": { "const": "event" },
        "topic": {
          "type": "string",
          "description": "MQTT topic to listen to"
        },
        "condition": {
          "type": "string",
          "description": "JavaScript expression to evaluate (e.g., 'payload.size > 1000')"
        },
        "debounce": {
          "type": "number",
          "minimum": 0,
          "description": "Debounce time in milliseconds"
        }
      }
    },
    "conditionTrigger": {
      "type": "object",
      "required": ["type", "check"],
      "properties": {
        "type": { "const": "condition" },
        "check": {
          "type": "string",
          "description": "JavaScript expression to evaluate periodically"
        },
        "interval": {
          "type": "number",
          "minimum": 1000,
          "default": 10000,
          "description": "Check interval in milliseconds"
        },
        "persist": {
          "type": "boolean",
          "default": false,
          "description": "Stay triggered until condition becomes false"
        }
      }
    },
    "compositeTrigger": {
      "type": "object",
      "required": ["type", "triggers"],
      "properties": {
        "type": { "const": "composite" },
        "logic": {
          "type": "string",
          "enum": ["AND", "OR", "NAND", "NOR", "XOR"],
          "default": "AND",
          "description": "Logic operator to combine triggers"
        },
        "triggers": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/definitions/trigger"
          },
          "description": "Sub-triggers to combine"
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        { "$ref": "#/definitions/mqttAction" },
        { "$ref": "#/definitions/httpAction" },
        { "$ref": "#/definitions/moduleAction" }
      ]
    },
    "mqttAction": {
      "type": "object",
      "required": ["type", "topic"],
      "properties": {
        "type": { "const": "mqtt" },
        "topic": {
          "type": "string",
          "description": "MQTT topic to publish to (supports {{templates}})"
        },
        "payload": {
          "description": "Payload to publish (supports {{templates}})"
        },
        "qos": {
          "type": "integer",
          "enum": [0, 1, 2],
          "default": 1,
          "description": "MQTT QoS level"
        }
      }
    },
    "httpAction": {
      "type": "object",
      "required": ["type", "url"],
      "properties": {
        "type": { "const": "http" },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "HTTP URL (supports {{templates}})"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
          "default": "GET"
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": {
          "description": "Request body (supports {{templates}})"
        },
        "timeout": {
          "type": "number",
          "minimum": 1000,
          "default": 30000,
          "description": "Request timeout in milliseconds"
        }
      }
    },
    "moduleAction": {
      "type": "object",
      "required": ["type", "module", "method"],
      "properties": {
        "type": { "const": "module" },
        "module": {
          "type": "string",
          "description": "Module name"
        },
        "method": {
          "type": "string",
          "description": "Method to call via events"
        },
        "params": {
          "type": "object",
          "description": "Parameters to pass"
        },
        "timeout": {
          "type": "number",
          "minimum": 1000,
          "default": 30000
        }
      }
    },
    "options": {
      "type": "object",
      "properties": {
        "maxRetries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 3,
          "description": "Maximum retry attempts on failure"
        },
        "retryDelay": {
          "type": "number",
          "minimum": 0,
          "default": 5000,
          "description": "Delay between retries in milliseconds"
        },
        "timeout": {
          "type": "number",
          "minimum": 1000,
          "default": 300000,
          "description": "Job execution timeout in milliseconds"
        },
        "overlap": {
          "type": "boolean",
          "default": false,
          "description": "Allow overlapping executions"
        },
        "circuitBreaker": {
          "type": "object",
          "properties": {
            "failureThreshold": {
              "type": "integer",
              "minimum": 1,
              "default": 5
            },
            "resetTimeout": {
              "type": "number",
              "minimum": 1000,
              "default": 60000
            },
            "halfOpenMaxAttempts": {
              "type": "integer",
              "minimum": 1,
              "default": 3
            }
          }
        },
        "timeWindows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "days": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
                }
              },
              "start": {
                "type": "string",
                "pattern": "^\\d{2}:\\d{2}$"
              },
              "end": {
                "type": "string",
                "pattern": "^\\d{2}:\\d{2}$"
              }
            }
          },
          "description": "Time windows when the job can execute"
        }
      }
    }
  }
}
