{
  "name": "credential-manager",
  "version": "2.0.0",
  "description": "Multi-level credential management with .env storage (GLOBAL/PROJECT/CLIENT/CUSTOM)",
  "author": "Aichat Team",
  "main": "index.js",

  "provides": {
    "events": [
      "credential.saved",
      "credential.updated",
      "credential.deleted",
      "credential.resolved",
      "credential.resolve.failed"
    ],
    "queries": [
      "credential.resolve.request"
    ]
  },

  "events": {
    "publishes": [
      {
        "event": "credential.saved",
        "description": "Credential saved or created",
        "schema": { "$ref": "./schemas/events.json#/definitions/credential_saved" }
      },
      {
        "event": "credential.updated",
        "description": "Credential value updated",
        "schema": { "$ref": "./schemas/events.json#/definitions/credential_updated" }
      },
      {
        "event": "credential.deleted",
        "description": "Credential removed",
        "schema": { "$ref": "./schemas/events.json#/definitions/credential_deleted" }
      },
      {
        "event": "credential.resolved",
        "description": "Credential successfully resolved",
        "schema": { "$ref": "./schemas/events.json#/definitions/credential_resolved" }
      },
      {
        "event": "credential.resolve.failed",
        "description": "Credential resolution failed",
        "schema": { "$ref": "./schemas/events.json#/definitions/credential_resolve_failed" }
      },
      {
        "event": "credential.resolve.response",
        "description": "Response to credential resolve request",
        "schema": { "$ref": "./schemas/events.json#/definitions/credential_resolve_response" }
      }
    ],
    "subscribes": [
      {
        "event": "credential.resolve.request",
        "description": "Handle credential resolution requests from other modules",
        "handler": "onResolveRequest"
      }
    ]
  },

  "ui": {
    "enabled": true,
    "version": "2.0",
    "title": "Credential Manager",
    "icon": "🔐",
    "description": "Multi-level credential management for AI providers",
    "access_level": "admin",
    "components": [
      "grid-credentials",
      "credential-card",
      "form-credential",
      "credential-tester"
    ],

    "views": {
      "main": {
        "type": "dashboard",
        "permissions": ["admin"],

        "layout": {
          "type": "two-column",
          "config": {
            "leftWidth": "65%",
            "rightWidth": "35%",
            "gap": "var(--space-lg)"
          }
        },

        "header": {
          "title": "🔐 Credential Manager",
          "subtitle": "Gestión de API Keys para Proveedores de IA",
          "actions": [
            {
              "type": "button",
              "label": "Nueva Credencial",
              "icon": "➕",
              "action": "open_form",
              "variant": "primary"
            },
            {
              "type": "button",
              "label": "Probar Resolución",
              "icon": "🔍",
              "action": "open_tester",
              "variant": "secondary"
            }
          ]
        },

        "sections": [
          {
            "id": "credentials_grid",
            "widget": "grid",
            "config": {
              "component": "grid-credentials",
              "endpoint": "/modules/credential-manager/credentials",
              "mqtt_topics": [
                "credential.saved",
                "credential.updated",
                "credential.deleted"
              ],
              "refresh_on_event": true,
              "item_component": "credential-card"
            }
          },
          {
            "id": "info_panel",
            "widget": "card",
            "config": {
              "title": "ℹ️ Información",
              "content": {
                "type": "info",
                "items": [
                  {
                    "label": "Total Credenciales",
                    "value_source": "metrics.credential.count.total",
                    "icon": "🔑"
                  },
                  {
                    "label": "GLOBAL",
                    "value_source": "metrics.credential.count.global",
                    "color": "#2FBF71"
                  },
                  {
                    "label": "PROJECT",
                    "value_source": "metrics.credential.count.project",
                    "color": "#1D4ED8"
                  },
                  {
                    "label": "CLIENT",
                    "value_source": "metrics.credential.count.client",
                    "color": "#F5B700"
                  },
                  {
                    "label": "CUSTOM",
                    "value_source": "metrics.credential.count.custom",
                    "color": "#E63946"
                  }
                ]
              }
            }
          },
          {
            "id": "cascade_info",
            "widget": "card",
            "config": {
              "title": "🔄 Cascada de Resolución",
              "content": {
                "type": "diagram",
                "flow": [
                  {"level": "CUSTOM", "priority": 1, "color": "#E63946"},
                  {"level": "CLIENT", "priority": 2, "color": "#F5B700"},
                  {"level": "PROJECT", "priority": 3, "color": "#1D4ED8"},
                  {"level": "GLOBAL", "priority": 4, "color": "#2FBF71"}
                ],
                "description": "El sistema busca credenciales en orden de prioridad"
              }
            }
          },
          {
            "id": "providers_status",
            "widget": "card",
            "config": {
              "title": "📊 Estado de Proveedores",
              "content": {
                "type": "status_list",
                "endpoint": "/modules/credential-manager/health",
                "items": [
                  {
                    "provider": "OPENAI",
                    "icon": "🤖",
                    "status_field": "providers.openai.configured"
                  },
                  {
                    "provider": "DEEPSEEK",
                    "icon": "🔮",
                    "status_field": "providers.deepseek.configured"
                  },
                  {
                    "provider": "ANTHROPIC",
                    "icon": "🧠",
                    "status_field": "providers.anthropic.configured"
                  },
                  {
                    "provider": "OLLAMA",
                    "icon": "🦙",
                    "status_field": "providers.ollama.configured"
                  }
                ]
              }
            }
          }
        ]
      },

      "create": {
        "type": "modal",
        "component": "form-credential",
        "mode": "create",
        "config": {
          "title": "Nueva Credencial",
          "endpoint": "/modules/credential-manager/credentials",
          "method": "POST",
          "on_success": {
            "close": true,
            "refresh_view": "main",
            "show_toast": {
              "message": "Credencial guardada correctamente",
              "type": "success"
            }
          }
        }
      },

      "edit": {
        "type": "modal",
        "component": "form-credential",
        "mode": "edit",
        "config": {
          "title": "Editar Credencial",
          "endpoint": "/modules/credential-manager/credentials/{key}",
          "method": "PUT",
          "on_success": {
            "close": true,
            "refresh_view": "main",
            "show_toast": {
              "message": "Credencial actualizada correctamente",
              "type": "success"
            }
          }
        }
      },

      "tester": {
        "type": "modal",
        "component": "credential-tester",
        "config": {
          "title": "Probar Resolución de Credenciales",
          "width": "700px",
          "height": "auto"
        }
      }
    },

    "mqtt": {
      "enabled": true,
      "topics": [
        "credential.saved",
        "credential.updated",
        "credential.deleted",
        "credential.resolved"
      ],
      "auto_refresh": true
    },

    "permissions": {
      "view": ["admin"],
      "create": ["admin"],
      "edit": ["admin"],
      "delete": ["admin"],
      "test": ["admin"]
    }
  },

  "schema": {
    "id": {
      "type": "string",
      "label": "ID",
      "format": "hidden"
    },
    "key": {
      "type": "string",
      "label": "Credential Key",
      "required": false
    },
    "provider": {
      "type": "enum",
      "label": "Provider",
      "enum": ["OPENAI", "ANTHROPIC", "DEEPSEEK", "OLLAMA", "CUSTOM"],
      "required": true
    },
    "level": {
      "type": "enum",
      "label": "Level",
      "enum": ["GLOBAL", "PROJECT", "CLIENT", "CUSTOM"],
      "required": true
    },
    "identifier": {
      "type": "string",
      "label": "Identifier",
      "required": false
    },
    "api_key": {
      "type": "string",
      "label": "API Key",
      "format": "password",
      "required": true
    },
    "api_key_preview": {
      "type": "string",
      "label": "API Key Preview",
      "required": false
    },
    "created": {
      "type": "boolean",
      "label": "Created"
    },
    "updated": {
      "type": "boolean",
      "label": "Updated"
    }
  },

  "apis": [
    {
      "method": "POST",
      "path": "/credentials",
      "handler": "handleSaveCredential",
      "description": "Save credential (publishes credential.saved)",
      "request_schema": { "$ref": "./schemas/credential.json#/definitions/save_request" },
      "response_schema": { "$ref": "./schemas/credential.json#/definitions/save_response" }
    },
    {
      "method": "GET",
      "path": "/credentials/resolve",
      "handler": "handleResolveCredential",
      "description": "Resolve credential by cascade (publishes credential.resolved)",
      "response_schema": { "$ref": "./schemas/credential.json#/definitions/resolve_response" }
    },
    {
      "method": "GET",
      "path": "/credentials",
      "handler": "handleListCredentials",
      "description": "List credentials (masked)",
      "response_schema": { "$ref": "./schemas/credential.json#/definitions/list_response" }
    },
    {
      "method": "PUT",
      "path": "/credentials/:key",
      "handler": "handleUpdateCredential",
      "description": "Update credential (publishes credential.updated)",
      "request_schema": { "$ref": "./schemas/credential.json#/definitions/update_request" },
      "response_schema": { "$ref": "./schemas/credential.json#/definitions/update_response" }
    },
    {
      "method": "DELETE",
      "path": "/credentials/:key",
      "handler": "handleDeleteCredential",
      "description": "Delete credential (publishes credential.deleted)",
      "response_schema": { "$ref": "./schemas/credential.json#/definitions/delete_response" }
    },
    {
      "method": "GET",
      "path": "/credentials/levels",
      "handler": "handleGetLevels",
      "description": "Get available credential levels"
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check endpoint"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Module metrics"
    }
  ],

  "observability": {
    "logging": {
      "level": "info",
      "structured": true,
      "correlation_id": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "credential.saved.total",
        "credential.updated.total",
        "credential.deleted.total",
        "credential.resolved.total",
        "credential.resolve.failed.total",
        "credential.errors.total"
      ],
      "gauges": [
        "credential.count.total",
        "credential.count.by_level"
      ],
      "timings": [
        "credential.resolve.duration",
        "credential.save.duration"
      ]
    }
  },

  "config": {
    "envFile": ".env",
    "maskLength": 4,
    "levels": {
      "CUSTOM": {
        "priority": 1,
        "requiresIdentifier": true,
        "description": "Highest priority - custom specific credentials"
      },
      "CLIENT": {
        "priority": 2,
        "requiresIdentifier": true,
        "description": "Client-specific credentials"
      },
      "PROJECT": {
        "priority": 3,
        "requiresIdentifier": true,
        "description": "Project-specific credentials"
      },
      "GLOBAL": {
        "priority": 4,
        "requiresIdentifier": false,
        "description": "Global fallback credentials"
      }
    }
  }
}
