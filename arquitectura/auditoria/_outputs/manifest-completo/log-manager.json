      { "key": "logsPath", "tipo": "string", "valor_default": "./data/logs" },
      { "key": "trackedModules", "tipo": "array", "valor_default": ["*"] },
      { "key": "excludedModules", "tipo": "array", "valor_default": ["log-manager"] },
      { "key": "maxFileSize", "tipo": "number", "valor_default": 10485760 },
      { "key": "retentionDays", "tipo": "number", "valor_default": 30 },
      { "key": "sessionRetentionDays", "tipo": "number", "valor_default": 7 },
      { "key": "rotateDaily", "tipo": "boolean", "valor_default": true }
    ]
