{
  "name": "send_photo",
  "description": "Enviar foto a un chat",
  "event": "telegram.send_photo.request",
  "method": "POST",
  "endpoint": "/bot{{bot_token}}/sendPhoto",
  "headers": {
    "Content-Type": "application/json"
  },
  "input": {
    "bot_token": {
      "type": "string",
      "description": "Token del bot",
      "required": true
    },
    "chat_id": {
      "type": "number",
      "description": "ID del chat destino",
      "required": true
    },
    "photo": {
      "type": "string",
      "description": "URL o file_id de la foto",
      "required": true
    },
    "caption": {
      "type": "string",
      "description": "Caption de la foto"
    }
  },
  "request_template": {
    "chat_id": "{{chat_id}}",
    "photo": "{{photo}}",
    "caption": "{{caption}}"
  },
  "output": {
    "message_id": {
      "type": "number",
      "description": "ID del mensaje enviado"
    }
  },
  "response_path": "result.message_id"
}
