  "recommended_module_json_template": {
    "description": "Formato estándar que debería generar plop module",
    "template": {
      "name": "{{name}}",
      "version": "1.0.0",
      "description": "{{description}}",
      "author": "{{author}}",
      "apis": [
        {
          "method": "GET|POST|PUT|DELETE",
          "path": "/endpoint",
          "handler": "handlerMethodName",
          "description": "Descripción del endpoint"
        }
      ],
      "events": {
        "publishes": ["{{name}}.created", "{{name}}.updated"],
        "subscribes": ["other.event"]
      },
      "tools": [
        {
          "name": "{{name}}.action",
          "description": "Descripción de la tool para AI",
          "handler": "handleToolAction",
          "parameters": {
            "type": "object",
            "properties": {
              "param1": { "type": "string", "description": "..." }
            },
            "required": ["param1"]
          }
        }
      ],
      "ui": {
        "zone": "work-bar|chat-config|chat-tools",
        "icon": "emoji"
      },
      "config": {}
    }
  },
  "recommended_index_js_template": {
    "description": "Estructura estándar para index.js",
    "structure": [
      "class ModuleNameModule {",
      "  constructor() - Estado inicial, sin dependencias",
      "  async onLoad(context) - Inyectar deps, registrar handlers",
      "  async onUnload() - Cleanup",
      "  async registerUIHandlers() - uiHandler.register()",
      "  async subscribeToEvents() - eventBus.subscribe()",
      "  // HTTP API handlers",
      "  async handleXxx(req, context) - return { status, data }",
      "  // Event handlers",
      "  async onEventName(event) - procesar eventos",
      "  // UI handlers",
      "  async handleUIAction(data, context) - handlers MQTT",
      "  // Tool handlers",
      "  async handleToolAction(params, context) - tools para AI",
      "}"
    ]
  },
  "learned_patterns": {
    "source": "modules/chat-session, modules/prompt-composer",
    "description": "Patrones extraídos de implementaciones reales para mejorar templates",
    "handler_naming_conventions": {
      "ui_handlers": "handleUI{Action} - ej: handleUICreate, handleUIList, handleUIDelete",
      "http_handlers": "handle{Action} - ej: handleCreateConversation, handleGetMessages",
      "event_handlers": "on{Event}Request - ej: onCreateRequest, onSaveRequest",
      "tool_handlers": "tool{Action} - ej: toolListConversations, toolGetMessages"
    },
    "module_structure": {
      "sections_order": [
        "1. constructor() - Estado inicial, Maps, Sets, pendingRequests",
        "2. onLoad(context) - Inyección de dependencias",
        "3. onUnload() - Cleanup con unsubscribe y clear",
        "4. registerUIHandlers() - uiHandler.register('domain', 'action', handler)",
        "5. subscribeToEvents() - eventBus.subscribe con tracking de unsubscribes",
        "6. Helper methods - queryDatabase, etc",
        "7. Core business logic - CRUD operations",
        "8. Event handlers - on*Request methods",
        "9. UI handlers - handleUI* methods",
        "10. HTTP handlers - handle* methods",
        "11. Tool handlers - tool* methods"
      ]
    },
    "request_response_pattern": {
      "description": "Patrón para comunicación async entre módulos",
      "example": {
        "request_event": "session.create.request",
        "response_event": "session.create.response",
        "payload": {
          "request": "{ request_id, project_id, user_id, options, correlation_id }",
          "response": "{ request_id, success, conversation?, error? }"
        }
      },
      "pending_tracking": "Map<request_id, { resolve, reject, timeout }>"
    },
    "ui_handler_pattern": {
      "registration": "this.uiHandler.register('domain', 'action', this.handler.bind(this))",
      "handler_signature": "async handleUIAction(data, context)",
      "return_format": "{ status: number, data?: any, error?: string }",
      "unregistration": "this.uiHandler.unregister('domain', 'action')"
    },
    "event_subscription_pattern": {
      "tracking": "this.unsubscribes = []",
      "subscribe": "const unsub = await this.eventBus.subscribe('event', handler); this.unsubscribes.push(unsub)",
      "cleanup": "for (const unsub of this.unsubscribes) { await unsub(); }"
    },
    "tools_for_ai": {
      "naming": "module.action_name (ej: session.list_conversations)",
      "handler_naming": "tool{ActionName} (ej: toolListConversations)",
      "return_format": "{ success: boolean, data?, error? }",
      "parameters_schema": "JSON Schema object with properties and required"
    },
    "service_module_pattern": {
      "source": "prompt-composer",
      "description": "Módulo de servicio sin persistencia propia que coordina con otros módulos",
      "characteristics": [
        "No tiene SQLite ni persistencia directa",
        "Usa eventos para obtener datos de otros módulos",
        "Expone misma funcionalidad via múltiples interfaces (UI, HTTP, Events, Tools)",
        "Incluye templates o configuración por defecto en memoria"
      ],
      "example_flow": [
        "1. Recibe request via cualquier interfaz",
        "2. Solicita contexto a otros módulos via eventos",
        "3. Procesa/transforma los datos",
        "4. Devuelve resultado"
      ]
    },
    "template_substitution_pattern": {
      "source": "prompt-composer",
      "description": "Sustitución de variables en strings con sintaxis Handlebars-like",
      "simple_variable": "{{variable_name}} → valor",
      "conditional_block": "{{#if variable}}content{{/if}} → content si truthy",
      "implementation": "substituteVariables(template, variables) method"
    },
    "graceful_degradation_pattern": {
      "source": "prompt-composer",
      "description": "Devolver valores por defecto en lugar de fallar cuando falta contexto",
      "example": {
        "missing_project": "return { project_name: 'Unknown Project', ... }",
        "timeout_storage": "resolve(null) en lugar de reject()"
      },
      "benefit": "Módulos pueden funcionar parcialmente sin todas las dependencias"
    },
    "multi_interface_consistency": {
      "source": "prompt-composer",
      "description": "Misma funcionalidad expuesta en múltiples interfaces",
      "interfaces": {
        "event": "prompt.compose.request → onComposeRequest()",
        "ui_handler": "mqttRequest('prompt', 'compose') → handleUICompose()",
        "http_api": "POST /compose → handleComposePrompt()",
        "tool": "prompt.compose → toolComposePrompt()"
      },
      "pattern": "Todas las interfaces llaman a los mismos métodos core internos"
    },
    "orchestrator_module_pattern": {
      "source": "chat-ai-bridge",
      "description": "Módulo que coordina flujo multi-paso entre otros módulos",
      "characteristics": [
        "No tiene lógica de negocio propia",
        "Coordina llamadas a otros módulos via eventos",
        "Mantiene estado del flujo en flowState object",
        "Tracking de stages para debugging/logging"
      ],
      "flow_state_tracking": {
        "structure": "{ flowId, stage, startTime, error, ...stepResults }",
        "stages": ["init", "step1", "step2", ..., "completed", "error"],
        "benefit": "Saber exactamente dónde falló un flujo"
      }
    },
    "async_flow_coordination": {
      "source": "chat-ai-bridge",
      "description": "Coordinar múltiples pasos async con manejo de errores",
      "pattern": {
        "try_catch_finally": "try { steps } catch { log & respond error } finally { cleanup }",
        "stage_tracking": "flowState.stage = 'step_name' antes de cada paso",
        "graceful_failures": "Algunos pasos pueden fallar sin romper el flujo"
      },
      "example_flow": [
        "1. onChatSendRequest() - entry point",
        "2. saveUserMessage() - puede fallar, no crítico",
        "3. loadConversationContext() - fallback a empty",
        "4. composePrompt() - fallback a default",
        "5. callAI() - crítico, falla el flujo",
        "6. saveAssistantMessage() - puede fallar, no crítico",
        "7. publish response"
      ]
    },
    "stats_tracking_pattern": {
      "source": "chat-ai-bridge",
      "description": "Tracking de estadísticas para observability",
      "structure": {
        "counters": "messagesProcessed, errors, aiCallsTotal",
        "increments": "this.stats.messagesProcessed++",
        "exposure": "via health check y status endpoints"
      },
      "benefit": "Métricas sin dependencia de sistema externo de metrics"
    },
    "dependency_injection_pattern": {
      "source": "all modules",
      "description": "Dependencias inyectadas en onLoad(), nunca imports directos entre módulos",
      "constructor": "Solo inicializa estado interno (Maps, Sets, config defaults)",
      "onLoad": "Recibe context con { logger, eventBus, uiHandler, config, moduleLoader }",
      "benefit": "Testeable, desacoplado, mockeable"
    },
    "pending_requests_map_pattern": {
      "source": "all modules",
      "description": "Patrón consistente para tracking de requests async",
      "structure": {
        "declaration": "this.pendingXxxRequests = new Map()",
        "entry": "{ resolve, reject, timeout: timeoutId }",
        "set": "this.pending.set(requestId, { resolve, reject, timeout })",
        "get_and_cleanup": "const pending = this.pending.get(id); clearTimeout(pending.timeout); this.pending.delete(id)"
      },
      "cleanup_in_onUnload": "for (const [, req] of pending) { clearTimeout(req.timeout); req.reject(new Error('Module unloading')); }"
    },
    "correlation_id_propagation": {
      "source": "all modules",
      "description": "Trazabilidad distribuida via correlation_id",
      "pattern": [
        "1. Recibir correlation_id en request",
        "2. Pasar a todos los sub-requests",
        "3. Incluir en todos los logs",
        "4. Devolver en response"
      ],
      "fallback": "correlationId = context?.correlationId || crypto.randomUUID()"
    },
    "dual_response_format": {
      "source": "all modules",
      "description": "Formatos de respuesta diferentes para HTTP vs UI",
      "http_handlers": "return { status: 200, data: { success: true, ... } }",
      "ui_handlers": "return { ... } o throw { status: 400, code: 'ERROR_CODE', message: '...' }",
      "reason": "HTTP necesita status code, UI espera datos directos o excepción"
    },
    "constructor_vs_onload_separation": {
      "source": "all modules",
      "description": "Separación clara de responsabilidades",
      "constructor": [
        "this.name = 'module-name'",
        "this.version = '1.0.0'",
        "this.someMap = new Map()",
        "this.unsubscribes = []",
        "this.startTime = Date.now()"
      ],
      "onLoad": [
        "this.logger = context.logger",
        "this.eventBus = context.eventBus",
        "await this.registerUIHandlers()",
        "await this.subscribeToEvents()"
      ],
      "rule": "Constructor: estado inicial. onLoad: conexiones y registros"
    },
    "module_self_documentation": {
      "source": "all modules",
      "description": "module.json como fuente de verdad de capacidades",
      "declares": ["events.publishes", "events.subscribes", "apis", "tools", "dependencies"],
      "consumed_by": ["moduleLoader", "tool-manager", "api-gateway", "UI auto-discovery"],
      "benefit": "Un módulo es introspectable sin leer su código"
    },
    "crypto_uuid_for_ids": {
      "source": "all modules",
      "description": "Usar crypto.randomUUID() para todos los IDs",
      "usage": [
        "const requestId = crypto.randomUUID()",
        "const messageId = crypto.randomUUID()",
        "const conversationId = crypto.randomUUID()"
      ],
      "import": "const crypto = require('crypto')"
    }
  },
