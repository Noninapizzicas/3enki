{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enki.local/arquitectura/decisiones/subsistema-carta/carta-borrada.schema.json",
  "title": "carta.borrada — payload schema",
  "description": "Soft-delete. La carta sigue existiendo en disco con meta.estado=archivada. Publicado por carta-manager.delete. Consumers la sacan de listas activas pero pueden seguir consultandola via carta.get. Valida el campo data del envelope del bus.",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_id", "carta", "correlation_id", "timestamp"],
  "properties": {
    "project_id": { "$ref": "_common.schema.json#/$defs/project_id" },
    "correlation_id": { "$ref": "_common.schema.json#/$defs/correlation_id" },
    "timestamp": { "$ref": "_common.schema.json#/$defs/timestamp" },
    "motivo": { "$ref": "_common.schema.json#/$defs/motivo" },
    "carta": { "$ref": "_common.schema.json#/$defs/carta_envelope_archivada" }
  }
}
