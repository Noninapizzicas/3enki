  "recommended_module_json_template": {
    "description": "Formato estándar que debería generar plop module",
    "template": {
      "name": "{{name}}",
      "version": "1.0.0",
      "description": "{{description}}",
      "author": "{{author}}",
      "apis": [
        {
          "method": "GET|POST|PUT|DELETE",
          "path": "/endpoint",
          "handler": "handlerMethodName",
          "description": "Descripción del endpoint"
        }
      ],
      "events": {
        "publishes": ["{{name}}.created", "{{name}}.updated"],
        "subscribes": ["other.event"]
      },
      "tools": [
        {
          "name": "{{name}}.action",
          "description": "Descripción de la tool para AI",
          "handler": "handleToolAction",
          "parameters": {
            "type": "object",
            "properties": {
              "param1": { "type": "string", "description": "..." }
            },
            "required": ["param1"]
          }
        }
      ],
      "ui": {
        "zone": "work-bar|chat-config|chat-tools",
        "icon": "emoji"
      },
      "config": {}
    }
  },
  "recommended_index_js_template": {
    "description": "Estructura estándar para index.js",
    "structure": [
      "class ModuleNameModule {",
      "  constructor() - Estado inicial, sin dependencias",
      "  async onLoad(context) - Inyectar deps, registrar handlers",
      "  async onUnload() - Cleanup",
      "  async registerUIHandlers() - uiHandler.register()",
      "  async subscribeToEvents() - eventBus.subscribe()",
      "  // HTTP API handlers",
      "  async handleXxx(req, context) - return { status, data }",
      "  // Event handlers",
      "  async onEventName(event) - procesar eventos",
      "  // UI handlers",
      "  async handleUIAction(data, context) - handlers MQTT",
      "  // Tool handlers",
      "  async handleToolAction(params, context) - tools para AI",
      "}"
    ]
  },
