{
  "name": "plugin-manager",
  "version": "1.0.0",
  "description": "Discovers, loads, and manages JSON-based plugins from the plugins/ directory",
  "main": "index.js",
  "author": "event-core team",
  "license": "MIT",
  "provides": [
    "plugin-discovery",
    "plugin-loading",
    "plugin-validation"
  ],
  "dependencies": [],
  "apis": {
    "get_plugin": {
      "method": "GET",
      "path": "/plugin/:name",
      "description": "Get a specific plugin definition by name"
    },
    "list_plugins": {
      "method": "GET",
      "path": "/plugins",
      "description": "List all loaded plugins"
    },
    "reload_plugins": {
      "method": "POST",
      "path": "/plugins/reload",
      "description": "Reload all plugins from disk"
    }
  },
  "events": {
    "publishes": [
      "plugin.loaded",
      "plugin.error"
    ],
    "subscribes": []
  },
  "config": {
    "plugins_path": "../../plugins",
    "auto_reload": false,
    "watch_interval": 5000
  }
}
