      { "domain": "conversation", "action": "list",            "handler": "handleList" },
      { "domain": "conversation", "action": "load",            "handler": "handleLoad" },
      { "domain": "conversation", "action": "delete",          "handler": "handleDelete" },
      { "domain": "conversation", "action": "update_settings", "handler": "handleUpdateSettings" },
      { "domain": "conversation", "action": "toggle_context",  "handler": "handleToggleContext" },
      { "domain": "conversation", "action": "context_stats",   "handler": "handleContextStats" }
    ]
  },

