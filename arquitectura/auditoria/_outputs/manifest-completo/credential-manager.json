{
  "_meta": {
    "modulo": "credential-manager",
    "ubicacion": "modules/credential-manager",
    "auditado_en": "2026-04-29",
    "parcela": "manifest-completo",
    "parcela_version": "2.0.0"
  },

  "identidad": {
    "name": "credential-manager",
    "version": "2.1.0",
    "description_oficial": "Multi-level credential management with .env storage (GLOBAL/PROJECT/CLIENT/CUSTOM)",
    "author": "Aichat Team",
    "main": "index.js"
  },

  "estado_en_sistema": {
    "habilitado_en_config": true,
    "en_disabled_de_config": false,
    "estado_modulo": "vivo",
    "tier_carga_inferido": "tier_1_infra",
    "tier_declarado": null,
    "dev_only_declarado": false,
    "enabled_declarado": null
  },

  "eventos": {
    "publica": [
      { "event": "credential.saved",            "description": "Credential saved or created" },
      { "event": "credential.updated",          "description": "Credential value updated" },
      { "event": "credential.deleted",          "description": "Credential removed" },
      { "event": "credential.resolved",         "description": "Credential successfully resolved" },
      { "event": "credential.resolve.failed",   "description": "Credential resolution failed" },
      { "event": "credential.resolve.response", "description": "Response to credential resolve request" },
      { "event": "credential/state",            "description": "Full UI state with providers, levels, and grouped credentials" }
    ],
    "subscribes": [
      { "event": "credential.resolve.request",       "handler": "onResolveRequest",      "extras": {} },
      { "event": "credential/state/request",         "handler": "onStateRequest",        "extras": {} },
      { "event": "credential/create",                "handler": "onCreateCredential",    "extras": {} },
      { "event": "credential/update",                "handler": "onUpdateCredential",    "extras": {} },
      { "event": "credential/delete",                "handler": "onDeleteCredential",    "extras": {} },
      { "event": "credential.oauth.resolve.request", "handler": "onOAuthResolveRequest", "extras": {} }
    ],
    "provides_eventos": [
      "credential.saved",
      "credential.updated",
      "credential.deleted",
      "credential.resolved",
      "credential.resolve.failed"
    ]
  },

  "tools": [
    {
      "name": "credential.list",
      "description": "Lista nombres de credenciales disponibles por proveedor y nivel. IMPORTANTE: Solo retorna metadata (provider, level, identifier), NUNCA valores de API keys.",
      "parameters_required": [],
      "parameters_property_names": ["level", "provider"],
      "parameters_size_chars": 389,
      "parameters_full_path_hint": "modules/credential-manager/module.json → tools[0].parameters"
    }
  ],

  "ui_handlers": {
    "campo_origen": "ui_handlers",
    "items": [
      { "domain": "credential", "action": "list",                "handler": "handleUIList" },
      { "domain": "credential", "action": "get",                 "handler": "handleUIGet" },
      { "domain": "credential", "action": "create",              "handler": "handleUICreate" },
      { "domain": "credential", "action": "update",              "handler": "handleUIUpdate" },
      { "domain": "credential", "action": "delete",              "handler": "handleUIDelete" },
      { "domain": "credential", "action": "test",                "handler": "handleUITest" },
      { "domain": "credential", "action": "oauth.start",         "handler": "handleUIOAuthStart" },
      { "domain": "credential", "action": "oauth.status",        "handler": "handleUIOAuthStatus" },
      { "domain": "credential", "action": "oauth.config.list",   "handler": "handleUIOAuthConfigList" },
      { "domain": "credential", "action": "oauth.config.save",   "handler": "handleUIOAuthConfigSave" },
      { "domain": "credential", "action": "oauth.config.delete", "handler": "handleUIOAuthConfigDelete" },
      { "domain": "credential", "action": "glovo.save",          "handler": "handleUIGlovoSave" },
      { "domain": "credential", "action": "glovo.delete",        "handler": "handleUIGlovoDelete" },
      { "domain": "credential", "action": "telegram.notif.save", "handler": "handleUITelegramNotifSave" },
      { "domain": "credential", "action": "telegram.notif.delete", "handler": "handleUITelegramNotifDelete" }
    ]
  },

  "apis_http": [
    {
      "method": "POST",
      "path": "/credentials",
      "handler": "handleSaveCredential",
      "description": "Save credential (publishes credential.saved)",
      "request_schema_ref": "./schemas/credential.json#/definitions/save_request",
      "response_schema_ref": "./schemas/credential.json#/definitions/save_response"
    },
    {
      "method": "GET",
      "path": "/credentials/resolve",
      "handler": "handleResolveCredential",
      "description": "Resolve credential by cascade (publishes credential.resolved)",
      "request_schema_ref": null,
      "response_schema_ref": "./schemas/credential.json#/definitions/resolve_response"
    },
    {
      "method": "GET",
      "path": "/credentials",
      "handler": "handleListCredentials",
      "description": "List credentials (masked)",
      "request_schema_ref": null,
      "response_schema_ref": "./schemas/credential.json#/definitions/list_response"
    },
    {
      "method": "PUT",
      "path": "/credentials/:key",
      "handler": "handleUpdateCredential",
      "description": "Update credential (publishes credential.updated)",
      "request_schema_ref": "./schemas/credential.json#/definitions/update_request",
      "response_schema_ref": "./schemas/credential.json#/definitions/update_response"
    },
    {
      "method": "DELETE",
      "path": "/credentials/:key",
      "handler": "handleDeleteCredential",
      "description": "Delete credential (publishes credential.deleted)",
      "request_schema_ref": null,
      "response_schema_ref": "./schemas/credential.json#/definitions/delete_response"
    },
    {
      "method": "GET",
      "path": "/credentials/levels",
      "handler": "handleGetLevels",
      "description": "Get available credential levels",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "POST",
      "path": "/ui/test",
      "handler": "handleTestCredential",
      "description": "Test if an API key is valid before saving",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "handleHealthCheck",
      "description": "Health check endpoint",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/metrics",
      "handler": "handleGetMetrics",
      "description": "Module metrics",
      "request_schema_ref": null,
      "response_schema_ref": null
    },
    {
      "method": "GET",
      "path": "/oauth/callback",
      "handler": "handleOAuthCallback",
      "description": "OAuth2 callback endpoint for Google authorization",
      "request_schema_ref": null,
      "response_schema_ref": null
    }
  ],

  "config_y_deps": {
    "dependencies_declaradas": [],
    "requires_declarado": [],
    "replaces_declarado": [],
    "config_declarada": [
      { "key": "envFile",    "tipo": "string", "valor_default": ".env" },
      { "key": "maskLength", "tipo": "number", "valor_default": 4 },
      { "key": "levels",     "tipo": "object", "valor_default": {
          "CUSTOM":  { "priority": 1, "requiresIdentifier": true,  "description": "Highest priority - custom specific credentials" },
          "CLIENT":  { "priority": 2, "requiresIdentifier": true,  "description": "Client-specific credentials" },
          "PROJECT": { "priority": 3, "requiresIdentifier": true,  "description": "Project-specific credentials" },
          "GLOBAL":  { "priority": 4, "requiresIdentifier": false, "description": "Global fallback credentials" }
        }
      }
    ]
  },

  "observability_declarada": {
    "logging": {
      "level": "info",
      "structured": true
    },
    "metrics": {
      "enabled": true,
      "counters": [
        "credential.saved.total",
        "credential.updated.total",
        "credential.deleted.total",
        "credential.resolved.total",
        "credential.resolve.failed.total",
        "credential.errors.total"
      ],
      "gauges": [
        "credential.count.total",
        "credential.count.by_level"
      ],
      "timings": [
        "credential.resolve.duration",
        "credential.save.duration"
      ]
    }
  },

  "agentes": {
    "inline_en_module_json": [],
    "archivos_propios": [],
    "agents_referenciados_en_intents": []
  },

  "intents_declarados": [],

  "ui_declarativa": {
    "presente": true,
    "enabled": true,
    "title": "Credential Manager",
    "icon": "🔐",
    "views_keys": ["main", "create", "oauth"],
    "section_widget_types": ["card", "stat-card", "table-advanced"],
    "permissions_declaradas": ["admin", "gerente"],
    "tamano_bytes": 6371,
    "endpoints_referenciados": [
      "/modules/credential-manager/credentials",
      "/modules/credential-manager/credentials/{{key}}"
    ],
    "mqtt_topics_declarados": [
      "credential.saved",
      "credential.updated",
      "credential.deleted"
    ]
  },

  "archivos_hermanos": {
    "agents": [],
    "schemas": [
      "modules/credential-manager/schemas/credential.json",
      "modules/credential-manager/schemas/events.json"
    ],
    "prompts": [],
    "context": false,
    "prompt_module": true,
    "readme": true,
    "tests_propios": false
  },

  "tags_declaradas": [],

  "outliers_capturados": {
    "campos_no_canonicos": [],
    "snapshots": {}
  },

  "version_archivada": {
    "existe": false,
    "ubicacion": null
  },

  "quirks": {
    "eventos_top_level": false,
    "ui_handlers_field_name": "ui_handlers",
    "module_json_bytes": 20396,
    "module_json_lineas": 628,
    "tiene_main_no_estandar": false,
    "warnings": [
      "provides top-level (no es canónico pero no es outlier: es una forma alternativa de declares eventos)",
      "schema top-level declarado (no en lista canónica pero no capturado como outlier — clave 'schema' está en lista_canonica_keys_top_level)",
      "events.subscribes items tienen campo 'description' adicional no mapeado en output (normalizado a extras:{})"
    ]
  }
}
