{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pizzepos.com/schemas/metricas/events.json",
  "title": "Eventos de Métricas",
  "description": "Schemas de eventos publicados por el módulo de métricas",

  "definitions": {
    "event_envelope": {
      "type": "object",
      "required": ["event_id", "event_type", "correlation_id", "occurred_at", "producer", "schema_version", "payload"],
      "properties": {
        "event_id": {
          "type": "string",
          "format": "uuid"
        },
        "event_type": {
          "type": "string"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "payload": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },

    "metricas_snapshot": {
      "allOf": [
        {
          "$ref": "#/definitions/event_envelope"
        },
        {
          "properties": {
            "event_type": {
              "const": "metricas.snapshot"
            },
            "payload": {
              "type": "object",
              "required": ["counters", "gauges", "timestamp"],
              "properties": {
                "counters": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "description": "Snapshot de todos los counters"
                },
                "gauges": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "number"
                  },
                  "description": "Snapshot de todos los gauges"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                },
                "uptime": {
                  "type": "number",
                  "description": "Uptime en segundos"
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },

    "metricas_alerta": {
      "allOf": [
        {
          "$ref": "#/definitions/event_envelope"
        },
        {
          "properties": {
            "event_type": {
              "const": "metricas.alerta"
            },
            "payload": {
              "type": "object",
              "required": ["tipo_alerta", "metrica", "valor_actual", "umbral", "timestamp"],
              "properties": {
                "tipo_alerta": {
                  "type": "string",
                  "enum": ["threshold_exceeded", "spike_detected", "drop_detected"],
                  "description": "Tipo de alerta detectada"
                },
                "metrica": {
                  "type": "string",
                  "description": "Nombre de la métrica que disparó la alerta"
                },
                "valor_actual": {
                  "type": "number",
                  "description": "Valor actual de la métrica"
                },
                "umbral": {
                  "type": "number",
                  "description": "Umbral configurado"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                },
                "severidad": {
                  "type": "string",
                  "enum": ["info", "warning", "error", "critical"],
                  "default": "warning"
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
